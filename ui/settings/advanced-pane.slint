import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { TerminalIcon } from "../icons/terminal-icon.slint";
import { TrashIcon } from "../icons/trash-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Toggle } from "../primitives/toggle.slint";
import { MicroButton } from "../primitives/button.slint";
import { StatusLine } from "../primitives/status-line.slint";

// One row in the audit-log file list. Self-contained so delete hit-testing
// doesn't fight the list-level layout (same shape as the relay rows).
component AuditFileRow inherits Rectangle {
    in property <string> name;
    in property <string> meta;
    in property <bool> show-divider: true;
    callback delete-clicked;

    height: 48px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 10px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: root.name;
                color: Palette.text-hi;
                font-size: Theme.fs(12px, 16px);
                font-weight: 500;
                overflow: elide;
            }

            Text {
                text: root.meta;
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                overflow: elide;
            }
        }

        VerticalLayout {
            alignment: center;
            MicroButton {
                label: "";
                pad-left: 8px;
                pad-right: 8px;
                TrashIcon {
                    stroke: Palette.text-mid;
                }

                clicked => {
                    root.delete-clicked();
                }
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

export component AdvancedPane inherits DetailPage {
    // Reads/writes AppState directly (telemetry/audit/debug toggles, audit
    // file list) and invokes its callbacks; the page above passes no bindings.

    PageHeader {
        title: @tr("Advanced");
        caption: @tr("Privacy & developer flags");
        TerminalIcon {
            stroke: Palette.text-mid;
        }
    }

    Section {
        label: @tr("SECURITY & PRIVACY");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Share anonymous app telemetry");
                sublabel: @tr("Share relay connection telemetry.");
                Toggle {
                    label: @tr("Share anonymous app telemetry");
                    on <=> AppState.telemetry-enabled;
                    toggled => {
                        AppState.telemetry-toggled(self.on);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Audit logs");
                sublabel: @tr("Create and send group audit log files. Applies immediately.");
                show-divider: false;
                Toggle {
                    label: @tr("Audit logs");
                    on <=> AppState.audit-enabled;
                    toggled => {
                        AppState.audit-toggled(self.on);
                    }
                }
            }
        }

        if AppState.audit-status != "": StatusLine {
            text: AppState.audit-status;
            kind: AppState.audit-status-kind;
        }
    }

    Section {
        label: @tr("AUDIT LOG FILES");
        GroupCard {
            if AppState.audit-files.length == 0: Rectangle {
                height: 48px;
                Text {
                    x: 16px;
                    width: parent.width - 32px;
                    height: parent.height;
                    text: @tr("No audit log files on disk.");
                    color: Palette.text-lo;
                    font-size: Theme.fs(12px, 16px);
                    vertical-alignment: center;
                }
            }
            for f[i] in AppState.audit-files: AuditFileRow {
                name: f.name;
                meta: f.meta;
                show-divider: i < AppState.audit-files.length - 1;
                delete-clicked => {
                    AppState.pending-audit-delete-path = f.path;
                    AppState.show-audit-delete-confirm = true;
                }
            }
        }

        HorizontalLayout {
            alignment: start;
            MicroButton {
                label: @tr("Refresh");
                RefreshIcon {
                    stroke: Palette.text-mid;
                }

                clicked => {
                    AppState.audit-refresh-files();
                }
            }
        }

        Text {
            text: @tr("Deleting the file being recorded rotates it — recording continues in a fresh file.");
            color: Palette.text-lo;
            font-size: Theme.fs(11px, 14px);
            wrap: word-wrap;
        }
    }

    Section {
        label: @tr("DEVELOPER");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Developer mode");
                sublabel: @tr("Shows diagnostics and MLS internals. Adds a Debug entry with account, key-packages, and group state.");
                show-divider: false;
                Toggle {
                    label: @tr("Developer mode");
                    on <=> AppState.debug-enabled;
                    toggled => {
                        AppState.debug-toggled(self.on);
                    }
                }
            }
        }
    }
}
