import { Palette, Theme } from "../tokens.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";
import { Section } from "../shells/section.slint";
import { GroupCard } from "../shells/group-card.slint";
import { KVRow } from "../shells/kv-row.slint";
import { MicroButton } from "../primitives/button.slint";

// Storage settings. The only on-disk store the user can act on today is the
// encrypted media cache (decrypted attachment bytes, sealed with the vault key).
// Size + a clear action are real and backed by `media_cache` in Rust — no
// placeholder controls.
export component StoragePane inherits DetailPage {
    // Preformatted human size ("12.4 MB"); Rust owns the formatting.
    in property <string> cache-size;
    // True while a clear is in flight — disables the button to avoid double-fire.
    in property <bool> clearing: false;
    callback clear-cache();
    // Full path to the directory holding vault.db (shown so a user keeping their
    // own backup knows where it lives).
    in property <string> vault-dir;
    callback open-vault-folder();
    callback create-backup();
    callback import-backup();

    PageHeader {
        title: @tr("Storage");
        caption: @tr("ON THIS DEVICE");
        ArchiveIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("MEDIA CACHE");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Cached attachments");
                sublabel: @tr("Decrypted images and files, stored encrypted on this device.");
                value: root.cache-size;
                show-divider: false;
                MicroButton {
                    label: root.clearing ? @tr("Clearing…") : @tr("Clear cache");
                    enabled: !root.clearing;
                    clicked => {
                        root.clear-cache();
                    }
                }
            }
        }
    }

    Section {
        label: @tr("KEYS & BACKUPS");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Location");
                sublabel: root.vault-dir;
                show-divider: true;
                MicroButton {
                    label: @tr("Open folder");
                    clicked => {
                        root.open-vault-folder();
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Back up everything");
                sublabel: @tr("Pack accounts, chats, and settings into one encrypted file.");
                show-divider: true;
                MicroButton {
                    label: @tr("Create backup…");
                    clicked => {
                        root.create-backup();
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Import a backup");
                sublabel: @tr("Merge the accounts from a backup file into this install.");
                show-divider: false;
                MicroButton {
                    label: @tr("Import…");
                    clicked => {
                        root.import-backup();
                    }
                }
            }
        }
    }
}
