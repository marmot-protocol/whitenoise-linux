import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { MicroButton } from "../primitives/button.slint";

// Storage settings. The only on-disk store the user can act on today is the
// encrypted media cache (decrypted attachment bytes, sealed with the vault key).
// Size + a clear action are real and backed by `media_cache` in Rust — no
// placeholder controls.
export component StoragePane inherits DetailPage {
    // Reads AppState directly (cache size/clearing, vault dir) and invokes
    // its callbacks; the page above passes no bindings.

    PageHeader {
        title: @tr("Storage");
        caption: @tr("ON THIS DEVICE");
        ArchiveIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("MEDIA CACHE");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Cached attachments");
                sublabel: @tr("Decrypted images and files, stored encrypted on this device.");
                value: AppState.storage-cache-size;
                show-divider: false;
                MicroButton {
                    label: AppState.storage-clearing ? @tr("Clearing…") : @tr("Clear cache");
                    enabled: !AppState.storage-clearing;
                    clicked => {
                        AppState.storage-clear-cache();
                    }
                }
            }
        }
    }

    Section {
        label: @tr("KEYS & BACKUPS");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Location");
                sublabel: AppState.storage-vault-dir;
                show-divider: true;
                MicroButton {
                    label: @tr("Open folder");
                    clicked => {
                        AppState.storage-open-vault-folder();
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Back up everything");
                sublabel: @tr("Pack accounts, chats, and settings into one encrypted file.");
                show-divider: true;
                MicroButton {
                    label: @tr("Create backup…");
                    clicked => {
                        AppState.storage-create-backup();
                    }
                }
            }

            // The receipt for the row above. Mounted only once a backup has
            // actually been written, so a fresh install shows nothing rather
            // than an empty "never" row.
            if AppState.storage-last-backup-path != "": KVRow {
                row-height: 48px;
                label: @tr("Last backup");
                sublabel: AppState.storage-last-backup-path;
                value: AppState.storage-last-backup-at;
                show-divider: true;
            }

            KVRow {
                row-height: 48px;
                label: @tr("Import a backup");
                sublabel: @tr("Merge the accounts from a backup file into this install.");
                show-divider: false;
                MicroButton {
                    label: @tr("Import…");
                    clicked => {
                        AppState.storage-import-backup();
                    }
                }
            }
        }
    }
}
