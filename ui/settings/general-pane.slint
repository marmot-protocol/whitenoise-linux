import { AppState } from "../shell/app-state.slint";
import { Palette, Theme, QuickReact } from "../tokens.slint";
import { QuickReactCell } from "../messages/quick-react-cell.slint";
import { SettingsIcon } from "../icons/settings-icon.slint";
import { ChevronRightIcon } from "../icons/chevron-right-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Toggle } from "../primitives/toggle.slint";
import { MicroButton } from "../primitives/button.slint";

export component GeneralPane inherits DetailPage {
    // Reads/writes AppState directly (locale, time/date format, startup
    // toggles) and invokes its callbacks; the page above passes no bindings.

    PageHeader {
        title: @tr("General");
        caption: "";
        SettingsIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("STARTUP");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Launch at login");
                Toggle {
                    on <=> AppState.launch-at-login;
                    toggled => {
                        AppState.launch-at-login-toggled(self.on);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Start minimized to tray");
                Toggle {
                    on <=> AppState.start-minimized-to-tray;
                    toggled => {
                        AppState.start-minimized-to-tray-toggled(self.on);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Restore last selected chat on launch");
                show-divider: false;
                Toggle {
                    on <=> AppState.restore-last-selected-chat;
                    toggled => {
                        AppState.restore-last-selected-chat-toggled(self.on);
                    }
                }
            }
        }
    }

    Section {
        label: @tr("LANGUAGE");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Interface language");
                value: AppState.locale-display;
                MicroButton {
                    label: @tr("language picker button" => "Change");
                    ChevronRightIcon {
                        stroke: Palette.text-mid;
                    }

                    clicked => {
                        AppState.change-language-clicked();
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Time format");
                MicroButton {
                    label: @tr("24-hour");
                    selected: AppState.time-format == "24h";
                    fg: AppState.time-format == "24h" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        AppState.time-format-selected("24h");
                    }
                }

                MicroButton {
                    label: @tr("12-hour");
                    selected: AppState.time-format == "12h";
                    fg: AppState.time-format == "12h" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        AppState.time-format-selected("12h");
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Date format");
                show-divider: false;
                // Labels are example renderings, not prose — keep untranslated.
                MicroButton {
                    label: "Jun 12";
                    selected: AppState.date-format == "mdy";
                    fg: AppState.date-format == "mdy" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        AppState.date-format-selected("mdy");
                    }
                }

                MicroButton {
                    label: "12 Jun";
                    selected: AppState.date-format == "dmy";
                    fg: AppState.date-format == "dmy" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        AppState.date-format-selected("dmy");
                    }
                }

                MicroButton {
                    label: "2026-06-12";
                    selected: AppState.date-format == "iso";
                    fg: AppState.date-format == "iso" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        AppState.date-format-selected("iso");
                    }
                }
            }
        }
    }

    Section {
        label: @tr("QUICK REACTIONS");
        GroupCard {
            KVRow {
                row-height: 60px;
                label: @tr("One-tap reactions");
                sublabel: @tr("Shown on the message toolbar and menu. Tap one to remove it.");
                show-divider: true;
                HorizontalLayout {
                    spacing: 1px;
                    alignment: end;
                    for e[i] in QuickReact.list: QuickReactCell {
                        emoji: e.emoji;
                        clip-x: e.clip-x;
                        clip-y: e.clip-y;
                        removable: true;
                        clicked => {
                            QuickReact.remove(i);
                        }
                    }

                    add-cell := QuickReactCell {
                        emoji: "+";
                        clicked => {
                            QuickReact.add-clicked(
                                self.absolute-position.x,
                                self.absolute-position.y + self.height,
                            );
                        }
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Restore the default reactions");
                show-divider: false;
                MicroButton {
                    label: @tr("Reset");
                    clicked => {
                        QuickReact.reset();
                    }
                }
            }
        }
    }
}
