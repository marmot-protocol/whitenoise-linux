import { Palette, Theme } from "../tokens.slint";
import { SettingsIcon } from "../icons/settings-icon.slint";
import { ChevronRightIcon } from "../icons/chevron-right-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";
import { Section } from "../shells/section.slint";
import { GroupCard } from "../shells/group-card.slint";
import { KVRow } from "../shells/kv-row.slint";
import { Toggle } from "toggle.slint";
import { MicroButton } from "../primitives/button.slint";

export component GeneralPane inherits DetailPage {
    in property <string> locale-display;
    callback change-language-clicked();
    // `24h` | `12h` and `mdy` | `dmy` | `iso` — mirrors Settings in Rust.
    in property <string> time-format: "24h";
    in property <string> date-format: "mdy";
    callback time-format-selected(string);
    callback date-format-selected(string);

    PageHeader {
        title: @tr("General");
        caption: "";
        SettingsIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("STARTUP");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Launch at login");
                Toggle {
                    on: true;
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Start minimized to tray");
                Toggle {
                    on: false;
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Restore last selected chat on launch");
                show-divider: false;
                Toggle {
                    on: true;
                }
            }
        }
    }

    Section {
        label: @tr("LANGUAGE");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Interface language");
                value: root.locale-display;
                MicroButton {
                    label: @tr("language picker button" => "Change");
                    ChevronRightIcon {
                        stroke: Palette.text-mid;
                    }

                    clicked => {
                        root.change-language-clicked();
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Time format");
                MicroButton {
                    label: @tr("24-hour");
                    selected: root.time-format == "24h";
                    fg: root.time-format == "24h" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        root.time-format-selected("24h");
                    }
                }

                MicroButton {
                    label: @tr("12-hour");
                    selected: root.time-format == "12h";
                    fg: root.time-format == "12h" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        root.time-format-selected("12h");
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Date format");
                show-divider: false;
                // Labels are example renderings, not prose — keep untranslated.
                MicroButton {
                    label: "Jun 12";
                    selected: root.date-format == "mdy";
                    fg: root.date-format == "mdy" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        root.date-format-selected("mdy");
                    }
                }

                MicroButton {
                    label: "12 Jun";
                    selected: root.date-format == "dmy";
                    fg: root.date-format == "dmy" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        root.date-format-selected("dmy");
                    }
                }

                MicroButton {
                    label: "2026-06-12";
                    selected: root.date-format == "iso";
                    fg: root.date-format == "iso" && Theme.selected-inverts-text ? Palette.bubble-out-fg : Palette.text-hi;
                    clicked => {
                        root.date-format-selected("iso");
                    }
                }
            }
        }
    }
}
