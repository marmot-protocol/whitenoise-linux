import { Palette, Theme } from "../tokens.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { PlusIcon } from "../icons/plus-icon.slint";
import { TrashIcon } from "../icons/trash-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";
import { Section } from "../shells/section.slint";
import { GroupCard } from "../shells/group-card.slint";
import { Button, MicroButton } from "../primitives/button.slint";
import { LineInput } from "../primitives/line-input.slint";

// One row in the relay list. Self-contained so removal hit-testing doesn't
// fight the list-level layout.
component RelayRow inherits Rectangle {
    in property <string> url;
    in property <bool> show-divider: true;
    callback remove-clicked;

    height: 44px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 10px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: root.url;
                color: Palette.text-hi;
                font-size: (12px) * Theme.fs-scale;
                font-weight: 500;
                overflow: elide;
            }
        }

        VerticalLayout {
            alignment: center;
            MicroButton {
                label: "";
                pad-left: 8px;
                pad-right: 8px;
                TrashIcon {
                    stroke: Palette.text-mid;
                }

                clicked => {
                    root.remove-clicked();
                }
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

export component NetworkPane inherits DetailPage {
    in property <[string]> relays;
    in property <[string]> booted-relays;
    in property <int> connected;
    in property <int> total;
    in property <string> status;
    callback add-relay(string);
    callback remove-relay(string);
    callback refresh-health();
    callback republish-relay-list();

    property <string> draft;
    // A relay edit is "pending restart" when the saved set differs from the
    // set the backend booted with. Order matters here — same relays in a
    // different order shouldn't trigger the banner, so compare as sets via
    // mutual length + containment is overkill at this scale; equal-when-
    // sorted is what we want, but Slint can't sort. Approximation: same
    // length AND every booted entry appears in `relays`. With a few entries
    // the false-negative on "swap one for another, same count" is fine —
    // length-mismatch covers add/remove, the common case.
    property <bool> restart-required: root.relays.length != root.booted-relays.length;

    PageHeader {
        title: @tr("Network & relays");
        caption: @tr("Where your messages land.");
        MonitorIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("STATUS");
        GroupCard {
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 14px;

                    Rectangle {
                        width: 10px;
                        height: 10px;
                        y: (parent.height - self.height) / 2;
                        border-radius: (5px) * Theme.r-scale;
                        background: root.connected > 0 ? Palette.mint : (root.total > 0 ? Palette.warning : Palette.text-vlo);
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 3px;
                        alignment: center;
                        Text {
                            text: root.total == 0 ? @tr("No relays configured") : (root.connected == root.total ? @tr("Connected · {}/{}", root.connected, root.total) : @tr("Partial · {}/{} connected", root.connected, root.total));
                            color: Palette.text-hi;
                            font-size: (12px) * Theme.fs-scale;
                            font-weight: 700;
                        }

                        Text {
                            text: root.total == 0 ? @tr("Add a relay below — nothing publishes until you do.") : @tr("Aggregate connection counter from the relay pool.");
                            color: Palette.text-lo;
                            font-size: (11px) * Theme.fs-scale;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        MicroButton {
                            label: @tr("Refresh");
                            RefreshIcon {
                                stroke: Palette.text-mid;
                            }

                            clicked => {
                                root.refresh-health();
                            }
                        }
                    }
                }
            }
        }
    }

    Section {
        label: @tr("RELAYS");
        GroupCard {
            // Add row.
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        border-width: 1px;
                        border-color: input.has-focus ? Palette.mint : Palette.border-2;
                        border-radius: (6px) * Theme.r-scale;
                        background: Palette.panel-2;
                        animate border-color { duration: 120ms; }
                        input := LineInput {
                            x: 10px;
                            y: 0;
                            width: parent.width - 20px;
                            height: parent.height;
                            placeholder: "wss://relay.example.com";
                            text <=> root.draft;
                            submit => {
                                if (root.draft != "") {
                                    root.add-relay(root.draft);
                                    root.draft = "";
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Button {
                            label: @tr("Add");
                            bg-color: Palette.mint;
                            fg: Palette.bubble-out-fg;
                            PlusIcon {
                                stroke: Palette.bubble-out-fg;
                            }

                            clicked => {
                                if (root.draft != "") {
                                    root.add-relay(root.draft);
                                    root.draft = "";
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Palette.border-2;
                }
            }

            // Saved relay list, or empty placeholder.
            if root.relays.length == 0: Rectangle {
                height: 56px;
                Text {
                    x: 16px;
                    width: parent.width - 32px;
                    height: parent.height;
                    text: @tr("No relays yet. Add one above.");
                    color: Palette.text-lo;
                    font-size: (12px) * Theme.fs-scale;
                    vertical-alignment: center;
                }
            }
            for url[i] in root.relays: RelayRow {
                url: url;
                show-divider: i < root.relays.length - 1;
                remove-clicked => {
                    root.remove-relay(url);
                }
            }
        }

        // Restart-required banner. Only shown when the saved list diverges
        // from the booted set — the running runtime can't be re-wired in
        // place, so the truthful signal is "edits queued, apply on restart".
        if root.restart-required: Rectangle {
            height: 36px;
            border-radius: (6px) * Theme.r-scale;
            border-width: 1px;
            border-color: Palette.warning-border;
            background: Palette.warning-soft;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: (3px) * Theme.r-scale;
                        background: Palette.warning;
                    }
                }

                Text {
                    text: @tr("Restart darkmatter to apply relay changes.");
                    color: Palette.text-hi;
                    font-size: (11px) * Theme.fs-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
        }

        // Republish action. Forces your NIP-65 + inbox relay lists to be
        // re-broadcast declaring the full configured set — fixes a stale list
        // that only names a subset of relays and leaves you undiscoverable.
        HorizontalLayout {
            alignment: start;
            Button {
                label: @tr("Republish relay list");
                RefreshIcon {
                    stroke: Palette.text-hi;
                }

                clicked => {
                    root.republish-relay-list();
                }
            }
        }

        Text {
            text: @tr("Re-broadcasts your relay lists to every relay above. Use this if peers can't find you.");
            color: Palette.text-lo;
            font-size: (11px) * Theme.fs-scale;
            wrap: word-wrap;
        }

        if root.status != "": Text {
            text: root.status;
            color: Palette.text-lo;
            font-size: (11px) * Theme.fs-scale;
        }
    }
}
