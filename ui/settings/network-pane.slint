import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { PlusIcon } from "../icons/plus-icon.slint";
import { TrashIcon } from "../icons/trash-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { Button, MicroButton } from "../primitives/button.slint";
import { LineInput } from "../primitives/line-input.slint";

// One row in the relay list. Self-contained so removal hit-testing doesn't
// fight the list-level layout.
component RelayRow inherits Rectangle {
    in property <string> url;
    in property <bool> show-divider: true;
    callback remove-clicked;

    height: 44px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 10px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: root.url;
                color: Palette.text-hi;
                font-size: Theme.fs(12px, 16px);
                font-weight: 500;
                overflow: elide;
            }
        }

        VerticalLayout {
            alignment: center;
            MicroButton {
                label: "";
                // Icon-only and destructive, so it needs a spoken name.
                a11y-label: @tr("Remove relay");
                focusable: true;
                pad-left: 8px;
                pad-right: 8px;
                TrashIcon {
                    stroke: Palette.text-mid;
                }

                clicked => {
                    root.remove-clicked();
                }
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

export component NetworkPane inherits DetailPage {
    // Reads/writes AppState directly (relay list, health counters, add-error)
    // and invokes its callbacks; the page above passes no bindings.

    property <string> draft;

    // The error belongs to the draft, and the draft dies with this pane (it
    // is recreated on every tab switch) — drop a stale error from a previous
    // incarnation (the AppState property outlives us), and clear it as the
    // user edits.
    init => {
        AppState.network-add-error = "";
    }
    changed draft => {
        AppState.network-add-error = "";
    }

    PageHeader {
        title: @tr("Network & relays");
        caption: @tr("Where your messages land.");
        MonitorIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("STATUS");
        GroupCard {
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 14px;

                    Rectangle {
                        width: 10px;
                        height: 10px;
                        y: (parent.height - self.height) / 2;
                        border-radius: (5px) * Theme.r-scale;
                        background: AppState.network-connected > 0 ? Palette.mint : (AppState.network-total > 0 ? Palette.warning : Palette.text-vlo);
                    }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        min-width: 0px;
                        spacing: 3px;
                        alignment: center;
                        Text {
                            text: AppState.network-total == 0 ? @tr("No relays configured") : (AppState.network-connected == AppState.network-total ? @tr("Connected · {}/{}", AppState.network-connected, AppState.network-total) : @tr("Partial · {}/{} connected", AppState.network-connected, AppState.network-total));
                            color: Palette.text-hi;
                            font-size: Theme.fs(12px, 16px);
                            font-weight: 700;
                            overflow: elide;
                        }

                        Text {
                            text: AppState.network-total == 0 ? @tr("Add a relay below — nothing publishes until you do.") : @tr("Aggregate connection counter from the relay pool.");
                            color: Palette.text-lo;
                            font-size: Theme.fs(11px, 14px);
                            overflow: elide;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        MicroButton {
                            label: @tr("Refresh");
                            RefreshIcon {
                                stroke: Palette.text-mid;
                            }

                            clicked => {
                                AppState.network-refresh-health();
                            }
                        }
                    }
                }
            }
        }
    }

    Section {
        label: @tr("RELAYS");
        GroupCard {
            // Add row.
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        border-width: 1px;
                        border-color: AppState.network-add-error != "" ? Palette.danger-border : (input.has-focus ? Palette.mint : Palette.border-2);
                        border-radius: (6px) * Theme.r-scale;
                        background: AppState.network-add-error != "" ? Palette.danger-soft : Palette.panel-2;
                        animate border-color { duration: Theme.transition-dur; }
                        input := LineInput {
                            x: 10px;
                            y: 0;
                            width: parent.width - 20px;
                            height: parent.height;
                            placeholder: "wss://relay.example.com";
                            text <=> root.draft;
                            submit => {
                                if (AppState.network-add-relay(root.draft)) {
                                    root.draft = "";
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Button {
                            label: @tr("Add");
                            bg-color: Palette.mint;
                            fg: Palette.bubble-out-fg;
                            PlusIcon {
                                stroke: Palette.bubble-out-fg;
                            }

                            clicked => {
                                if (AppState.network-add-relay(root.draft)) {
                                    root.draft = "";
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Palette.border-2;
                }
            }

            if AppState.network-add-error != "": HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: AppState.network-add-error;
                    color: Palette.danger;
                    font-size: Theme.fs(11px, 14px);
                    wrap: word-wrap;
                }
            }

            // Saved relay list, or empty placeholder.
            if AppState.network-relays.length == 0: Rectangle {
                height: 56px;
                Text {
                    x: 16px;
                    width: parent.width - 32px;
                    height: parent.height;
                    text: @tr("No relays yet. Add one above.");
                    color: Palette.text-lo;
                    font-size: Theme.fs(12px, 16px);
                    vertical-alignment: center;
                }
            }
            for url[i] in AppState.network-relays: RelayRow {
                url: url;
                show-divider: i < AppState.network-relays.length - 1;
                remove-clicked => {
                    AppState.relay-remove-target = url;
                }
            }
        }

        // Restart-required banner. Only shown when the saved list diverges
        // from the booted set — the running runtime can't be re-wired in
        // place, so the truthful signal is "edits queued, apply on restart".
        if AppState.network-restart-required: Rectangle {
            height: 36px;
            border-radius: (6px) * Theme.r-scale;
            border-width: 1px;
            border-color: Palette.warning-border;
            background: Palette.warning-soft;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                alignment: start;
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: (3px) * Theme.r-scale;
                        background: Palette.warning;
                    }
                }

                Text {
                    text: @tr("Restart darkmatter to apply relay changes.");
                    color: Palette.text-hi;
                    font-size: Theme.fs(11px, 14px);
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
        }

        // Republish action. Forces your NIP-65 + inbox relay lists to be
        // re-broadcast declaring the full configured set — fixes a stale list
        // that only names a subset of relays and leaves you undiscoverable.
        HorizontalLayout {
            alignment: start;
            Button {
                label: AppState.network-republish-busy ? @tr("Republishing…") : @tr("Republish relay list");
                enabled: !AppState.network-republish-busy;
                RefreshIcon {
                    stroke: Palette.text-hi;
                }

                clicked => {
                    if (!AppState.network-republish-busy) {
                        AppState.network-republish-relay-list();
                    }
                }
            }
        }

        Text {
            text: @tr("Re-broadcasts your relay lists to every relay above. Use this if peers can't find you.");
            color: Palette.text-lo;
            font-size: Theme.fs(11px, 14px);
            wrap: word-wrap;
        }

        if AppState.network-status != "": Text {
            text: AppState.network-status;
            color: Palette.text-lo;
            font-size: Theme.fs(11px, 14px);
        }
    }
}
