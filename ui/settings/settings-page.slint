import { Palette } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { SettingsSidebar } from "settings-sidebar.slint";
import { GeneralPane } from "general-pane.slint";
import { AppearancePane } from "appearance-pane.slint";
import { StoragePane } from "storage-pane.slint";
import { NotificationsPane } from "notifications-pane.slint";
import { NetworkPane } from "network-pane.slint";
import { AdvancedPane } from "advanced-pane.slint";
import { DebugPane } from "debug-pane.slint";
import { AboutPane } from "about-pane.slint";

// Navigation/layout only — the panes read and write AppState themselves.
export component SettingsPage inherits Rectangle {
    // The active tab lives on AppState so the shell can host the sidebar in the
    // left card; `show-sidebar` lets the shell render just the panes here.
    in-out property <int> active-tab <=> AppState.settings-tab;
    in property <bool> show-sidebar: true;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-width: 0px;
    preferred-height: 0px;
    background: Palette.bg;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 0;

        if root.show-sidebar: SettingsSidebar {
            active-tab <=> root.active-tab;
        }

        Rectangle {
            horizontal-stretch: 1;
            background: Palette.bg;

            if root.active-tab == 0: GeneralPane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 1: NetworkPane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 2: AppearancePane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 3: NotificationsPane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 4: StoragePane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 5: AdvancedPane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 6: AboutPane {
                width: parent.width;
                height: parent.height;
            }
            if root.active-tab == 7: DebugPane {
                width: parent.width;
                height: parent.height;
            }
        }
    }
}
