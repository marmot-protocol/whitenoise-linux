import { Palette, Theme } from "../tokens.slint";
import { LogoMark } from "../icons/logo-mark.slint";
import { GroupCard } from "../layout/group-card.slint";

// Hero artwork — the SNES lab scene in a framed card, with the app identity
// strip (logo, name, version pill, tagline) beneath it. Fully static.
export component AboutHeroCard inherits GroupCard {
    VerticalLayout {
        spacing: 0;

        Rectangle {
            clip: true;
            background: Palette.artwork-plate;

            Image {
                width: parent.width;
                height: parent.height;
                source: @image-url("../../assets/about.png");
                image-fit: contain;
                horizontal-alignment: center;
            }
        }

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 14px;
            alignment: start;

            LogoMark {
                size: 42px;
                color: Palette.mint;
            }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 4px;
                alignment: center;

                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;

                    Text {
                        text: "White Noise";
                        color: Palette.text-hi;
                        font-size: Theme.fs(18px, 20px);
                        font-weight: 700;
                        font-family: Theme.font;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        border-radius: (11px) * Theme.r-scale;
                        background: Palette.mint-surface;
                        border-width: Theme.border-w;
                        border-color: Palette.mint-dim;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            padding-top: 5px;

                            Text {
                                text: "v0.1.0";
                                color: Palette.mint;
                                font-size: Theme.fs(10px, 14px);
                                font-weight: 700;
                                font-family: Theme.font;
                                letter-spacing: 0.6px;
                            }
                        }
                    }
                }

                Text {
                    text: @tr("End-to-end encrypted group messaging for Linux.");
                    color: Palette.text-mid;
                    font-size: Theme.fs(11px, 14px);
                    wrap: word-wrap;
                }
            }
        }
    }
}
