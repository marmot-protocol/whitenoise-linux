import { Palette, Theme } from "../tokens.slint";

export component SettingsNavItem inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> dim: false;
    callback clicked;

    height: 30px;
    border-radius: (5px) * Theme.r-scale;
    background: root.selected ? Palette.selected : (touch.has-hover ? Palette.hover : transparent);
    animate background { duration: 80ms; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 9px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            @children
        }

        Text {
            text: root.label;
            color: root.dim ? Palette.text-mid : (Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-hi);
            font-size: (12px) * Theme.fs-scale;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}
