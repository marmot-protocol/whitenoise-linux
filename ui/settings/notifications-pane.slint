import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { BellIcon } from "../icons/bell-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Toggle } from "../primitives/toggle.slint";

// Desktop-notification preferences. The master toggle gates the two detail
// toggles (they dim + stop responding when notifications are off), mirroring
// how the rest of the app treats dependent settings.
export component NotificationsPane inherits DetailPage {
    // Reads/writes AppState directly (notification toggles) and invokes its
    // callbacks; the page above passes no bindings.

    PageHeader {
        title: @tr("Notifications");
        caption: @tr("DESKTOP ALERTS");
        BellIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("INCOMING MESSAGES");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Desktop notifications");
                sublabel: @tr("Alert me about messages in chats I'm not viewing.");
                Toggle {
                    label: @tr("Desktop notifications");
                    on <=> AppState.notifications-enabled;
                    toggled => {
                        AppState.notifications-toggled(self.on);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Play a sound");
                Toggle {
                    label: @tr("Play a sound");
                    on <=> AppState.notification-sound;
                    enabled: AppState.notifications-enabled;
                    toggled => {
                        AppState.notification-sound-toggled(self.on);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Show message preview");
                sublabel: @tr("Off shows only \"New message\" without the text.");
                show-divider: false;
                Toggle {
                    label: @tr("Show message preview");
                    on <=> AppState.notification-preview;
                    enabled: AppState.notifications-enabled;
                    toggled => {
                        AppState.notification-preview-toggled(self.on);
                    }
                }
            }
        }
    }
}
