import { Palette, Theme } from "../tokens.slint";
import { InfoIcon } from "../icons/info-icon.slint";
import { AboutHeroCard } from "about-hero-card.slint";
import { LockIcon } from "../icons/lock-icon.slint";
import { KeyIcon } from "../icons/key-icon.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { ScrollView } from "../primitives/scroll-view.slint";

// Compact feature row with a tinted icon tile on the left.
component AboutFeatureRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> show-divider: true;

    height: 64px;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 12px;
        alignment: stretch;

        Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            border-radius: (8px) * Theme.r-scale;
            background: Palette.mint-surface;
            border-width: Theme.border-w;
            border-color: Palette.card-border;

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    @children
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 3px;
            alignment: center;

            Text {
                text: root.title;
                color: Palette.text-hi;
                font-size: Theme.fs(12px, 16px);
                font-weight: 700;
            }

            Text {
                text: root.detail;
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                wrap: word-wrap;
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

export component AboutPane inherits Rectangle {
    horizontal-stretch: 1;
    background: Palette.bg;

    ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-height: page.preferred-height;
        viewport-width: self.visible-width;

        page := VerticalLayout {
            width: parent.width;
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 16px;
            padding-bottom: 28px;
            spacing: 20px;

            PageHeader {
                title: @tr("About");
                caption: @tr("Encrypted group chat on Nostr");
                InfoIcon {
                    stroke: Palette.mint;
                    size: 14px;
                }
            }

            AboutHeroCard { }

            Section {
                label: @tr("WHAT IT IS");

                GroupCard {
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 14px;
                        padding-bottom: 14px;
                        spacing: 10px;

                        Text {
                            text: @tr("Dark Matter is a native desktop client for private group chat. Messages are encrypted with MLS before they leave your machine, routed over Nostr relays, and decrypted only for the people in the room.");
                            color: Palette.text-mid;
                            font-size: Theme.fs(12px, 16px);
                            wrap: word-wrap;
                        }

                        Text {
                            text: @tr("Your keys stay on this device — we never see them.");
                            color: Palette.mint;
                            font-size: Theme.fs(11px, 14px);
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            Section {
                label: @tr("UNDER THE HOOD");

                GroupCard {
                    AboutFeatureRow {
                        title: @tr("End-to-end encryption");
                        detail: @tr("MLS group keys; no server in the trust path.");
                        LockIcon {
                            stroke: Palette.mint;
                        }
                    }

                    AboutFeatureRow {
                        title: @tr("Decentralized network");
                        detail: @tr("Connect to Nostr relays you choose.");
                        MonitorIcon {
                            stroke: Palette.mint;
                        }
                    }

                    AboutFeatureRow {
                        title: @tr("Local key custody");
                        detail: @tr("Private material is stored on this device, encrypted with your password.");
                        show-divider: false;
                        KeyIcon {
                            stroke: Palette.mint;
                        }
                    }
                }
            }

            Section {
                label: @tr("CREDITS");

                GroupCard {
                    KVRow {
                        row-height: 48px;
                        label: @tr("Built with");
                        value: "Rust · Nostr · MLS · Slint";
                        show-divider: false;
                    }
                }
            }

            Text {
                text: @tr("Made with marmots, math, and a little purple liquid.");
                color: Palette.text-vlo;
                font-size: Theme.fs(10px, 14px);
                font-weight: 600;
                letter-spacing: 0.4px;
                horizontal-alignment: center;
            }
        }
    }
}
