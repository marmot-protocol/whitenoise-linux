import { Palette, Theme } from "../tokens.slint";
import { SettingsIcon } from "../icons/settings-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";

export component PlaceholderPane inherits DetailPage {
    in property <string> title;
    in property <string> body;
    PageHeader {
        title: root.title;
        caption: "";
        SettingsIcon {
            stroke: Palette.text-mid;
        }
    }

    Text {
        text: root.body;
        color: Palette.text-lo;
        font-size: Theme.fs(12px, 16px);
    }
}
