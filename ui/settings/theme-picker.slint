// Theme dropdown with live previews (Settings → Appearance).
//
// Lists every registered theme, the built-ins first and then whatever Rust
// loaded from `$DM_HOME/themes/`. Each row shows a mini preview built from that
// theme's actual ThemeColors data (Theme.colors-at(id)) so the swatch always
// matches the real palette, user themes included. Picking a row emits
// theme-mode-selected(mode). Add a built-in theme by appending a name+mode pair
// below; user themes need no edit here, they arrive via Theme.user-theme-names.
import { Palette, Theme, ThemeColors } from "../tokens.slint";

// Mini app-preview chip for one theme id: canvas + side panel + accent dot + text bar.
component ThemeSwatch inherits Rectangle {
    in property <int> pack-id: 0;
    // Fold built-in and user packs so a user theme id (>= built-in count)
    // previews from its real ThemeColors, same as the built-ins.
    property <ThemeColors> pack: Theme.colors-at(root.pack-id);
    width: 46px;
    height: 30px;
    border-radius: 5px * Theme.r-scale;
    clip: true;
    background: root.pack.bg;
    border-width: 1px;
    border-color: root.pack.border;
    // Side panel strip.
    Rectangle {
        x: 0;
        y: 0;
        width: 15px;
        height: parent.height;
        background: root.pack.panel;
    }
    // Accent dot.
    Rectangle {
        x: 22px;
        y: 7px;
        width: 8px;
        height: 8px;
        border-radius: 4px * Theme.r-scale;
        background: root.pack.accent-base[Theme.accent];
    }
    // Text bar.
    Rectangle {
        x: 22px;
        y: 19px;
        width: 17px;
        height: 4px;
        border-radius: 2px * Theme.r-scale;
        background: root.pack.text-hi;
    }
}

// One dropdown row. Extracted so the built-in and user-theme loops share the
// same body without duplicating the swatch/label/check markup.
component ThemeRow inherits Rectangle {
    in property <int> pack-id: 0;
    in property <string> label;
    in property <bool> is-selected: false;
    in property <bool> is-focused: false;
    callback chosen();
    height: 44px;
    border-radius: 7px * Theme.r-scale;
    background: root.is-selected ? Palette.selected : ((root.is-focused || row-touch.has-hover) ? Palette.hover : transparent);
    animate background { duration: 80ms; }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 10px;
        alignment: start;
        ThemeSwatch {
            pack-id: root.pack-id;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: root.label;
            color: Palette.text-hi;
            font-family: Theme.font;
            font-size: Theme.fs(12px, 16px);
            font-weight: root.is-selected ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        if root.is-selected: Text {
            text: "✓";
            color: Palette.mint;
            font-family: Theme.font;
            font-size: Theme.fs(13px, 16px);
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    row-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.chosen();
        }
    }
}

export component ThemePicker inherits Rectangle {
    // Active theme id (0=dark, 1=light, 2=retro, 3=terminal, 4=crayon,
    // 5=synthwave, 6=chalkboard, 7=amoled), computed by the caller.
    in property <int> selected-id: 0;
    callback theme-mode-selected(string);

    property <[string]> names: [
        @tr("Dark"),
        @tr("Light"),
        @tr("Retro"),
        @tr("Terminal"),
        @tr("Sketch"),
        @tr("Synthwave"),
        @tr("Chalkboard"),
        @tr("AMOLED")
    ];
    property <[string]> modes: [
        "dark",
        "light",
        "retro",
        "terminal",
        "crayon",
        "synthwave",
        "chalkboard",
        "amoled"
    ];

    // Total selectable themes = built-ins plus whatever Rust loaded from
    // `$DM_HOME/themes/`. The two fold helpers below map a row id onto the
    // built-in arrays for the first `names.length` ids and onto the
    // Rust-provided user arrays beyond that, so one id space spans both.
    function theme-count() -> int {
        return root.names.length + Theme.user-theme-names.length;
    }
    function name-at(i: int) -> string {
        return i < root.names.length ? root.names[i] : Theme.user-theme-names[i - root.names.length];
    }
    function mode-at(i: int) -> string {
        return i < root.modes.length ? root.modes[i] : Theme.user-theme-modes[i - root.modes.length];
    }

    // Keyboard cursor inside the open dropdown; reset to the active theme each
    // time the popup opens.
    property <int> focus-idx: 0;

    width: 184px;
    height: 38px;

    function open-popup() {
        root.focus-idx = root.selected-id;
        popup.show();
    }

    // ── Trigger ──
    trigger := Rectangle {
        background: trig-touch.has-hover ? Palette.field-hover : Palette.field;
        border-width: Theme.border-w;
        border-color: trig-touch.has-hover ? Palette.field-border-hover : Palette.field-border;
        border-radius: 8px * Theme.r-scale;
        animate background, border-color { duration: 120ms; }
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 10px;
            spacing: 9px;
            alignment: start;
            ThemeSwatch {
                pack-id: root.selected-id;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: root.name-at(root.selected-id);
                color: Palette.text-hi;
                font-family: Theme.font;
                font-size: Theme.fs(12px, 16px);
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Text {
                text: "▾";
                color: Palette.text-lo;
                font-family: Theme.font;
                font-size: Theme.fs(12px, 16px);
                vertical-alignment: center;
            }
        }

        trig-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.open-popup();
            }
        }

        // Zero-size FocusScope so the trigger joins the Tab chain without
        // stealing pointer focus. Enter/Space/Down/Up open the dropdown.
        trig-fs := FocusScope {
            width: 0px;
            height: 0px;
            key-pressed(event) => {
                if (event.text == Key.Return || event.text == " " || event.text == Key.DownArrow || event.text == Key.UpArrow) {
                    root.open-popup();
                    return accept;
                }
                return reject;
            }
        }

        // Accent focus ring on the trigger when Tab-focused.
        if trig-fs.has-focus: Rectangle {
            x: -3px;
            y: -3px;
            width: parent.width + 6px;
            height: parent.height + 6px;
            border-radius: (11px) * Theme.r-scale;
            border-width: 2px;
            border-color: Palette.mint;
            background: transparent;
        }
    }

    // ── Dropdown ──
    popup := PopupWindow {
        x: root.width - self.width;
        y: root.height + 5px;
        width: 230px;
        close-policy: close-on-click-outside;

        Rectangle {
            background: Palette.elevated;
            border-width: Theme.border-w;
            border-color: Palette.elevated-border;
            border-radius: 10px * Theme.r-scale;
            drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
            drop-shadow-offset-x: Theme.hard-shadow ? 4px : 0px;
            drop-shadow-offset-y: Theme.hard-shadow ? 4px : 10px;
            drop-shadow-blur: Theme.hard-shadow ? 0px : 24px;

            // FocusScope owns the keyboard while the dropdown is open:
            // ↑/↓ move the cursor, Enter/Space commit, Esc closes.
            pop-fs := FocusScope {
                init => {
                    self.focus();
                }
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        popup.close();
                        return accept;
                    }
                    if (event.text == Key.UpArrow) {
                        root.focus-idx = root.focus-idx == 0 ? root.theme-count() - 1 : root.focus-idx - 1;
                        return accept;
                    }
                    if (event.text == Key.DownArrow) {
                        root.focus-idx = mod(root.focus-idx + 1, root.theme-count());
                        return accept;
                    }
                    if (event.text == Key.Return || event.text == " ") {
                        root.theme-mode-selected(root.mode-at(root.focus-idx));
                        popup.close();
                        return accept;
                    }
                    return reject;
                }

                VerticalLayout {
                    padding: 5px;
                    spacing: 2px;
                    for name[i] in root.names: ThemeRow {
                        pack-id: i;
                        label: name;
                        is-selected: i == root.selected-id;
                        is-focused: i == root.focus-idx;
                        chosen => {
                            root.theme-mode-selected(root.modes[i]);
                            popup.close();
                        }
                    }
                    for uname[j] in Theme.user-theme-names: ThemeRow {
                        pack-id: root.names.length + j;
                        label: uname;
                        is-selected: (root.names.length + j) == root.selected-id;
                        is-focused: (root.names.length + j) == root.focus-idx;
                        chosen => {
                            root.theme-mode-selected(Theme.user-theme-modes[j]);
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}
