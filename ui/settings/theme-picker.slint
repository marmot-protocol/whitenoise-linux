// Theme dropdown with live previews (Settings → Appearance).
//
// Replaces the old per-theme toggles. Lists every registered theme; each row
// shows a mini preview built from that theme's actual ThemeColors data
// (Theme.color-packs[id]) so the swatch always matches the real palette. Picking
// a row emits theme-mode-selected(mode) — the same callback the toggles used, so
// no Rust changes. Add a theme → just append a name+mode pair below.
import { Palette, Theme } from "../tokens.slint";

// Mini app-preview chip for one theme id: canvas + side panel + accent dot + text bar.
component ThemeSwatch inherits Rectangle {
    in property <int> pack-id: 0;
    width: 46px;
    height: 30px;
    border-radius: 5px * Theme.r-scale;
    clip: true;
    background: Theme.color-packs[root.pack-id].bg;
    border-width: 1px;
    border-color: Theme.color-packs[root.pack-id].border;
    // Side panel strip.
    Rectangle {
        x: 0;
        y: 0;
        width: 15px;
        height: parent.height;
        background: Theme.color-packs[root.pack-id].panel;
    }
    // Accent dot.
    Rectangle {
        x: 22px;
        y: 7px;
        width: 8px;
        height: 8px;
        border-radius: 4px * Theme.r-scale;
        background: Theme.color-packs[root.pack-id].accent-base[Theme.accent];
    }
    // Text bar.
    Rectangle {
        x: 22px;
        y: 19px;
        width: 17px;
        height: 4px;
        border-radius: 2px * Theme.r-scale;
        background: Theme.color-packs[root.pack-id].text-hi;
    }
}

export component ThemePicker inherits Rectangle {
    // Active theme id (0=dark, 1=light, 2=retro, 3=terminal, 4=crayon,
    // 5=synthwave), computed by the caller.
    in property <int> selected-id: 0;
    callback theme-mode-selected(string);

    property <[string]> names: [
        @tr("Dark"),
        @tr("Light"),
        @tr("Retro"),
        @tr("Terminal"),
        @tr("Sketch"),
        @tr("Synthwave"),
        @tr("Chalkboard")
    ];
    property <[string]> modes: ["dark", "light", "retro", "terminal", "crayon", "synthwave", "chalkboard"];

    // Keyboard cursor inside the open dropdown; reset to the active theme each
    // time the popup opens.
    property <int> focus-idx: 0;

    width: 184px;
    height: 38px;

    function open-popup() {
        root.focus-idx = root.selected-id;
        popup.show();
    }

    // ── Trigger ──
    trigger := Rectangle {
        background: trig-touch.has-hover ? Palette.field-hover : Palette.field;
        border-width: Theme.border-w;
        border-color: trig-touch.has-hover ? Palette.field-border-hover : Palette.field-border;
        border-radius: 8px * Theme.r-scale;
        animate background, border-color { duration: 120ms; }
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 10px;
            spacing: 9px;
            alignment: start;
            ThemeSwatch {
                pack-id: root.selected-id;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: root.names[root.selected-id];
                color: Palette.text-hi;
                font-family: Theme.font;
                font-size: 12px * Theme.fs-scale;
                font-weight: 700;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Text {
                text: "▾";
                color: Palette.text-lo;
                font-family: Theme.font;
                font-size: 12px * Theme.fs-scale;
                vertical-alignment: center;
            }
        }

        trig-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.open-popup();
            }
        }

        // Zero-size FocusScope so the trigger joins the Tab chain without
        // stealing pointer focus. Enter/Space/Down/Up open the dropdown.
        trig-fs := FocusScope {
            width: 0px;
            height: 0px;
            key-pressed(event) => {
                if (event.text == Key.Return || event.text == " " || event.text == Key.DownArrow || event.text == Key.UpArrow) {
                    root.open-popup();
                    return accept;
                }
                return reject;
            }
        }

        // Accent focus ring on the trigger when Tab-focused.
        if trig-fs.has-focus: Rectangle {
            x: -3px;
            y: -3px;
            width: parent.width + 6px;
            height: parent.height + 6px;
            border-radius: (11px) * Theme.r-scale;
            border-width: 2px;
            border-color: Palette.mint;
            background: transparent;
        }
    }

    // ── Dropdown ──
    popup := PopupWindow {
        x: root.width - self.width;
        y: root.height + 5px;
        width: 230px;
        close-policy: close-on-click-outside;

        Rectangle {
            background: Palette.elevated;
            border-width: Theme.border-w;
            border-color: Palette.elevated-border;
            border-radius: 10px * Theme.r-scale;
            drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
            drop-shadow-offset-x: Theme.hard-shadow ? 4px : 0px;
            drop-shadow-offset-y: Theme.hard-shadow ? 4px : 10px;
            drop-shadow-blur: Theme.hard-shadow ? 0px : 24px;

            // FocusScope owns the keyboard while the dropdown is open:
            // ↑/↓ move the cursor, Enter/Space commit, Esc closes.
            pop-fs := FocusScope {
                init => {
                    self.focus();
                }
                key-pressed(event) => {
                    if (event.text == Key.Escape) {
                        popup.close();
                        return accept;
                    }
                    if (event.text == Key.UpArrow) {
                        root.focus-idx = root.focus-idx == 0 ? root.names.length - 1 : root.focus-idx - 1;
                        return accept;
                    }
                    if (event.text == Key.DownArrow) {
                        root.focus-idx = mod(root.focus-idx + 1, root.names.length);
                        return accept;
                    }
                    if (event.text == Key.Return || event.text == " ") {
                        root.theme-mode-selected(root.modes[root.focus-idx]);
                        popup.close();
                        return accept;
                    }
                    return reject;
                }

                VerticalLayout {
                    padding: 5px;
                    spacing: 2px;
                    for name[i] in root.names: Rectangle {
                        height: 44px;
                        border-radius: 7px * Theme.r-scale;
                        background: i == root.selected-id ? Palette.selected : (i == root.focus-idx ? Palette.hover : (row-touch.has-hover ? Palette.hover : transparent));
                        animate background { duration: 80ms; }
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: start;
                            ThemeSwatch {
                                pack-id: i;
                                y: (parent.height - self.height) / 2;
                            }

                            Text {
                                text: name;
                                color: Palette.text-hi;
                                font-family: Theme.font;
                                font-size: 12px * Theme.fs-scale;
                                font-weight: i == root.selected-id ? 700 : 500;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            if i == root.selected-id: Text {
                                text: "✓";
                                color: Palette.mint;
                                font-family: Theme.font;
                                font-size: 13px * Theme.fs-scale;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }

                        row-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.theme-mode-selected(root.modes[i]);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}
