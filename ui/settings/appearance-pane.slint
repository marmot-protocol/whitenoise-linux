import { Palette } from "../tokens.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";
import { Section } from "../shells/section.slint";
import { GroupCard } from "../shells/group-card.slint";
import { KVRow } from "../shells/kv-row.slint";
import { Toggle } from "toggle.slint";
import { AccentPicker } from "accent-picker.slint";
import { ThemePicker } from "theme-picker.slint";

export component AppearancePane inherits DetailPage {
    in-out property <bool> light-theme: false;
    in-out property <bool> retro-mode: false;
    in-out property <bool> terminal-mode: false;
    in-out property <bool> crayon-mode: false;
    in-out property <bool> synthwave-mode: false;
    in-out property <bool> chalkboard-mode: false;
    in-out property <bool> amoled-mode: false;
    in-out property <int> accent-color: 0;
    in-out property <bool> outgoing-on-right: true;
    callback theme-mode-selected(string);
    callback accent-selected(int);
    callback outgoing-on-right-toggled(bool);

    property <[string]> accent-names: [
        @tr("Mint"),
        @tr("Ocean"),
        @tr("Berry"),
        @tr("Coral"),
        @tr("Lavender"),
    ];

    PageHeader {
        title: @tr("Appearance");
        caption: "";
        MonitorIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("THEME");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Theme");
                sublabel: @tr("Pick the whole app's look.");
                ThemePicker {
                    selected-id: root.amoled-mode ? 7 : (root.chalkboard-mode ? 6 : (root.synthwave-mode ? 5 : (root.crayon-mode ? 4 : (root.terminal-mode ? 3 : (root.retro-mode ? 2 : (root.light-theme ? 1 : 0))))));
                    theme-mode-selected(mode) => {
                        root.theme-mode-selected(mode);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Accent color");
                value: accent-names[root.accent-color];
                show-divider: false;
                AccentPicker {
                    selected <=> root.accent-color;
                    accent-selected(idx) => {
                        root.accent-selected(idx);
                    }
                }
            }
        }
    }

    Section {
        label: @tr("MESSAGES");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Own messages on the right");
                sublabel: @tr("Place your sent messages on the right side.");
                show-divider: false;
                Toggle {
                    on <=> root.outgoing-on-right;
                    toggled => {
                        root.outgoing-on-right-toggled(root.outgoing-on-right);
                    }
                }
            }
        }
    }
}
