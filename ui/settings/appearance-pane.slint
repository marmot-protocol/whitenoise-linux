import { AppState } from "../shell/app-state.slint";
import { Palette } from "../tokens.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Toggle } from "../primitives/toggle.slint";
import { AccentPicker } from "accent-picker.slint";
import { ThemePicker } from "theme-picker.slint";

export component AppearancePane inherits DetailPage {
    // Reads/writes AppState directly (theme, accent, bubble side) and invokes
    // its callbacks; the page above passes no bindings.

    property <[string]> accent-names: [
        @tr("Mint"),
        @tr("Ocean"),
        @tr("Berry"),
        @tr("Coral"),
        @tr("Lavender"),
    ];

    PageHeader {
        title: @tr("Appearance");
        caption: "";
        MonitorIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("THEME");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Theme");
                sublabel: @tr("Pick the whole app's look.");
                ThemePicker {
                    selected-id: AppState.theme-id;
                    theme-mode-selected(mode) => {
                        AppState.theme-mode-selected(mode);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Accent color");
                value: accent-names[AppState.accent-color];
                show-divider: false;
                AccentPicker {
                    selected <=> AppState.accent-color;
                    accent-selected(idx) => {
                        AppState.accent-selected(idx);
                    }
                }
            }
        }
    }

    Section {
        label: @tr("MESSAGES");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Own messages on the right");
                sublabel: @tr("Place your sent messages on the right side.");
                show-divider: false;
                Toggle {
                    on <=> AppState.outgoing-on-right;
                    toggled => {
                        AppState.outgoing-on-right-toggled(AppState.outgoing-on-right);
                    }
                }
            }
        }
    }
}
