import { Palette } from "../tokens.slint";
import { MonitorIcon } from "../icons/monitor-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Toggle } from "../primitives/toggle.slint";
import { AccentPicker } from "accent-picker.slint";
import { ThemePicker } from "theme-picker.slint";

export component AppearancePane inherits DetailPage {
    in-out property <int> theme-id: 0;
    in-out property <int> accent-color: 0;
    in-out property <bool> outgoing-on-right: true;
    callback theme-mode-selected(string);
    callback accent-selected(int);
    callback outgoing-on-right-toggled(bool);

    property <[string]> accent-names: [
        @tr("Mint"),
        @tr("Ocean"),
        @tr("Berry"),
        @tr("Coral"),
        @tr("Lavender"),
    ];

    PageHeader {
        title: @tr("Appearance");
        caption: "";
        MonitorIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: @tr("THEME");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Theme");
                sublabel: @tr("Pick the whole app's look.");
                ThemePicker {
                    selected-id: root.theme-id;
                    theme-mode-selected(mode) => {
                        root.theme-mode-selected(mode);
                    }
                }
            }

            KVRow {
                row-height: 48px;
                label: @tr("Accent color");
                value: accent-names[root.accent-color];
                show-divider: false;
                AccentPicker {
                    selected <=> root.accent-color;
                    accent-selected(idx) => {
                        root.accent-selected(idx);
                    }
                }
            }
        }
    }

    Section {
        label: @tr("MESSAGES");
        GroupCard {
            KVRow {
                row-height: 48px;
                label: @tr("Own messages on the right");
                sublabel: @tr("Place your sent messages on the right side.");
                show-divider: false;
                Toggle {
                    on <=> root.outgoing-on-right;
                    toggled => {
                        root.outgoing-on-right-toggled(root.outgoing-on-right);
                    }
                }
            }
        }
    }
}
