import { Palette , Theme} from "../tokens.slint";

export component Toggle inherits Rectangle {
    in-out property <bool> on: false;
    callback toggled;
    width: Theme.retro ? 44px : 34px; height: Theme.retro ? 22px : 18px;
    border-radius: (9px) * Theme.r-scale;
    background: root.on ? Palette.mint : Palette.field;
    border-width: Theme.retro ? Theme.border-w : (root.on ? 0px : 1px);
    border-color: Palette.border;
    drop-shadow-color: Theme.retro ? Palette.shadow : transparent;
    drop-shadow-offset-x: Theme.retro ? 2px : 0px;
    drop-shadow-offset-y: Theme.retro ? 2px : 0px;
    drop-shadow-blur: 0px;
    animate background { duration: 120ms; }

    Rectangle {
        width: Theme.retro ? 14px : 14px; height: Theme.retro ? 14px : 14px;
        x: root.on ? parent.width - self.width - (Theme.retro ? 4px : 2px) : (Theme.retro ? 4px : 2px);
        y: (parent.height - self.height) / 2;
        border-radius: (7px) * Theme.r-scale;
        background: root.on ? Palette.bubble-out-fg : Palette.text-mid;
        animate x { duration: 120ms; easing: ease-in-out; }
    }

    if Theme.retro : Text {
        x: root.on ? 6px : parent.width - self.width - 6px;
        y: (parent.height - self.height) / 2;
        text: root.on ? "ON" : "OFF";
        color: root.on ? Palette.bubble-out-fg : Palette.text-mid;
        font-size: 8px;
        font-family: Theme.font;
        font-weight: 700;
        vertical-alignment: center;
    }

    TouchArea {
        clicked => { root.on = !root.on; root.toggled(); }
    }
}
