import { Palette, Theme } from "../tokens.slint";

export component Toggle inherits Rectangle {
    in-out property <bool> on: false;
    in property <bool> enabled: true;
    callback toggled;
    width: Theme.pixel-metrics ? 44px : 34px;
    height: Theme.pixel-metrics ? 22px : 18px;
    opacity: root.enabled ? 1.0 : 0.45;
    animate opacity { duration: Theme.transition-dur; }
    border-radius: (9px) * Theme.r-scale;
    background: root.on ? Palette.mint : Palette.field;
    border-width: Theme.outline-surfaces ? Theme.border-w : (root.on ? 0px : 1px);
    border-color: Palette.border;
    drop-shadow-color: Theme.hard-shadow ? Palette.shadow : transparent;
    drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-blur: 0px;
    animate background { duration: Theme.transition-dur; }

    Rectangle {
        width: 14px;
        height: 14px;
        x: root.on ? parent.width - self.width - (Theme.pixel-metrics ? 4px : 2px) : (Theme.pixel-metrics ? 4px : 2px);
        y: (parent.height - self.height) / 2;
        border-radius: (7px) * Theme.r-scale;
        background: root.on ? Palette.bubble-out-fg : Palette.text-mid;
        animate x {
            duration: Theme.transition-dur;
            easing: ease-in-out;
        }
    }

    if Theme.pixel-icons: Text {
        x: root.on ? 6px : parent.width - self.width - 6px;
        y: (parent.height - self.height) / 2;
        text: root.on ? "ON" : "OFF";
        color: root.on ? Palette.bubble-out-fg : Palette.text-mid;
        // Zpix is a 12px-grid bitmap font; off-grid sizes rasterize blurry.
        font-size: Theme.fs(12px, 16px);
        font-family: Theme.font;
        font-weight: 700;
        vertical-alignment: center;
    }

    // FocusScope owns the keyboard: Tab reaches the toggle, Enter/Space flip
    // it. Mirrors AccentPicker's key handling in accent-picker.slint.
    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.on = !root.on;
                root.toggled();
                return accept;
            }
            return reject;
        }

        TouchArea {
            enabled: root.enabled;
            clicked => {
                root.on = !root.on;
                root.toggled();
            }
        }
    }

    // Accent focus ring just outside the track (mirrors AccentPicker's).
    if fs.has-focus: Rectangle {
        x: -3px;
        y: -3px;
        width: parent.width + 6px;
        height: parent.height + 6px;
        border-radius: (12px) * Theme.r-scale;
        border-width: 2px;
        border-color: Palette.mint;
        background: transparent;
    }
}
