import { Palette, Theme } from "../tokens.slint";
import { TerminalIcon } from "../icons/terminal-icon.slint";
import { DetailPage } from "../shells/detail-page.slint";
import { PageHeader } from "../shells/page-header.slint";
import { Section } from "../shells/section.slint";
import { Button } from "../primitives/button.slint";

export component DebugPane inherits DetailPage {
    in property <string> dump;
    // Which view is loaded into the dump area: 0 = state snapshot,
    // 1 = raw events, 2 = key packages. Rust reads it back in `load`.
    property <int> mode: 0;
    // Fires with the mode to (re)load; Rust collects the matching dump on a
    // worker thread and sets `dump`.
    callback load(int);
    callback copy-clicked;

    PageHeader {
        title: @tr("Debug");
        caption: @tr("State / raw events / key packages");
        TerminalIcon {
            stroke: Palette.mint;
        }
    }

    Section {
        label: root.mode == 1 ? @tr("RAW EVENTS") : root.mode == 2 ? @tr("KEY PACKAGES") : @tr("STATE SNAPSHOT");

        // Split into a view selector and an actions row so the five buttons
        // never overrun a narrow pane and clip at the edge; each row fits on
        // its own and stays fully visible at any window width.
        VerticalLayout {
            spacing: 8px;
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Button {
                    label: @tr("State");
                    clicked => {
                        root.mode = 0;
                        root.load(0);
                    }
                }

                Button {
                    label: @tr("Raw events");
                    clicked => {
                        root.mode = 1;
                        root.load(1);
                    }
                }

                Button {
                    label: @tr("Key packages");
                    clicked => {
                        root.mode = 2;
                        root.load(2);
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                Button {
                    label: @tr("Refresh");
                    clicked => {
                        root.load(root.mode);
                    }
                }

                Button {
                    label: @tr("Copy JSON");
                    clicked => {
                        root.copy-clicked();
                    }
                }
            }
        }

        Rectangle {
            border-width: 1px;
            border-color: Palette.border-2;
            border-radius: (6px) * Theme.r-scale;
            background: Palette.panel-2;
            preferred-height: 540px;
            vertical-stretch: 1;
            clip: true;

            Flickable {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                viewport-width: parent.width;
                viewport-height: dump-text.preferred-height + 24px;

                dump-text := Text {
                    x: 12px;
                    y: 12px;
                    width: parent.width - 24px;
                    text: root.dump != "" ? root.dump : @tr("(no snapshot yet — click Refresh)");
                    color: Palette.text-hi;
                    font-family: Theme.font;
                    font-size: Theme.fs(11px, 14px);
                    wrap: word-wrap;
                }
            }
        }
    }
}
