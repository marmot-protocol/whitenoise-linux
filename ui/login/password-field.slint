import { Palette, Theme } from "../tokens.slint";
import { VaultField } from "vault-field.slint";
import { EyeIcon } from "../icons/eye-icon.slint";

// A VaultField that is always a password entry: masked by default, with an
// eye button inside the box that reveals the typed characters. Reveal state
// is per instance, so leaving a login mode resets every field to masked.
export component PasswordField inherits VaultField {
    property <bool> revealed: false;
    password: !root.revealed;
    function toggle-reveal() {
        root.revealed = !root.revealed;
    }

    Rectangle {
        width: 22px;
        reveal-touch := TouchArea {
            mouse-cursor: pointer;
            accessible-role: button;
            accessible-label: root.revealed ? @tr("Hide password") : @tr("Show password");
            accessible-action-default => {
                root.toggle-reveal();
            }
            clicked => {
                root.toggle-reveal();
            }
        }

        EyeIcon {
            stroke: reveal-touch.has-hover ? Palette.text-hi : Palette.text-mid;
            crossed: root.revealed;
        }
    }
}
