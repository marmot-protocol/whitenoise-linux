// Sign-in gate. Four modes (controlled by `mode`):
//   0 = choose:  paste an existing nsec, or generate a new one
//   1 = enter:   paste/type an nsec AND set a vault password, then continue
//   2 = show:    display the freshly generated nsec + set a vault password
//   3 = unlock:  an encrypted vault already exists — enter its password
//
// Secrets are sealed in a password-encrypted vault on disk (no OS keyring).
// Rust owns validation, generation, encryption, and persistence. This is dumb.

import { Palette, Theme } from "../tokens.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Button } from "../primitives/button.slint";
import { LogoMark } from "../icons/logo-mark.slint";
import { KeyIcon } from "../icons/key-icon.slint";
import { LockIcon } from "../icons/lock-icon.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { PlusIcon } from "../icons/plus-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { Avatar } from "../primitives/avatar.slint";

// A labeled field box matching the login card style. Used for the nsec input
// and the password / confirm-password fields.
component VaultField inherits VerticalLayout {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> text;
    in property <bool> password: false;
    in property <bool> error: false;
    callback submit;
    spacing: 6px;

    Text {
        text: root.label;
        color: Palette.text-mid;
        font-size: (9px) * Theme.fs-scale;
        font-weight: 700;
        letter-spacing: 1.6px;
    }
    Rectangle {
        height: 44px;
        border-radius: (7px) * Theme.r-scale;
        background: root.error ? Palette.danger-soft : Palette.field;
        border-width: 1px;
        border-color: root.error
            ? Palette.danger-border
            : (vf-input.has-focus ? Palette.mint-dim : Palette.field-border);
        drop-shadow-blur: vf-input.has-focus && !root.error && Theme.focus-glow ? 10px : 0px;
        drop-shadow-color: Palette.mint-glow;
        animate border-color { duration: 140ms; easing: ease-out; }
        HorizontalLayout {
            padding-left: 14px; padding-right: 14px;
            vf-input := LineInput {
                placeholder: root.placeholder;
                text <=> root.text;
                password: root.password;
                // LineInput multiplies by fs-scale internally.
                font-size: Theme.fsr(13px, 14px);
                fg: Palette.text-hi;
                placeholder-color: Palette.text-vlo;
                submit => { root.submit(); }
            }
        }
    }
}

export component LoginScreen inherits Rectangle {
    // 0 = choose, 1 = enter nsec, 2 = show generated, 3 = unlock existing vault.
    in-out property <int> mode: 0;
    // bound to LineInput; Rust reads on submit.
    in-out property <string> nsec-input;
    // vault password (set in modes 1/2, entered in mode 3) and its confirmation.
    in-out property <string> password-input;
    in-out property <string> password-confirm;
    // shown in mode 2 after Rust fills it from Keys::generate().
    in property <string> generated-nsec;
    in property <string> generated-npub;
    // Random "[Adjective] [Animal]" name + locally rendered starter avatar.
    in property <string> generated-display-name;
    in property <image> generated-avatar;
    in property <bool> generated-has-avatar: false;
    // error from last attempt (empty = no error). in-out so the component can also
    // clear it locally when the user navigates between modes.
    in-out property <string> error: "";
    // disable actions while Rust is working (deriving the key, booting).
    in property <bool> busy: false;
    // Mode-2 name/avatar reveal progress (0 → 1).
    property <float> name-reveal: 0;
    property <float> avatar-reveal: 0;
    changed generated-display-name => {
        if (root.generated-display-name != "") {
            self.name-reveal = 0;
            self.name-reveal = 1;
        }
    }
    changed generated-has-avatar => {
        if (root.generated-has-avatar) {
            self.avatar-reveal = 0;
            self.avatar-reveal = 1;
        }
    }
    animate name-reveal, avatar-reveal { duration: 300ms; easing: ease-out; }

    callback login-with-nsec(string, string, string); // nsec, password, confirm
    callback generate-requested();
    callback confirm-saved(string, string);            // password, confirm
    callback unlock(string);                            // vault password
    callback reset-vault();
    callback copy-nsec(string);
    callback import-backup();                            // restore from an encrypted backup

    // Guarded action helpers so submit-on-Enter and button clicks share a path.
    function create-account() {
        if (!root.busy) {
            root.login-with-nsec(root.nsec-input, root.password-input, root.password-confirm);
        }
    }
    function save-generated() {
        if (!root.busy) { root.confirm-saved(root.password-input, root.password-confirm); }
    }
    function do-unlock() {
        if (!root.busy) { root.unlock(root.password-input); }
    }

    background: Palette.bg;

    // Subtle vignette so the card pops.
    Rectangle {
        width: parent.width; height: parent.height;
        background: Theme.light && !Theme.retro
            ? @radial-gradient(circle, #FFFFFF00 0%, #D8CFBF80 100%)
            : @radial-gradient(circle, #0F141A00 0%, #00000080 100%);
    }

    // Centered card.
    Rectangle {
        width: 480px;
        // Per-mode baseline, but never clip the content: translated strings
        // (de/ja) can run taller than the English layout was tuned for.
        height: max(root.mode == 2 ? 740px : root.mode == 1 ? 520px : 420px,
                    card-content.preferred-height);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: (12px) * Theme.r-scale;
        background: Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 40px;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : #000000C0;
        drop-shadow-offset-x: Theme.hard-shadow ? 6px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 6px : 10px;
        animate height { duration: 200ms; easing: ease-in-out; }

        // Top bevel highlight (matches the Modal card convention).
        Rectangle {
            x: 1px; y: 1px;
            width: parent.width - 2px;
            height: 1px;
            background: Palette.top-glint;
        }

        card-content := VerticalLayout {
            padding-left: 32px; padding-right: 32px;
            padding-top: 32px; padding-bottom: 24px;
            spacing: 22px;

            // Header — logo + title + caption.
            VerticalLayout {
                spacing: 12px;
                alignment: center;
                LogoMark {
                    size: 48px;
                    color: Palette.mint;
                }
                Text {
                    text: "darkmatter";
                    color: Palette.text-hi;
                    font-size: (22px) * Theme.fs-scale;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.mode == 0
                        ? @tr("Sign in to your Nostr identity")
                        : root.mode == 1
                            ? @tr("Import a key & set a password")
                            : root.mode == 3
                                ? @tr("Enter your password to unlock")
                                : @tr("Save your new key");
                    color: Palette.text-lo;
                    font-size: (12px) * Theme.fs-scale;
                    horizontal-alignment: center;
                }
            }

            // === MODE 0: choose ===
            if root.mode == 0 : VerticalLayout {
                spacing: 12px;

                Button {
                    label: @tr("I have an nsec");
                    button-height: 44px;
                    radius: 8px;
                    font-size: Theme.fs(13px, 16px);
                    bg-color: Palette.mint;
                    outline: Palette.mint;
                    hover-bg: Palette.mint-hi;
                    hover-outline: Palette.mint-hi;
                    fg: Palette.bubble-out-fg;
                    KeyIcon { stroke: Palette.bubble-out-fg; }
                    clicked => {
                        root.error = "";
                        root.nsec-input = "";
                        root.password-input = "";
                        root.password-confirm = "";
                        root.mode = 1;
                    }
                }

                Button {
                    label: @tr("Generate a new key");
                    button-height: 44px;
                    radius: 8px;
                    font-size: Theme.fs(13px, 16px);
                    bg-color: Palette.field;
                    outline: Palette.field-border;
                    hover-bg: Palette.field-hover;
                    hover-outline: Palette.field-border-hover;
                    PlusIcon { stroke: Palette.text-mid; size: 12px; }
                    clicked => {
                        root.error = "";
                        root.password-input = "";
                        root.password-confirm = "";
                        root.generate-requested();
                    }
                }

                Button {
                    label: @tr("Import a backup");
                    button-height: 44px;
                    radius: 8px;
                    font-size: Theme.fs(13px, 16px);
                    bg-color: Palette.field;
                    outline: Palette.field-border;
                    hover-bg: Palette.field-hover;
                    hover-outline: Palette.field-border-hover;
                    clicked => {
                        root.error = "";
                        root.import-backup();
                    }
                }

                Rectangle { vertical-stretch: 1; }

                Text {
                    text: @tr("Your key never leaves this device.");
                    color: Palette.text-vlo;
                    font-size: (10px) * Theme.fs-scale;
                    horizontal-alignment: center;
                }
            }

            // === MODE 1: enter existing nsec + set vault password ===
            if root.mode == 1 : VerticalLayout {
                spacing: 12px;

                VaultField {
                    label: @tr("NSEC");
                    placeholder: "nsec1…";
                    text <=> root.nsec-input;
                    error: root.error != "";
                    submit => { root.create-account(); }
                }
                VaultField {
                    label: @tr("VAULT PASSWORD");
                    placeholder: @tr("Choose a password");
                    text <=> root.password-input;
                    password: true;
                    submit => { root.create-account(); }
                }
                VaultField {
                    label: @tr("CONFIRM PASSWORD");
                    placeholder: @tr("Re-enter password");
                    text <=> root.password-confirm;
                    password: true;
                    submit => { root.create-account(); }
                }

                if root.error != "" : Text {
                    text: root.error;
                    color: Palette.danger;
                    font-size: (11px) * Theme.fs-scale;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 10px;
                    Button {
                        label: @tr("Back");
                        button-height: 38px;
                        min-w: 96px;
                        clicked => {
                            root.error = "";
                            root.mode = 0;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        label: root.busy ? @tr("Signing in…") : @tr("Continue");
                        button-height: 38px;
                        min-w: 120px;
                        bg-color: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-hi;
                        hover-outline: Palette.mint-hi;
                        fg: Palette.bubble-out-fg;
                        clicked => { root.create-account(); }
                    }
                }
            }

            // === MODE 2: show generated key + set vault password ===
            if root.mode == 2 : VerticalLayout {
                spacing: 14px;

                if root.generated-display-name != "" : Rectangle {
                    height: 72px;
                    border-radius: (8px) * Theme.r-scale;
                    background: Palette.field;
                    border-width: 1px;
                    border-color: Palette.field-border;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        spacing: 14px;
                        alignment: center;
                        if root.generated-has-avatar : Rectangle {
                            width: 48px; height: 48px;
                            opacity: root.avatar-reveal;
                            Avatar {
                                size: 48px;
                                picture: root.generated-avatar;
                                has-picture: true;
                                initials: "";
                                color-a: Palette.mint;
                                color-b: Palette.mint-dim;
                                font-size: 16px;
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: @tr("YOUR DISPLAY NAME");
                                color: Palette.text-mid;
                                font-size: (9px) * Theme.fs-scale;
                                font-weight: 700;
                                letter-spacing: 1.6px;
                            }
                            Text {
                                text: root.generated-display-name;
                                color: Palette.text-hi;
                                font-size: Theme.fs(16px, 18px);
                                font-weight: 700;
                                opacity: root.name-reveal;
                            }
                        }
                    }
                }

                // Warning banner.
                Rectangle {
                    height: 64px;
                    background: Palette.warning-soft;
                    border-radius: (8px) * Theme.r-scale;
                    border-width: 1px;
                    border-color: Palette.warning-border;
                    HorizontalLayout {
                        padding-left: 14px; padding-right: 14px;
                        padding-top: 10px; padding-bottom: 10px;
                        spacing: 12px;
                        VerticalLayout {
                            alignment: center;
                            LockIcon { stroke: Palette.warning; }
                        }
                        VerticalLayout {
                            spacing: 3px;
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: @tr("Back up your nsec before saving");
                                color: Palette.warning;
                                font-size: (12px) * Theme.fs-scale;
                                font-weight: 700;
                            }
                            Text {
                                text: @tr("Sealed with your password on this device. Keep your own copy of the nsec too — lose both and this identity is gone.");
                                color: Palette.text-lo;
                                font-size: (10px) * Theme.fs-scale;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                // npub readout.
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "PUBLIC KEY (NPUB)";
                        color: Palette.text-mid;
                        font-size: (9px) * Theme.fs-scale;
                        font-weight: 700;
                        letter-spacing: 1.6px;
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: (7px) * Theme.r-scale;
                        background: Palette.field;
                        border-width: 1px;
                        border-color: Palette.field-border;
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 14px;
                            Text {
                                text: root.generated-npub;
                                color: Palette.text-hi;
                                font-size: Theme.fs(12px, 12px);
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }

                // nsec readout + action row below (split prevents the elided text
                // from overlapping the buttons when the row gets tight).
                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "SECRET KEY (NSEC)";
                        color: Palette.text-mid;
                        font-size: (9px) * Theme.fs-scale;
                        font-weight: 700;
                        letter-spacing: 1.6px;
                    }
                    Rectangle {
                        height: 38px;
                        border-radius: (7px) * Theme.r-scale;
                        background: Palette.field;
                        border-width: 1px;
                        border-color: Palette.field-border;
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 14px;
                            Text {
                                text: root.generated-nsec;
                                color: Palette.text-hi;
                                font-size: Theme.fs(12px, 12px);
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Button {
                            label: @tr("Regenerate");
                            button-height: 30px;
                            radius: 5px;
                            pad-left: 10px;
                            pad-right: 12px;
                            font-size: Theme.fs(11px, 12px);
                            RefreshIcon { stroke: Palette.text-mid; }
                            clicked => { root.generate-requested(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Button {
                            label: @tr("Copy");
                            button-height: 30px;
                            radius: 5px;
                            pad-left: 10px;
                            pad-right: 12px;
                            font-size: Theme.fs(11px, 12px);
                            CopyIcon { stroke: Palette.text-mid; }
                            clicked => { root.copy-nsec(root.generated-nsec); }
                        }
                    }
                }

                // Vault password + confirm.
                VaultField {
                    label: @tr("VAULT PASSWORD");
                    placeholder: @tr("Choose a password");
                    text <=> root.password-input;
                    password: true;
                    submit => { root.save-generated(); }
                }
                VaultField {
                    label: @tr("CONFIRM PASSWORD");
                    placeholder: @tr("Re-enter password");
                    text <=> root.password-confirm;
                    password: true;
                    submit => { root.save-generated(); }
                }

                if root.error != "" : Text {
                    text: root.error;
                    color: Palette.danger;
                    font-size: (11px) * Theme.fs-scale;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 10px;
                    Button {
                        label: @tr("Back");
                        button-height: 38px;
                        min-w: 96px;
                        clicked => { root.mode = 0; }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        label: root.busy ? @tr("Saving…") : @tr("Create vault");
                        button-height: 38px;
                        min-w: 160px;
                        bg-color: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-hi;
                        hover-outline: Palette.mint-hi;
                        fg: Palette.bubble-out-fg;
                        clicked => { root.save-generated(); }
                    }
                }
            }

            // === MODE 3: unlock an existing vault ===
            if root.mode == 3 : VerticalLayout {
                spacing: 14px;

                VaultField {
                    label: @tr("VAULT PASSWORD");
                    placeholder: @tr("Enter your password");
                    text <=> root.password-input;
                    password: true;
                    error: root.error != "";
                    submit => { root.do-unlock(); }
                }

                if root.error != "" : Text {
                    text: root.error;
                    color: Palette.danger;
                    font-size: (11px) * Theme.fs-scale;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 10px;
                    Button {
                        label: @tr("Use another key");
                        button-height: 38px;
                        min-w: 140px;
                        clicked => { root.reset-vault(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        label: root.busy ? @tr("Unlocking…") : @tr("Unlock");
                        button-height: 38px;
                        min-w: 120px;
                        bg-color: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-hi;
                        hover-outline: Palette.mint-hi;
                        fg: Palette.bubble-out-fg;
                        clicked => { root.do-unlock(); }
                    }
                }
            }
        }
    }
}
