// Sign-in gate. Four modes (controlled by `mode`):
//   0 = choose:  paste an existing nsec, or generate a new one
//   1 = enter:   paste/type an nsec AND set a vault password, then continue
//   2 = show:    display the freshly generated nsec + set a vault password
//   3 = unlock:  an encrypted vault already exists — enter its password
//
// Secrets are sealed in a password-encrypted vault on disk (no OS keyring).
// Rust owns validation, generation, encryption, and persistence. This is dumb.

import { Palette, Theme } from "../tokens.slint";
import { Button } from "../primitives/button.slint";
import { SectionLabel } from "../primitives/section-label.slint";
import { Avatar } from "../primitives/avatar.slint";
import { CypherScroll } from "../primitives/cypher-scroll.slint";
import { VaultField } from "vault-field.slint";
import { PasswordField } from "password-field.slint";
import { ReadoutBox } from "readout-box.slint";
import { FormMessages } from "form-messages.slint";
import { LogoMark } from "../icons/logo-mark.slint";
import { KeyIcon } from "../icons/key-icon.slint";
import { LockIcon } from "../icons/lock-icon.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { PlusIcon } from "../icons/plus-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { ConfirmModal } from "../modals/confirm-modal.slint";

export component LoginScreen inherits Rectangle {
    // 0 = choose, 1 = enter nsec, 2 = show generated, 3 = unlock existing vault.
    in-out property <int> mode: 0;
    // bound to LineInput; Rust reads on submit.
    in-out property <string> nsec-input;
    // vault password (set in modes 1/2, entered in mode 3) and its confirmation.
    in-out property <string> password-input;
    in-out property <string> password-confirm;
    // shown in mode 2 after Rust fills it from Keys::generate().
    in property <string> generated-nsec;
    in property <string> generated-npub;
    // Random "[Adjective] [Animal]" name + locally rendered starter avatar.
    in property <string> generated-display-name;
    in property <image> generated-avatar;
    in property <bool> generated-has-avatar: false;
    // error from last attempt (empty = no error). in-out so the component can also
    // clear it locally when the user navigates between modes.
    in-out property <string> error: "";
    in-out property <string> status: "";
    // disable actions while Rust is working (deriving the key, booting).
    in property <bool> busy: false;
    // Reset confirmation: "Use another key" deletes the vault and there is no
    // password recovery, so the button arms this modal instead of firing
    // reset-vault() directly.
    property <bool> show-reset-confirm: false;
    // Mode-2 name/avatar reveal progress (0 → 1).
    property <float> name-reveal: 0;
    property <float> avatar-reveal: 0;
    changed generated-display-name => {
        if (root.generated-display-name != "") {
            self.name-reveal = 0;
            self.name-reveal = 1;
        }
    }
    changed generated-has-avatar => {
        if (root.generated-has-avatar) {
            self.avatar-reveal = 0;
            self.avatar-reveal = 1;
        }
    }
    animate name-reveal, avatar-reveal {
        duration: 300ms;
        easing: ease-out;
    }

    callback login-with-nsec(string, string, string); // nsec, password, confirm
    callback generate-requested();
    callback confirm-saved(string, string);            // password, confirm
    callback unlock(string);                            // vault password
    callback reset-vault();
    callback copy-nsec(string);
    callback import-backup();                            // restore from an encrypted backup
    pure callback login-password-valid(string, string) -> bool; // password, confirm

    // Local password-validation state used to fail fast in the UI before the
    // Argon2id round-trip. `password-ok` gates the primary action;
    // `password-mismatch` drives error styling on the confirm field.
    pure function password-mismatch() -> bool {
        root.password-confirm != "" && root.password-confirm != root.password-input
    }
    pure function password-ok() -> bool {
        root.login-password-valid(root.password-input, root.password-confirm)
    }

    // Guarded action helpers so submit-on-Enter and button clicks share a path.
    function create-account() {
        if (!root.busy) {
            root.login-with-nsec(root.nsec-input, root.password-input, root.password-confirm);
        }
    }
    function save-generated() {
        if (!root.busy) {
            root.confirm-saved(root.password-input, root.password-confirm);
        }
    }
    function do-unlock() {
        if (!root.busy) {
            root.unlock(root.password-input);
        }
    }

    background: Palette.bg;

    // Subtle vignette so the card pops.
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: @radial-gradient(circle, Palette.vignette.with-alpha(0) 0%, Palette.vignette 100%);
    }

    // Centered card. Clamp to the available window height; mode 2 can exceed
    // the minimum window size, especially with translated copy, so overflowing
    // content must scroll instead of clipping the footer actions.
    Rectangle {
        width: 480px;
        // Per-mode baseline, but never clip the content: translated strings
        // (de/ja) can run taller than the English layout was tuned for.
        height: min(max(root.mode == 2 ? 740px : root.mode == 1 ? 520px : 420px,
                       card-content.preferred-height),
                    max(0px, parent.height - 32px));
        x: (parent.width - self.width) / 2;
        y: max(16px, (parent.height - self.height) / 2);
        clip: true;
        border-radius: (12px) * Theme.r-scale;
        background: Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 40px;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-card;
        drop-shadow-offset-x: Theme.hard-shadow ? 6px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 6px : 10px;
        animate height {
            duration: 200ms;
            easing: ease-in-out;
        }

        // Top bevel highlight (matches the Modal card convention).
        Rectangle {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: 1px;
            background: Palette.top-glint;
        }

        CypherScroll {
            width: parent.width;
            height: parent.height;
            viewport-height: card-content.preferred-height;
            viewport-width: self.visible-width;

            card-content := VerticalLayout {
                width: parent.width;
                padding-left: 32px;
                padding-right: 32px;
                padding-top: 32px;
                padding-bottom: 24px;
                spacing: 22px;

                // Header — logo + title + caption.
            VerticalLayout {
                    spacing: 12px;
                    alignment: center;
                    LogoMark {
                        size: 48px;
                        color: Palette.mint;
                    }

                    Text {
                        text: "darkmatter";
                        color: Palette.text-hi;
                        font-size: Theme.fs(22px, 26px);
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.mode == 0 ? @tr("Sign in to your Nostr identity") : root.mode == 1 ? @tr("Import a key & set a password") : root.mode == 3 ? @tr("Enter your password to unlock") : @tr("Save your new key");
                        color: Palette.text-lo;
                        font-size: Theme.fs(12px, 16px);
                        horizontal-alignment: center;
                    }
                }

                // === MODE 0: choose ===
            if root.mode == 0: VerticalLayout {
                    spacing: 12px;

                    Button {
                        label: @tr("I have an nsec");
                        button-height: 44px;
                        radius: 8px;
                        font-size: Theme.fs(13px, 16px);
                        bg-color: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-hi;
                        hover-outline: Palette.mint-hi;
                        fg: Palette.bubble-out-fg;
                        KeyIcon {
                            stroke: Palette.bubble-out-fg;
                        }

                        clicked => {
                            root.error = "";
                            root.nsec-input = "";
                            root.password-input = "";
                            root.password-confirm = "";
                            root.mode = 1;
                        }
                    }

                    Button {
                        label: @tr("Generate a new key");
                        button-height: 44px;
                        radius: 8px;
                        font-size: Theme.fs(13px, 16px);
                        bg-color: Palette.field;
                        outline: Palette.field-border;
                        hover-bg: Palette.field-hover;
                        hover-outline: Palette.field-border-hover;
                        PlusIcon {
                            stroke: Palette.text-mid;
                            size: 12px;
                        }

                        clicked => {
                            root.error = "";
                            root.password-input = "";
                            root.password-confirm = "";
                            root.generate-requested();
                        }
                    }

                    Button {
                        label: @tr("Import a backup");
                        button-height: 44px;
                        radius: 8px;
                        font-size: Theme.fs(13px, 16px);
                        bg-color: Palette.field;
                        outline: Palette.field-border;
                        hover-bg: Palette.field-hover;
                        hover-outline: Palette.field-border-hover;
                        clicked => {
                            root.error = "";
                            root.import-backup();
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    Text {
                        text: @tr("Your key never leaves this device.");
                        color: Palette.text-vlo;
                        font-size: Theme.fs(10px, 14px);
                        horizontal-alignment: center;
                    }
                }

                // === MODE 1: enter existing nsec + set vault password ===
            if root.mode == 1: VerticalLayout {
                    spacing: 12px;

                    VaultField {
                        label: @tr("NSEC");
                        placeholder: "nsec1…";
                        text <=> root.nsec-input;
                        error: root.error != "";
                        init => {
                            self.take-focus();
                        }
                        submit => {
                            root.create-account();
                        }
                    }

                    PasswordField {
                        label: @tr("PASSWORD");
                        placeholder: @tr("Choose a password");
                        text <=> root.password-input;
                        submit => {
                            root.create-account();
                        }
                    }

                    PasswordField {
                        label: @tr("CONFIRM PASSWORD");
                        placeholder: @tr("Re-enter password");
                        text <=> root.password-confirm;
                        error: root.password-mismatch();
                        submit => {
                            root.create-account();
                        }
                    }

                    FormMessages {
                        show-mismatch: root.password-mismatch();
                        error: root.error;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        Button {
                            label: @tr("Back");
                            button-height: 38px;
                            min-w: 96px;
                            clicked => {
                                root.error = "";
                                root.mode = 0;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        Button {
                            label: root.busy ? @tr("Signing in…") : @tr("Continue");
                            button-height: 38px;
                            min-w: 120px;
                            enabled: !root.busy && root.nsec-input != "" && root.password-ok();
                            bg-color: Palette.mint;
                            outline: Palette.mint;
                            hover-bg: Palette.mint-hi;
                            hover-outline: Palette.mint-hi;
                            fg: Palette.bubble-out-fg;
                            clicked => {
                                root.create-account();
                            }
                        }
                    }
                }

                // === MODE 2: show generated key + set vault password ===
            if root.mode == 2: VerticalLayout {
                    spacing: 14px;

                    if root.generated-display-name != "": Rectangle {
                        height: 72px;
                        border-radius: (8px) * Theme.r-scale;
                        background: Palette.field;
                        border-width: 1px;
                        border-color: Palette.field-border;
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 14px;
                            alignment: center;
                            if root.generated-has-avatar: Rectangle {
                                width: 48px;
                                height: 48px;
                                opacity: root.avatar-reveal;
                                Avatar {
                                    size: 48px;
                                    picture: root.generated-avatar;
                                    has-picture: true;
                                    initials: "";
                                    color-a: Palette.mint;
                                    color-b: Palette.mint-dim;
                                    font-size: Theme.fsr(16px, 16px);
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                alignment: center;
                                horizontal-stretch: 1;
                                SectionLabel {
                                    text: @tr("YOUR DISPLAY NAME");
                                }

                                Text {
                                    text: root.generated-display-name;
                                    color: Palette.text-hi;
                                    font-size: Theme.fs(16px, 18px);
                                    font-weight: 700;
                                    opacity: root.name-reveal;
                                }
                            }
                        }
                    }

                    // Warning banner.
                Rectangle {
                        height: 64px;
                        background: Palette.warning-soft;
                        border-radius: (8px) * Theme.r-scale;
                        border-width: 1px;
                        border-color: Palette.warning-border;
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            padding-top: 10px;
                            padding-bottom: 10px;
                            spacing: 12px;
                            VerticalLayout {
                                alignment: center;
                                LockIcon {
                                    stroke: Palette.warning;
                                }
                            }

                            VerticalLayout {
                                spacing: 3px;
                                alignment: center;
                                horizontal-stretch: 1;
                                Text {
                                    text: @tr("Back up your nsec before saving");
                                    color: Palette.warning;
                                    font-size: Theme.fs(12px, 16px);
                                    font-weight: 700;
                                }

                                Text {
                                    text: @tr("Sealed with your password on this device. Keep your own copy of the nsec too — lose both and this identity is gone.");
                                    color: Palette.text-lo;
                                    font-size: Theme.fs(10px, 14px);
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // npub readout.
                VerticalLayout {
                        spacing: 6px;
                        ReadoutBox {
                            label: @tr("PUBLIC KEY (NPUB)");
                            value: root.generated-npub;
                        }
                    }

                    // nsec readout + action row below (split prevents the elided text
                // from overlapping the buttons when the row gets tight).
                VerticalLayout {
                        spacing: 6px;
                        ReadoutBox {
                            label: @tr("SECRET KEY (NSEC)");
                            value: root.generated-nsec;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                label: @tr("Regenerate");
                                button-height: 30px;
                                radius: 5px;
                                pad-left: 10px;
                                pad-right: 12px;
                                font-size: Theme.fs(11px, 12px);
                                RefreshIcon {
                                    stroke: Palette.text-mid;
                                }

                                clicked => {
                                    root.generate-requested();
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Button {
                                label: @tr("Copy");
                                button-height: 30px;
                                radius: 5px;
                                pad-left: 10px;
                                pad-right: 12px;
                                font-size: Theme.fs(11px, 12px);
                                CopyIcon {
                                    stroke: Palette.text-mid;
                                }

                                clicked => {
                                    root.copy-nsec(root.generated-nsec);
                                }
                            }
                        }
                    }

                    // Vault password + confirm.
                PasswordField {
                        label: @tr("PASSWORD");
                        placeholder: @tr("Choose a password");
                        text <=> root.password-input;
                        init => {
                            self.take-focus();
                        }
                        submit => {
                            root.save-generated();
                        }
                    }

                    PasswordField {
                        label: @tr("CONFIRM PASSWORD");
                        placeholder: @tr("Re-enter password");
                        text <=> root.password-confirm;
                        error: root.password-mismatch();
                        submit => {
                            root.save-generated();
                        }
                    }

                    FormMessages {
                        show-mismatch: root.password-mismatch();
                        error: root.error;
                        status: root.status;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        Button {
                            label: @tr("Back");
                            button-height: 38px;
                            min-w: 96px;
                            clicked => {
                                root.mode = 0;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        Button {
                            label: root.busy ? @tr("Saving…") : @tr("Save key");
                            button-height: 38px;
                            min-w: 160px;
                            enabled: !root.busy && root.password-ok();
                            bg-color: Palette.mint;
                            outline: Palette.mint;
                            hover-bg: Palette.mint-hi;
                            hover-outline: Palette.mint-hi;
                            fg: Palette.bubble-out-fg;
                            clicked => {
                                root.save-generated();
                            }
                        }
                    }
                }

                // === MODE 3: unlock an existing vault ===
            if root.mode == 3: VerticalLayout {
                    spacing: 14px;

                    PasswordField {
                        label: @tr("PASSWORD");
                        placeholder: @tr("Enter your password");
                        text <=> root.password-input;
                        error: root.error != "";
                        init => {
                            self.take-focus();
                        }
                        submit => {
                            root.do-unlock();
                        }
                    }

                    FormMessages {
                        error: root.error;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        Button {
                            label: @tr("Use another key");
                            button-height: 38px;
                            min-w: 140px;
                            clicked => {
                            // Guarded like do-unlock(): while an unlock is in
                            // flight, deleting the vault would race the worker,
                            // which still boots the destroyed identity on a
                            // correct password.
                            if (!root.busy) {
                                    root.show-reset-confirm = true;
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        Button {
                            label: root.busy ? @tr("Unlocking…") : @tr("Unlock");
                            button-height: 38px;
                            min-w: 120px;
                            bg-color: Palette.mint;
                            outline: Palette.mint;
                            hover-bg: Palette.mint-hi;
                            hover-outline: Palette.mint-hi;
                            fg: Palette.bubble-out-fg;
                            clicked => {
                                root.do-unlock();
                            }
                        }
                    }
                }
            }
        }
    }

    // Destructive-action gate for "Use another key". Deleting the vault is
    // irreversible: without a separately saved nsec the identity is gone, so
    // the consequence is spelled out before reset-vault() fires.
    if root.show-reset-confirm: ConfirmModal {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        title: @tr("Use another key?");
        subtitle: @tr("This removes the key stored on this device. You'll need the nsec you backed up to use this identity again. This can't be undone.");
        confirm-label: @tr("Remove key");
        confirm => {
            root.show-reset-confirm = false;
            root.reset-vault();
        }
        dismissed => {
            root.show-reset-confirm = false;
        }
    }
}
