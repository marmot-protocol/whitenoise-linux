// title bar — DARKMATTER mark, breadcrumb, and global actions.
import { MentionInboxItem, Palette, Theme } from "tokens.slint";
import { MentionsInbox } from "main-pane/mentions-inbox.slint";

export component TitleBar inherits Rectangle {
    in property <string> breadcrumb;
    in property <length> rail-width: 56px;
    in property <[MentionInboxItem]> mention-items;
    in property <bool> mentions-loading: false;
    callback mentions-inbox-opened();
    callback mention-inbox-item-selected(string, string);

    height: 40px;
    background: Palette.bg;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }

    // Faint mint wash under the brand mark.
    if Theme.soft-decor: Rectangle {
        x: root.rail-width + 8px;
        width: 140px;
        height: parent.height;
        background: @linear-gradient(90deg, Palette.mint-glow 0%, transparent 100%);
        opacity: 0.6;
    }

    HorizontalLayout {
        spacing: 0;
        alignment: center;

        // empty column — width matches the LeftRail so the content
        // below the title bar starts in the same horizontal slot.
        Rectangle {
            width: root.rail-width + 8px;
        }

        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 0;
            alignment: start;
            Text {
                text: "DARKMATTER";
                color: Palette.text-hi;
                font-size: (11px) * Theme.fs-scale;
                font-weight: 700;
                vertical-alignment: center;
                letter-spacing: 1.6px;
            }

            Rectangle {
                width: 20px;
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: (parent.height - 14px) / 2;
                background: Palette.border;
            }

            Rectangle {
                width: 14px;
            }

            Text {
                text: root.breadcrumb;
                color: Palette.mint-dim;
                font-size: (10px) * Theme.fs-scale;
                font-weight: 600;
                vertical-alignment: center;
                letter-spacing: 1.2px;
                opacity: 0.9;
            }
        }

        // Global inbox belongs in the app chrome, not in the active chat.
        // Keep it as the far-right title-bar action, matching Discord's inbox.
        Rectangle {
            width: 32px;
            height: 32px;
            y: (parent.height - self.height) / 2;
            background: mention-inbox-touch.has-hover ? Palette.hover : transparent;
            border-radius: (6px) * Theme.r-scale;
            animate background { duration: 100ms; }

            mention-inbox-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.mentions-inbox-opened();
                    mention-inbox.open();
                }

                Text {
                    text: "@";
                    color: mention-inbox-touch.has-hover ? Palette.mint : Palette.text-mid;
                    font-family: Theme.font;
                    font-size: Theme.fs(12px, 17px);
                    font-weight: 800;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }

            mention-inbox := MentionsInbox {
                x: parent.width;
                y: 0px;
                items: root.mention-items;
                loading: root.mentions-loading;
                selected(group-id, message-id) => {
                    root.mention-inbox-item-selected(group-id, message-id);
                }
            }
        }

        Rectangle {
            width: 8px;
        }
    }
}
