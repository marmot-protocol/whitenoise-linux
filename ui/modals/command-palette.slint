import { Palette, Theme } from "../tokens.slint";
import { SearchIcon } from "../icons/search-icon.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Modal } from "modal.slint";

// A single row in the palette. Rust supplies the array, filtering & selection logic.
export struct PaletteAction {
    id: string,
    label: string,
    group: string,
    kbd: string,
}

export component CommandPalette inherits Modal {
    callback execute(string);          // id of triggered action
    callback query-changed(string);    // Rust filters the action list

    in property <[PaletteAction]> actions;
    in-out property <string> query;
    in-out property <int> selected: 0;

    function move-selection(delta: int) {
        if (root.actions.length > 0) {
            if (delta < 0) {
                root.selected = root.selected == 0 ? root.actions.length - 1 : root.selected - 1;
            } else {
                root.selected = mod(root.selected + 1, root.actions.length);
            }
        }
    }

    function activate-selected() {
        if (root.actions.length > 0) {
            root.execute(root.actions[root.selected].id);
            root.dismissed();
        }
    }

    // Top-anchored frameless card: the palette brings its own search header,
    // list, and hint strip, plus a FocusScope that owns the keyboard.
    card-width: min(560px, root.width - 64px);
    v-pos: 0.16;
    title: "";
    show-close: false;
    content-padding: 0px;
    grab-focus: false;

    // Key handling — Esc dismiss, arrows navigate, Enter execute. Focus the
    // search field so type-to-search works immediately; LineInput captures
    // nav/Enter/Esc while focused because TextInput consumes arrows as caret moves.
    focus-scope := FocusScope {
        init => {
            query-input.take-focus();
        }
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            if (event.text == Key.UpArrow) {
                root.move-selection(-1);
                return accept;
            }
            if (event.text == Key.DownArrow) {
                root.move-selection(1);
                return accept;
            }
            if (event.text == Key.Return) {
                root.activate-selected();
                return accept;
            }
            return reject;
        }

        VerticalLayout {
            spacing: 0;

            // ── Search row ─────────────────────────────────────────────
            Rectangle {
                height: 52px;
                background: transparent;
                HorizontalLayout {
                    padding-left: 18px;
                    padding-right: 18px;
                    spacing: 12px;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: center;
                        SearchIcon {
                            size: 16px;
                            stroke: Palette.text-mid;
                        }
                    }

                    query-input := LineInput {
                        placeholder: @tr("Type a command…");
                        text <=> root.query;
                        enter-submits: false;
                        capture-nav: true;
                        nav-tab-commits: false;
                        nav(delta) => {
                            root.move-selection(delta);
                        }
                        commit-mention => {
                            root.activate-selected();
                        }
                        dismiss-mention => {
                            root.dismissed();
                        }
                        font-size: Theme.fsr(14px, 16px);
                        fg: Palette.text-hi;
                        placeholder-color: Palette.text-vlo;
                    }

                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            height: 22px;
                            min-width: kbd-text.preferred-width + 14px;
                            border-radius: (4px) * Theme.r-scale;
                            border-width: Theme.border-w;
                            border-color: Palette.border-2;
                            background: Palette.panel-2;
                            kbd-text := Text {
                                // macOS uses ⌘; everything else Ctrl. Modifier
                                // glyphs are key labels, not prose, so they stay
                                // out of @tr().
                                text: Theme.is-mac ? "⌘ K" : "Ctrl K";
                                color: Palette.text-mid;
                                font-size: (10px) * Theme.fs-scale;
                                font-weight: 700;
                                font-family: Theme.font;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                                x: 7px;
                                y: 0;
                                width: parent.width - 14px;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // ── Divider ─────────────────────────────────────────────────
            Rectangle {
                height: Theme.border-w;
                background: Palette.divider;
            }

            // ── Action list ─────────────────────────────────────────────
            Rectangle {
                height: min(380px, list-layout.preferred-height + 8px);
                clip: true;
                list-layout := VerticalLayout {
                    padding-top: 6px;
                    padding-bottom: 6px;
                    spacing: 0;
                    for action[i] in root.actions: Rectangle {
                        height: row-stack.preferred-height;
                        row-stack := VerticalLayout {
                            spacing: 0;
                            // Group header — only when this row's group differs from the previous row's.
                            if i == 0 || root.actions[i - 1].group != action.group: Rectangle {
                                height: 24px;
                                HorizontalLayout {
                                    padding-left: 18px;
                                    padding-right: 18px;
                                    padding-top: 8px;
                                    Text {
                                        text: action.group;
                                        color: Palette.text-vlo;
                                        font-size: (9px) * Theme.fs-scale;
                                        font-weight: 700;
                                        letter-spacing: 1.4px;
                                        font-family: Theme.font;
                                    }
                                }
                            }
                            // Row body.
                            Rectangle {
                                height: 36px;
                                background: i == root.selected ? (Theme.selected-inverts-text ? Palette.selected : Palette.bubble-in) : (row-touch.has-hover ? Palette.hover : transparent);
                                border-radius: (5px) * Theme.r-scale;
                                animate background {
                                    duration: 90ms;
                                    easing: ease-out;
                                }

                                // Mint accent bar on selected row (normal mode).
                                if !Theme.pixel-select-marker: Rectangle {
                                    x: 8px;
                                    width: 2px;
                                    y: (parent.height - self.height) / 2;
                                    height: i == root.selected ? 18px : 0px;
                                    background: Palette.mint;
                                    border-radius: 1px;
                                    animate height {
                                        duration: 160ms;
                                        easing: ease-in-out;
                                    }
                                }
                                // Retro selection chevron.
                                if Theme.pixel-select-marker && i == root.selected: Text {
                                    x: 6px;
                                    y: (parent.height - self.height) / 2;
                                    text: "▶";
                                    color: Palette.bubble-out-fg;
                                    font-size: 12px;
                                    font-family: Theme.font;
                                    vertical-alignment: center;
                                }

                                HorizontalLayout {
                                    padding-left: 22px;
                                    padding-right: 18px;
                                    spacing: 12px;
                                    alignment: stretch;
                                    Text {
                                        text: action.label;
                                        color: Theme.pixel-select-marker && i == root.selected ? Palette.bubble-out-fg : Palette.text-hi;
                                        font-size: Theme.fs(12px, 13px);
                                        font-weight: i == root.selected ? 700 : 500;
                                        font-family: Theme.font;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    if action.kbd != "": Rectangle {
                                        height: 20px;
                                        min-width: kbd-pill-text.preferred-width + 12px;
                                        border-radius: (4px) * Theme.r-scale;
                                        border-width: Theme.border-w;
                                        border-color: Palette.border-2;
                                        background: i == root.selected && !Theme.pixel-select-marker ? Palette.panel : Palette.panel-2;
                                        y: (parent.height - self.height) / 2;
                                        kbd-pill-text := Text {
                                            text: action.kbd;
                                            color: Palette.text-mid;
                                            font-size: (9px) * Theme.fs-scale;
                                            font-weight: 700;
                                            font-family: Theme.font;
                                            x: 6px;
                                            y: 0;
                                            width: parent.width - 12px;
                                            height: parent.height;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    clicked => {
                                        root.selected = i;
                                        root.execute(action.id);
                                        root.dismissed();
                                    }
                                }
                            }
                        }
                    }

                    if root.actions.length == 0: Rectangle {
                        height: 60px;
                        Text {
                            text: @tr("No matches");
                            color: Palette.text-lo;
                            font-size: (12px) * Theme.fs-scale;
                            font-family: Theme.font;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }

            // ── Footer hint strip ───────────────────────────────────────
            Rectangle {
                height: Theme.border-w;
                background: Palette.divider;
            }

            Rectangle {
                height: 28px;
                background: Palette.field;
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 16px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        Text {
                            // Arrow/⏎/Esc glyphs are key labels; only the verbs
                            // are translated.
                            text: "↑↓ " + @tr("command palette footer" => "Navigate");
                            color: Palette.text-vlo;
                            font-size: (9px) * Theme.fs-scale;
                            font-weight: 700;
                            letter-spacing: 1.0px;
                            font-family: Theme.font;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "⏎ " + @tr("command palette footer" => "Select");
                            color: Palette.text-vlo;
                            font-size: (9px) * Theme.fs-scale;
                            font-weight: 700;
                            letter-spacing: 1.0px;
                            font-family: Theme.font;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Esc " + @tr("command palette footer" => "Close");
                            color: Palette.text-vlo;
                            font-size: (9px) * Theme.fs-scale;
                            font-weight: 700;
                            letter-spacing: 1.0px;
                            font-family: Theme.font;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }

    // When the query changes, tell Rust so it can refilter & reset selection.
    property <string> last-query: "";
    changed query => {
        if (root.query != root.last-query) {
            root.last-query = root.query;
            root.selected = 0;
            root.query-changed(root.query);
        }
    }
}
