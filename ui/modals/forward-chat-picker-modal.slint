import { Palette, Theme, ChatMeta } from "../tokens.slint";
import { Modal, ModalField } from "modal.slint";
import { Avatar } from "../primitives/avatar.slint";

// Forward picker. Opened from a message's context menu: pick a destination
// chat and the selected message's content is re-sent there (text + any
// attachments, re-encrypted for the target group — the Rust side owns that).
// The current chat is skipped: forwarding back into the same thread is a no-op.
// A quoted chip shows which message is about to be forwarded, and the search
// field narrows the destination list by chat name. The search field owns the
// keyboard: typing filters, ↑/↓ move the row cursor, Enter forwards to the
// cursored row (`capture-nav` on the field routes those keys here before the
// TextInput can swallow them as caret moves).
export component ForwardPickerModal inherits Modal {
    callback select(int);   // destination chat index (into `chats`)
    in property <[ChatMeta]> chats;
    in property <int> active-chat: -1;
    // The message about to be forwarded — same author/preview pair the reply
    // chip uses (initials for peers, "You" for own messages).
    in property <string> source-author;
    in property <string> source-text;
    // Rust filters chat names on `query-changed` (Slint has no substring
    // match) and pushes one match flag per `chats` row. Only consulted while
    // the query is non-empty, so a stale array from a previous open is inert.
    in property <[bool]> match-flags;
    // Chat indices of the rows currently shown, in list order — recomputed by
    // Rust alongside `match-flags` (active chat skipped, query applied). The
    // keyboard cursor walks this array so hidden rows are never focusable.
    in property <[int]> visible-rows;
    callback query-changed(string);

    property <string> query;
    changed query => {
        // A new query reorders the visible set, so the cursor restarts at the
        // top match and the list scrolls back up to show it.
        root.cursor = 0;
        flick.viewport-y = 0;
        root.query-changed(root.query);
    }
    // Prime `visible-rows`/`match-flags` for the empty query on open: the root
    // arrays outlive the modal and would otherwise be stale from a previous
    // open (different active chat).
    init => {
        root.query-changed(root.query);
    }
    // Chats can be re-pushed while the picker is open (a new message re-sorts
    // the list); re-derive the visible set so the cursor tracks fresh indices.
    changed chats => {
        root.query-changed(root.query);
    }

    // Keyboard cursor: a position in `visible-rows`, resolved to a chat index
    // for row highlighting and Enter. -1 = nothing selectable.
    property <int> cursor: 0;
    property <int> cursor-chat: root.visible-rows.length == 0 ? -1 : root.visible-rows[min(root.cursor, root.visible-rows.length - 1)];

    function commit() {
        // Bounds re-check besides the -1 guard: `visible-rows` may lag a
        // `chats` mutation by one frame, and forwarding must never target the
        // source chat or a vanished index.
        if (root.cursor-chat >= 0 && root.cursor-chat < root.chats.length && root.cursor-chat != root.active-chat) {
            root.select(root.cursor-chat);
        }
    }
    // ↑/↓ step the cursor through the visible rows, wrapping at both ends.
    function move-cursor(delta: int) {
        if (root.visible-rows.length > 0) {
            if (delta < 0) {
                root.cursor = root.cursor <= 0 || root.cursor >= root.visible-rows.length ? root.visible-rows.length - 1 : root.cursor - 1;
            } else {
                root.cursor = mod(root.cursor + 1, root.visible-rows.length);
            }
            root.scroll-to-cursor();
        }
    }
    // Nudge the flickable just enough to keep the cursored row (62px pitch)
    // fully in view; no-op while everything already fits.
    function scroll-to-cursor() {
        if (62px * root.cursor < -flick.viewport-y) {
            flick.viewport-y = -62px * root.cursor;
        } else if (62px * (root.cursor + 1) > flick.height - flick.viewport-y) {
            flick.viewport-y = flick.height - 62px * (root.cursor + 1);
        }
    }

    // Rows stack with zero layout spacing (the 6px gap lives inside each shown
    // row), so the list's preferred height is 0 exactly when no row is visible.
    property <bool> any-visible: list.preferred-height > 0px;
    // How many chats are eligible at all (ignoring the query) — distinguishes
    // "nothing matches your search" from "there is nowhere to forward to".
    property <int> forwardable-count: root.chats.length - (root.active-chat >= 0 && root.active-chat < root.chats.length ? 1 : 0);

    card-width: 440px;
    card-height: 520px;
    title: @tr("Forward to…");
    subtitle: @tr("Pick a chat to forward this message to.");
    secondary-label: @tr("Cancel");

    // Quoted preview of the source message, same accent-bar chip language as
    // the composer's reply chip.
    Rectangle {
        height: 48px;
        background: Palette.panel;
        border-width: 1px;
        border-color: Palette.border-2;
        border-radius: (6px) * Theme.r-scale;
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 8px;
            Rectangle {
                width: 3px;
                height: 26px;
                y: (parent.height - self.height) / 2;
                background: Palette.mint;
                border-radius: 1.5px;
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;
                Text {
                    text: root.source-author == "" ? @tr("Forwarding:") : @tr("Forwarding from {}:", root.source-author);
                    color: Palette.mint;
                    font-size: Theme.fs(10px, 14px);
                    font-weight: 700;
                    font-family: Theme.font;
                    overflow: elide;
                }

                Text {
                    text: root.source-text == "" ? @tr("(attachment)") : root.source-text;
                    color: Palette.text-mid;
                    font-size: Theme.fs(11px, 14px);
                    font-family: Theme.font;
                    overflow: elide;
                }
            }
        }
    }

    ModalField {
        placeholder: @tr("Search chats…");
        text <=> root.query;
        autofocus: true;
        capture-nav: true;
        nav(delta) => {
            root.move-cursor(delta);
        }
        submitted => {
            root.commit();
        }
        nav-dismissed => {
            root.dismissed();
        }
    }

    Rectangle {
        vertical-stretch: 1;

        flick := Flickable {
            width: 100%;
            height: 100%;
            viewport-width: self.width;
            viewport-height: list.preferred-height;
            list := VerticalLayout {
                spacing: 0;
                for chat[idx] in root.chats: Rectangle {
                    // Skip the chat the message is already in; the query
                    // filters the rest by chat name (flags computed in Rust).
                    property <bool> shown: idx != root.active-chat && (root.query == "" || (idx < root.match-flags.length && root.match-flags[idx]));
                    // Keyboard cursor on this row (mouse hover is independent).
                    property <bool> cursored: idx == root.cursor-chat;
                    height: shown ? 62px : 0px;
                    visible: shown;

                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 56px;
                        border-radius: (10px) * Theme.r-scale;
                        background: cursored || row-touch.has-hover ? Palette.hover : transparent;
                        animate background {
                            duration: 100ms;
                            easing: ease-out;
                        }

                        // Accent focus bar on the cursored row, same treatment
                        // as the language picker's rows.
                        if cursored: Rectangle {
                            x: 0;
                            width: 2px;
                            y: (parent.height - self.height) / 2;
                            height: 26px;
                            background: Palette.mint;
                            border-radius: 1px;
                        }

                        // Wraps the row content so it wins the hit-test over the card's
                        // click-swallower (nested TouchAreas beat outer ones).
                        row-touch := TouchArea {
                            enabled: shown;
                            mouse-cursor: pointer;
                            clicked => {
                                root.select(idx);
                            }

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 14px;
                                spacing: 12px;

                                VerticalLayout {
                                    alignment: center;
                                    Avatar {
                                        size: 36px;
                                        initials: chat.av-initials;
                                        color-a: chat.av-a;
                                        color-b: chat.av-b;
                                        picture: chat.picture;
                                        has-picture: chat.has-picture;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 3px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: chat.name;
                                        color: Palette.text-hi;
                                        font-size: Theme.fs(12px, 16px);
                                        font-weight: 700;
                                        font-family: Theme.font;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: chat.preview;
                                        color: Palette.text-lo;
                                        font-size: Theme.fs(10px, 14px);
                                        font-family: Theme.font;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if !root.any-visible: VerticalLayout {
            alignment: center;
            Text {
                text: root.forwardable-count == 0 ? @tr("No other chats to forward to.") : @tr("No chats match your search.");
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                font-family: Theme.font;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }
}
