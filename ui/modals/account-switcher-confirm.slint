import { Palette, Theme, AccountEntry } from "../tokens.slint";
import { Avatar } from "../primitives/avatar.slint";

// Remove-confirm body for the account switcher. The Modal owns the title,
// subtitle, and danger footer; this renders the account chip plus the plain
// list of what removal erases.
export component AccountSwitcherConfirm inherits VerticalLayout {
    in property <AccountEntry> account;

    spacing: 10px;

    Rectangle {
        height: 52px;
        border-radius: (10px) * Theme.r-scale;
        background: Palette.danger-soft;
        border-width: Theme.border-w;
        border-color: Palette.danger-border;
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 14px;
            spacing: 12px;
            VerticalLayout {
                alignment: center;
                Avatar {
                    size: 34px;
                    initials: root.account.av-initials;
                    color-a: root.account.av-a;
                    color-b: root.account.av-b;
                    picture: root.account.picture;
                    has-picture: root.account.has-picture;
                    a11y-label: root.account.name;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;
                Text {
                    text: root.account.name;
                    color: Palette.text-hi;
                    font-size: Theme.fs(12px, 16px);
                    font-weight: 700;
                    font-family: Theme.font;
                    overflow: elide;
                }

                Text {
                    text: root.account.npub-short;
                    color: Palette.text-lo;
                    font-size: Theme.fs(10px, 14px);
                    font-family: Theme.font;
                    overflow: elide;
                }
            }
        }
    }

    for line in [
        @tr("Its secret key is erased from this device's vault."),
        @tr("Its background session ends and it leaves the account list."),
        @tr("Back it up first if you'll want to sign in again — this can't be undone."),
    ]: Text {
        text: "•  " + line;
        color: Palette.text-mid;
        font-size: Theme.fs(11px, 14px);
        font-family: Theme.font;
        wrap: word-wrap;
    }
}
