import { Palette, Theme } from "../tokens.slint";
import { Button } from "../primitives/button.slint";
import { LineInput } from "../primitives/line-input.slint";

// The one modal. Every dialog in the app inherits this — it owns the backdrop,
// entrance animation, Esc/click-outside dismissal, header (title/subtitle/✕),
// status line, and footer action strip. Children fill the content zone.
//
// Modes:
//   - default: centered card, auto-height (or fixed via `card-height`)
//   - `v-pos`: anchor the card top at a fraction of the window (command palette)
//   - `bare`: no card chrome at all — backdrop + entrance + floating ✕ only
//     (image lightbox). Children own their own hit-testing in bare mode.
//
// The backdrop is deliberately a single subtle flat scrim — just enough dim to
// signal modality and make click-outside readable. Depth comes from the card's
// own shadow, not from backdrop layers. (Subclasses needing a heavier darken,
// like the image lightbox, override `background`.)
export component Modal inherits Rectangle {
    callback dismissed;
    // Footer actions. The secondary button always dismisses after firing
    // `secondary()` (cleanup hook); the primary is gated on readiness and busy
    // state.
    callback primary;
    callback secondary;

    in property <string> title;
    in property <string> subtitle;
    in property <string> primary-label;        // "" = no primary button
    in property <string> primary-busy-label;   // label swap while busy
    in property <bool> primary-enabled: true;
    in property <bool> primary-busy: false;
    in property <bool> primary-danger: false;  // red primary for destructive confirms
    in property <string> secondary-label;      // "" = no secondary button
    in property <string> status;               // inline status/error line above the footer
    in property <color> status-color: Palette.text-lo;
    in property <bool> show-close: true;
    in property <bool> bare: false;
    // Set false when a child mounts its own FocusScope (command palette) so
    // the modal doesn't fight it for keyboard focus.
    in property <bool> grab-focus: true;
    // Width tiers: 360px compact (single-purpose pickers), 440px default,
    // 460px+ wide (forms with side-by-side fields). Pick a tier rather than
    // inventing a new width per dialog.
    in property <length> card-width: 440px;
    in property <length> card-height: 0px;     // 0 = size to content
    in property <length> content-padding: 24px;
    in property <float> v-pos: -1.0;            // -1 = centered, else fraction of window height for the card top

    property <bool> has-footer: root.primary-label != "" || root.secondary-label != "";
    property <length> card-w: root.bare ? root.width : root.card-width;
    property <length> card-h: root.bare ? root.height : (root.card-height > 0px ? root.card-height : main-column.preferred-height);
    property <length> card-x: root.bare ? 0px : (root.width - root.card-w) / 2;
    property <length> card-y: (root.bare ? 0px : (root.v-pos < 0 ? (root.height - root.card-h) / 2 : root.height * root.v-pos)) + root.y-offset;

    // Entrance progress 0 → 1. Defaults to 0; init flips to 1, which animates.
    // Retro snaps in with a punchy short ease; normal glides in slower.
    property <float> open: 0;
    property <duration> ease-dur: Theme.motion-fast ? 140ms : 220ms;
    init => {
        self.open = 1;
        if (root.grab-focus) {
            esc-scope.focus();
        }
    }

    opacity: root.open;
    animate opacity {
        duration: root.ease-dur;
        easing: ease-out;
    }

    // Slide-up offset: card starts below its final position, animates to 0.
    property <length> y-offset: (1 - root.open) * (Theme.motion-fast ? 32px : 18px);
    animate y-offset {
        duration: root.ease-dur;
        easing: ease-out;
    }

    background: Palette.overlay;

    backdrop-touch := TouchArea {
        clicked => {
            root.dismissed();
        }
    }

    // Esc dismisses from anywhere — the scope wraps the card so key events
    // rejected by inner inputs bubble up to it.
    esc-scope := FocusScope {
        width: 100%;
        height: 100%;
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            return reject;
        }

        card := Rectangle {
            x: root.card-x;
            y: root.card-y;
            width: root.card-w;
            height: root.card-h;
            border-radius: root.bare ? 0px : (14px) * Theme.r-scale;
            clip: !root.bare;
            // Token-driven so every theme resolves correctly — not just the
            // hardcoded light/dark pair (that branch left Sketch/Synthwave with a
            // wrong-palette dark card). Flat in retro; a subtle elevated→bg
            // gradient elsewhere reads as a lit card on any palette.
            background: root.bare ? transparent : (Theme.hard-shadow ? Palette.elevated : @linear-gradient(180deg, Palette.elevated 0%, Palette.bg 100%));
            border-width: root.bare ? 0px : Theme.border-w;
            border-color: Palette.elevated-border;
            // With no backdrop layers, the shadow alone sells the elevation —
            // wide, soft, and offset down.
            drop-shadow-blur: root.bare ? 0px : (Theme.hard-shadow ? 0px : 56px);
            drop-shadow-color: root.bare ? transparent : (Theme.hard-shadow ? Palette.shadow : Palette.shadow-card);
            drop-shadow-offset-x: Theme.hard-shadow ? 6px : 0px;
            drop-shadow-offset-y: Theme.hard-shadow ? 6px : 14px;

            // Swallows clicks on the card so they don't reach the backdrop.
            // It wraps the content (rather than being a sibling) so nested
            // interactive TouchAreas always win the hit-test. Disabled in
            // bare mode — there the backdrop must stay clickable and children
            // swallow their own hits.
            swallow := TouchArea {
                enabled: !root.bare;

                main-column := VerticalLayout {
                    spacing: 0;

                    if root.title != "": HorizontalLayout {
                        padding-left: 24px;
                        padding-right: 18px;
                        padding-top: 20px;
                        spacing: 12px;
                        alignment: stretch;

                        VerticalLayout {
                            spacing: 5px;
                            horizontal-stretch: 1;
                            Text {
                                text: root.title;
                                color: Palette.text-hi;
                                font-size: (17px) * Theme.fs-scale;
                                font-weight: 800;
                                font-family: Theme.font;
                            }

                            if root.subtitle != "": Text {
                                text: root.subtitle;
                                color: Palette.text-lo;
                                font-size: (11px) * Theme.fs-scale;
                                font-family: Theme.font;
                                wrap: word-wrap;
                            }
                        }

                        if root.show-close: VerticalLayout {
                            alignment: start;
                            Rectangle {
                                width: 28px;
                                height: 28px;
                                border-radius: (6px) * Theme.r-scale;
                                background: header-close.has-hover ? Palette.panel-2 : transparent;
                                animate background { duration: 100ms; }
                                Text {
                                    text: "✕";
                                    color: Palette.text-mid;
                                    font-size: (14px) * Theme.fs-scale;
                                    font-family: Theme.font;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                header-close := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.dismissed();
                                    }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        padding-left: root.bare ? 0px : root.content-padding;
                        padding-right: root.bare ? 0px : root.content-padding;
                        padding-top: root.bare ? 0px : (root.title == "" ? root.content-padding : min(root.content-padding, 16px));
                        padding-bottom: root.bare ? 0px : root.content-padding;
                        spacing: 14px;
                        vertical-stretch: 1;
                        @children
                    }

                    if root.status != "": HorizontalLayout {
                        padding-left: 24px;
                        padding-right: 24px;
                        padding-bottom: 14px;
                        Text {
                            text: root.status;
                            color: root.status-color;
                            font-size: (10px) * Theme.fs-scale;
                            font-family: Theme.font;
                            wrap: word-wrap;
                        }
                    }

                    if root.has-footer: Rectangle {
                        height: Theme.border-w;
                        background: Palette.divider;
                    }
                    if root.has-footer: Rectangle {
                        height: 62px;
                        background: Palette.card-well;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            spacing: 10px;
                            alignment: stretch;
                            VerticalLayout {
                                alignment: center;
                                if root.secondary-label != "": Button {
                                    label: root.secondary-label;
                                    focusable: true;
                                    button-height: 34px;
                                    pad-left: 14px;
                                    min-w: 96px;
                                    clicked => {
                                        root.secondary();
                                        root.dismissed();
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            VerticalLayout {
                                alignment: center;
                                if root.primary-label != "": Button {
                                    label: root.primary-busy && root.primary-busy-label != "" ? root.primary-busy-label : root.primary-label;
                                    enabled: root.primary-enabled && !root.primary-busy;
                                    focusable: true;
                                    button-height: 34px;
                                    pad-left: 14px;
                                    min-w: 96px;
                                    bg-color: root.primary-danger ? Palette.danger : Palette.mint;
                                    outline: root.primary-danger ? Palette.danger : Palette.mint;
                                    hover-bg: root.primary-danger ? Palette.danger.brighter(0.12) : Palette.mint-hi;
                                    hover-outline: root.primary-danger ? Palette.danger.brighter(0.12) : Palette.mint-hi;
                                    fg: Palette.bubble-out-fg;
                                    clicked => {
                                        if (root.primary-enabled && !root.primary-busy) {
                                            root.primary();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Accent "aurora" hairline along the card's top edge — gradient in
            // soft-decor themes, a solid title strip in flat ones. Drawn last so it sits
            // above the header; the card's clip rounds its corners.
            if !root.bare: Rectangle {
                x: 0;
                y: 0;
                width: parent.width;
                height: Theme.pixel-metrics ? 4px : 2px;
                background: Theme.soft-decor ? @linear-gradient(90deg, transparent 0%, Palette.mint 28%, Palette.mint-hi 50%, Palette.mint 72%, transparent 100%) : Palette.mint;
            }
        }
    }

    // Floating close button for bare (lightbox) mode, top-right of the window.
    if root.bare && root.show-close: Rectangle {
        x: parent.width - self.width - 24px;
        y: 24px;
        width: 40px;
        height: 40px;
        border-radius: (8px) * Theme.r-scale;
        // Dark scrim so the glyph stays legible when a bright image sits
        // underneath (white-alpha disappears over light photos).
        background: bare-close.has-hover ? #00000066 : #00000040;
        animate background { duration: 100ms; }
        border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
        border-color: Palette.border-2;
        Text {
            text: "✕";
            color: #FFFFFF;
            font-size: (18px) * Theme.fs-scale;
            font-family: Theme.font;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        bare-close := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.dismissed();
            }
        }
    }
}

// Labelled input field with modal chrome: uppercase micro-label, themed frame,
// accent focus ring. Replaces the hand-rolled label+Rectangle+LineInput stacks
// every input modal used to carry.
export component ModalField inherits VerticalLayout {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> text;
    in property <bool> multiline: false;
    in property <bool> password: false;
    in property <bool> autofocus: false;
    in property <length> field-height: root.multiline ? 120px : 38px;
    callback submitted;
    // Forwarded LineInput nav-capture hooks: a list-picker modal sets
    // `capture-nav` so ↑/↓ drive its cursor (`nav`) while focus stays in this
    // field. A focused TextInput otherwise consumes arrow keys as caret moves,
    // so they never bubble to an outer FocusScope. While captured, Enter
    // fires `submitted` and Esc fires `nav-dismissed` instead of editing
    // keys; Tab keeps its focus-traversal role.
    in property <bool> capture-nav: false;
    callback nav(int);
    callback nav-dismissed;

    spacing: 7px;

    init => {
        if (root.autofocus) {
            inner.set-cursor(0);
        }
    }

    if root.label != "": Text {
        text: root.label;
        color: Palette.text-mid;
        font-size: (9px) * Theme.fs-scale;
        font-weight: 700;
        font-family: Theme.font;
        letter-spacing: 1.6px;
    }

    frame := Rectangle {
        height: root.field-height;
        border-radius: (8px) * Theme.r-scale;
        background: Palette.field;
        border-width: Theme.border-w;
        border-color: inner.has-focus ? Palette.mint : Palette.field-border;
        drop-shadow-blur: inner.has-focus && Theme.focus-glow ? 10px : 0px;
        drop-shadow-color: inner.has-focus && Theme.focus-glow ? Palette.mint-glow : transparent;
        animate border-color {
            duration: 120ms;
            easing: ease-out;
        }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: root.multiline ? 10px : 0px;
            padding-bottom: root.multiline ? 10px : 0px;
            inner := LineInput {
                placeholder: root.placeholder;
                text <=> root.text;
                single-line: !root.multiline;
                // In a multiline field Enter must insert the newline the
                // placeholder promises ("one per line"), not fire submit.
                enter-submits: !root.multiline;
                password: root.password;
                font-size: Theme.fsr(12px, 14px);
                fg: Palette.text-hi;
                placeholder-color: Palette.text-vlo;
                submit => {
                    root.submitted();
                }
                capture-nav: root.capture-nav;
                nav-tab-commits: false;
                nav(delta) => {
                    root.nav(delta);
                }
                commit-mention => {
                    root.submitted();
                }
                dismiss-mention => {
                    root.nav-dismissed();
                }
            }
        }
    }
}
