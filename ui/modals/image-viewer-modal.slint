import { Modal } from "modal.slint";
import { Palette, Theme } from "../tokens.slint";
import { Button } from "../primitives/button.slint";
import { MenuItem } from "../primitives/context-menu.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { SaveIcon } from "../icons/save-icon.slint";
import { StatusPill } from "../primitives/status-pill.slint";
import { NavChevron } from "../primitives/nav-chevron.slint";

component ImageActionContextMenu inherits Rectangle {
    in property <length> anchor-x;
    in property <length> anchor-y;
    callback copy();
    callback save();
    callback dismissed();

    property <int> selected-index: 0;
    property <length> inset: 8px;
    property <length> px: min(max(root.inset, root.anchor-x), root.width - panel.width - root.inset);
    property <length> py: min(max(root.inset, root.anchor-y), root.height - panel.height - root.inset);
    property <bool> opened: false;

    function move-selection(delta: int) {
        root.selected-index = min(max(0, root.selected-index + delta), 1);
    }
    function activate-selected() {
        if (root.selected-index == 0) {
            root.copy();
        } else {
            root.save();
        }
    }

    init => {
        root.opened = true;
        keys.focus();
    }

    TouchArea {
        clicked => {
            root.dismissed();
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.dismissed();
            }
        }
    }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -4px);
        width: max(130px, col.preferred-width);
        height: col.preferred-height;
        opacity: root.opened ? 1.0 : 0.0;
        animate opacity {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        animate y {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        background: Palette.elevated;
        border-radius: (10px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 14px;

        TouchArea {
            col := VerticalLayout {
                padding: 4px;
                spacing: 1px;
                MenuItem {
                    glyph: "⧉";
                    label: @tr("ImageViewerModal" => "Copy");
                    selected: root.selected-index == 0;
                    activated => {
                        root.copy();
                    }
                    hovered => {
                        root.selected-index = 0;
                    }
                }

                MenuItem {
                    glyph: "⭳";
                    label: @tr("ImageViewerModal" => "Save");
                    selected: root.selected-index == 1;
                    activated => {
                        root.save();
                    }
                    hovered => {
                        root.selected-index = 1;
                    }
                }
            }
        }
    }

    keys := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            if (e.text == Key.UpArrow) {
                root.move-selection(-1);
                return accept;
            }
            if (e.text == Key.DownArrow) {
                root.move-selection(1);
                return accept;
            }
            if (e.text == Key.Return || e.text == " ") {
                root.activate-selected();
                return accept;
            }
            return reject;
        }
    }
}

// Full-window lightbox for image attachments, built on Modal's bare mode:
// the backdrop darkens the whole app and the image is letterboxed
// (`image-fit: contain`) into ~90% of the window so any aspect ratio fits
// without cropping. Backdrop click, the floating ✕, and Esc all dismiss;
// tapping the image itself is swallowed so it doesn't bubble to the backdrop.
//
// Slideshow: when the chat holds more than one image attachment, `count` > 1
// turns on the prev/next chevrons, a "n / N" counter, and ←/→ key navigation.
// Rust owns the ordered list and swaps `source` (and toggles `loading`/`failed`
// while a not-yet-decoded image downloads).
export component ImageViewerModal inherits Modal {
    in property <image> source;
    // Total image attachments in the chat, and the 1-based position of the
    // currently shown one. `count <= 1` hides all slideshow chrome.
    in property <int> count: 1;
    in property <int> index: 1;
    // True while the next/prev target is still downloading + decoding.
    in property <bool> loading: false;
    // True when the current target failed to download/decode. The failure pill
    // is clickable so Rust can retry the same slideshow item.
    in property <bool> failed: false;
    // Copy/Save require Rust's slideshow state, not just a visible cached image.
    in property <bool> actions-ready: false;
    callback prev;
    callback next;
    callback retry;
    callback copy;
    callback save;

    property <bool> has-prev: root.index > 1;
    property <bool> has-next: root.index < root.count;
    property <bool> actions-enabled: root.actions-ready && !root.loading && !root.failed;
    property <bool> action-context-open: false;
    property <length> action-context-x: 0px;
    property <length> action-context-y: 0px;

    bare: true;
    // Lightboxes want a real darken, unlike the subtle scrim card modals use.
    background: Palette.overlay-strong;
    // Own the keyboard via the nested FocusScope below (←/→ navigation); the
    // base Modal otherwise grabs focus for Esc. Esc still works: keys this
    // scope rejects bubble up to the base esc-scope.
    grab-focus: false;

    // Single non-layout child so the image and the overlay controls stack
    // (a VerticalLayout — the bare content zone — would tile them instead).
    Rectangle {
        nav-scope := FocusScope {
            width: 100%;
            height: 100%;
            init => {
                self.focus();
            }
            key-pressed(event) => {
                if (event.text == Key.LeftArrow && root.has-prev) {
                    root.prev();
                    return accept;
                }
                if (event.text == Key.RightArrow && root.has-next) {
                    root.next();
                    return accept;
                }
                return reject;
            }

            Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: parent.width * 0.9;
                height: parent.height * 0.9;
                visible: !root.failed;
                source: root.source;
                image-fit: contain;
                // Swallow taps on the image so they don't reach the backdrop;
                // right-click opens the lightbox action menu at the pointer.
                TouchArea {
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right && root.actions-enabled) {
                            root.action-context-x = self.absolute-position.x + self.mouse-x;
                            root.action-context-y = self.absolute-position.y + self.mouse-y;
                            root.action-context-open = true;
                        }
                    }
                }
            }
        }

        // "Loading…" pill while a navigated-to image downloads.
        if root.loading: StatusPill {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: @tr("Loading…");
        }

        // Failure pill when the selected image could not be downloaded/decoded.
        if root.failed && !root.loading: StatusPill {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            pill-height: 42px;
            text: @tr("Image didn't load. Tap to retry.");
            clickable: true;
            border-color: Palette.danger;
            border-width: Theme.outline-surfaces ? Theme.border-w : 1px;
            clicked => {
                root.retry();
            }
        }

        // Copy / Save actions for the currently visible image. These live in
        // the lightbox instead of the bubble so a downloaded album cell has the
        // same affordances as a single-image attachment.
        HorizontalLayout {
            x: 24px;
            y: 24px;
            spacing: 8px;
            Button {
                label: @tr("Copy");
                enabled: root.actions-enabled;
                button-height: 34px;
                min-w: 86px;
                radius: 8px;
                border-w: 1px;
                fg: Palette.media-chip-fg;
                hover-fg: Palette.media-chip-fg;
                bg-color: Palette.media-chip-bg;
                hover-bg: Palette.media-chip-bg-hover;
                outline: Palette.media-chip-outline;
                hover-outline: Palette.media-chip-fg-dim;
                CopyIcon {
                    stroke: Palette.media-chip-fg;
                    fill: Palette.media-chip-bg;
                }

                clicked => {
                    root.copy();
                }
            }

            Button {
                label: @tr("Save");
                enabled: root.actions-enabled;
                button-height: 34px;
                min-w: 84px;
                radius: 8px;
                border-w: 1px;
                fg: Palette.media-chip-fg;
                hover-fg: Palette.media-chip-fg;
                bg-color: Palette.media-chip-bg;
                hover-bg: Palette.media-chip-bg-hover;
                outline: Palette.media-chip-outline;
                hover-outline: Palette.media-chip-fg-dim;
                SaveIcon {
                    stroke: Palette.media-chip-fg;
                }

                clicked => {
                    root.save();
                }
            }
        }

        // Prev chevron.
        if root.count > 1 && root.has-prev: NavChevron {
            x: 24px;
            y: (parent.height - self.height) / 2;
            glyph: "‹";
            clicked => {
                root.prev();
            }
        }

        // Next chevron.
        if root.count > 1 && root.has-next: NavChevron {
            x: parent.width - self.width - 24px;
            y: (parent.height - self.height) / 2;
            glyph: "›";
            clicked => {
                root.next();
            }
        }

        // "n / N" counter pill, bottom-center.
        if root.count > 1: Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 30px;
            width: counter-text.preferred-width + 26px;
            height: 30px;
            border-radius: (15px) * Theme.r-scale;
            background: Palette.media-chip-bg;
            border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
            border-color: Palette.border-2;
            counter-text := Text {
                text: root.index + " / " + root.count;
                color: Palette.media-chip-fg;
                font-size: Theme.fs(12px, 16px);
                font-family: Theme.font;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.action-context-open: ImageActionContextMenu {
            anchor-x: root.action-context-x;
            anchor-y: root.action-context-y;
            copy => {
                root.action-context-open = false;
                root.copy();
            }
            save => {
                root.action-context-open = false;
                root.save();
            }
            dismissed => {
                root.action-context-open = false;
            }
        }
    }
}
