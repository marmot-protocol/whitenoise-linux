import { Palette, Theme } from "../tokens.slint";
import { Modal } from "modal.slint";
import { CopyChip } from "../primitives/copy-chip.slint";

// Contact QR card — opened from the contact detail "Show as QR" action. Shows
// the contact's `marmot://profile/<npub>` deep link rasterized into a QR
// on a permanently white plate so it scans in every theme, plus a tap-to-copy
// npub chip. Single-purpose picker → compact 360px width.
export component QrModal inherits Modal {
    in property <image> qr;
    in property <string> npub-short;
    in property <string> name;
    callback copy-npub;

    card-width: 360px;
    title: root.name;
    subtitle: @tr("Scan to add or message on another device");

    VerticalLayout {
        spacing: 18px;
        alignment: center;

        // QR plate — white in every theme so the code stays scannable.
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 224px;
                height: 224px;
                background: Palette.qr-plate;
                border-radius: (12px) * Theme.r-scale;
                border-width: Theme.border-w;
                border-color: Palette.field-border;
                Image {
                    width: 196px;
                    height: 196px;
                    source: root.qr;
                    image-rendering: pixelated;
                }
            }
        }

        // npub chip — tap to copy, flashes "Copied ✓".
        HorizontalLayout {
            alignment: center;
            CopyChip {
                value: root.npub-short;
                copy-requested => {
                    root.copy-npub();
                }
            }
        }
    }
}
