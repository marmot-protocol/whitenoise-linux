import { Palette, Theme, SharedGroup } from "../tokens.slint";
import { Modal } from "modal.slint";
import { Avatar } from "../primitives/avatar.slint";
import { SharedGroupsList } from "../layout/shared-groups.slint";
import { CopyChip } from "../primitives/copy-chip.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";

// User profile card — opened by tapping an @mention or any avatar in the chat
// tree. Hero layout: a banner tinted with the user's deterministic avatar
// gradient, the avatar overlapping its bottom edge in a card-colored ring,
// then name / nip05 / npub copy chip / about / lightning address. While a
// relay lookup is in flight the text zone renders pulsing skeleton bars.
export component ProfileModal inherits Modal {
    in property <string> display-name;
    in property <string> npub-short;
    in property <string> nip05;
    in property <bool> nip05-verified: false;
    in property <string> about;
    in property <string> lud16;
    in property <bool> loading: false;
    in property <bool> not-found: false;
    in property <bool> is-contact: false;
    in property <bool> is-self: false;
    in property <bool> adding: false;
    in property <color> av-a;
    in property <color> av-b;
    in property <string> av-initials;
    in property <image> av-picture;
    in property <bool> av-has-picture: false;
    // The picture download failed and the avatar fell back to initials; offer a
    // retry over it.
    in property <bool> picture-failed: false;
    in property <[SharedGroup]> shared-groups;
    callback copy-npub;
    callback add-contact;
    callback open-shared-group(string);
    callback retry-picture;

    card-width: 380px;
    title: "";
    show-close: false;          // custom ✕ lives on the banner
    content-padding: 0px;
    // Adding only needs the npub (known before the relay round-trip), so the
    // button shows even while the profile is still loading — otherwise a slow
    // or failed kind-0 fetch hides the action entirely.
    primary-label: root.is-self || root.is-contact ? "" : @tr("Add contact");
    primary-busy-label: @tr("Adding…");
    primary-busy: root.adding;
    primary => {
        root.add-contact();
    }


    // Skeleton pulse while the relay fetch is in flight.
    property <bool> pulse: false;
    pulse-timer := Timer {
        interval: 750ms;
        running: root.loading;
        triggered => {
            root.pulse = !root.pulse;
        }
    }

    property <float> skeleton-opacity: root.pulse ? 0.35 : 0.85;

    VerticalLayout {
        spacing: 0;

        // ── Banner — the user's avatar gradient, full bleed ─────────────
        banner := Rectangle {
            height: 88px;
            background: Theme.soft-decor ? @linear-gradient(135deg, root.av-a 0%, root.av-b 100%) : root.av-a;

            // Soft darken toward the bottom so the avatar ring pops.
            if Theme.soft-decor: Rectangle {
                width: parent.width;
                height: parent.height;
                background: @linear-gradient(180deg, transparent 30%, Palette.media-ghost-bg 100%);
            }
            if !Theme.soft-decor: Rectangle {
                y: parent.height - 2px;
                width: parent.width;
                height: 2px;
                background: Palette.border;
            }

            close-rect := Rectangle {
                x: parent.width - self.width - 12px;
                y: 12px;
                width: 30px;
                height: 30px;
                border-radius: (8px) * Theme.r-scale;
                // Dark scrim, not white-alpha: the banner can be a bright
                // picture (or a bright theme's gradient) where white overlays vanish.
                background: close-touch.has-hover ? Palette.media-ghost-bg-hover : Palette.media-ghost-bg;
                animate background { duration: Theme.hover-dur; }
                Text {
                    text: "✕";
                    color: Palette.media-chip-fg;
                    font-size: Theme.fs(14px, 18px);
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                close-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.dismissed();
                    }
                }
            }
        }

        // ── Avatar shelf — ring overlaps the banner bottom ──────────────
        Rectangle {
            height: 52px;
            ring := Rectangle {
                x: (parent.width - self.width) / 2;
                y: -44px;
                width: 96px;
                height: 96px;
                border-radius: (48px) * Theme.r-scale;
                background: Palette.elevated;
                Avatar {
                    x: 4px;
                    y: 4px;
                    size: 88px;
                    initials: root.av-initials;
                    color-a: root.av-a;
                    color-b: root.av-b;
                    picture: root.av-picture;
                    has-picture: root.av-has-picture;
                    a11y-label: root.display-name;
                    font-size: Theme.fs(26px, 26px);
                }

                // Retry badge over the fallback initials when the picture failed
                // to load; the avatar itself is the hit target.
                if root.picture-failed && !root.av-has-picture: Rectangle {
                    x: parent.width - self.width - 2px;
                    y: parent.height - self.height - 2px;
                    width: 28px;
                    height: 28px;
                    border-radius: (14px) * Theme.r-scale;
                    background: Palette.danger;
                    border-width: 2px;
                    border-color: Palette.elevated;
                    RefreshIcon {
                        stroke: white;
                    }
                }

                if root.picture-failed && !root.av-has-picture: TouchArea {
                    x: 4px;
                    y: 4px;
                    width: 88px;
                    height: 88px;
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: @tr("Retry loading profile picture");
                    accessible-action-default => {
                        root.retry-picture();
                    }
                    clicked => {
                        root.retry-picture();
                    }
                }
            }
        }

        // ── Details ──────────────────────────────────────────────────────
        VerticalLayout {
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 10px;
            padding-bottom: 26px;
            spacing: 10px;

            // Name (or skeleton bar while loading).
            if !root.loading: Text {
                text: root.display-name;
                color: Palette.text-hi;
                font-size: Theme.fs(18px, 20px);
                font-weight: 800;
                font-family: Theme.font;
                horizontal-alignment: center;
                overflow: elide;
            }
            if root.loading: HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 150px;
                    height: 18px;
                    border-radius: (5px) * Theme.r-scale;
                    background: Palette.panel-2;
                    opacity: root.skeleton-opacity;
                    animate opacity {
                        duration: 700ms;
                        easing: ease-in-out;
                    }
                }
            }

            // nip05 handle line. The check + mint accent appear only once the
            // handle is verified against the domain's `.well-known/nostr.json`;
            // an unverified (self-declared) handle shows in a muted tone with no
            // badge, so the checkmark never overstates trust.
            if !root.loading && root.nip05 != "": HorizontalLayout {
                alignment: center;
                spacing: 6px;
                if root.nip05-verified: VerticalLayout {
                    alignment: center;
                    CheckMark {
                        stroke: Palette.mint;
                    }
                }

                Text {
                    text: root.nip05;
                    color: root.nip05-verified ? Palette.mint : Palette.text-lo;
                    font-size: Theme.fs(11px, 14px);
                    font-weight: 700;
                    font-family: Theme.font;
                    overflow: elide;
                }
            }

            // npub chip — tap to copy, flashes "Copied ✓".
            HorizontalLayout {
                alignment: center;
                CopyChip {
                    value: root.npub-short;
                    copy-requested => {
                        root.copy-npub();
                    }
                }
            }

            // Contact badge.
            if !root.loading && root.is-contact && !root.is-self: HorizontalLayout {
                alignment: center;
                Rectangle {
                    height: 22px;
                    width: badge-text.preferred-width + 22px;
                    border-radius: (11px) * Theme.r-scale;
                    background: Palette.mint-surface;
                    badge-text := Text {
                        width: parent.width;
                        height: parent.height;
                        text: @tr("✓ In your contacts");
                        color: Palette.mint;
                        font-size: Theme.fs(9.5px, 12px);
                        font-weight: 700;
                        font-family: Theme.font;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // About / bio.
            if !root.loading && root.about != "": Rectangle {
                height: min(bio-text.preferred-height, 120px);
                clip: true;
                bio-text := Text {
                    width: parent.width;
                    height: 120px;
                    text: root.about;
                    color: Palette.text-mid;
                    font-size: Theme.fs(12px, 16px);
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    vertical-alignment: top;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }
            if root.loading: VerticalLayout {
                spacing: 6px;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 220px;
                        height: 11px;
                        border-radius: (4px) * Theme.r-scale;
                        background: Palette.panel-2;
                        opacity: root.skeleton-opacity;
                        animate opacity {
                            duration: 700ms;
                            easing: ease-in-out;
                        }
                    }
                }

                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 170px;
                        height: 11px;
                        border-radius: (4px) * Theme.r-scale;
                        background: Palette.panel-2;
                        opacity: root.skeleton-opacity;
                        animate opacity {
                            duration: 700ms;
                            easing: ease-in-out;
                        }
                    }
                }
            }

            // Lightning address.
            if !root.loading && root.lud16 != "": Text {
                text: "⚡ " + root.lud16;
                color: Palette.text-lo;
                font-size: Theme.fs(10.5px, 14px);
                font-family: Theme.font;
                horizontal-alignment: center;
                overflow: elide;
            }

            // Groups in common — only when there are any and this isn't the
            // user's own profile (you can't share a group with yourself). The
            // full list with its empty state lives on the contact detail page;
            // the modal stays a quick-glance card.
            if !root.loading && !root.is-self && root.shared-groups.length > 0: VerticalLayout {
                spacing: 8px;
                Rectangle {
                    height: 1px;
                    background: Palette.border-2;
                }

                Text {
                    text: @tr("GROUPS IN COMMON");
                    color: Palette.text-mid;
                    font-size: Theme.fs(9.5px, 12px);
                    font-weight: 700;
                    letter-spacing: 1.4px;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                }

                SharedGroupsList {
                    groups: root.shared-groups;
                    open-group(id) => {
                        root.open-shared-group(id);
                    }
                }
            }

            // Relay-lookup status lines.
            if root.loading: Text {
                text: @tr("Contacting relays…");
                color: Palette.text-vlo;
                font-size: Theme.fs(10.5px, 14px);
                font-family: Theme.font;
                horizontal-alignment: center;
            }
            if root.not-found: Text {
                text: @tr("No profile found on relays.");
                color: Palette.text-vlo;
                font-size: Theme.fs(10.5px, 14px);
                font-family: Theme.font;
                horizontal-alignment: center;
            }
        }
    }
}
