import { Palette, Theme } from "../tokens.slint";
import { Modal } from "modal.slint";
import { Avatar } from "../primitives/avatar.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { CheckMark } from "../icons/check-mark.slint";

// User profile card — opened by tapping an @mention or any avatar in the chat
// tree. Hero layout: a banner tinted with the user's deterministic avatar
// gradient, the avatar overlapping its bottom edge in a card-colored ring,
// then name / nip05 / npub copy chip / about / lightning address. While a
// relay lookup is in flight the text zone renders pulsing skeleton bars.
export component ProfileModal inherits Modal {
    in property <string> display-name;
    in property <string> npub-short;
    in property <string> nip05;
    in property <string> about;
    in property <string> lud16;
    in property <bool> loading: false;
    in property <bool> not-found: false;
    in property <bool> is-contact: false;
    in property <bool> is-self: false;
    in property <bool> adding: false;
    in property <color> av-a;
    in property <color> av-b;
    in property <string> av-initials;
    in property <image> av-picture;
    in property <bool> av-has-picture: false;
    callback copy-npub;
    callback add-contact;

    card-width: 380px;
    title: "";
    show-close: false;          // custom ✕ lives on the banner
    content-padding: 0px;
    // Adding only needs the npub (known before the relay round-trip), so the
    // button shows even while the profile is still loading — otherwise a slow
    // or failed kind-0 fetch hides the action entirely.
    primary-label: root.is-self || root.is-contact ? "" : @tr("Add contact");
    primary-busy-label: @tr("Adding…");
    primary-busy: root.adding;
    primary => { root.add-contact(); }

    // Transient "Copied ✓" feedback on the npub chip.
    property <bool> copied: false;
    copy-reset := Timer {
        interval: 1.4s;
        running: root.copied;
        triggered => { root.copied = false; }
    }

    // Skeleton pulse while the relay fetch is in flight.
    property <bool> pulse: false;
    pulse-timer := Timer {
        interval: 750ms;
        running: root.loading;
        triggered => { root.pulse = !root.pulse; }
    }
    property <float> skeleton-opacity: root.pulse ? 0.35 : 0.85;

    VerticalLayout {
        spacing: 0;

        // ── Banner — the user's avatar gradient, full bleed ─────────────
        banner := Rectangle {
            height: 88px;
            background: Theme.retro ? root.av-a
                : @linear-gradient(135deg, root.av-a 0%, root.av-b 100%);

            // Soft darken toward the bottom so the avatar ring pops.
            if !Theme.retro : Rectangle {
                width: parent.width; height: parent.height;
                background: @linear-gradient(180deg, #00000000 30%, #00000038 100%);
            }
            if Theme.retro : Rectangle {
                y: parent.height - 2px;
                width: parent.width; height: 2px;
                background: Palette.border;
            }

            close-rect := Rectangle {
                x: parent.width - self.width - 12px;
                y: 12px;
                width: 30px;
                height: 30px;
                border-radius: (8px) * Theme.r-scale;
                // Dark scrim, not white-alpha: the banner can be a bright
                // picture (or light-theme gradient) where white overlays vanish.
                background: close-touch.has-hover ? #00000059 : #00000038;
                animate background { duration: 100ms; }
                Text {
                    text: "✕";
                    color: #FFFFFFE6;
                    font-size: (14px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                close-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.dismissed(); }
                }
            }
        }

        // ── Avatar shelf — ring overlaps the banner bottom ──────────────
        Rectangle {
            height: 52px;
            ring := Rectangle {
                x: (parent.width - self.width) / 2;
                y: -44px;
                width: 96px;
                height: 96px;
                border-radius: (48px) * Theme.r-scale;
                background: Palette.elevated;
                Avatar {
                    x: 4px; y: 4px;
                    size: 88px;
                    initials: root.av-initials;
                    color-a: root.av-a;
                    color-b: root.av-b;
                    picture: root.av-picture;
                    has-picture: root.av-has-picture;
                    font-size: (Theme.retro ? 26px : 26px) * Theme.fs-scale;
                }
            }
        }

        // ── Details ──────────────────────────────────────────────────────
        VerticalLayout {
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 10px;
            padding-bottom: 26px;
            spacing: 10px;

            // Name (or skeleton bar while loading).
            if !root.loading : Text {
                text: root.display-name;
                color: Palette.text-hi;
                font-size: (18px) * Theme.fs-scale;
                font-weight: 800;
                font-family: Theme.font;
                horizontal-alignment: center;
                overflow: elide;
            }
            if root.loading : HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 150px;
                    height: 18px;
                    border-radius: (5px) * Theme.r-scale;
                    background: Palette.panel-2;
                    opacity: root.skeleton-opacity;
                    animate opacity { duration: 700ms; easing: ease-in-out; }
                }
            }

            // nip05 verification line.
            if !root.loading && root.nip05 != "" : HorizontalLayout {
                alignment: center;
                spacing: 6px;
                VerticalLayout {
                    alignment: center;
                    CheckMark { stroke: Palette.mint; }
                }
                Text {
                    text: root.nip05;
                    color: Palette.mint;
                    font-size: (11px) * Theme.fs-scale;
                    font-weight: 700;
                    font-family: Theme.font;
                    overflow: elide;
                }
            }

            // npub chip — tap to copy, flashes "Copied ✓".
            HorizontalLayout {
                alignment: center;
                chip := Rectangle {
                    height: 30px;
                    width: chip-row.preferred-width + 28px;
                    border-radius: (15px) * Theme.r-scale;
                    background: chip-touch.has-hover ? Palette.field-hover : Palette.field;
                    border-width: Theme.retro ? Theme.border-w : 1px;
                    border-color: root.copied ? Palette.mint : Palette.field-border;
                    animate background, border-color { duration: 120ms; }
                    chip-row := HorizontalLayout {
                        x: 14px;
                        width: self.preferred-width;
                        spacing: 7px;
                        alignment: center;
                        Text {
                            text: root.copied ? @tr("Copied ✓") : root.npub-short;
                            color: root.copied ? Palette.mint : Palette.text-mid;
                            font-size: (10.5px) * Theme.fs-scale;
                            font-weight: 700;
                            font-family: Theme.font;
                            vertical-alignment: center;
                        }
                        if !root.copied : VerticalLayout {
                            alignment: center;
                            CopyIcon { stroke: Palette.text-lo; }
                        }
                    }
                    chip-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.copy-npub();
                            root.copied = true;
                        }
                    }
                }
            }

            // Contact badge.
            if !root.loading && root.is-contact && !root.is-self : HorizontalLayout {
                alignment: center;
                Rectangle {
                    height: 22px;
                    width: badge-text.preferred-width + 22px;
                    border-radius: (11px) * Theme.r-scale;
                    background: Palette.mint-surface;
                    badge-text := Text {
                        width: parent.width;
                        height: parent.height;
                        text: @tr("✓ In your contacts");
                        color: Palette.mint;
                        font-size: (9.5px) * Theme.fs-scale;
                        font-weight: 700;
                        font-family: Theme.font;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // About / bio.
            if !root.loading && root.about != "" : Rectangle {
                max-height: 120px;
                clip: true;
                Text {
                    width: parent.width;
                    text: root.about;
                    color: Palette.text-mid;
                    font-size: (12px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
            if root.loading : VerticalLayout {
                spacing: 6px;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 220px; height: 11px;
                        border-radius: (4px) * Theme.r-scale;
                        background: Palette.panel-2;
                        opacity: root.skeleton-opacity;
                        animate opacity { duration: 700ms; easing: ease-in-out; }
                    }
                }
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 170px; height: 11px;
                        border-radius: (4px) * Theme.r-scale;
                        background: Palette.panel-2;
                        opacity: root.skeleton-opacity;
                        animate opacity { duration: 700ms; easing: ease-in-out; }
                    }
                }
            }

            // Lightning address.
            if !root.loading && root.lud16 != "" : Text {
                text: "⚡ " + root.lud16;
                color: Palette.text-lo;
                font-size: (10.5px) * Theme.fs-scale;
                font-family: Theme.font;
                horizontal-alignment: center;
                overflow: elide;
            }

            // Relay-lookup status lines.
            if root.loading : Text {
                text: @tr("Contacting relays…");
                color: Palette.text-vlo;
                font-size: (10.5px) * Theme.fs-scale;
                font-family: Theme.font;
                horizontal-alignment: center;
            }
            if root.not-found : Text {
                text: @tr("No profile found on relays.");
                color: Palette.text-vlo;
                font-size: (10.5px) * Theme.fs-scale;
                font-family: Theme.font;
                horizontal-alignment: center;
            }
        }
    }
}
