import { Palette, Theme } from "../tokens.slint";
import { Modal } from "modal.slint";
import { CheckMark } from "../icons/check-mark.slint";

component LanguageRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> focused: false;
    in property <bool> show-divider: true;
    callback clicked;

    height: 44px;
    background: ta.pressed ? Palette.hover
        : (root.focused ? Palette.hover
            : (root.selected ? Palette.mint-surface : transparent));
    animate background { duration: 80ms; }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 14px;
        spacing: 10px;
        alignment: stretch;

        Text {
            horizontal-stretch: 1;
            text: root.label;
            color: root.selected ? Palette.mint : Palette.text-hi;
            font-size: (13px) * Theme.fs-scale;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;
        }

        VerticalLayout {
            alignment: center;
            if root.selected : CheckMark { stroke: Palette.mint; }
        }
    }

    // Accent focus bar on the keyboard-focused row.
    if root.focused : Rectangle {
        x: 0;
        width: 2px;
        y: (parent.height - self.height) / 2;
        height: 22px;
        background: Palette.mint;
        border-radius: 1px;
    }

    if root.show-divider : Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

export component LanguagePickerModal inherits Modal {
    in property <string> active-locale;
    callback locale-selected(string);

    card-width: 360px;
    title: @tr("Interface language");

    // Labels are language endonyms (proper nouns), so they stay out of @tr().
    property <[string]> labels: ["English", "Italiano", "Deutsch", "日本語"];
    property <[string]> locales: ["en", "it", "de", "ja"];

    // Keyboard cursor. Initialised to the active locale on open so Tab/arrows
    // start from the current language.
    property <int> focus-idx: 0;

    // Let our own FocusScope own the keyboard instead of the Modal's esc-scope,
    // matching the command-palette pattern. Esc is handled here too.
    grab-focus: false;

    function commit(i: int) {
        root.locale-selected(root.locales[i]);
        root.dismissed();
    }

    Rectangle {
        height: rows-layout.preferred-height;
        border-radius: (8px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.border-2;
        background: Palette.panel-2;
        clip: true;

        // ↑/↓ move the cursor, Enter/Space commit, Esc dismisses.
        nav := FocusScope {
            init => {
                // Start the cursor on the active locale.
                root.focus-idx =
                    root.active-locale == "it" ? 1
                    : root.active-locale == "de" ? 2
                    : root.active-locale == "ja" ? 3
                    : 0;
                self.focus();
            }
            key-pressed(event) => {
                if (event.text == Key.Escape) {
                    root.dismissed();
                    return accept;
                }
                if (event.text == Key.UpArrow) {
                    root.focus-idx = root.focus-idx == 0
                        ? root.labels.length - 1
                        : root.focus-idx - 1;
                    return accept;
                }
                if (event.text == Key.DownArrow) {
                    root.focus-idx = mod(root.focus-idx + 1, root.labels.length);
                    return accept;
                }
                if (event.text == Key.Return || event.text == " ") {
                    root.commit(root.focus-idx);
                    return accept;
                }
                return reject;
            }

            rows-layout := VerticalLayout {
                padding: 0;

                for label[i] in root.labels : LanguageRow {
                    label: label;
                    selected: root.active-locale == root.locales[i];
                    focused: nav.has-focus && root.focus-idx == i;
                    show-divider: i < root.labels.length - 1;
                    clicked => {
                        root.focus-idx = i;
                        root.commit(i);
                    }
                }
            }
        }
    }
}
