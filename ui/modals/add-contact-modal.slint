import { Modal, ModalField } from "modal.slint";

export component AddContactModal inherits Modal {
    // add-contact(input) — the raw field content; Rust trims it, resolves a
    // NIP-05 username (name@domain) or validates an npub/hex key, republishes
    // the follow list, and surfaces errors via `status`.
    callback add-contact(string);
    in-out property <string> npub-text;
    in property <bool> busy: false;

    card-width: 460px;
    title: @tr("Add contact");
    subtitle: @tr("Enter their username (name@domain), npub, or hex public key. They'll appear in your contacts on every device.");
    secondary-label: @tr("Cancel");
    primary-label: @tr("Add contact");
    primary-busy-label: @tr("Adding…");
    primary-busy: root.busy;
    primary => {
        root.add-contact(root.npub-text);
    }

    ModalField {
        label: @tr("USERNAME OR KEY");
        placeholder: "name@example.com or npub1…";
        text <=> root.npub-text;
        autofocus: true;
        submitted => {
            if (!root.busy) {
                root.add-contact(root.npub-text);
            }
        }
    }
}
