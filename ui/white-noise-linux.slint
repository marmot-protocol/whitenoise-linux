    in-out property <image> chat-group-picture <=> AppState.chat-group-picture;
    in-out property <bool> chat-group-has-picture <=> AppState.chat-group-has-picture;
    in-out property <color> chat-group-av-a <=> AppState.chat-group-av-a;
    in-out property <color> chat-group-av-b <=> AppState.chat-group-av-b;
    in-out property <string> chat-group-av-initials <=> AppState.chat-group-av-initials;
    in-out property <bool> group-rename-busy <=> AppState.group-rename-busy;
    in-out property <bool> group-description-busy <=> AppState.group-description-busy;
    in-out property <bool> group-image-busy <=> AppState.group-image-busy;
    in-out property <bool> group-leave-busy <=> AppState.group-leave-busy;
    in-out property <string> group-settings-status <=> AppState.group-settings-status;
    in-out property <int> group-settings-status-kind <=> AppState.group-settings-status-kind;
    in-out property <string> group-rename-draft <=> AppState.group-rename-draft;
    in-out property <string> group-description-draft <=> AppState.group-description-draft;
    in-out property <bool> show-chat-members <=> AppState.show-chat-members;
    in-out property <bool> show-new-chat <=> AppState.show-new-chat;
    in-out property <string> new-chat-name <=> AppState.new-chat-name;
    in-out property <string> new-chat-members <=> AppState.new-chat-members;
    in-out property <bool> new-chat-busy <=> AppState.new-chat-busy;
    in-out property <string> new-chat-status <=> AppState.new-chat-status;
    in-out property <bool> show-add-contact <=> AppState.show-add-contact;
    in-out property <string> add-contact-input <=> AppState.add-contact-input;
    in-out property <bool> add-contact-busy <=> AppState.add-contact-busy;
    in-out property <string> add-contact-status <=> AppState.add-contact-status;
    in-out property <[AccountEntry]> accounts <=> AppState.accounts;
    in-out property <bool> show-account-switcher <=> AppState.show-account-switcher;
    in-out property <bool> show-add-account <=> AppState.show-add-account;
    in-out property <string> add-account-nsec <=> AppState.add-account-nsec;
    in-out property <bool> add-account-busy <=> AppState.add-account-busy;
    in-out property <string> add-account-status <=> AppState.add-account-status;
    in-out property <bool> add-account-generated <=> AppState.add-account-generated;
    in-out property <bool> show-nickname-modal <=> AppState.show-nickname-modal;
    in-out property <string> nickname-input <=> AppState.nickname-input;
    in-out property <string> nickname-contact-name <=> AppState.nickname-contact-name;
    in-out property <bool> contact-qr-open <=> AppState.contact-qr-open;
    in-out property <image> contact-qr <=> AppState.contact-qr;
    in-out property <string> contact-qr-npub-short <=> AppState.contact-qr-npub-short;
    in-out property <string> contact-qr-npub <=> AppState.contact-qr-npub;
    in-out property <string> contact-qr-name <=> AppState.contact-qr-name;
    in-out property <bool> show-block-confirm <=> AppState.show-block-confirm;
    in-out property <string> contact-chat-hex <=> AppState.contact-chat-hex;
    in-out property <bool> contact-chat-muted <=> AppState.contact-chat-muted;
    in-out property <bool> contact-blocked <=> AppState.contact-blocked;
    in-out property <bool> show-contact-block-confirm <=> AppState.show-contact-block-confirm;
    in-out property <bool> show-contact-remove-confirm <=> AppState.show-contact-remove-confirm;
    // END GENERATED ALIASES

    // The active theme id drives `Theme.id` directly; Rust sets `theme-id` and
    // the whole palette/style resolution follows. `init` covers first paint
    // (a `changed` handler never fires at construction). The mirrors observe
    // the global so the bridge keeps firing now that the contract is aliased.
    // Both arms push the resolved chat body size straight after assigning the
    // id: `Theme.body-fs` is a binding, so reading it here sees the new pack,
    // and Rust needs it before it wraps another message body.
    init => {
        Theme.id = root.theme-id;
        AppState.body-fs-changed(Theme.body-fs);
    }
    private property <int> theme-id-obs: AppState.theme-id;
    changed theme-id-obs => {
        Theme.id = self.theme-id-obs;
        AppState.body-fs-changed(Theme.body-fs);
    }
    private property <int> accent-color-obs: AppState.accent-color;
    changed accent-color-obs => {
        Theme.accent = self.accent-color-obs;
    }

    // ═══ Window body ═══════════════════════════════════════════════════════
    // Ctrl+K and the zoom shortcuts are handled here for the whole app. A key
    // event only reaches an ancestor FocusScope by bubbling up from the focused
    // element, so this scope WRAPS the entire body (main content, every modal,
    // splash, login) as their ancestor: whichever widget holds focus — the
    // composer, a settings control, a modal's own scope — its unhandled Ctrl
    // keys bubble here instead of dying at the focused leaf. init() grabs focus
    // on startup so the shortcuts also work before anything else is focused.
    global-keys := FocusScope {
        init => {
            self.focus();
        }
        key-pressed(event) => {
            if (event.modifiers.control) {
                if (root.logged-in && event.text == "k") {
                    AppState.palette-requested();
                    return accept;
                }
                // In-conversation search: only meaningful with an open chat.
                if (root.logged-in && event.text == "f") {
                    if (AppState.active-page == 0 && AppState.chats.length > 0) {
                        AppState.msg-search-open = true;
                    }
                    return accept;
                }
                // "+" needs shift on most layouts, so accept the bare "=" too.
                if (event.text == "+" || event.text == "=") {
                    AppState.zoom-adjust(1);
                    return accept;
                }
                if (event.text == "-") {
                    AppState.zoom-adjust(-1);
                    return accept;
                }
                if (event.text == "0") {
                    AppState.zoom-adjust(0);
                    return accept;
                }
            }
            // Close the search bar when Esc bubbles up unconsumed (focus
            // outside the field; the field's own scope handles Esc itself).
            if (event.text == Key.Escape && AppState.msg-search-open) {
                AppState.msg-search-open = false;
                AppState.msg-search-closed();
                return accept;
            }
            return reject;
        }

        // Mount order is paint order: the shell first, the overlay stack over
        // it, the boot splash over open modals, and the login gate over
        // everything. ModalHost/ShellTimers are transparent, input-neutral
        // Rectangles, so mounting them unconditionally costs nothing.
        if root.logged-in && !root.booting: AppShell { }

        ModalHost { }

        if root.logged-in && root.booting: SplashScreen {
            status: root.booting-status;
            phase: root.booting-phase;
            phase-count: root.booting-phase-count;
        }

        ShellTimers { }

        if !root.logged-in: LoginGate { }
    }
}
