// White Noise — the window root.
//
// This file is deliberately thin: it declares the Rust-facing contract (every
// property/callback below is a two-way alias onto the AppState global, so the
// generated `WhiteNoiseLinux` API is unchanged) and mounts the four shell
// pieces that do the actual work:
//
//   shell/app-shell.slint    — the signed-in window body (rail, pages, bars)
//   shell/modal-host.slint   — the overlay stack (modals, menus, pickers)
//   shell/login-gate.slint   — the pre-unlock login screen
//   shell/shell-timers.slint — non-visual clockwork (sync ticker, toast reset)
//
// Adding UI goes in those files (state in shell/app-state.slint); only a new
// Rust-facing member adds a line to the alias contract here.

import {
    Palette,
    Theme,
    ChatMeta,
    ChatMessage,
    MentionInboxItem,
    SearchHit,
    Contact,
    SharedGroup,
    ArchivedChat,
    GroupMember,
    AccountEntry,
    TextSelection,
} from "tokens.slint";
import { KeyPackageInfo } from "keys/types.slint";
import { PaletteAction } from "modals/command-palette.slint";
import { SplashScreen } from "shell/splash.slint";
import {
    EmojiEntry,
    EmojiSheet,
    Linkout,
    ProfileSink,
    QuickReact,
    EffectCatalog,
    ErrorCopy,
    TimeCopy,
    SystemCopy,
    NativeDialogStrings,
} from "tokens.slint";
import { EditVersion } from "tokens.slint";
import { AuditLogEntry } from "tokens.slint";
import { StagedAttachment } from "tokens.slint";
import { AppState } from "shell/app-state.slint";
import { AppShell } from "shell/app-shell.slint";
import { ModalHost } from "shell/modal-host.slint";
import { LoginGate } from "shell/login-gate.slint";
import { ShellTimers } from "shell/shell-timers.slint";
// Globals re-exported for Rust. Slint only generates a Rust binding for a
// global when the entry file exports it (or names it in the component tree).
export {
    AppState,             // the whole view-model surface; Rust binds every callback here
    EmojiSheet,           // Twemoji sprite sheet; Rust sets `sprite` at startup
    Theme,                // theme registry; Rust fills color-packs/style-packs (src/themes.rs)
    Linkout,              // Markdown link sink, bound once to open URLs externally
    ProfileSink,          // profile lookups for reactor popovers etc.
    QuickReact,           // quick-reaction hub; Rust pushes the emoji set + binds callbacks
    NativeDialogStrings,  // @tr file-dialog titles, read before opening the rfd picker
    EffectCatalog,        // message-effect catalog + armed selection, read/cleared on send
    ErrorCopy,            // localized error/status copy, read on the UI thread
    TimeCopy,             // localized time/date vocabulary for Rust-side stamp formatters
    SystemCopy,           // group system-line templates, filled in system_event_text
    TextSelection,        // in-bubble selection state; Rust binds `request-word`
}
export component WhiteNoiseTray inherits SystemTrayIcon {
    icon: @image-url("../assets/svg/logo.svg");
    // Total unread across all chats, pushed from Rust by refresh_unread_chrome
    // alongside the window title so the tray surfaces the same count the taskbar
    // does. Zero drops the suffix and shows the plain product name.
    in property <int> unread-count: 0;
    tooltip: root.unread-count > 0
        ? @tr("White Noise · 1 unread message" | "White Noise · {n} unread messages" % root.unread-count)
        : @tr("White Noise");
    title: root.unread-count > 0
        ? @tr("White Noise ({} unread)", root.unread-count)
        : @tr("White Noise");

    callback show-window();
    callback quit();

    clicked => {
        root.show-window();
    }

    Menu {
        MenuItem {
            title: @tr("Show White Noise");
            activated => {
                root.show-window();
            }
        }

        MenuSeparator { }

        MenuItem {
            title: @tr("Quit");
            activated => {
                root.quit();
            }
        }
    }
}

export component WhiteNoiseLinux inherits Window {
    // Window/taskbar title. Rust prefixes the total unread count — `(3) White Noise`
    // — so the count shows wherever the OS surfaces the title (taskbar/tray/Alt-Tab).
    in property <string> window-title: "White Noise";
    title: root.window-title;
    preferred-width: 1920px;
    preferred-height: 1080px;
    // Kept low so the app fits half-screen tiles; below ~1100px the chat-list
    // sidebar collapses to a slim strip (see layout/side-panel.slint). Tiling
    // window managers ignore minimum sizes anyway, so the layout has to
    // survive narrow widths rather than forbid them.
    min-width: Theme.pixel-metrics ? 720px : 640px;
    min-height: Theme.pixel-metrics ? 760px : 650px;
    background: Palette.bg;
    default-font-family: Theme.font;
    // Set once from Rust (cfg!(target_os = "macos")); drives ⌘-vs-Ctrl hints.
    in property <bool> is-macos: false;
    changed is-macos => {
        Theme.is-mac = root.is-macos;
    }

    // ═══ The Rust-facing contract ═══════════════════════════════════════════
    // One alias per view-model member; the state itself lives in the AppState
    // global (shell/app-state.slint — the member docs are there too). Keep the
    // names identical on both sides: the alias is what generates the Rust API.
    // BEGIN GENERATED ALIASES — edit ui/shell/app-state.slint and run scripts/update-root-aliases.sh
    in-out property <int> active-chat <=> AppState.active-chat;
    in-out property <int> active-page <=> AppState.active-page;
    in-out property <int> active-contact <=> AppState.active-contact;
    in-out property <int> active-archived <=> AppState.active-archived;
    in-out property <[MentionInboxItem]> mention-inbox-items <=> AppState.mention-inbox-items;
    in-out property <bool> mention-inbox-loading <=> AppState.mention-inbox-loading;
    in-out property <bool> outgoing-on-right <=> AppState.outgoing-on-right;
    in-out property <length> shell-chats-width <=> AppState.shell-chats-width;
    in-out property <length> shell-info-width <=> AppState.shell-info-width;
    in-out property <bool> shell-centered <=> AppState.shell-centered;
    in-out property <int> settings-tab <=> AppState.settings-tab;
    in-out property <int> theme-id <=> AppState.theme-id;
    in-out property <string> storage-cache-size <=> AppState.storage-cache-size;
