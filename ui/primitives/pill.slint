import { Palette, Theme } from "../tokens.slint";
import { LockIcon } from "../icons/lock-icon.slint";

export component Pill inherits Rectangle {
    in property <string> label;
    in property <color> fg: Palette.bg;
    in property <color> bg-color: Palette.mint;
    // Zpix sits on a 12px grid, so retro bumps both the type and the chip
    // so the chunky SNES controls don't dwarf the labels.
    in property <length> font-size: Theme.retro ? 12px : 10px;
    in property <bool> has-lock: false;
    height: Theme.retro ? 24px : 20px;
    background: root.bg-color;
    border-radius: (4px) * Theme.r-scale;
    HorizontalLayout {
        alignment: center;
        padding-left: 7px; padding-right: 8px;
        spacing: 5px;
        if root.has-lock : LockIcon {
            stroke: root.fg;
        }
        Text {
            text: root.label;
            color: root.fg;
            font-size: (root.font-size) * Theme.fs-scale;
            font-weight: 700;
            font-family: Theme.font;
            vertical-alignment: center;
        }
    }
}
