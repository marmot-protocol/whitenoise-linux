import {
    Palette,
    Theme,
    Reaction,
    Reactor,
    ProfileSink,
    QuickReact,
    EmojiSheet,
} from "../tokens.slint";

// A single emoji + count chip. `mine` controls the highlight style.
component ReactionChip inherits Rectangle {
    in property <string> emoji;
    // Sprite-sheet tile for `emoji`; clip-x < 0 falls back to the text glyph.
    in property <int> clip-x: -1;
    in property <int> clip-y: -1;
    in property <int> count;
    in property <bool> mine: false;
    // Everyone who used this emoji, shown as mention chips in the hover popover
    // below. Empty while a just-added reaction is still optimistic.
    in property <[Reactor]> reactors;
    callback clicked();
    // Popover open-state. `want-open` is the raw hover union (chip or popover);
    // `pop-open` is what actually mounts the popover and lingers briefly after
    // the pointer leaves the chip. That grace is the whole point: without it the
    // popover unmounts the instant the chip loses hover, so the pointer can never
    // reach the badges above. `pop-hovered` is set from the popover's own
    // TouchArea (it can't be referenced from the `if` that mounts it).
    property <bool> pop-hovered: false;
    property <bool> want-open: touch.has-hover || root.pop-hovered;
    property <bool> pop-open: false;
    property <duration> left-at;
    changed want-open => {
        if (root.want-open) {
            root.pop-open = true;
        } else {
            root.left-at = animation-tick();
        }
    }

    height: 22px;
    min-width: 36px;
    border-radius: (11px) * Theme.r-scale;
    border-width: 1px;
    border-color: root.mine ? Palette.mint : (touch.has-hover ? Palette.mint-dim : Palette.border-2);
    background: root.mine ? Palette.mint-surface : (touch.has-hover ? Palette.panel-2 : Palette.panel);
    horizontal-stretch: 0;
    // Pop-in: when a new chip appears (optimistic add, or relay echo), it
    // fades in. Colors animate too so toggling `mine` glides between states.
    property <float> enter: 0;
    init => {
        self.enter = 1;
    }
    animate enter {
        duration: 160ms;
        easing: ease-out;
    }
    opacity: root.enter;
    animate background, border-color {
        duration: 140ms;
        easing: ease-out;
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 4px;
        alignment: center;
        // Colour tile from the shared Twemoji sheet (matching the quick-reaction
        // row and inline bubble emoji); text glyph when the sheet lacks it.
        if root.clip-x >= 0: Image {
            width: 15px;
            height: 15px;
            source: EmojiSheet.sprite;
            source-clip-x: root.clip-x;
            source-clip-y: root.clip-y;
            source-clip-width: EmojiSheet.tile;
            source-clip-height: EmojiSheet.tile;
        }
        if root.clip-x < 0: Text {
            text: root.emoji;
            font-size: (12px) * Theme.fs-scale;
            vertical-alignment: center;
        }

        if root.count > 1: Text {
            text: root.count;
            color: root.mine ? Palette.text-hi : Palette.text-mid;
            font-size: (11px) * Theme.fs-scale;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }

    // Hovering the chip reveals who reacted with this emoji — a non-destructive
    // way to inspect a reaction that leaves the click-to-toggle intact. Each
    // reactor is a mention chip (same plate + gradient as an @mention); clicking
    // one opens their profile through the same `ProfileSink` avatars and
    // mentions use. The card sits just above the chip; `pop-open` keeps it
    // mounted for a short grace period after the chip loses hover so the pointer
    // can travel up onto it (`expired` closes it once the grace lapses and the
    // pointer is elsewhere). The overlapping bridge below the card closes the
    // 4px visual gap for hit-testing so the hand-off has no dead zone.
    if root.pop-open && root.reactors.length > 0: Rectangle {
        x: 0;
        y: -self.height;
        width: pop-col.preferred-width + 16px;
        height: pop-col.preferred-height + 12px;
        background: transparent;
        // Close once the grace window lapses and the pointer is truly gone. The
        // grace keeps the popover alive long enough to move onto it and click a
        // badge, even if a badge's own TouchArea briefly takes the hover off
        // `pop-touch`.
        property <bool> expired: !root.want-open
            && (animation-tick() - root.left-at) > 450ms;
        changed expired => {
            if (self.expired) {
                root.pop-open = false;
            }
        }

        pop-touch := TouchArea {
            changed has-hover => {
                root.pop-hovered = self.has-hover;
            }
            // The visible card. Height leaves a 4px bridge at the bottom of the
            // TouchArea (which spans to y=parent.height, flush with the chip top)
            // so there is no gap between chip and card for the pointer to fall
            // through.
            card := Rectangle {
                width: 100%;
                height: parent.height - 4px;
                background: Palette.elevated;
                border-radius: (8px) * Theme.r-scale;
                border-width: Theme.border-w;
                border-color: Palette.elevated-border;
                drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-float;
                drop-shadow-offset-y: Theme.hard-shadow ? 2px : 1px;
                drop-shadow-blur: Theme.hard-shadow ? 0px : 6px;
            }

            pop-col := VerticalLayout {
                x: 8px;
                y: 6px;
                spacing: 4px;
                for reactor in root.reactors: HorizontalLayout {
                    alignment: start;
                    Rectangle {
                        height: 22px;
                        border-radius: min((6px) * Theme.r-scale, self.height / 2);
                        background: @linear-gradient(135deg, reactor.a 0%, reactor.b 100%);
                        // Subtle outline on hover so the badge reads as clickable.
                        border-width: rt.has-hover ? 1px : 0px;
                        border-color: #ffffff88;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            Text {
                                text: reactor.name;
                                color: white;
                                font-size: (11px) * Theme.fs-scale;
                                font-weight: 600;
                                font-family: Theme.font;
                                vertical-alignment: center;
                            }
                        }

                        // Clicking a reactor opens their profile — the same modal
                        // `ProfileSink` opens from an @mention or an avatar.
                        rt := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                ProfileSink.open(reactor.id);
                            }
                        }
                    }
                }
            }
        }
    }
}

// In-flow row of reaction chips, rendered directly under a bubble (only when
// the message actually has reactions, so empty messages stay tight). Tapping a
// chip toggles my reaction on/off.
export component ReactionChips inherits HorizontalLayout {
    in property <string> message-id;
    in property <[Reaction]> reactions;
    in property <bool> align-right: false;
    callback react(string, string);
    callback unreact(string, string);

    spacing: 6px;
    alignment: root.align-right ? end : start;

    for r in root.reactions: ReactionChip {
        emoji: r.emoji;
        clip-x: r.clip-x;
        clip-y: r.clip-y;
        count: r.count;
        mine: r.mine;
        reactors: r.reactors;
        clicked => {
            if (r.mine) {
                root.unreact(root.message-id, r.emoji);
            } else {
                root.react(root.message-id, r.emoji);
            }
        }
    }
}

// One tappable emoji in the quick-reaction row (the hover toolbar, the context
// menu, and the Settings editor). Renders the glyph over a hover highlight.
// `removable` overlays a small ✕ on hover so the same cell doubles as the
// delete control in the Settings editor, where a tap removes the emoji.
export component QuickReactCell inherits Rectangle {
    in property <string> emoji;
    // Sprite-sheet tile for `emoji`; clip-x < 0 falls back to the text glyph.
    in property <int> clip-x: -1;
    in property <int> clip-y: -1;
    in property <bool> removable: false;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: (8px) * Theme.r-scale;
    background: touch.has-hover ? Palette.hover : transparent;
    animate background { duration: 100ms; }

    // A tile from the shared Twemoji sheet — the same texture the chat bubbles
    // draw inline emoji from, so a quick reaction looks identical to the emoji
    // it posts.
    if root.clip-x >= 0: Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        source: EmojiSheet.sprite;
        source-clip-x: root.clip-x;
        source-clip-y: root.clip-y;
        source-clip-width: EmojiSheet.tile;
        source-clip-height: EmojiSheet.tile;
    }

    // Fallback glyph: the "+" add cell, or an emoji the sheet doesn't carry.
    if root.clip-x < 0: Text {
        width: 100%;
        height: 100%;
        text: root.emoji;
        font-size: (15px) * Theme.fs-scale;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Delete affordance for the editor: a red ✕ badge that only shows on hover,
    // so the row reads as emoji until the user reaches for one to remove.
    if root.removable && touch.has-hover: Rectangle {
        x: parent.width - self.width + 3px;
        y: -3px;
        width: 14px;
        height: 14px;
        border-radius: 7px;
        background: Palette.danger;
        Text {
            text: "✕";
            color: white;
            font-size: (8px) * Theme.fs-scale;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// One round icon button inside the floating toolbar.
component ActionButton inherits Rectangle {
    in property <string> glyph;
    // When false the button collapses to nothing — used to keep the edit
    // button in the tree (so its id stays referenceable) while hiding it for
    // non-authors.
    in property <bool> shown: true;
    callback clicked();
    out property <bool> hovered: touch.has-hover;

    visible: root.shown;
    width: root.shown ? 28px : 0px;
    height: 28px;
    border-radius: (8px) * Theme.r-scale;
    background: touch.has-hover ? Palette.hover : transparent;
    animate background { duration: 100ms; }
    Text {
        text: root.glyph;
        color: touch.has-hover ? Palette.text-hi : Palette.text-mid;
        font-size: (13px) * Theme.fs-scale;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// Floating action toolbar — a one-tap quick-reaction row (👍 ❤️ … + "+" into
// the full picker), then reply and (author-only) edit. Positioned by the row to
// the side of the bubble and shown on hover. It's a self-contained card so it
// reads as a hovering control rather than chrome baked into the row. `hovered`
// tracks the whole bar (via the ancestor TouchArea) so the row can keep it open
// while the pointer is on a cell (which steals hover from the bubble sensor).
export component HoverActions inherits Rectangle {
    in property <string> message-id;
    in property <string> reply-preview-text;
    in property <string> reply-author;
    in property <bool> can-edit: false;
    callback request-picker(string, length, length);
    callback request-reply(string, string, string);
    callback request-edit(string, string);
    // A single ancestor TouchArea reports the hover for the whole bar (it stays
    // hovered while the pointer is over any nested cell/button, so the row can
    // keep the toolbar open), and nested cell TouchAreas still win their own
    // clicks — the wrapping pattern the emoji picker and context menu rely on.
    out property <bool> hovered: bar-touch.has-hover;

    width: bar.preferred-width;
    height: bar.preferred-height;
    border-radius: (10px) * Theme.r-scale;
    background: Palette.elevated;
    border-width: Theme.border-w;
    border-color: Palette.elevated-border;
    drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-float;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : 2px;
    drop-shadow-blur: Theme.hard-shadow ? 0px : 10px;

    bar-touch := TouchArea {
        bar := HorizontalLayout {
            padding: 3px;
            spacing: 2px;
            // One-tap quick reactions, then a "+" that opens the full picker.
            for e in QuickReact.list: QuickReactCell {
                emoji: e.emoji;
                clip-x: e.clip-x;
                clip-y: e.clip-y;
                clicked => {
                    QuickReact.react(root.message-id, e.emoji);
                }
            }

            plus-btn := ActionButton {
                glyph: "+";
                clicked => {
                    root.request-picker(
                        root.message-id,
                        self.absolute-position.x,
                        self.absolute-position.y + self.height,
                    );
                }
            }

            // Divider between the reactions and the message actions.
            Rectangle {
                width: 7px;
                Rectangle {
                    x: 3px;
                    y: 6px;
                    width: 1px;
                    height: parent.height - 12px;
                    background: Palette.border-2;
                }
            }

            reply-btn := ActionButton {
                glyph: "↩";
                clicked => {
                    root.request-reply(root.message-id, root.reply-preview-text, root.reply-author);
                }
            }

            edit-btn := ActionButton {
                glyph: "✎";
                shown: root.can-edit;
                clicked => {
                    root.request-edit(root.message-id, root.reply-preview-text);
                }
            }
        }
    }
}
