import { Palette, Theme } from "../tokens.slint";

// Small uppercase label above form sections (login fields, modal info rows,
// key readouts). The shared styling — muted text, 9px, bold, wide tracking —
// keeps section headers consistent across every surface that uses one.
export component SectionLabel inherits Text {
    color: Palette.text-mid;
    font-size: Theme.fs(9px, 12px);
    font-weight: 700;
    font-family: Theme.font;
    letter-spacing: 1.6px;
}
