import { Palette, Theme } from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { Avatar } from "avatar.slint";
import { UnreadBadge } from "unread-badge.slint";

export component ChatListItem inherits Rectangle {
    callback clicked;

    in property <string> name;
    in property <string> preview;
    in property <string> stamp;
    in property <string> badge;
    in property <bool> selected: false;
    in property <bool> sending: false;
    in property <bool> read: false;
    in property <color> av-a;
    in property <color> av-b;
    in property <string> av-initials;
    in property <image> picture;
    in property <bool> has-picture: false;

    height: 64px;
    background: root.selected
        ? Palette.selected
        : (touch.has-hover ? Palette.hover : transparent);
    border-radius: (8px) * Theme.r-scale;
    border-width: Theme.retro && root.selected ? Theme.border-w : (root.selected && !Theme.retro ? 1px : 0px);
    border-color: root.selected && !Theme.retro ? Palette.mint-glow : Palette.border;
    animate background, border-color { duration: 140ms; easing: ease-out; }

    // Animated mint selection bar — grows from center when selected.
    if !Theme.retro : Rectangle {
        x: 0px;
        width: 3px;
        height: root.selected ? 40px : 0px;
        y: (parent.height - self.height) / 2;
        background: Palette.mint;
        border-radius: (1.5px) * Theme.r-scale;
        drop-shadow-blur: root.selected ? 6px : 0px;
        drop-shadow-color: Palette.mint-glow;
        opacity: root.selected ? 1.0 : 0.0;
        animate height { duration: 220ms; easing: ease-in-out; }
        animate opacity { duration: 160ms; easing: ease-out; }
    }
    // SNES selection chevron — slides in from outside the edge.
    if Theme.retro : Text {
        x: root.selected ? 2px : -14px;
        y: (parent.height - self.height) / 2;
        text: "▶";
        color: Palette.bubble-out-fg;
        font-size: 14px;
        font-family: Theme.font;
        vertical-alignment: center;
        opacity: root.selected ? 1.0 : 0.0;
        animate x { duration: 140ms; easing: ease-out; }
        animate opacity { duration: 100ms; }
    }

    HorizontalLayout {
        padding-left: 12px; padding-right: 12px;
        padding-top: 14px; padding-bottom: 14px;
        spacing: 12px;
        Avatar {
            size: 36px;
            initials: root.av-initials;
            color-a: root.av-a;
            color-b: root.av-b;
            picture: root.picture;
            has-picture: root.has-picture;
            font-size: (Theme.retro ? 16px : 11px) * Theme.fs-scale;
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: root.name;
                    color: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.text-hi;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 700;
                    font-family: Theme.font;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Text {
                    text: root.stamp;
                    color: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                    font-size: (10px) * Theme.fs-scale;
                    font-family: Theme.font;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: root.preview;
                    color: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                    font-size: (Theme.retro ? 16px : 11px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-stretch: 1;
                    overflow: elide;
                    vertical-alignment: center;
                }
                if root.badge != "" : UnreadBadge {
                    count: root.badge;
                }
                if root.badge == "" && root.read : CheckMark {
                    stroke: Palette.text-lo;
                    double: true;
                    y: 4px;
                }
                if root.badge == "" && root.sending : Rectangle {
                    width: 12px; height: 12px;
                    y: 3px;
                    border-radius: (6px) * Theme.r-scale;
                    border-width: 1px;
                    border-color: Palette.text-vlo;
                }
            }
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
