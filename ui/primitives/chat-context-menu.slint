import { Palette, Theme } from "../tokens.slint";
import { MenuItem } from "context-menu.slint";

// Right-click context menu for a chat row in the rail. Full-window mount (like
// MessageContextMenu / EmojiPicker) so the invisible backdrop catches outside
// clicks; the panel sits at the anchor, clamped inside the window. Actions:
// pin/unpin, mute/unmute, and leave for group rows the viewer can leave.
export component ChatContextMenu inherits Rectangle {
    in property <length> anchor-x;
    in property <length> anchor-y;
    // Current state of the target row — picks each item's label.
    in property <bool> pinned: false;
    in property <bool> muted: false;
    in property <bool> can-leave: false;
    callback toggle-pin();
    callback toggle-mute();
    callback export-chat();
    callback leave-group();
    callback dismissed();

    property <int> item-count: 3 + (root.can-leave ? 1 : 0);
    property <int> selected-index: 0;

    function move-selection(delta: int) {
        root.selected-index = min(max(0, root.selected-index + delta), root.item-count - 1);
    }
    function wrap-selection(delta: int) {
        if (root.selected-index + delta < 0) {
            root.selected-index = root.item-count - 1;
        } else if (root.selected-index + delta >= root.item-count) {
            root.selected-index = 0;
        } else {
            root.selected-index = root.selected-index + delta;
        }
    }
    function activate-selected() {
        if (root.selected-index == 0) {
            root.toggle-pin();
        } else if (root.selected-index == 1) {
            root.toggle-mute();
        } else if (root.selected-index == 2) {
            root.export-chat();
        } else if (root.selected-index == 3 && root.can-leave) {
            root.leave-group();
        }
    }

    // Backdrop — invisible, dismisses on a click or another right-click.
    TouchArea {
        clicked => {
            root.dismissed();
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.dismissed();
            }
        }
    }

    property <length> inset: 8px;
    property <length> px: min(max(root.inset, root.anchor-x), root.width - panel.width - root.inset);
    property <length> py: min(max(root.inset, root.anchor-y), root.height - panel.height - root.inset);

    property <bool> opened: false;
    init => {
        root.opened = true;
        root.selected-index = 0;
        keys.focus();
    }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -4px);
        width: max(160px, col.preferred-width);
        height: col.preferred-height;
        opacity: root.opened ? 1.0 : 0.0;
        animate opacity {
            duration: 120ms;
            easing: ease-out;
        }
        animate y {
            duration: 120ms;
            easing: ease-out;
        }
        background: Palette.elevated;
        border-radius: (10px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 14px;

        TouchArea {
            col := VerticalLayout {
                padding: 4px;
                spacing: 1px;
                MenuItem {
                    glyph: root.pinned ? "▽" : "▲";
                    label: root.pinned ? @tr("Unpin") : @tr("Pin to top");
                    selected: root.selected-index == 0;
                    activated => {
                        root.toggle-pin();
                    }
                    hovered => {
                        root.selected-index = 0;
                    }
                }

                MenuItem {
                    glyph: root.muted ? "♪" : "♩";
                    label: root.muted ? @tr("Unmute") : @tr("Mute");
                    selected: root.selected-index == 1;
                    activated => {
                        root.toggle-mute();
                    }
                    hovered => {
                        root.selected-index = 1;
                    }
                }

                MenuItem {
                    glyph: "⭳";
                    label: @tr("Export transcript…");
                    selected: root.selected-index == 2;
                    activated => {
                        root.export-chat();
                    }
                    hovered => {
                        root.selected-index = 2;
                    }
                }

                MenuItem {
                    shown: root.can-leave;
                    glyph: "←";
                    label: @tr("Leave group");
                    selected: root.selected-index == 3;
                    activated => {
                        root.leave-group();
                    }
                    hovered => {
                        root.selected-index = 3;
                    }
                }
            }
        }
    }

    keys := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            if (e.text == Key.UpArrow) {
                root.move-selection(-1);
                return accept;
            }
            if (e.text == Key.DownArrow) {
                root.move-selection(1);
                return accept;
            }
            if (e.text == Key.Home) {
                root.selected-index = 0;
                return accept;
            }
            if (e.text == Key.End) {
                root.selected-index = root.item-count - 1;
                return accept;
            }
            if (e.text == Key.Tab) {
                root.wrap-selection(1);
                return accept;
            }
            if (e.text == Key.Backtab) {
                root.wrap-selection(-1);
                return accept;
            }
            if (e.text == Key.Return) {
                root.activate-selected();
                return accept;
            }
            return reject;
        }
    }
}
