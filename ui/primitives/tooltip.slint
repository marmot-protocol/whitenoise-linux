import { Palette, Theme } from "../tokens.slint";

// Tooltip — a small floating label that appears to the right of a target element.
// Used in the left rail for icon-only buttons when the rail is collapsed, and to
// reveal text a surface had to elide (composer reply preview, attachment names).
export component Tooltip inherits Rectangle {
    in property <string> label: "";
    in property <bool> is-visible: false;
    in property <length> offset-y: 0px;
    // Caps how wide the tooltip may grow before the label wraps onto more
    // lines, so revealing a long elided string can't run off the window. 0px
    // (the default) keeps the single-line, grow-to-fit behaviour short labels
    // want.
    in property <length> wrap-width: 0px;

    x: 0px;
    y: root.offset-y;
    width: root.wrap-width <= 0px ? self.preferred-width : min(self.preferred-width, root.wrap-width);
    height: max(28px, label-text.preferred-height + 12px);
    background: Palette.elevated;
    border-radius: (6px) * Theme.r-scale;
    border-width: Theme.border-w;
    border-color: Palette.elevated-border;
    opacity: root.is-visible ? 1.0 : 0.0;
    drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-float;
    drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : 1px;
    drop-shadow-blur: Theme.hard-shadow ? 0px : 4px;
    animate opacity {
        duration: Theme.transition-dur;
        easing: ease-out;
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 6px;
        padding-bottom: 6px;
        alignment: center;
        label-text := Text {
            text: root.label;
            color: Palette.text-mid;
            font-size: Theme.fs(10px, 14px);
            font-weight: 600;
            font-family: Theme.font;
            vertical-alignment: center;
            wrap: root.wrap-width <= 0px ? no-wrap : word-wrap;
        }
    }
}
