// Generic button primitive — the only button in the system.
// Variations: pass overrides at the call site, or use the presets below.
//
// @children slot is for an optional leading icon. Label is set via `label` property.
import { Palette, Theme } from "../tokens.slint";

export component Button inherits Rectangle {
    callback clicked;
    // Secondary affordance — fires on right-click or a ~450ms long-press.
    // Used by the composer Send button to open the message-effect picker
    // Telegram-style without a second overlapping TouchArea.
    callback alt-action;
    in property <string> label;
    in property <length> button-height: 32px;
    in property <length> button-width: 0px;   // 0 = auto (preferred-width)
    in property <length> min-w: 0px;
    in property <length> radius: 6px;
    in property <length> pad-left: 12px;
    in property <length> pad-right: 14px;
    in property <length> spacing: 8px;
    in property <length> font-size: Theme.fsr(12px, 16px);
    in property <int>    font-weight: 700;
    in property <color>  fg: Palette.text-hi;
    in property <color>  bg-color: Palette.panel-2;
    in property <color>  outline: Palette.border;
    in property <length> border-w: Theme.border-w;
    in property <bool>   selected: false;
    in property <color>  selected-bg: Palette.selected;
    in property <color>  hover-bg: Palette.bubble-in;
    in property <color>  hover-fg: root.fg;
    in property <color>  hover-outline: root.outline;
    in property <bool>   use-hover: true;
    in property <bool>   has-fill: true;
    // When false the button dims, drops its hover styling, and swallows no
    // clicks — callers gate "send with empty draft", "primary while busy", etc.
    in property <bool>   enabled: true;
    // Opt-in Tab focusability (modal footers, chat-request actions, Send).
    // Opt-in rather than default so the tab chain only contains buttons
    // that make sense to reach from the keyboard.
    in property <bool>   focusable: false;
    out property <bool> has-hover: touch.has-hover;
    out property <bool> is-primary: root.bg-color == Palette.mint;

    property <bool> hovered: root.enabled && root.use-hover && touch.has-hover;

    height: root.button-height;
    min-width: root.button-width > 0px ? root.button-width : root.min-w;
    max-width: root.button-width > 0px ? root.button-width : 100000px;
    border-radius: (root.radius) * Theme.r-scale;
    border-width: root.border-w;
    border-color: root.hovered ? root.hover-outline : root.outline;
    background: root.selected
        ? root.selected-bg
        : (root.hovered ? root.hover-bg : root.bg-color);
    opacity: root.enabled ? 1.0 : 0.5;
    animate opacity { duration: 120ms; easing: ease-out; }
    accessible-role: button;
    accessible-enabled: root.enabled;
    accessible-label: root.label;
    accessible-action-default => { if root.enabled { root.clicked(); } }
    drop-shadow-color: Theme.hard-shadow && root.has-fill ? Palette.shadow
        : (root.is-primary && root.has-fill ? Palette.mint-glow : transparent);
    // In retro: hover pushes the shadow further (3px) for a "lifted" SNES-button feel.
    drop-shadow-offset-x: Theme.hard-shadow && root.has-fill
        ? (root.hovered ? 3px : 2px)
        : (root.is-primary && root.has-fill && root.hovered ? 0px : 0px);
    drop-shadow-offset-y: Theme.hard-shadow && root.has-fill
        ? (root.hovered ? 3px : 2px)
        : (root.is-primary && root.has-fill ? 2px : 0px);
    drop-shadow-blur: Theme.hard-shadow && root.has-fill ? 0px : (root.is-primary && root.has-fill ? 12px : 0px);
    animate background, border-color { duration: 120ms; easing: ease-out; }
    animate drop-shadow-offset-x, drop-shadow-offset-y { duration: 90ms; easing: ease-out; }

    // SNES bevel: bright pixel highlight on top edge, dark shade on bottom.
    if Theme.bevel && root.has-fill && !root.hovered : Rectangle {
        x: root.border-w; y: root.border-w;
        width: parent.width - root.border-w * 2;
        height: 2px;
        background: Palette.bevel-hi;
        opacity: root.selected ? 0.6 : 0.35;
    }
    if Theme.bevel && root.has-fill && !root.hovered : Rectangle {
        x: root.border-w; y: parent.height - root.border-w - 2px;
        width: parent.width - root.border-w * 2;
        height: 2px;
        background: Palette.bevel-lo;
        opacity: 0.5;
    }

    HorizontalLayout {
        padding-left: root.pad-left;
        padding-right: root.label == "" ? root.pad-left : root.pad-right;
        spacing: root.spacing;
        alignment: center;

        VerticalLayout {
            alignment: center;
            @children
        }

        if root.label != "" : Text {
            // Terminal/TUI themes bracket button labels: [ Send ].
            text: Theme.bracket-labels ? "[ " + root.label + " ]" : root.label;
            color: root.hovered ? root.hover-fg : root.fg;
            font-size: (root.font-size) * Theme.fs-scale;
            font-weight: root.font-weight;
            font-family: Theme.font;
            vertical-alignment: center;
            animate color { duration: 120ms; easing: ease-out; }
        }
    }

    // `alt-fired` suppresses the trailing left-`clicked` after a long-press, and
    // is reset on the next left-down so a click following a right-click still
    // sends (the right-press sets it true with no `clicked` to clear it).
    property <bool> pressing: false;
    property <bool> alt-fired: false;
    touch := TouchArea {
        enabled: root.enabled;
        pointer-event(ev) => {
            if ev.button == PointerEventButton.right {
                if ev.kind == PointerEventKind.down {
                    root.alt-fired = true;
                    root.alt-action();
                }
            } else if ev.button == PointerEventButton.left {
                if ev.kind == PointerEventKind.down {
                    root.alt-fired = false;
                    root.pressing = true;
                } else if ev.kind == PointerEventKind.up {
                    root.pressing = false;
                }
            }
        }
        clicked => { if !root.alt-fired { root.clicked(); } }
    }
    longpress := Timer {
        interval: 450ms;
        running: root.pressing;
        triggered => {
            root.pressing = false;
            self.running = false;
            root.alt-fired = true;
            root.alt-action();
        }
    }

    // Zero-size FocusScope: participates in the Tab chain but never receives
    // pointer events, so clicking the button can't pull keyboard focus away
    // from the composer (a full-size scope grabs focus on click).
    fs := FocusScope {
        width: 0px; height: 0px;
        enabled: root.focusable && root.enabled;
        key-pressed(event) => {
            if (event.text == Key.Return || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    // Focus ring just outside the bounds. Accent for regular buttons; primary
    // buttons are already accent-filled, so their ring flips to text-hi.
    if fs.has-focus : Rectangle {
        x: -3px; y: -3px;
        width: parent.width + 6px;
        height: parent.height + 6px;
        background: transparent;
        border-radius: (root.radius + 3px) * Theme.r-scale;
        border-width: 2px;
        border-color: root.is-primary ? Palette.text-hi : Palette.mint;
    }
}

// Small chip-style button (info-row actions in settings/profile/keys/contacts).
export component MicroButton inherits Button {
    button-height: 26px;
    radius: 5px;
    pad-left: 10px;
    pad-right: 12px;
    spacing: 6px;
    font-size: Theme.fsr(11px, 15px);
}

// Icon-only ghost button used in the left nav rail.
export component RailButton inherits Button {
    button-height: 30px;
    button-width: 36px;
    radius: 6px;
    bg-color: transparent;
    outline: transparent;
    border-w: 0px;
    has-fill: false;
    use-hover: true;
    hover-bg: Palette.hover;
    pad-left: 0px;
    pad-right: 0px;
    spacing: 0px;
}
