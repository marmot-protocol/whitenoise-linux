import { Palette, Theme, Reaction, MessageLine, ProfileSink, AlbumCell } from "../tokens.slint";
import { Avatar } from "avatar.slint";
import { MessageBubble } from "message-bubble.slint";
import { ReactionChips, HoverActions } from "reactions-row.slint";

export component OutgoingRow inherits VerticalLayout {
    in property <int> effect-id: 0;
    in property <int> effect-clip-x: 0;
    in property <int> effect-clip-y: 0;
    in property <bool> effect-autoplay: false;
    // Fire the burst in the shared overlay (above all bubbles). See IncomingRow.
    callback play-effect(int, int, int, length, length, length, length);
    function fire-effect() {
        root.play-effect(root.effect-id, root.effect-clip-x, root.effect-clip-y,
            bubble.absolute-position.x, bubble.absolute-position.y, bubble.width, bubble.height);
    }
    init => { if (root.effect-autoplay && root.effect-id > 0) { fx-timer.running = true; } }
    fx-timer := Timer {
        interval: 120ms;
        running: false;
        triggered => { self.running = false; root.fire-effect(); }
    }
    in property <string> text;
    in property <[MessageLine]> lines;
    in property <string> stamp;
    in property <string> stamp-full;
    in property <length> bubble-max: 440px;
    in property <length> row-w: 9999px;
    in property <bool> show-avatar: true;
    in property <bool> align-right: true;
    in property <color> av-a: #BEF264;
    in property <color> av-b: #65A30D;
    in property <string> av-initials: "Y";
    in property <image> av-picture;
    in property <bool> av-has-picture: false;
    // Own account-id hex — avatar taps open the profile modal via ProfileSink.
    in property <string> sender-id;
    in property <string> message-id;
    in property <[Reaction]> reactions;
    in property <bool> first-in-group: true;
    in property <bool> last-in-group: true;
    in property <bool> jumbo-emoji: false;
    in property <bool> pending: false;
    in property <bool> failed: false;
    in property <string> reply-to-id;
    in property <string> reply-to-text;
    in property <string> reply-to-author;
    in property <image> reply-to-image;
    in property <bool> reply-to-has-image: false;
    in property <bool> has-attachment: false;
    in property <string> att-name;
    in property <string> att-mime;
    in property <string> att-size-label;
    in property <bool> att-is-image: false;
    in property <bool> att-is-video: false;
    in property <bool> att-is-audio: false;
    in property <bool> att-audio-playing: false;
    in property <float> att-audio-progress: 0.0;
    in property <string> att-duration;
    in property <image> att-image;
    in property <bool> att-has-image: false;
    in property <bool> att-loading: false;
    in property <bool> att-failed: false;
    in property <[AlbumCell]> album: [];
    in property <length> album-w;
    in property <length> album-h;
    in property <bool> edited: false;
    in property <int> edit-count: 0;
    in property <bool> can-edit: false;
    in property <bool> deleted: false;
    callback album-cell-clicked(string);
    callback react(string, string);
    callback unreact(string);
    callback request-picker(string, length, length);
    callback request-reply(string, string, string);
    callback request-edit(string, string);
    // message_id, text, author, can_edit, window-abs x, y
    callback request-context-menu(string, string, string, bool, length, length);
    callback show-history(string);
    callback retry();
    callback attachment-clicked(string);
    callback audio-play-clicked(string); // message_id
    callback audio-seek-clicked(string, float); // message_id, fraction

    spacing: 0;

    HorizontalLayout {
        spacing: 10px;
        alignment: root.align-right ? end : start;

        if root.align-right : Rectangle { horizontal-stretch: 1; }

        if !root.align-right && root.show-avatar : TouchArea {
            width: 28px;
            height: 28px;
            mouse-cursor: pointer;
            clicked => { if (root.sender-id != "") { ProfileSink.open(root.sender-id); } }
            Avatar {
                size: 28px;
                y: 0;
                initials: root.av-initials;
                color-a: root.av-a;
                color-b: root.av-b;
                picture: root.av-picture;
                has-picture: root.av-has-picture;
                font-size: Theme.fs(9px, 14px);
            }
        }
        if !root.align-right && !root.show-avatar : Rectangle { width: 28px; }

        VerticalLayout {
            spacing: 2px;

            block := Rectangle {
                horizontal-stretch: 0;
                width: bubble.width;
                height: bubble.height;

                // Stable hover region spanning toolbar → bubble. The toolbar
                // floats on the side opposite the avatar (left when right-
                // aligned), overflowing into the gutter.
                hover := TouchArea {
                    x: root.align-right ? -(acts.width + 6px) : 0px;
                    y: 0;
                    width: bubble.width + 6px + acts.width;
                    height: parent.height;
                }

                bubble := MessageBubble {
                    x: 0; y: 0;
                    message: root.text;
                    effect-id: root.effect-id;
                    effect-clip-x: root.effect-clip-x;
                    effect-clip-y: root.effect-clip-y;
                    lines: root.lines;
                    stamp: root.stamp;
                    stamp-full: root.stamp-full;
                    outgoing: true;
                    align-right: root.align-right;
                    max-w: root.bubble-max;
                    available-w: max(80px, root.row-w - 28px - 10px - 10px);
                    first-in-group: root.first-in-group;
                    last-in-group: root.last-in-group;
                    jumbo-emoji: root.jumbo-emoji;
                    pending: root.pending;
                    failed: root.failed;
                    reply-to-id: root.reply-to-id;
                    reply-to-text: root.reply-to-text;
                    reply-to-author: root.reply-to-author;
                    reply-to-image: root.reply-to-image;
                    reply-to-has-image: root.reply-to-has-image;
                    has-attachment: root.has-attachment;
                    att-name: root.att-name;
                    att-mime: root.att-mime;
                    att-size-label: root.att-size-label;
                    att-is-image: root.att-is-image;
                    att-is-video: root.att-is-video;
                    att-is-audio: root.att-is-audio;
                    att-audio-playing: root.att-audio-playing;
                    att-audio-progress: root.att-audio-progress;
                    att-duration: root.att-duration;
                    att-image: root.att-image;
                    att-has-image: root.att-has-image;
                    att-loading: root.att-loading;
                    att-failed: root.att-failed;
                    album: root.album;
                    album-w: root.album-w;
                    album-h: root.album-h;
                    edited: root.edited;
                    edit-count: root.edit-count;
                    deleted: root.deleted;
                    retry-clicked => { root.retry(); }
                    attachment-clicked => { root.attachment-clicked(root.message-id); }
                    audio-play-clicked => { root.audio-play-clicked(root.message-id); }
                    audio-seek-clicked(fraction) => { root.audio-seek-clicked(root.message-id, fraction); }
                    album-cell-clicked(key) => { root.album-cell-clicked(key); }
                    show-history-clicked => { root.show-history(root.message-id); }
                    context-menu-requested(ax, ay) => {
                        // Same gate as the hover toolbar: confirmed rows only,
                        // and never on a retracted tombstone.
                        if (root.message-id != "" && !root.pending && !root.failed && !root.deleted) {
                            root.request-context-menu(root.message-id, root.text, @tr("You"), root.can-edit, ax, ay);
                        }
                    }
                    body-clicked => { if (root.effect-id > 0) { root.fire-effect(); } }
                }

                acts := HoverActions {
                    x: root.align-right ? -(self.width + 6px) : (bubble.width + 6px);
                    y: (parent.height - self.height) / 2;
                    message-id: root.message-id;
                    reply-preview-text: root.text;
                    reply-author: @tr("You");
                    can-edit: root.can-edit;
                    visible: root.message-id != "" && !root.pending && !root.failed && !root.deleted
                        && (hover.has-hover || self.hovered);
                    opacity: (hover.has-hover || self.hovered) ? 1.0 : 0.0;
                    animate opacity { duration: 100ms; }
                    request-picker(id, ax, ay) => { root.request-picker(id, ax, ay); }
                    request-reply(id, preview, author) => { root.request-reply(id, preview, author); }
                    request-edit(id, current) => { root.request-edit(id, current); }
                }
            }

            if root.message-id != "" && !root.pending && !root.failed && root.reactions.length > 0 : ReactionChips {
                message-id: root.message-id;
                reactions: root.reactions;
                align-right: root.align-right;
                react(id, emoji) => { root.react(id, emoji); }
                unreact(id) => { root.unreact(id); }
            }
        }

        if root.align-right && root.show-avatar : TouchArea {
            width: 28px;
            height: 28px;
            mouse-cursor: pointer;
            clicked => { if (root.sender-id != "") { ProfileSink.open(root.sender-id); } }
            Avatar {
                size: 28px;
                y: 0;
                initials: root.av-initials;
                color-a: root.av-a;
                color-b: root.av-b;
                picture: root.av-picture;
                has-picture: root.av-has-picture;
                font-size: Theme.fs(9px, 14px);
            }
        }
        if root.align-right && !root.show-avatar : Rectangle { width: 28px; }

        if !root.align-right : Rectangle { horizontal-stretch: 1; }
    }
}
