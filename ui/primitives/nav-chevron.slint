import { Palette, Theme } from "../tokens.slint";

// Nav chevron for the image lightbox slideshow: a 48×48 ghost button that
// brightens on hover. Sits on `overlay-strong`, so colors come from the
// media-ghost token tier. The call site positions it (left/right edge) and
// passes the glyph + clicked callback.
export component NavChevron inherits Rectangle {
    in property <string> glyph;
    // Screen-reader name for this chevron ("Previous image" / "Next image").
    // The glyph carries no text, so without this the control is unnamed to
    // assistive tech; every call site must set it.
    in property <string> label;
    callback clicked;

    width: 48px;
    height: 48px;
    border-radius: (24px) * Theme.r-scale;
    background: chevron-touch.has-hover ? Palette.media-ghost-bg-hover : Palette.media-ghost-bg;
    animate background { duration: Theme.hover-dur; }
    border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
    border-color: Palette.border-2;
    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => {
        root.clicked();
    }

    Text {
        text: root.glyph;
        color: Palette.media-chip-fg;
        font-size: Theme.fs(34px, 40px);
        font-family: Theme.font;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    chevron-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}
