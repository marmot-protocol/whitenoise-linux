import { Palette, Theme, MessageLine, EmojiSheet, Linkout, AlbumCell } from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { SketchOutline } from "sketch-outline.slint";
import { Tooltip } from "tooltip.slint";

// One inline run inside a wrapped chat line. The Text element is always
// instantiated (empty string when emoji) so the wrapper can bind to its
// `preferred-width` — a Rectangle that only conditionally hosts children
// reports zero preferred-width to its parent HorizontalLayout and all runs
// collapse onto each other.
component RunCell inherits Rectangle {
    in property <bool> is-emoji;
    in property <string> text;
    in property <int> clip-x;
    in property <int> clip-y;
    in property <length> body-fs;
    in property <length> emoji-px;
    in property <color> fg;
    // Inline Markdown styling, resolved per-run by the Rust AST walker.
    in property <bool> bold;
    in property <bool> italic;
    in property <bool> strike;
    in property <bool> code;
    in property <string> link;
    // Per-line font scale (headings). 1.0 for body text.
    in property <float> scale: 1.0;
    in property <color> link-color;
    in property <color> code-bg;
    // iMessage inline text effects, packed as a bitmask (see MessageRun.fx) so
    // any effects stack on one glyph. Slint has no bitwise ops, so each bit is
    // decoded with mod(floor(fx / 2^n), 2). `phase` is the per-letter index
    // along a span (Ripple's travelling crest, Jitter's decorrelation).
    in property <int> fx: 0;
    in property <float> phase: 0;
    property <bool> f-big:     mod(floor(root.fx / 1), 2) == 1;
    property <bool> f-small:   mod(floor(root.fx / 2), 2) == 1;
    property <bool> f-explode: mod(floor(root.fx / 4), 2) == 1;
    property <bool> f-bloom:   mod(floor(root.fx / 8), 2) == 1;
    property <bool> f-shake:   mod(floor(root.fx / 16), 2) == 1;
    property <bool> f-nod:     mod(floor(root.fx / 32), 2) == 1;
    property <bool> f-ripple:  mod(floor(root.fx / 64), 2) == 1;
    property <bool> f-jitter:  mod(floor(root.fx / 128), 2) == 1;

    // Big/Small are a persistent size; everything else animates on a continuous
    // burst-then-rest loop. animation-tick() is read only when something
    // animates, so static cells (and plain text) never repaint. `tsec` is
    // elapsed seconds.
    property <bool> animated: root.f-explode || root.f-bloom || root.f-shake || root.f-nod || root.f-ripple || root.f-jitter;
    property <float> tsec: root.animated ? animation-tick() / 1s : 0;
    property <length> amp: root.body-fs * root.scale;

    property <float> shake-l: mod(root.tsec, 1.6);
    property <float> nod-l: mod(root.tsec, 1.7);

    // Explode cycle: a readable HOLD (1.3s, text sits still and fully visible),
    // then the BURST (0.7s, every glyph flings off on its own ballistic arc and
    // fades out fast), then a short gap before fading back in for the next hold.
    // `ep` is the burst progress (0 throughout the hold). `vx`/`vy` are
    // per-glyph launch velocities seeded from `phase` so the letters scatter in
    // different directions instead of moving as a block.
    property <float> explode-l: mod(root.tsec, 2.4);
    property <float> ep: clamp((root.explode-l - 1.3) / 0.7, 0, 1);
    property <float> vx: sin(root.phase * 6.3 * 1turn) + 0.4 * sin((root.phase * 2.1 + 1.0) * 1turn);
    property <float> vy: 1.0 + 0.45 * sin(root.phase * 3.7 * 1turn);

    // Bloom: a "rolling bold" — a sharp crest travels letter-to-letter (offset
    // by per-glyph `phase`), thickening each glyph to bold as it passes.
    property <float> bloom-w: max(sin((root.tsec * 0.85 - root.phase * 0.85) * 1turn), 0);
    property <float> bloom-b: root.bloom-w * root.bloom-w * root.bloom-w;

    // Per-effect transforms, composed below. Each is gated by its flag when
    // summed, so unused ones contribute nothing.
    property <length> exp-dx: root.amp * 2.6 * root.vx * root.ep;
    property <length> exp-dy: root.amp * (-3.2 * root.vy * root.ep + 9.0 * root.ep * root.ep);
    property <length> shake-dx: root.amp * 0.10 * (root.shake-l < 0.6 ? sin(root.shake-l / 0.6 * 0.5turn) : 0) * sin(root.shake-l / 0.6 * 6 * 1turn);
    property <length> nod-dy: root.amp * 0.22 * (root.nod-l < 0.9 ? sin(root.nod-l / 0.9 * 1turn) : 0);
    property <length> ripple-dy: root.amp * 0.5 * sin((root.tsec * 1.0 - root.phase * 0.8) * 1turn);
    property <length> jitter-dx: root.amp * 0.05 * sin((root.tsec * 6 + root.phase * 5) * 1turn);
    property <length> jitter-dy: root.amp * 0.05 * cos((root.tsec * 7.5 + root.phase * 7) * 1turn);

    // Compose all active effects. Size effects multiply onto `base-sz`; motion
    // effects (and explode's arc) sum onto the offset.
    property <float> base-sz: root.f-big ? 1.5 : (root.f-small ? 0.72 : 1.0);
    // The animated scale multiplier — kept separate from base-sz so the layout
    // box reserves the persistent (Big/Small) size and the explode/bloom scale
    // overflows it instead of reflowing the line.
    property <float> anim-sz:
        (root.f-explode ? (1 - 0.25 * root.ep) : 1.0)
        * (root.f-bloom ? (1 + 0.16 * root.bloom-b) : 1.0);
    property <float> sz: root.base-sz * root.anim-sz;
    // During the hold the glyph is solid (with a quick fade-in at the very
    // start); during the burst it fades out fast (gone by ~40% of the arc, so
    // no half-faded letters drift across the bubble), and stays gone until the
    // next hold.
    property <float> fx-opacity:
        root.f-explode
            ? (root.explode-l < 1.3 ? clamp(root.explode-l / 0.25, 0, 1) : clamp(1 - root.ep * 1.6, 0, 1))
            : 1.0;
    property <length> dx:
        (root.f-explode ? root.exp-dx : 0px)
        + (root.f-shake ? root.shake-dx : 0px)
        + (root.f-jitter ? root.jitter-dx : 0px);
    property <length> dy:
        (root.f-explode ? root.exp-dy : 0px)
        + (root.f-nod ? root.nod-dy : 0px)
        + (root.f-ripple ? root.ripple-dy : 0px)
        + (root.f-jitter ? root.jitter-dy : 0px);

    property <bool> is-link: root.link != "";
    // Layout size. The box reserves the persistent Big/Small size (so the line
    // reflows for those, like iMessage); the animated explode/bloom scale is
    // divided back out so it overflows the box (centered, below) without
    // reflowing the line frame to frame.
    property <length> em-px: root.emoji-px * root.scale * root.base-sz;
    horizontal-stretch: 0;
    width: root.is-emoji ? root.em-px : t.preferred-width / max(root.anim-sz, 0.01);
    height: root.is-emoji ? root.em-px : t.preferred-height / max(root.anim-sz, 0.01);

    // Inline-code plate — flush to the cell so adjacent code runs read as one
    // continuous span.
    if root.code && !root.is-emoji : Rectangle {
        width: 100%;
        height: 100%;
        background: root.code-bg;
        border-radius: (2px) * Theme.r-scale;
    }

    t := Text {
        // Centre the glyph in its (base-sized) cell so an animated scale grows
        // symmetrically and overflows instead of pushing neighbours; for static
        // cells the cell already equals preferred size, so the term is 0.
        x: root.dx + (root.width - self.preferred-width) / 2;
        y: root.dy + (root.height - self.preferred-height) / 2;
        text: root.is-emoji ? "" : root.text;
        color: root.is-link ? root.link-color : root.fg;
        font-size: root.body-fs * root.scale * root.sz;
        font-family: Theme.font;
        // Bloom rolls a bold crest across the glyphs; otherwise plain weight.
        font-weight: (root.f-bloom && root.bloom-b > 0.3) ? 700 : (root.bold ? 700 : 400);
        font-italic: root.italic;
        opacity: root.fx-opacity;
        visible: !root.is-emoji;
    }

    if root.is-emoji : Image {
        x: root.dx + (root.width - self.width) / 2;
        y: root.dy + (root.height - self.height) / 2;
        width: root.emoji-px * root.scale * root.sz;
        height: root.emoji-px * root.scale * root.sz;
        opacity: root.fx-opacity;
        source: EmojiSheet.sprite;
        source-clip-x: root.clip-x;
        source-clip-y: root.clip-y;
        source-clip-width: EmojiSheet.tile;
        source-clip-height: EmojiSheet.tile;
        image-fit: contain;
    }

    // Strikethrough — Slint's Text has no strike property, so overlay a rule
    // across the cell's mid-line.
    if root.strike && !root.is-emoji : Rectangle {
        y: parent.height / 2;
        width: 100%;
        height: 1px;
        background: root.is-link ? root.link-color : root.fg;
    }
    // Link underline.
    if root.is-link && !root.is-emoji : Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: root.link-color;
    }

    // Always mounted (never `if`-gated) and disabled for non-link runs so it
    // doesn't intercept hover/clicks meant for the bubble's hover sensor.
    TouchArea {
        enabled: root.is-link;
        mouse-cursor: root.is-link ? pointer : default;
        clicked => { Linkout.open(root.link); }
    }
}

export component MessageBubble inherits Rectangle {
    in property <string> message;
    // Pre-tokenized + pre-wrapped body, one MessageLine per visual line.
    // The body renders as a VerticalLayout-of-HorizontalLayouts so each
    // Text cell is sized by Slint's real text metrics (no width estimation
    // in Rust — that produced huge inter-word gaps). Empty falls back to
    // a plain `Text` so synthetic / programmatic uses still work.
    in property <[MessageLine]> lines;
    in property <string> stamp;
    // Full localized date+time for the stamp's hover tooltip; empty hides it.
    in property <string> stamp-full;
    in property <bool> outgoing: false;
    // Which screen edge the bubble hugs. Outgoing bubbles can be placed on the
    // left (when "own messages on the right" is off), so the tail + tight corner
    // must follow the actual alignment, not the outgoing flag. Incoming always
    // hugs the left (avatar side).
    in property <bool> align-right: true;
    property <bool> hug-right: root.outgoing && root.align-right;
    in property <length> max-w: 640px;
    in property <length> min-w: 56px;
    in property <length> available-w: 9999px;
    // Optimistic-send states. `pending` = inserted locally, waiting on relay
    // ack; `failed` = the send raised an error and the row sits in retry state.
    in property <bool> pending: false;
    in property <bool> failed: false;
    // Quoted-parent preview. Empty `reply-to-id` => not a reply, no block.
    in property <string> reply-to-id;
    in property <string> reply-to-text;
    in property <string> reply-to-author;
    in property <image> reply-to-image;
    in property <bool> reply-to-has-image: false;
    // Attachment block — rendered when has-attachment is true. Tapping the
    // chip (or the image placeholder) fires attachment-clicked(); for images
    // this kicks off decrypt+decode; for files it opens a save dialog.
    in property <bool> has-attachment: false;
    in property <string> att-name;
    in property <string> att-mime;
    in property <string> att-size-label;
    in property <bool> att-is-image: false;
    // Video attachment: poster tile + ▶ overlay, opens the in-app libmpv viewer.
    in property <bool> att-is-video: false;
    in property <bool> att-is-audio: false;
    in property <bool> att-audio-playing: false;
    in property <float> att-audio-progress: 0.0;
    in property <string> att-duration;
    in property <image> att-image;
    in property <bool> att-has-image: false;
    in property <bool> att-loading: false;
    in property <bool> att-failed: false;
    // Album block — 2+ images sent together, rendered as an aspect-aware grid
    // (rects precomputed in Rust). Tapping a cell fires album-cell-clicked(key)
    // which opens the lightbox slideshow at that image.
    in property <[AlbumCell]> album: [];
    in property <length> album-w;
    in property <length> album-h;
    callback album-cell-clicked(string);
    // Edit state. When `edited` is true an "(edited)" affordance renders next
    // to the timestamp; tapping it asks the root to open the history modal.
    in property <bool> edited: false;
    in property <int> edit-count: 0;
    // Retracted ("delete for everyone"): drop the body/attachments/reactions
    // and render a muted italic tombstone, keeping only the timestamp.
    in property <bool> deleted: false;
    // Visual grouping. `first-in-group` controls whether the top corner on the
    // avatar side is rounded (group head) or tightened (continuation). A
    // standalone bubble is the head, so it defaults true.
    in property <bool> first-in-group: true;
    in property <bool> last-in-group: true;
    // Emoji-only message: drop the bubble chrome, render the glyphs large, and
    // float the timestamp pill on hover (Telegram-style). The `lines` model is
    // unchanged — only the per-emoji size and the surrounding chrome differ.
    in property <bool> jumbo-emoji: false;
    // Message-effect indicator: when `effect-id > 0` a small emoji chip in the
    // top-corner shows which effect this bubble carries (and that tapping it
    // replays). `effect-clip-x/y` index the emoji in the shared Twemoji sheet.
    in property <int> effect-id: 0;
    in property <int> effect-clip-x: 0;
    in property <int> effect-clip-y: 0;
    // True while the pointer is anywhere over the bubble. Read by the row to
    // reveal the floating action toolbar. Sourced from a bottom-most sensor so
    // it never steals taps from the attachment / retry areas above it.
    out property <bool> hovered: hover-sensor.has-hover;
    callback retry-clicked();
    callback attachment-clicked();
    callback audio-play-clicked();
    callback audio-seek-clicked(float);
    callback show-history-clicked();
    // Plain background tap — the row uses it to replay the message effect.
    callback body-clicked();
    // Right-click anywhere on the bubble — reports window-absolute pointer
    // coords so the row can anchor a context menu there.
    callback context-menu-requested(length, length);

    property <length> pad-h: 14px;
    property <length> pad-v: 10px;
    property <length> gap: 12px;
    property <length> effective-max: min(root.max-w, root.available-w);
    property <length> text-budget: max(40px, root.effective-max - root.pad-h * 2 - root.gap - meta.preferred-width);
    // Body typography. Emoji glyphs are sized off `body-fs` so they ride
    // the text line cleanly.
    property <length> body-fs: (13px) * Theme.fs-scale;
    property <length> emoji-px: root.jumbo-emoji ? (66px) * Theme.fs-scale : root.body-fs * 1.2;

    property <float> enter: 0;
    init => { self.enter = 1; }
    animate enter { duration: Theme.motion-fast ? 120ms : 220ms; easing: ease-out; }
    // Retro send pop: bubble starts slightly smaller/higher, snaps to full size.
    property <float> pop-scale: Theme.bubble-bounce ? (0.90 + root.enter * 0.10) : 1.0;
    property <length> pop-y: Theme.bubble-bounce ? (1.0 - root.enter) * -6px : 0px;
    animate pop-scale, pop-y { duration: Theme.bubble-bounce ? 120ms : 0ms; easing: ease-out; }

    // Sketch (hand-drawn) bubbles round the body more, but keep the tail-side
    // corner nearly square so the speech tail meets a straight edge (a rounded
    // corner there leaves a gap and the tail reads as a detached spike).
    property <length> r-lg: (Theme.sketch-bubbles ? 13px : 16px) * Theme.r-scale;
    property <length> r-sm: (Theme.sketch-bubbles ? 3px : 5px) * Theme.r-scale;

    // Outgoing bubbles get a vertical mint gradient for a bit of depth; retro
    // stays flat for the pixel aesthetic. Incoming stays on the flat surface.
    // Sketch bubbles paint their fill + outline as a hand-drawn path
    // (SketchOutline, mounted below), so the rectangle itself stays transparent.
    background: (root.jumbo-emoji || Theme.sketch-bubbles)
        ? transparent
        : (root.outgoing
            // Retro bubbles use a flat fill; modern themes get a subtle vertical
            // accent gradient for depth.
            ? (Theme.retro
                ? Palette.mint
                : @linear-gradient(180deg, Palette.mint-hi 0%, Palette.mint 92%))
            : Palette.bubble-in);
    // Chat-style asymmetric corners. The tail corner (bottom, avatar side)
    // stays tight; within a group the top corner on the avatar side also
    // tightens so consecutive bubbles read as one stacked column.
    // Sketch bubbles square the TOP hug-side corner (where the up-pointing tail
    // attaches) and round the other three; standard bubbles keep the chat
    // asymmetric-corner grouping (tight bottom tail corner + continuation tuck).
    border-top-left-radius: Theme.sketch-bubbles
        ? (root.hug-right ? root.r-lg : root.r-sm)
        : (root.hug-right ? root.r-lg : (root.first-in-group ? root.r-lg : root.r-sm));
    border-top-right-radius: Theme.sketch-bubbles
        ? (root.hug-right ? root.r-sm : root.r-lg)
        : (root.hug-right ? (root.first-in-group ? root.r-lg : root.r-sm) : root.r-lg);
    border-bottom-left-radius: Theme.sketch-bubbles ? root.r-lg : (root.hug-right ? root.r-lg : root.r-sm);
    border-bottom-right-radius: Theme.sketch-bubbles ? root.r-lg : (root.hug-right ? root.r-sm : root.r-lg);
    border-width: (root.jumbo-emoji || Theme.sketch-bubbles) ? 0px : (root.failed ? 1.5px : Theme.border-w);
    // Sketch bubbles get a dark "ink" outline on BOTH sides (outgoing included,
    // which is borderless in modern themes) — the comic/hand-drawn signature.
    // text-hi is the page's pencil-ink colour, so outlines match the body text.
    border-color: root.failed
        ? Palette.danger-on-bubble
        : (Theme.sketch-bubbles
            ? Palette.text-hi
            : (root.outgoing ? transparent : Palette.border-2));
    // Sketch bubbles stay shadowless — the ink outline defines the edge; a soft
    // blur underneath just muddies the flat hand-drawn look.
    drop-shadow-color: (root.jumbo-emoji || Theme.sketch-bubbles)
        ? transparent
        : (Theme.hard-shadow
            ? Palette.shadow
            : (root.outgoing ? Palette.mint-glow : (Theme.light ? #00000018 : #00000050)));
    drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : (root.outgoing ? 3px : 2px);
    drop-shadow-blur: root.jumbo-emoji ? 0px : (Theme.hard-shadow ? 0px : (root.outgoing ? 14px : 8px));
    y: root.pop-y;
    width: (root.jumbo-emoji ? layout.preferred-width : max(root.min-w, layout.preferred-width)) * root.pop-scale;
    height: layout.preferred-height * root.pop-scale;
    opacity: root.pending ? root.enter * 0.62 : root.enter;
    animate opacity { duration: 180ms; easing: ease-out; }

    // Hand-drawn fill + ink outline for sketch bubbles, painted behind the
    // content (the rectangle's own background/border are transparent in sketch
    // mode). Tracks the bubble's runtime size so it reflows with the content.
    if Theme.sketch-bubbles && !root.jumbo-emoji : SketchOutline {
        x: 0;
        y: 0;
        w: root.width;
        h: root.height;
        radius: root.r-lg;
        fill: root.outgoing ? Palette.mint : Palette.bubble-in;
        ink: root.failed ? Palette.danger-on-bubble : Palette.text-hi;
        // Tail on the first bubble of a group, curling toward the avatar: top-left
        // normally, top-right when own messages are placed on the right.
        tail: root.first-in-group ? (root.hug-right ? 2 : 1) : 0;
    }

    // Bottom-most hover sensor. No click handler, so taps fall through to the
    // attachment / retry areas declared above it; it reports `has-hover` so
    // the row can float its action toolbar, and right-clicks so the row can
    // open the context menu.
    hover-sensor := TouchArea {
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.context-menu-requested(
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
        // A plain background tap (not on a link / attachment / album cell /
        // edited badge / retry, which sit on top) replays the message effect.
        clicked => { root.body-clicked(); }
    }

    if root.failed : TouchArea {
        clicked => { root.retry-clicked(); }
    }

    layout := VerticalLayout {
        padding-left: root.jumbo-emoji ? 0px : root.pad-h;
        padding-right: root.jumbo-emoji ? 0px : root.pad-h;
        padding-top: root.jumbo-emoji ? 0px : root.pad-v;
        padding-bottom: root.jumbo-emoji ? 0px : root.pad-v;
        spacing: 6px;
        alignment: stretch;

        // Quoted parent — a recessed plate inside the bubble with an accent
        // bar on the left. For outgoing (mint) bubbles the accent is dark so
        // it actually shows up; for incoming (dark) bubbles it's mint.
        if root.reply-to-id != "" && !root.deleted : Rectangle {
            background: root.outgoing ? #00000018 : (Theme.light ? #F8FAFC : #ffffff0c);
            border-radius: (3px) * Theme.r-scale;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px;
                padding-top: 5px; padding-bottom: 5px;
                spacing: 7px;
                Rectangle {
                    width: 2.5px;
                    background: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                    border-radius: 1.25px;
                }
                VerticalLayout {
                    spacing: 1px;
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: root.reply-to-author == "" ? @tr("Original message") : root.reply-to-author;
                        color: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                        font-size: (10px) * Theme.fs-scale;
                        font-family: Theme.font;
                        font-weight: 700;
                        overflow: elide;
                        opacity: root.outgoing ? 0.85 : 1.0;
                        width: max(40px, root.text-budget - 18px - (root.reply-to-has-image ? 41px : 0px));
                    }
                    Text {
                        text: root.reply-to-text == "" ? @tr("(message unavailable)") : root.reply-to-text;
                        color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                        font-size: (11px) * Theme.fs-scale;
                        font-family: Theme.font;
                        overflow: elide;
                        opacity: root.outgoing ? 0.65 : 0.9;
                        width: max(40px, root.text-budget - 18px - (root.reply-to-has-image ? 41px : 0px));
                    }
                }
                // Signal-style media thumbnail of the quoted parent, at the
                // right edge of the plate.
                if root.reply-to-has-image : Rectangle {
                    width: 34px;
                    height: 34px;
                    border-radius: (4px) * Theme.r-scale;
                    clip: true;
                    Image {
                        source: root.reply-to-image;
                        width: parent.width;
                        height: parent.height;
                        image-fit: cover;
                    }
                }
            }
        }

        // Album grid. Each cell's rect is precomputed in Rust; we absolute-
        // position a clipped image (or a subtle placeholder until it decodes).
        if root.album.length > 0 && !root.deleted : Rectangle {
            width: root.album-w;
            height: root.album-h;
            for cell[i] in root.album : Rectangle {
                x: cell.x;
                y: cell.y;
                width: cell.w;
                height: cell.h;
                border-radius: (6px) * Theme.r-scale;
                background: root.outgoing ? #00000022 : (Theme.light ? #E2E8F0 : #ffffff10);
                clip: true;
                border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
                border-color: Palette.border-2;
                if cell.has-image : Image {
                    width: parent.width;
                    height: parent.height;
                    source: cell.image;
                    image-fit: cover;
                }
                if !cell.has-image : Text {
                    text: cell.loading ? "…" : "🖼";
                    color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                    font-size: (22px) * Theme.fs-scale;
                    font-family: Theme.font;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    opacity: 0.7;
                }
                TouchArea {
                    enabled: !cell.loading;
                    mouse-cursor: pointer;
                    clicked => { root.album-cell-clicked(cell.key); }
                }
            }
        }

        // Attachment block. Image attachments render as a tappable preview
        // tile (placeholder until decoded); other files render as a chip with
        // filename + size. Both fire `attachment-clicked` on tap.
        // Video attachment — poster frame (decoded first frame or imeta thumb)
        // with a ▶ play badge + optional duration. Tap opens the in-app viewer.
        if root.has-attachment && root.att-is-video && !root.deleted : vid-tile := Rectangle {
            property <length> vid-w: min(280px, max(120px, root.text-budget));
            width: self.vid-w;
            height: 180px;
            border-radius: (8px) * Theme.r-scale;
            background: root.outgoing ? #00000033 : (Theme.light ? #1E293B : #00000044);
            clip: true;
            border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
            border-color: Palette.border-2;
            if root.att-has-image : Image {
                width: parent.width;
                height: parent.height;
                source: root.att-image;
                image-fit: cover;
            }
            // Play badge (always shown over the poster / placeholder).
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: (28px) * Theme.r-scale;
                background: #00000099;
                border-width: Theme.border-w;
                border-color: #FFFFFFCC;
                Text {
                    // Nudge the glyph optically-center inside the circle.
                    x: parent.width / 2 - self.width / 2 + 3px;
                    text: root.att-loading ? "…" : (root.att-failed ? "!" : "▶");
                    color: #FFFFFF;
                    font-size: (24px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            // Duration badge, bottom-right.
            if root.att-duration != "" : Rectangle {
                x: parent.width - self.width - 6px;
                y: parent.height - self.height - 6px;
                width: dur-text.preferred-width + 12px;
                height: 18px;
                border-radius: (4px) * Theme.r-scale;
                background: #000000AA;
                dur-text := Text {
                    text: root.att-duration;
                    color: #FFFFFF;
                    font-size: (10px) * Theme.fs-scale;
                    font-family: Theme.font;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            TouchArea {
                enabled: !root.att-loading;
                mouse-cursor: pointer;
                clicked => { root.attachment-clicked(); }
            }
        }

        // Audio attachment — inline player: play/pause, filename, scrubber,
        // size + duration. Height tracks the row's content so the bubble only
        // grows the extra rows when there's a filename to show.
        if root.has-attachment && root.att-is-audio && !root.deleted : aud := Rectangle {
            property <length> audio-w: min(280px, max(180px, root.text-budget));
            // Width left for the text column: player width minus padding,
            // play button, and inter-column spacing (10 + 36 + 10 + 12).
            property <length> col-w: max(40px, self.audio-w - 68px);
            width: self.audio-w;
            height: aud-row.preferred-height;
            border-radius: (8px) * Theme.r-scale;
            background: root.outgoing ? #00000022 : (Theme.light ? #E2E8F0 : #ffffff10);
            border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
            border-color: Palette.border-2;

            aud-row := HorizontalLayout {
                padding-left: 10px;
                padding-right: 12px;
                padding-top: 9px;
                padding-bottom: 9px;
                spacing: 10px;
                alignment: stretch;

                // Play / pause button. Fixed size, so the HorizontalLayout
                // centers it vertically on the cross axis automatically — an
                // explicit `y` here would take it out of the layout flow.
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: (18px) * Theme.r-scale;
                    background: play-touch.has-hover
                        ? (root.outgoing ? Palette.text-hi : Palette.mint-hi)
                        : (root.outgoing ? Palette.bubble-out-fg : Palette.mint);
                    animate background { duration: 100ms; }
                    Text {
                        x: parent.width / 2 - self.width / 2
                            + (root.att-audio-playing || root.att-loading || root.att-failed ? 0px : 2px);
                        // Loading → ellipsis, failed → retry, else play/pause.
                        text: root.att-loading ? "…"
                            : (root.att-failed ? "↻"
                                : (root.att-audio-playing ? "⏸" : "▶"));
                        color: root.outgoing ? Palette.mint : Palette.bg;
                        font-size: (14px) * Theme.fs-scale;
                        font-family: Theme.font;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    play-touch := TouchArea {
                        enabled: !root.att-loading;
                        mouse-cursor: pointer;
                        clicked => { root.audio-play-clicked(); }
                    }
                }

                // Text column. `horizontal-stretch` makes it absorb the
                // remaining player width; setting `y` would detach it from that
                // flow and collapse the children to their preferred sizes.
                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    alignment: center;

                    // Filename — only when the attachment carries one.
                    if root.att-name != "" : Text {
                        text: root.att-name;
                        width: aud.col-w;
                        overflow: elide;
                        color: root.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                        font-size: (11px) * Theme.fs-scale;
                        font-family: Theme.font;
                        font-weight: 600;
                    }

                    // Scrubber. The visible track is 5px, but a taller
                    // transparent wrapper hosts the seek TouchArea so the hit
                    // target is comfortable.
                    Rectangle {
                        height: 16px;
                        bar-bg := Rectangle {
                            y: (parent.height - self.height) / 2;
                            width: 100%;
                            height: 5px;
                            border-radius: 2.5px * Theme.r-scale;
                            background: root.outgoing ? #00000022 : (Theme.light ? #CBD5E1 : #00000044);
                            Rectangle {
                                x: 0;
                                width: parent.width * clamp(root.att-audio-progress, 0.0, 1.0);
                                height: 100%;
                                border-radius: 2.5px * Theme.r-scale;
                                background: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                            }
                        }
                        seek-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.audio-seek-clicked(self.mouse-x / self.width); }
                        }
                    }

                    // Meta row: size on the left, elapsed/total on the right.
                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: root.att-failed ? @tr("failed · tap to retry") : root.att-size-label;
                            horizontal-stretch: 1;
                            overflow: elide;
                            color: root.att-failed
                                ? (root.outgoing ? Palette.danger-on-bubble : Palette.danger)
                                : (root.outgoing ? Palette.bubble-out-fg : Palette.text-mid);
                            font-size: (10px) * Theme.fs-scale;
                            font-family: Theme.font;
                            opacity: root.att-failed ? 1.0 : (root.outgoing ? 0.75 : 0.9);
                        }
                        Text {
                            text: root.att-duration;
                            color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                            font-size: (10px) * Theme.fs-scale;
                            font-family: Theme.font;
                            horizontal-alignment: right;
                        }
                    }
                }
            }
        }

        if root.has-attachment && root.att-is-image && !root.deleted : img-tile := Rectangle {
            property <length> img-w: min(280px, max(120px, root.text-budget));
            property <length> img-h: 180px;
            width: self.img-w;
            height: self.img-h;
            border-radius: (8px) * Theme.r-scale;
            background: root.outgoing ? #00000022 : (Theme.light ? #E2E8F0 : #ffffff10);
            clip: true;
            border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
            border-color: Palette.border-2;
            if root.att-has-image : Image {
                width: parent.width;
                height: parent.height;
                source: root.att-image;
                image-fit: cover;
            }
            if !root.att-has-image : VerticalLayout {
                alignment: center;
                spacing: 4px;
                Text {
                    text: root.att-loading ? "…" : (root.att-failed ? "!" : "🖼");
                    color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                    font-size: (28px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.att-loading
                        ? @tr("decrypting…")
                        : (root.att-failed
                            ? @tr("tap to retry")
                            : @tr("tap to load"));
                    color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                    font-size: (10px) * Theme.fs-scale;
                    font-family: Theme.font;
                    horizontal-alignment: center;
                    opacity: 0.85;
                }
            }
            TouchArea {
                enabled: !root.att-loading;
                clicked => { root.attachment-clicked(); }
            }
        }

        if root.has-attachment && !root.att-is-image && !root.att-is-video && !root.att-is-audio && !root.deleted : Rectangle {
            background: root.outgoing ? #00000022 : (Theme.light ? #F1F5F9 : #ffffff0e);
            border-radius: (6px) * Theme.r-scale;
            border-width: Theme.outline-surfaces ? Theme.border-w : 0px;
            border-color: Palette.border-2;
            height: chip-l.preferred-height;
            chip-l := HorizontalLayout {
                padding-left: 10px; padding-right: 10px;
                padding-top: 8px; padding-bottom: 8px;
                spacing: 10px;
                alignment: stretch;
                Text {
                    text: root.att-loading ? "…" : "📎";
                    color: root.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                    font-size: (16px) * Theme.fs-scale;
                    font-family: Theme.font;
                    vertical-alignment: center;
                }
                VerticalLayout {
                    spacing: 1px;
                    horizontal-stretch: 1;
                    Text {
                        text: root.att-name;
                        color: root.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                        font-size: (12px) * Theme.fs-scale;
                        font-family: Theme.font;
                        font-weight: 600;
                        overflow: elide;
                        width: max(40px, root.text-budget - 32px);
                    }
                    Text {
                        text: root.att-failed
                            ? @tr("failed · tap to retry")
                            : (root.att-size-label != "" && root.att-mime != ""
                                ? root.att-size-label + "  ·  " + root.att-mime
                                : root.att-size-label + root.att-mime);
                        color: root.att-failed
                            ? (root.outgoing ? Palette.danger-on-bubble : Palette.danger)
                            : (root.outgoing ? Palette.bubble-out-fg : Palette.text-mid);
                        font-size: (10px) * Theme.fs-scale;
                        font-family: Theme.font;
                        opacity: root.att-failed ? 1.0 : (root.outgoing ? 0.75 : 0.9);
                        overflow: elide;
                        width: max(40px, root.text-budget - 32px);
                    }
                }
            }
            TouchArea {
                enabled: !root.att-loading;
                clicked => { root.attachment-clicked(); }
            }
        }

        HorizontalLayout {
        spacing: root.jumbo-emoji ? 0px : root.gap;
        alignment: stretch;

        // Runs renderer — one HorizontalLayout per line of pre-wrapped runs.
        // Slint sizes Text cells from real font metrics (no Rust-side
        // estimation), so spacing matches what a plain `Text` would render.
        // Empty `lines` falls back to a plain `Text` so synthetic / legacy
        // paths still render.
        // Retraction tombstone — replaces the body (and all the blocks gated
        // off above) with a muted italic placeholder. The timestamp in `meta`
        // still renders so the deleted row keeps its place in the timeline.
        if root.deleted : Text {
            text: @tr("This message was deleted");
            color: root.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
            font-size: root.body-fs;
            font-family: Theme.font;
            font-italic: true;
            opacity: root.outgoing ? 0.7 : 0.85;
            vertical-alignment: top;
            wrap: word-wrap;
            width: min(self.preferred-width, root.text-budget);
        }
        if root.lines.length > 0 && !root.deleted : VerticalLayout {
            spacing: 0;
            alignment: start;
            for line in root.lines : Rectangle {
                // Fenced/indented code lines get a subtle monospace plate that
                // hugs their content.
                background: line.code-block
                    ? (root.outgoing ? #00000022 : (Theme.light ? #0000000d : #ffffff10))
                    : transparent;
                border-radius: line.code-block ? (3px) * Theme.r-scale : 0;
                HorizontalLayout {
                    spacing: 0;
                    alignment: start;
                    // Blockquote accent bar.
                    if line.quote > 0 : Rectangle {
                        width: 2.5px;
                        background: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                        border-radius: 1.25px;
                    }
                    // List / blockquote nesting inset.
                    if line.indent > 0px : Rectangle { width: line.indent; }
                    // Thematic break — a horizontal divider, no runs.
                    if line.rule : Rectangle {
                        height: 11px;
                        width: root.text-budget;
                        Rectangle {
                            y: parent.height / 2;
                            width: 100%;
                            height: 1px;
                            opacity: 0.5;
                            background: root.outgoing ? Palette.bubble-out-fg : Palette.border-2;
                        }
                    }
                    if !line.rule : HorizontalLayout {
                        spacing: 0;
                        alignment: start;
                        for r in line.runs : RunCell {
                            is-emoji: r.is-emoji;
                            text: r.text;
                            clip-x: r.clip-x;
                            clip-y: r.clip-y;
                            body-fs: root.body-fs;
                            emoji-px: root.emoji-px;
                            scale: line.scale;
                            fg: root.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                            bold: r.bold;
                            italic: r.italic;
                            strike: r.strike;
                            code: r.code;
                            link: r.link;
                            fx: r.fx;
                            phase: r.phase;
                            link-color: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                            code-bg: root.outgoing ? #00000022 : (Theme.light ? #0000000d : #ffffff14);
                        }
                    }
                }
            }
        }
        if root.lines.length == 0 && !root.deleted : Text {
            text: root.message;
            color: root.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
            font-size: root.body-fs;
            font-family: Theme.font;
            vertical-alignment: top;
            wrap: Theme.char-wrap ? char-wrap : word-wrap;
            width: min(self.preferred-width, root.text-budget);
        }

        meta := VerticalLayout {
            alignment: end;
            // Hidden for jumbo emoji — the timestamp floats as a pill instead
            // (see `stamp-pill` below), so it doesn't reserve inline width.
            if !root.jumbo-emoji : HorizontalLayout {
                spacing: 4px;
                alignment: end;
                // "(edited)" affordance — opens the history modal on tap. Sits
                // before the timestamp so the stamp + check stay rightmost.
                if root.edited && !root.failed && !root.deleted : edited-rect := Rectangle {
                    height: edited-label.preferred-height;
                    width: edited-label.preferred-width;
                    y: parent.height - self.height;
                    edited-label := Text {
                        text: @tr("edited");
                        color: root.outgoing ? Palette.bubble-out-fg : Palette.mint;
                        font-size: (10px) * Theme.fs-scale;
                        font-family: Theme.font;
                        font-weight: 600;
                        vertical-alignment: bottom;
                        opacity: edited-touch.has-hover ? 1.0 : (root.outgoing ? 0.7 : 0.85);
                        animate opacity { duration: 100ms; }
                    }
                    edited-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.show-history-clicked(); }
                    }
                }
                stamp-rect := Rectangle {
                    height: stamp-label.preferred-height;
                    width: stamp-label.preferred-width;
                    y: parent.height - self.height;
                    stamp-label := Text {
                        text: root.failed ? @tr("failed · tap to retry") : root.stamp;
                        color: root.failed ? Palette.danger-on-bubble : (root.outgoing ? Palette.bubble-out-fg : Palette.text-lo);
                        font-size: (10px) * Theme.fs-scale;
                        font-family: Theme.font;
                        vertical-alignment: bottom;
                        opacity: root.outgoing && !root.failed ? 0.7 : 1;
                    }
                    // Hover sensor for the datetime tooltip. Sits above the
                    // whole-bubble TouchAreas, so it forwards clicks (retry /
                    // effect replay) and right-clicks (context menu) to keep
                    // the stamp region behaving exactly like the rest of the
                    // bubble — same reason `edited-touch` above swallows.
                    stamp-touch := TouchArea {
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                root.context-menu-requested(
                                    self.absolute-position.x + self.mouse-x,
                                    self.absolute-position.y + self.mouse-y);
                            }
                        }
                        clicked => {
                            if (root.failed) {
                                root.retry-clicked();
                            } else {
                                root.body-clicked();
                            }
                        }
                    }
                    // Floats above the stamp, right-aligned; the bubble root
                    // doesn't clip, so it can overflow into the previous row.
                    if stamp-touch.has-hover && !root.failed && root.stamp-full != "" : Tooltip {
                        x: parent.width - self.width;
                        y: -self.height - 6px;
                        label: root.stamp-full;
                        is-visible: true;
                    }
                }
                // Status indicator: confirmed = double check, pending = single
                // (lighter, animates), failed = "!" in red. Only on outgoing.
                if root.outgoing && !root.failed : CheckMark {
                    stroke: Palette.bubble-out-fg;
                    double: !root.pending;
                    opacity: root.pending ? 0.55 : 1.0;
                    animate opacity { duration: 180ms; }
                }
                if root.outgoing && root.failed : Text {
                    text: "!";
                    color: Palette.danger-on-bubble;
                    font-size: (11px) * Theme.fs-scale;
                    font-family: Theme.font;
                    vertical-alignment: bottom;
                }
            }
        }
        }
    }

    // Floating timestamp for jumbo-emoji messages. There's no bubble to host
    // the inline meta, so the stamp (+ outgoing status tick) rides a translucent
    // pill overlapping the bottom of the glyphs, revealed on hover — or kept up
    // while a send is pending/failed so state is never hidden. Anchored inside
    // the bubble bounds so it never overlaps the neighbouring row.
    if root.jumbo-emoji : Rectangle {
        x: parent.width - self.width;
        y: parent.height - self.height;
        height: pill-row.preferred-height;
        width: pill-row.preferred-width;
        background: #00000088;
        border-radius: (10px) * Theme.r-scale;
        opacity: (hover-sensor.has-hover || root.pending || root.failed) ? 1.0 : 0.0;
        animate opacity { duration: 120ms; easing: ease-out; }
        pill-row := HorizontalLayout {
            padding-left: 7px; padding-right: 7px;
            padding-top: 3px; padding-bottom: 3px;
            spacing: 4px;
            alignment: end;
            Text {
                text: root.failed ? @tr("failed · tap to retry") : root.stamp;
                color: root.failed ? Palette.danger-on-bubble : #FFFFFF;
                font-size: (10px) * Theme.fs-scale;
                font-family: Theme.font;
                vertical-alignment: center;
            }
            if root.outgoing && !root.failed : CheckMark {
                stroke: #FFFFFF;
                double: !root.pending;
                opacity: root.pending ? 0.55 : 1.0;
            }
        }
        // Datetime tooltip for the pill. The pill is always mounted (opacity-
        // gated), so this TouchArea covers its region even while invisible —
        // clicks and right-clicks are forwarded like `stamp-touch` above so
        // the jumbo glyph region keeps its retry/replay/context-menu behavior.
        pill-touch := TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    root.context-menu-requested(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y);
                }
            }
            clicked => {
                if (root.failed) {
                    root.retry-clicked();
                } else {
                    root.body-clicked();
                }
            }
        }
        if pill-touch.has-hover && !root.failed && root.stamp-full != "" : Tooltip {
            x: parent.width - self.width;
            y: -self.height - 6px;
            label: root.stamp-full;
            is-visible: true;
        }
    }

    // (The speech tail is part of the SketchOutline path above, so it's a single
    // connected, filled silhouette — see sketch-outline.slint.)

    // Message-effect indicator: a small emoji chip on the top-outer corner,
    // showing which effect this bubble carries (and hinting that a tap replays
    // it). Sits on the corner away from the tail; never clipped (the bubble root
    // doesn't clip).
    if root.effect-id > 0 : Rectangle {
        x: root.outgoing ? -7px : parent.width - self.width + 7px;
        y: -7px;
        width: 20px;
        height: 20px;
        border-radius: (10px) * Theme.r-scale;
        background: Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : #00000038;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 5px;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 2px : 1px;
        Image {
            width: 13px;
            height: 13px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: EmojiSheet.sprite;
            source-clip-x: root.effect-clip-x;
            source-clip-y: root.effect-clip-y;
            source-clip-width: EmojiSheet.tile;
            source-clip-height: EmojiSheet.tile;
        }
    }
}
