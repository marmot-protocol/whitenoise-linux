import {
    Palette,
    Theme,
    ChatMessage,
    EmojiSheet,
    Linkout,
    TextSelection,
} from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { SketchOutline } from "sketch-outline.slint";
import { Tooltip } from "tooltip.slint";
import { RunCell } from "message-bubble/run-cell.slint";
import { AlbumGrid } from "message-bubble/album-grid.slint";
import { VideoTile } from "message-bubble/video-tile.slint";
import { AudioTile } from "message-bubble/audio-tile.slint";
import { ImageTile } from "message-bubble/image-tile.slint";
import { FileChip } from "message-bubble/file-chip.slint";

export component MessageBubble inherits Rectangle {
    // The whole message — the body, stamp, reply/attachment/album blocks, and
    // state flags all read `root.msg.*` (see ChatMessage in tokens.slint for
    // per-field docs). Row context that is not carried on the message stays a
    // scalar property below.
    in property <ChatMessage> msg;
    in property <bool> highlighted: false;
    // Which screen edge the bubble hugs. Outgoing bubbles can be placed on the
    // left (when "own messages on the right" is off), so the tail + tight corner
    // must follow the actual alignment, not the outgoing flag. Incoming always
    // hugs the left (avatar side).
    in property <bool> align-right: true;
    property <bool> hug-right: root.msg.outgoing && root.align-right;
    in property <length> min-w: 56px;
    in property <length> available-w: 9999px;
    callback album-cell-clicked(string);
    // True while the pointer is anywhere over the bubble. Read by the row to
    // reveal the floating action toolbar. Sourced from a bottom-most sensor
    // (which never steals taps from the attachment / retry areas above it)
    // plus the text-selection area, which sits over the body lines and would
    // otherwise starve the sensor of hover while the pointer is on text.
    out property <bool> hovered: hover-sensor.has-hover || root.sel-hover;
    property <bool> sel-hover: false;

    // Multi-press chain on the body text: press 1 anchors a drag (release
    // without drag = plain click), press 2 selects the word under the pointer
    // and enters word mode (dragging then extends by whole words), press 3
    // selects the whole bubble. A press continues the chain when it lands
    // within 225ms of the previous press or release. The window is measured
    // by comparing `animation-tick()` timestamps rather than a `Timer`
    // element: a Timer with a `running: false` binding is never started, so
    // its `restart()` is a no-op and `running` never turns true.
    property <int> press-chain: 0;
    property <duration> now-tick: animation-tick();
    property <duration> last-press-tick: -1000ms;
    // Where the previous press landed (text-block space) — a chained press
    // must land nearby, like native double-click slop.
    property <length> last-press-x: -10000px;
    property <length> last-press-y: -10000px;

    callback retry-clicked();
    callback attachment-clicked();
    callback audio-play-clicked();
    callback audio-seek-clicked(float);
    callback show-history-clicked();
    // Plain background tap — the row uses it to replay the message effect.
    callback body-clicked();
    // Right-click anywhere on the bubble — reports window-absolute pointer
    // coords so the row can anchor a context menu there.
    callback context-menu-requested(length, length);

    property <length> pad-h: 14px;
    property <length> pad-v: 10px;
    property <length> gap: 12px;
    property <length> effective-max: min(root.msg.bubble-max, root.available-w);
    property <length> text-budget: max(40px, root.effective-max - root.pad-h * 2 - root.gap - meta.preferred-width);
    property <string> stamp-with-delivery:
        root.msg.failed ? @tr("failed · tap to retry") : root.msg.stamp;
    // Body typography. Emoji glyphs are sized off `body-fs` so they ride
    // the text line cleanly.
    property <length> body-fs: Theme.fs(13px, 16px);
    property <length> emoji-px: root.msg.jumbo-emoji ? Theme.fs(66px, 72px) : root.body-fs * 1.2;

    property <float> enter: 0;
    init => {
        self.enter = 1;
    }
    animate enter {
        duration: Theme.motion-fast ? 120ms : 220ms;
        easing: ease-out;
    }
    // Retro send pop: bubble starts slightly smaller/higher, snaps to full size.
    property <float> pop-scale: Theme.bubble-bounce ? (0.90 + root.enter * 0.10) : 1.0;
    property <length> pop-y: Theme.bubble-bounce ? (1.0 - root.enter) * -6px : 0px;
    animate pop-scale, pop-y {
        duration: Theme.bubble-bounce ? 120ms : 0ms;
        easing: ease-out;
    }

    // Sketch (hand-drawn) bubbles round the body more, but keep the tail-side
    // corner nearly square so the speech tail meets a straight edge (a rounded
    // corner there leaves a gap and the tail reads as a detached spike).
    property <length> r-lg: (Theme.sketch-bubbles ? 13px : 16px) * Theme.r-scale;
    property <length> r-sm: (Theme.sketch-bubbles ? 3px : 5px) * Theme.r-scale;

    // Outgoing bubbles get a vertical mint gradient for a bit of depth; retro
    // stays flat for the pixel aesthetic. Incoming stays on the flat surface.
    // Sketch bubbles paint their fill + outline as a hand-drawn path
    // (SketchOutline, mounted below), so the rectangle itself stays transparent.
    background: (root.msg.jumbo-emoji || Theme.sketch-bubbles) ? transparent : (root.msg.outgoing
            // Flat-capability themes use a solid fill; soft-decor themes get a
            // subtle vertical accent gradient for depth.
            ? (Theme.soft-decor ? @linear-gradient(180deg, Palette.mint-hi 0%, Palette.mint 92%) : Palette.mint) : Palette.bubble-in);
    // Chat-style asymmetric corners. The tail corner (bottom, avatar side)
    // stays tight; within a group the top corner on the avatar side also
    // tightens so consecutive bubbles read as one stacked column.
    // Sketch bubbles square the TOP hug-side corner (where the up-pointing tail
    // attaches) and round the other three; standard bubbles keep the chat
    // asymmetric-corner grouping (tight bottom tail corner + continuation tuck).
    border-top-left-radius: Theme.sketch-bubbles ? (root.hug-right ? root.r-lg : root.r-sm) : (root.hug-right ? root.r-lg : (root.msg.first-in-group ? root.r-lg : root.r-sm));
    border-top-right-radius: Theme.sketch-bubbles ? (root.hug-right ? root.r-sm : root.r-lg) : (root.hug-right ? (root.msg.first-in-group ? root.r-lg : root.r-sm) : root.r-lg);
    border-bottom-left-radius: Theme.sketch-bubbles ? root.r-lg : (root.hug-right ? root.r-lg : root.r-sm);
    border-bottom-right-radius: Theme.sketch-bubbles ? root.r-lg : (root.hug-right ? root.r-sm : root.r-lg);
    border-width: (root.msg.jumbo-emoji || Theme.sketch-bubbles) ? 0px : (root.highlighted ? max(Theme.border-w, 3px) : (root.msg.mentioned ? max(Theme.border-w, 2px) : (root.msg.failed ? 1.5px : Theme.border-w)));
    // Sketch bubbles get a dark "ink" outline on BOTH sides (outgoing included,
    // which is borderless in modern themes) — the comic/hand-drawn signature.
    // text-hi is the page's pencil-ink colour, so outlines match the body text.
    border-color: root.msg.failed ? Palette.danger-on-bubble : (root.highlighted ? Palette.mint-hi : (root.msg.mentioned ? Palette.mint : (Theme.sketch-bubbles ? Palette.text-hi : (root.msg.outgoing ? transparent : Palette.border-2))));
    // Sketch bubbles stay shadowless — the ink outline defines the edge; a soft
    // blur underneath just muddies the flat hand-drawn look.
    drop-shadow-color: (root.msg.jumbo-emoji || Theme.sketch-bubbles) ? transparent : (Theme.hard-shadow ? Palette.shadow : (root.msg.outgoing ? Palette.mint-glow : Palette.shadow-bubble-in));
    drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : (root.msg.outgoing ? 3px : 2px);
    drop-shadow-blur: root.msg.jumbo-emoji ? 0px : (Theme.hard-shadow ? 0px : (root.msg.outgoing ? 14px : 8px));
    y: root.pop-y;
    width: (root.msg.jumbo-emoji ? layout.preferred-width : max(root.min-w, layout.preferred-width)) * root.pop-scale;
    height: layout.preferred-height * root.pop-scale;
    opacity: root.msg.pending ? root.enter * 0.62 : root.enter;
    animate opacity {
        duration: 180ms;
        easing: ease-out;
    }

    // Hand-drawn fill + ink outline for sketch bubbles, painted behind the
    // content (the rectangle's own background/border are transparent in sketch
    // mode). Tracks the bubble's runtime size so it reflows with the content.
    if Theme.sketch-bubbles && !root.msg.jumbo-emoji: SketchOutline {
        x: 0;
        y: 0;
        w: root.width;
        h: root.height;
        radius: root.r-lg;
        fill: root.msg.outgoing ? Palette.mint : Palette.bubble-in;
        ink: root.msg.failed ? Palette.danger-on-bubble : (root.highlighted ? Palette.mint-hi : (root.msg.mentioned ? Palette.mint : Palette.text-hi));
        // Tail on the first bubble of a group, curling toward the avatar: top-left
        // normally, top-right when own messages are placed on the right.
        tail: root.msg.first-in-group ? (root.hug-right ? 2 : 1) : 0;
    }

    // Bottom-most hover sensor. No click handler, so taps fall through to the
    // attachment / retry areas declared above it; it reports `has-hover` so
    // the row can float its action toolbar, and right-clicks so the row can
    // open the context menu.
    hover-sensor := TouchArea {
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.context-menu-requested(
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
        // A plain background tap (not on a link / attachment / album cell /
        // edited badge / retry, which sit on top) replays the message effect.
        clicked => {
            root.body-clicked();
        }
    }

    if root.msg.failed: TouchArea {
        clicked => {
            root.retry-clicked();
        }
    }

    layout := VerticalLayout {
        padding-left: root.msg.jumbo-emoji ? 0px : root.pad-h;
        padding-right: root.msg.jumbo-emoji ? 0px : root.pad-h;
        padding-top: root.msg.jumbo-emoji ? 0px : root.pad-v;
        padding-bottom: root.msg.jumbo-emoji ? 0px : root.pad-v;
        spacing: 6px;
        alignment: stretch;

        // Quoted parent — a recessed plate inside the bubble with an accent
        // bar on the left. For outgoing (mint) bubbles the accent is dark so
        // it actually shows up; for incoming (dark) bubbles it's mint.
        if root.msg.reply-to-id != "" && !root.msg.deleted: Rectangle {
            background: root.msg.outgoing ? Palette.bubble-inset-out : Palette.bubble-inset;
            border-radius: (3px) * Theme.r-scale;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 7px;
                Rectangle {
                    width: 2.5px;
                    background: root.msg.outgoing ? Palette.bubble-out-fg : Palette.mint;
                    border-radius: 1.25px * Theme.r-scale;
                }

                VerticalLayout {
                    spacing: 1px;
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: root.msg.reply-to-author == "" ? @tr("Original message") : root.msg.reply-to-author;
                        color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.mint;
                        font-size: Theme.fs(10px, 14px);
                        font-family: Theme.font;
                        font-weight: 700;
                        overflow: elide;
                        opacity: root.msg.outgoing ? 0.85 : 1.0;
                        width: max(40px, root.text-budget - 18px - (root.msg.reply-to-has-image ? 41px : 0px));
                    }

                    Text {
                        text: root.msg.reply-to-text == "" ? @tr("(message unavailable)") : root.msg.reply-to-text;
                        color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                        font-size: Theme.fs(11px, 14px);
                        font-family: Theme.font;
                        overflow: elide;
                        opacity: root.msg.outgoing ? 0.65 : 0.9;
                        width: max(40px, root.text-budget - 18px - (root.msg.reply-to-has-image ? 41px : 0px));
                    }
                }
                // Signal-style media thumbnail of the quoted parent, at the
                // right edge of the plate.
                if root.msg.reply-to-has-image: Rectangle {
                    width: 34px;
                    height: 34px;
                    border-radius: (4px) * Theme.r-scale;
                    clip: true;
                    Image {
                        source: root.msg.reply-to-image;
                        width: parent.width;
                        height: parent.height;
                        image-fit: cover;
                    }
                }
            }
        }

        // Album grid (message-bubble/album-grid.slint).
        if root.msg.album.length > 0 && !root.msg.deleted: AlbumGrid {
            msg: root.msg;
            cell-clicked(key) => {
                root.album-cell-clicked(key);
            }
        }

        // Attachment block. Image attachments render as a tappable preview
        // tile (placeholder until decoded); other files render as a chip with
        // filename + size. All fire `attachment-clicked` on tap; the tiles
        // live in message-bubble/*.slint.
        if root.msg.has-attachment && root.msg.att-is-video && !root.msg.deleted: VideoTile {
            msg: root.msg;
            text-budget: root.text-budget;
            clicked => {
                root.attachment-clicked();
            }
        }

        // Audio attachment — inline player (message-bubble/audio-tile.slint).
        if root.msg.has-attachment && root.msg.att-is-audio && !root.msg.deleted: AudioTile {
            msg: root.msg;
            text-budget: root.text-budget;
            play-clicked => {
                root.audio-play-clicked();
            }
            seek-clicked(frac) => {
                root.audio-seek-clicked(frac);
            }
        }

        if root.msg.has-attachment && root.msg.att-is-image && !root.msg.deleted: ImageTile {
            msg: root.msg;
            text-budget: root.text-budget;
            clicked => {
                root.attachment-clicked();
            }
        }

        if root.msg.has-attachment && !root.msg.att-is-image && !root.msg.att-is-video && !root.msg.att-is-audio && !root.msg.deleted: FileChip {
            msg: root.msg;
            text-budget: root.text-budget;
            clicked => {
                root.attachment-clicked();
            }
        }

        HorizontalLayout {
            spacing: root.msg.jumbo-emoji ? 0px : root.gap;
            alignment: stretch;

            // Runs renderer — one HorizontalLayout per line of pre-wrapped runs.
        // Slint sizes Text cells from real font metrics (no Rust-side
        // estimation), so spacing matches what a plain `Text` would render.
        // Empty `lines` falls back to a plain `Text` so synthetic / legacy
        // paths still render.
        // Retraction tombstone — replaces the body (and all the blocks gated
        // off above) with a muted italic placeholder. The timestamp in `meta`
        // still renders so the deleted row keeps its place in the timeline.
        if root.msg.deleted: Text {
                text: @tr("This message was deleted");
                color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.text-mid;
                font-size: root.body-fs;
                font-family: Theme.font;
                font-italic: true;
                opacity: root.msg.outgoing ? 0.7 : 0.85;
                vertical-alignment: top;
                wrap: word-wrap;
                width: min(self.preferred-width, root.text-budget);
            }
            // Body lines, wrapped in the text-selection TouchArea. Wrapping
            // (rather than overlaying) keeps the nested link cells winning
            // the hit-test, exactly like the context-menu panel. The area
            // owns the Signal-style select-to-copy drag: press anchors a
            // selection in TextSelection, drag extends it (the run cells
            // hit-test themselves against the points), and a plain click
            // clears it while still delivering the tap actions (retry /
            // effect replay).
            if root.msg.lines.length > 0 && !root.msg.deleted: sel-touch := TouchArea {
                horizontal-stretch: 0;
                // Text cursor over the body; nested link cells override it
                // with a pointer via their own TouchArea.
                mouse-cursor: text;
                property <bool> dragging: false;
                changed has-hover => {
                    root.sel-hover = self.has-hover;
                }
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                        root.context-menu-requested(
                            self.absolute-position.x + self.mouse-x,
                            self.absolute-position.y + self.mouse-y);
                    }
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left && root.msg.message-id != "") {
                        self.dragging = false;
                        root.press-chain = (root.now-tick - root.last-press-tick <= 225ms && abs(self.mouse-x - root.last-press-x) <= 6px && abs(self.mouse-y - root.last-press-y) <= 6px) ? root.press-chain + 1 : 1;
                        root.last-press-tick = root.now-tick;
                        root.last-press-x = self.mouse-x;
                        root.last-press-y = self.mouse-y;
                        if (root.press-chain == 1) {
                            TextSelection.begin(root.msg.message-id, self.mouse-x, self.mouse-y);
                        } else if (root.press-chain == 2) {
                            // The first press resolved this spot into the
                            // press cache (which survives the plain-click
                            // clear in between); Rust expands it to a word,
                            // stores the anchor word, and activates.
                            if (TextSelection.p-line >= 0 && TextSelection.p-run >= 0) {
                                TextSelection.request-word(root.msg.message-id, TextSelection.p-line, TextSelection.p-run, TextSelection.p-frac);
                            }
                        } else {
                            // Third press: select everything in the bubble.
                            // The end run is an open-ended sentinel rather
                            // than the last line's run count — a trailing
                            // rule or empty line has zero runs, and both the
                            // highlight comparisons and the extractor treat
                            // "past every run" as full coverage.
                            root.press-chain = 0;
                            TextSelection.owner = root.msg.message-id;
                            TextSelection.word-mode = false;
                            TextSelection.a-line = 0;
                            TextSelection.a-run = 0;
                            TextSelection.a-frac = 0;
                            TextSelection.b-line = root.msg.lines.length - 1;
                            TextSelection.b-run = 1000000;
                            TextSelection.b-frac = 1.0;
                            TextSelection.active = true;
                        }
                    }
                }
                moved => {
                    // `pressed` filters to left-button drags — `moved` also
                    // fires while a right-button press holds the grab, and
                    // that must not disturb an existing selection.
                    if (self.pressed && root.msg.message-id != "" && TextSelection.owner == root.msg.message-id) {
                        TextSelection.cursor-x = self.mouse-x;
                        TextSelection.cursor-y = self.mouse-y;
                        if (!self.dragging && (abs(self.mouse-x - self.pressed-x) > 3px || abs(self.mouse-y - self.pressed-y) > 3px)) {
                            self.dragging = true;
                            if (!TextSelection.word-mode) {
                                TextSelection.active = true;
                            }
                        }
                        if (self.dragging && TextSelection.c-line >= 0 && TextSelection.c-run >= 0) {
                            if (TextSelection.word-mode) {
                                // Word mode: Rust snaps the endpoints to the
                                // union of the anchor word and the word under
                                // the pointer, extending or retracting whole
                                // words on either side.
                                TextSelection.request-word-extend(root.msg.message-id, TextSelection.c-line, TextSelection.c-run, TextSelection.c-frac);
                            } else {
                                // Character mode: the end endpoint follows the
                                // pointer's claimed position directly.
                                TextSelection.b-line = TextSelection.c-line;
                                TextSelection.b-run = TextSelection.c-run;
                                TextSelection.b-frac = TextSelection.c-frac;
                            }
                        }
                    }
                }
                clicked => {
                    // The release re-arms the chain window, like native
                    // double-click detection.
                    root.last-press-tick = root.now-tick;
                    if (self.dragging) {
                        // Commit the final pointer position: the cursor
                        // claims flush a frame behind the drag handler, so
                        // the release re-syncs the end endpoint.
                        self.dragging = false;
                        if (TextSelection.owner == root.msg.message-id && TextSelection.c-line >= 0 && TextSelection.c-run >= 0) {
                            if (TextSelection.word-mode) {
                                TextSelection.request-word-extend(root.msg.message-id, TextSelection.c-line, TextSelection.c-run, TextSelection.c-frac);
                            } else {
                                TextSelection.b-line = TextSelection.c-line;
                                TextSelection.b-run = TextSelection.c-run;
                                TextSelection.b-frac = TextSelection.c-frac;
                            }
                        }
                    } else if (root.press-chain == 1) {
                        // A plain click clears the selection and keeps the
                        // old tap behavior (retry / effect replay).
                        TextSelection.clear();
                        if (root.msg.failed) {
                            root.retry-clicked();
                        } else {
                            root.body-clicked();
                        }
                    }
                }
                VerticalLayout {
                    spacing: 0;
                    alignment: start;
                    for line[li] in root.msg.lines: line-r := Rectangle {
                // Fenced/indented code lines get a subtle monospace plate that
                // hugs their content.
                background: line.code-block ? (root.msg.outgoing ? Palette.code-plate-out : Palette.code-plate) : transparent;
                        border-radius: line.code-block ? (3px) * Theme.r-scale : 0;
                    // This line's y-band in text-block space, for the run
                    // cells' selection hit-tests.
                    property <length> band-top: self.absolute-position.y - sel-touch.absolute-position.y;
                        HorizontalLayout {
                            spacing: 0;
                            alignment: start;
                    // Blockquote accent bar.
                    if line.quote > 0: Rectangle {
                                width: 2.5px;
                                background: root.msg.outgoing ? Palette.bubble-out-fg : Palette.mint;
                                border-radius: 1.25px * Theme.r-scale;
                            }
                    // List / blockquote nesting inset.
                    if line.indent > 0px: Rectangle {
                                width: line.indent;
                            }
                    // Thematic break — a horizontal divider, no runs.
                    if line.rule: Rectangle {
                                height: 11px;
                                width: root.text-budget;
                                Rectangle {
                                    y: parent.height / 2;
                                    width: 100%;
                                    height: 1px;
                                    opacity: 0.5;
                                    background: root.msg.outgoing ? Palette.bubble-out-fg : Palette.border-2;
                                }
                            }
                            if !line.rule: HorizontalLayout {
                                spacing: 0;
                                alignment: start;
                                for r[ri] in line.runs: RunCell {
                                    is-emoji: r.is-emoji;
                                    text: r.text;
                                    clip-x: r.clip-x;
                                    clip-y: r.clip-y;
                                    body-fs: root.body-fs;
                                    emoji-px: root.emoji-px;
                                    scale: line.scale;
                                    fg: root.msg.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                                    bold: r.bold;
                                    italic: r.italic;
                                    strike: r.strike;
                                    code: r.code;
                                    link: r.link;
                                    fx: r.fx;
                                    phase: r.phase;
                                    mention: r.mention;
                                    mention-a: r.mention-a;
                                    mention-b: r.mention-b;
                                    link-color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.mint;
                                    code-bg: root.msg.outgoing ? Palette.code-plate-out : Palette.code-plate;
                                    sel-msg-id: root.msg.message-id;
                                    sel-line-idx: li;
                                    sel-run-idx: ri;
                                    sel-first-run: ri == 0;
                                    sel-last-run: ri == line.runs.length - 1;
                                    sel-first-line: line.first-content;
                                    sel-last-line: line.last-content;
                                    sel-origin-x: sel-touch.absolute-position.x;
                                    band-t: line-r.band-top;
                                    band-b: line-r.band-top + line-r.height;
                                    sel-bg: root.msg.outgoing ? Palette.bubble-selection-out : Palette.mint.transparentize(0.7);
                                }
                            }
                        }
                    }
                }
            }
            if root.msg.lines.length == 0 && !root.msg.deleted: Text {
                text: root.msg.text;
                color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.text-hi;
                font-size: root.body-fs;
                font-family: Theme.font;
                vertical-alignment: top;
                wrap: Theme.char-wrap ? char-wrap : word-wrap;
                width: min(self.preferred-width, root.text-budget);
            }

            meta := VerticalLayout {
                alignment: end;
            // Hidden for jumbo emoji — the timestamp floats as a pill instead
            // (see `stamp-pill` below), so it doesn't reserve inline width.
            if !root.msg.jumbo-emoji: HorizontalLayout {
                    spacing: 4px;
                    alignment: end;
                // "(edited)" affordance — opens the history modal on tap. Sits
                // before the timestamp so the stamp + check stay rightmost.
                if root.msg.edited && !root.msg.failed && !root.msg.deleted: edited-rect := Rectangle {
                        height: edited-label.preferred-height;
                        width: edited-label.preferred-width;
                        y: parent.height - self.height;
                        edited-label := Text {
                            text: @tr("edited");
                            color: root.msg.outgoing ? Palette.bubble-out-fg : Palette.mint;
                            font-size: Theme.fs(10px, 14px);
                            font-family: Theme.font;
                            font-weight: 600;
                            vertical-alignment: bottom;
                            opacity: edited-touch.has-hover ? 1.0 : (root.msg.outgoing ? 0.7 : 0.85);
                            animate opacity { duration: Theme.hover-dur; }
                        }

                        edited-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.show-history-clicked();
                            }
                        }
                    }
                    stamp-rect := Rectangle {
                        height: stamp-label.preferred-height;
                        width: stamp-label.preferred-width;
                        y: parent.height - self.height;
                        stamp-label := Text {
                            text: root.stamp-with-delivery;
                            color: root.msg.failed ? Palette.danger-on-bubble : (root.msg.outgoing ? Palette.bubble-out-fg : Palette.text-lo);
                            font-size: Theme.fs(10px, 14px);
                            font-family: Theme.font;
                            vertical-alignment: bottom;
                            opacity: root.msg.outgoing && !root.msg.failed ? 0.7 : 1;
                        }
                    // Hover sensor for the datetime tooltip. Sits above the
                    // whole-bubble TouchAreas, so it forwards clicks (retry /
                    // effect replay) and right-clicks (context menu) to keep
                    // the stamp region behaving exactly like the rest of the
                    // bubble — same reason `edited-touch` above swallows.
                    stamp-touch := TouchArea {
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                                    root.context-menu-requested(
                                    self.absolute-position.x + self.mouse-x,
                                    self.absolute-position.y + self.mouse-y);
                                }
                            }
                            clicked => {
                                if (root.msg.failed) {
                                    root.retry-clicked();
                                } else {
                                    root.body-clicked();
                                }
                            }
                        }
                    // Floats above the stamp, right-aligned; the bubble root
                    // doesn't clip, so it can overflow into the previous row.
                    if stamp-touch.has-hover && !root.msg.failed && root.msg.stamp-full != "": Tooltip {
                            x: parent.width - self.width;
                            y: -self.height - 6px;
                            label: root.msg.stamp-full;
                            is-visible: true;
                        }
                    }
                // Status indicator: confirmed = double check, pending = single
                // (lighter, animates), failed = "!" in red. Only on outgoing.
                if root.msg.outgoing && !root.msg.failed: CheckMark {
                        stroke: Palette.bubble-out-fg;
                        double: !root.msg.pending;
                        opacity: root.msg.pending ? 0.55 : 1.0;
                        animate opacity { duration: 180ms; }
                    }
                    if root.msg.outgoing && root.msg.failed: Text {
                        text: "!";
                        color: Palette.danger-on-bubble;
                        font-size: Theme.fs(11px, 14px);
                        font-family: Theme.font;
                        vertical-alignment: bottom;
                    }
                }
            }
        }
    }

    // Floating timestamp for jumbo-emoji messages. There's no bubble to host
    // the inline meta, so the stamp (+ outgoing status tick) rides a translucent
    // pill overlapping the bottom of the glyphs, revealed on hover — or kept up
    // while a send is pending/failed so state is never hidden. Anchored inside
    // the bubble bounds so it never overlaps the neighbouring row.
    if root.msg.jumbo-emoji: Rectangle {
        x: parent.width - self.width;
        y: parent.height - self.height;
        height: pill-row.preferred-height;
        width: pill-row.preferred-width;
        background: Palette.media-ghost-bg-hover;
        border-radius: (10px) * Theme.r-scale;
        opacity: (hover-sensor.has-hover || root.msg.pending || root.msg.failed) ? 1.0 : 0.0;
        animate opacity {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        pill-row := HorizontalLayout {
            padding-left: 7px;
            padding-right: 7px;
            padding-top: 3px;
            padding-bottom: 3px;
            spacing: 4px;
            alignment: end;
            Text {
                text: root.stamp-with-delivery;
                color: root.msg.failed ? Palette.danger-on-bubble : Palette.media-chip-fg;
                font-size: Theme.fs(10px, 14px);
                font-family: Theme.font;
                vertical-alignment: center;
            }

            if root.msg.outgoing && !root.msg.failed: CheckMark {
                stroke: Palette.media-chip-fg;
                double: !root.msg.pending;
                opacity: root.msg.pending ? 0.55 : 1.0;
            }
        }
        // Datetime tooltip for the pill. The pill is always mounted (opacity-
        // gated), so this TouchArea covers its region even while invisible —
        // clicks and right-clicks are forwarded like `stamp-touch` above so
        // the jumbo glyph region keeps its retry/replay/context-menu behavior.
        pill-touch := TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                    root.context-menu-requested(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y);
                }
            }
            clicked => {
                if (root.msg.failed) {
                    root.retry-clicked();
                } else {
                    root.body-clicked();
                }
            }
        }

        if pill-touch.has-hover && !root.msg.failed && root.msg.stamp-full != "": Tooltip {
            x: parent.width - self.width;
            y: -self.height - 6px;
            label: root.msg.stamp-full;
            is-visible: true;
        }
    }

    // (The speech tail is part of the SketchOutline path above, so it's a single
    // connected, filled silhouette — see sketch-outline.slint.)

    // Message-effect indicator: a small emoji chip on the top-outer corner,
    // showing which effect this bubble carries (and hinting that a tap replays
    // it). Sits on the corner away from the tail; never clipped (the bubble root
    // doesn't clip).
    if root.msg.effect-id > 0: Rectangle {
        x: root.msg.outgoing ? -7px : parent.width - self.width + 7px;
        y: -7px;
        width: 20px;
        height: 20px;
        border-radius: (10px) * Theme.r-scale;
        background: Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-float;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 5px;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 2px : 1px;
        Image {
            width: 13px;
            height: 13px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: EmojiSheet.sprite;
            source-clip-x: root.msg.effect-clip-x;
            source-clip-y: root.msg.effect-clip-y;
            source-clip-width: EmojiSheet.tile;
            source-clip-height: EmojiSheet.tile;
        }
    }
}
