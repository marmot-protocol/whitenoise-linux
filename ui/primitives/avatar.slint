import { Palette, Theme } from "../tokens.slint";

export component Avatar inherits Rectangle {
    in property <string> initials;
    in property <color> color-a: Palette.mint;
    in property <color> color-b: Palette.mint-dim;
    in property <length> size: 36px;
    in property <length> font-size: Theme.fsr(11px, 16px);
    // Optional profile picture. When `has-picture` is true, the Image is
    // rendered over the gradient (so a transparent/loading texture still
    // shows the palette underneath). Rust sets both together.
    in property <image> picture;
    in property <bool> has-picture: false;
    width: root.size;
    height: root.size;
    border-radius: (root.size / 2) * Theme.r-scale;
    background: Theme.soft-decor ? @linear-gradient(135deg, root.color-a 0%, root.color-b 100%) : root.color-a;
    border-width: max(Theme.border-w, 1.5px);
    border-color: Palette.avatar-ring;
    clip: true;
    drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
    drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 2px : 2px;
    drop-shadow-blur: Theme.hard-shadow ? 0px : 6px;
    if !root.has-picture: Text {
        text: root.initials;
        color: white;
        font-size: root.font-size;
        font-weight: 700;
        font-family: Theme.font;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    if root.has-picture: Image {
        source: root.picture;
        width: 100%;
        height: 100%;
        image-fit: cover;
    }
}
