import { Palette, Theme } from "../tokens.slint";

export component Avatar inherits Rectangle {
    in property <string> initials;
    in property <color> color-a: #6B66E4;
    in property <color> color-b: #4338CA;
    in property <length> size: 36px;
    in property <length> font-size: Theme.retro ? 16px : 11px;
    // Optional profile picture. When `has-picture` is true, the Image is
    // rendered over the gradient (so a transparent/loading texture still
    // shows the palette underneath). Rust sets both together.
    in property <image> picture;
    in property <bool> has-picture: false;
    width: root.size; height: root.size;
    border-radius: (root.size / 2) * Theme.r-scale;
    background: Theme.retro ? root.color-a : @linear-gradient(135deg, root.color-a 0%, root.color-b 100%);
    border-width: Theme.retro ? Theme.border-w : 1.5px;
    border-color: Theme.retro ? white : #FFFFFF20;
    clip: true;
    drop-shadow-color: Theme.retro ? Palette.shadow : #00000060;
    drop-shadow-offset-x: Theme.retro ? 2px : 0px;
    drop-shadow-offset-y: Theme.retro ? 2px : 2px;
    drop-shadow-blur: Theme.retro ? 0px : 6px;
    if !root.has-picture : Text {
        text: root.initials;
        color: white;
        font-size: (root.font-size) * Theme.fs-scale;
        font-weight: 700;
        font-family: Theme.font;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    if root.has-picture : Image {
        source: root.picture;
        width: 100%;
        height: 100%;
        image-fit: cover;
    }
}
