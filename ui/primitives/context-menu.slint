import { Palette, Theme } from "../tokens.slint";

// One row in the message context menu. `shown` collapses the row (rather than
// `if`-mounting it) so the TouchArea is always live — `if`-mounted TouchAreas
// race the first click (see the cell notes in emoji-picker.slint).
export component MenuItem inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    in property <bool> shown: true;
    // Keyboard selection — highlighted exactly like hover so arrow-key users
    // get the same visible focus indicator mouse users get.
    in property <bool> selected: false;
    callback activated();

    property <bool> highlighted: touch.has-hover || root.selected;

    visible: root.shown;
    height: root.shown ? 32px : 0px;
    border-radius: (6px) * Theme.r-scale;
    background: root.highlighted ? Palette.hover : transparent;
    animate background { duration: 100ms; }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 16px;
        spacing: 9px;
        Text {
            text: root.glyph;
            color: root.highlighted ? Palette.text-hi : Palette.text-mid;
            font-size: (13px) * Theme.fs-scale;
            font-family: Theme.font;
            width: 16px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            color: Palette.text-hi;
            font-size: (12px) * Theme.fs-scale;
            font-family: Theme.font;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        enabled: root.shown;
        mouse-cursor: pointer;
        clicked => {
            root.activated();
        }
        // Pointer movement keeps keyboard selection in sync so hovering one
        // row and then pressing Return acts on the row under the cursor.
        moved => {
            root.hovered();
        }
    }
    // Internal hover-sync hook so the parent can mirror the selected index.
    // Named `hovered` (not `activated-*`) because it fires no action — it only
    // tells the parent "the pointer is over me, sync your selection index."
    callback hovered();
}

// Right-click context menu for a message bubble. Mounted full-window (like
// EmojiPicker) so the invisible backdrop catches outside clicks; the panel
// sits at the anchor point, clamped inside the window.
export component MessageContextMenu inherits Rectangle {
    // Anchor point (top-left of the panel, in window coords).
    in property <length> anchor-x;
    in property <length> anchor-y;
    in property <bool> can-edit: false;
    // Fired with the panel's clamped position so the emoji picker can open
    // where the menu was.
    callback add-reaction(length, length);
    callback reply();
    callback forward();
    callback edit();
    // "Delete for everyone" (kind-5 retraction) — author-only, so gated by
    // can-edit. "Delete for me" is a local-only hide, available on any message.
    callback delete-for-everyone();
    callback delete-for-me();
    callback dismissed();

    // Keyboard navigation. The always-shown rows come first so the selectable
    // range stays the contiguous [0, count-1] regardless of can-edit:
    //   0 = Add reaction, 1 = Reply, 2 = Forward, 3 = Delete for me  (always)
    //   4 = Edit, 5 = Delete for everyone                            (author-only)
    property <int> item-count: root.can-edit ? 6 : 4;
    property <int> selected-index: 0;

    function move-selection(delta: int) {
        root.selected-index = min(max(0, root.selected-index + delta), root.item-count - 1);
    }
    // Tab wraps around the list rather than escaping the menu.
    function wrap-selection(delta: int) {
        // Manual modulo so this doesn't depend on a Math.mod builtin.
        if (root.selected-index + delta < 0) {
            root.selected-index = root.item-count - 1;
        } else if (root.selected-index + delta >= root.item-count) {
            root.selected-index = 0;
        } else {
            root.selected-index = root.selected-index + delta;
        }
    }
    function activate-selected() {
        if (root.selected-index == 0) {
            root.add-reaction(root.px, root.py);
        } else if (root.selected-index == 1) {
            root.reply();
        } else if (root.selected-index == 2) {
            root.forward();
        } else if (root.selected-index == 3) {
            root.delete-for-me();
        } else if (root.selected-index == 4 && root.can-edit) {
            root.edit();
        } else if (root.selected-index == 5 && root.can-edit) {
            root.delete-for-everyone();
        }
    }

    // Backdrop — invisible, dismisses on a click or another right-click
    // outside the panel.
    TouchArea {
        clicked => {
            root.dismissed();
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.dismissed();
            }
        }
    }

    // Clamp the panel inside the window with a small inset.
    property <length> inset: 8px;
    property <length> px: min(max(root.inset, root.anchor-x), root.width - panel.width - root.inset);
    property <length> py: min(max(root.inset, root.anchor-y), root.height - panel.height - root.inset);

    // Open animation — same flip-after-mount trick as EmojiPicker.
    property <bool> opened: false;
    init => {
        root.opened = true;
        root.selected-index = 0;
        keys.focus();
    }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -4px);
        width: max(150px, col.preferred-width);
        height: col.preferred-height;
        opacity: root.opened ? 1.0 : 0.0;
        animate opacity {
            duration: 120ms;
            easing: ease-out;
        }
        animate y {
            duration: 120ms;
            easing: ease-out;
        }
        background: Palette.elevated;
        border-radius: (10px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : #00000050;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 14px;

        // Swallow any click inside the panel that no item claims. Wrapping
        // the content (rather than being a sibling) guarantees the nested
        // item TouchAreas win the hit-test — see emoji-picker.slint.
        TouchArea {
            col := VerticalLayout {
                padding: 4px;
                spacing: 1px;
                MenuItem {
                    glyph: "☺";
                    label: @tr("Add reaction");
                    selected: root.selected-index == 0;
                    activated => {
                        root.add-reaction(root.px, root.py);
                    }
                    hovered => {
                        root.selected-index = 0;
                    }
                }

                MenuItem {
                    glyph: "↩";
                    label: @tr("Reply");
                    selected: root.selected-index == 1;
                    activated => {
                        root.reply();
                    }
                    hovered => {
                        root.selected-index = 1;
                    }
                }

                MenuItem {
                    glyph: "➦";
                    label: @tr("Forward");
                    selected: root.selected-index == 2;
                    activated => {
                        root.forward();
                    }
                    hovered => {
                        root.selected-index = 2;
                    }
                }

                MenuItem {
                    glyph: "⌫";
                    label: @tr("Delete for me");
                    selected: root.selected-index == 3;
                    activated => {
                        root.delete-for-me();
                    }
                    hovered => {
                        root.selected-index = 3;
                    }
                }

                MenuItem {
                    glyph: "✎";
                    label: @tr("Edit message");
                    shown: root.can-edit;
                    selected: root.selected-index == 4;
                    activated => {
                        root.edit();
                    }
                    hovered => {
                        root.selected-index = 4;
                    }
                }

                MenuItem {
                    glyph: "⊘";
                    label: @tr("Delete for everyone");
                    shown: root.can-edit;
                    selected: root.selected-index == 5;
                    activated => {
                        root.delete-for-everyone();
                    }
                    hovered => {
                        root.selected-index = 5;
                    }
                }
            }
        }
    }

    // Keyboard handling — focused on mount so keys land here. Esc dismisses;
    // Up/Down (and Tab/Backtab) move the selection, Home/End jump to the
    // first/last item; Return/Enter activates.
    keys := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            if (e.text == Key.UpArrow) {
                root.move-selection(-1);
                return accept;
            }
            if (e.text == Key.DownArrow) {
                root.move-selection(1);
                return accept;
            }
            if (e.text == Key.Home) {
                root.selected-index = 0;
                return accept;
            }
            if (e.text == Key.End) {
                root.selected-index = root.item-count - 1;
                return accept;
            }
            if (e.text == Key.Tab) {
                root.wrap-selection(1);
                return accept;
            }
            if (e.text == Key.Backtab) {
                root.wrap-selection(-1);
                return accept;
            }
            if (e.text == Key.Return) {
                root.activate-selected();
                return accept;
            }
            return reject;
        }
    }
}
