import { Palette, Theme } from "../tokens.slint";
import { CopyIcon } from "../icons/copy-icon.slint";

// Tap-to-copy pill chip: shows `value` with a copy glyph, flashes "Copied ✓"
// for 1.4s after a tap. Owns the flash state; the tap fires `copy-requested`
// and the caller does the actual clipboard write.
export component CopyChip inherits Rectangle {
    in property <string> value;
    callback copy-requested();

    property <bool> copied: false;
    copy-reset := Timer {
        interval: 1.4s;
        running: root.copied;
        triggered => {
            root.copied = false;
        }
    }

    height: 30px;
    width: chip-row.preferred-width + 28px;
    border-radius: (15px) * Theme.r-scale;
    background: chip-touch.has-hover ? Palette.field-hover : Palette.field;
    border-width: Theme.border-w;
    border-color: root.copied ? Palette.mint : Palette.field-border;
    animate background, border-color { duration: Theme.transition-dur; }
    chip-row := HorizontalLayout {
        x: 14px;
        width: self.preferred-width;
        spacing: 7px;
        alignment: center;
        Text {
            text: root.copied ? @tr("Copied ✓") : root.value;
            color: root.copied ? Palette.mint : Palette.text-mid;
            font-size: Theme.fs(10.5px, 14px);
            font-weight: 700;
            font-family: Theme.font;
            vertical-alignment: center;
        }

        if !root.copied: VerticalLayout {
            alignment: center;
            CopyIcon {
                stroke: Palette.text-lo;
            }
        }
    }

    chip-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.copy-requested();
            root.copied = true;
        }
    }
}
