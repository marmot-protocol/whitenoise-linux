import { Palette, Theme } from "../tokens.slint";

// ScrollView — vertical scroll container with a styled scrollbar (mint thumb
// on a panel track). Wheel scrolls; thumb is draggable; track click scrubs.
// No drag-pan on the body (selection / clicks pass through).
export component ScrollView inherits Rectangle {
    in-out property <length> viewport-width <=> flick.viewport-width;
    in-out property <length> viewport-height <=> flick.viewport-height;
    in-out property <length> viewport-x <=> flick.viewport-x;
    in-out property <length> viewport-y <=> flick.viewport-y;
    out property <length> visible-width <=> flick.width;
    out property <length> visible-height <=> flick.height;

    property <length> bar-w: 10px;
    property <bool> needs-bar: flick.viewport-height > flick.height + 1px;
    property <length> track-pad: 6px;
    property <length> track-h: max(0px, flick.height - 2 * track-pad);
    property <length> thumb-h: min(track-h, max(28px,
        track-h * (flick.height / max(1px, flick.viewport-height))));
    property <length> max-scroll: max(0px, flick.viewport-height - flick.height);
    property <length> thumb-travel: max(0px, track-h - thumb-h);
    property <length> thumb-y: max-scroll > 0px ? (-flick.viewport-y / max-scroll) * thumb-travel : 0px;

    flick := Flickable {
        x: 0;
        y: 0;
        width: parent.width - (root.needs-bar ? root.bar-w : 0px);
        height: parent.height;
        interactive: false;
        @children
    }

    if needs-bar: Rectangle {
        x: parent.width - root.bar-w;
        y: 0;
        width: root.bar-w;
        height: parent.height;
        background: Palette.panel-2;

        Rectangle {
            x: 0;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Palette.border;
        }

        Rectangle {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: 1px;
            background: Palette.mint-dim;
        }

        Rectangle {
            x: 2px;
            y: parent.height - 3px;
            width: parent.width - 4px;
            height: 1px;
            background: Palette.mint-dim;
        }

        for i[idx] in 24: Rectangle {
            x: parent.width / 2 - 0.5px;
            y: root.track-pad + (idx + 0.5) * (root.track-h / 24);
            width: 1px;
            height: 1px;
            background: Palette.border;
            opacity: 0.6;
        }

        track-touch := TouchArea {
            x: 1px;
            y: root.track-pad;
            width: parent.width - 2px;
            height: root.track-h;

            moved => {
                if (self.pressed && root.thumb-travel > 0px && root.max-scroll > 0px) {
                    flick.viewport-y = -max(0px, min(root.max-scroll,
                        ((self.mouse-y - root.thumb-h / 2) / root.thumb-travel) * root.max-scroll));
                }
            }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && root.thumb-travel > 0px && root.max-scroll > 0px) {
                    flick.viewport-y = -max(0px, min(root.max-scroll,
                        ((self.mouse-y - root.thumb-h / 2) / root.thumb-travel) * root.max-scroll));
                }
            }

            thumb := Rectangle {
                x: 1px;
                y: root.thumb-y;
                width: parent.width - 2px;
                height: root.thumb-h;
                background: track-touch.pressed ? Palette.mint-hi : (track-touch.has-hover ? Palette.mint : Palette.mint-dim);
                border-radius: (1px) * Theme.r-scale;
                animate background { duration: Theme.transition-dur; }

                Rectangle {
                    x: 2px;
                    y: parent.height / 2 - 2px;
                    width: parent.width - 4px;
                    height: 1px;
                    background: Palette.bg;
                    opacity: 0.35;
                }

                Rectangle {
                    x: 2px;
                    y: parent.height / 2 + 1px;
                    width: parent.width - 4px;
                    height: 1px;
                    background: Palette.bg;
                    opacity: 0.35;
                }
            }
        }
    }
}
