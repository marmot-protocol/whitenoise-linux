// status bar — online dot, relays, MLS, cwd, hotkey hint.
import { Palette, Theme } from "tokens.slint";

export component StatusBar inherits Rectangle {
    height: Theme.pixel-metrics ? 36px : 30px;
    background: Palette.status-bar;

    in property <int> relays-connected;
    in property <int> relays-total;
    // Seconds since the last successful relay-health/sync poll. -1 means the
    // boot/post-connect sync has not completed yet, so keep showing SYNCING.
    in property <int> sync-secs: -1;
    in property <string> message;
    in property <bool> message-is-error: false;

    property <bool> has-relays: root.relays-total > 0;
    property <bool> has-connection: root.relays-connected > 0;
    property <bool> is-syncing: root.has-connection && root.sync-secs < 0;
    property <string> connection-label:
        !root.has-relays ? @tr("OFFLINE") : (!root.has-connection ? @tr("CONNECTING") : @tr("ONLINE"));
    property <string> sync-label:
        !root.has-connection ? "" : (root.sync-secs < 0 ? @tr("SYNCING…") : @tr("SYNCED") + " " + root.sync-secs + "S " + @tr("AGO"));

    Rectangle {
        y: 0;
        width: parent.width;
        height: Theme.border-w;
        background: Palette.card-border;
    }

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 18px;
        alignment: stretch;

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Rectangle {
                width: 8px;
                height: 8px;
                y: (parent.height - self.height) / 2;
                border-radius: (4px) * Theme.r-scale;
                background: root.is-syncing ? Palette.warning : (root.has-connection ? Palette.mint-dim : (root.has-relays ? Palette.warning : Palette.text-vlo));
                drop-shadow-blur: Theme.hard-shadow ? 0px : 4px;
                drop-shadow-color: root.has-connection && !root.is-syncing ? Palette.mint-glow : transparent;
            }

            Text {
                text: root.connection-label;
                color: Palette.text-hi;
                font-size: Theme.fs(10px, 14px);
                font-weight: 700;
                letter-spacing: 1.2px;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.relays-connected + "/" + root.relays-total + " " + @tr("RELAYS");
            color: Palette.text-mid;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            letter-spacing: 1.2px;
            vertical-alignment: center;
        }

        if root.sync-label != "": Text {
            text: root.sync-label;
            color: root.sync-secs < 0 ? Palette.warning : Palette.text-mid;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            letter-spacing: 1.2px;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
            preferred-width: 0px;
            clip: true;

            Text {
                width: parent.width;
                height: parent.height;
                text: root.message;
                color: root.message-is-error ? Palette.danger : Palette.mint;
                font-size: Theme.fs(10px, 14px);
                font-weight: 700;
                overflow: elide;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }

        Text {
            // macOS uses ⌘; everything else Ctrl. Mirrors the command-palette
            // modal so both surfaces show the same shortcut. Modifier glyphs are
            // key labels, not prose, so they stay out of @tr().
            text: Theme.is-mac ? "⌘ K" : "Ctrl K";
            color: Palette.text-mid;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            letter-spacing: 1.0px;
            vertical-alignment: center;
        }

        Text {
            text: "·";
            color: Palette.text-vlo;
            font-size: Theme.fs(10px, 14px);
            vertical-alignment: center;
        }

        Text {
            text: @tr("COMMAND");
            color: Palette.text-mid;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            letter-spacing: 1.4px;
            vertical-alignment: center;
        }
    }
}
