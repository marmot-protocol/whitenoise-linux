import { Palette, Theme } from "../tokens.slint";

// One label/value row: a bold label with an optional sublabel on the left, a
// right-aligned value plus any @children (buttons, toggles) on the right, and a
// 1px bottom divider. `row-height` is the only knob families vary; empty
// sublabel/value are gated so a row collapses cleanly to a single line.
//
// Responsive: the label and value columns carry `min-width: 0` and elide, so
// when the pane is narrow the flexible text yields space and the fixed trailing
// controls stay on screen, instead of the row forcing its card wider than the
// pane and clipping every control at the window edge.
export component KVRow inherits Rectangle {
    in property <string> label;
    in property <string> sublabel;
    in property <string> value;
    in property <bool> show-divider: true;
    in property <length> row-height: 56px;

    height: root.row-height;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 14px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            min-width: 0px;
            spacing: 3px;
            alignment: center;
            Text {
                text: root.label;
                color: Palette.text-hi;
                font-size: Theme.fs(12px, 16px);
                font-weight: 700;
                overflow: elide;
            }

            if root.sublabel != "": Text {
                text: root.sublabel;
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                overflow: elide;
            }
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 0;
            HorizontalLayout {
                alignment: end;
                spacing: 10px;
                if root.value != "": Text {
                    text: root.value;
                    color: Palette.text-hi;
                    font-size: Theme.fs(12px, 16px);
                    font-family: Theme.font;
                    vertical-alignment: center;
                    overflow: elide;
                }

                @children
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}
