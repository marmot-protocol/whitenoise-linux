import { Palette, Theme } from "../tokens.slint";

export component Section inherits VerticalLayout {
    in property <string> label;
    spacing: 10px;
    Text {
        text: root.label;
        color: Palette.text-mid;
        font-size: Theme.fs(10px, 14px);
        font-weight: 700;
        letter-spacing: 1.4px;
    }

    @children
}
