// The standard chat-list row body (avatar + name + preview + badges).
// This is skin 0 of the row; ChatListEntry (chat-list-entry.slint) is the
// Layer-1 skin slot that picks between this and the IRC-style body.
import { Palette, Theme } from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { PinIcon } from "../icons/pin-icon.slint";
import { MuteIcon } from "../icons/mute-icon.slint";
import { Avatar } from "../primitives/avatar.slint";
import { UnreadBadge } from "../primitives/unread-badge.slint";

export component ChatListItem inherits Rectangle {
    callback clicked;
    // Right-click on the row — anchor coords are window-absolute so the caller
    // can open a context menu at the cursor.
    callback context-menu(length, length);

    in property <string> name;
    in property <string> preview;
    in property <string> stamp;
    in property <string> badge;
    in property <bool> selected: false;
    in property <bool> sending: false;
    in property <bool> read: false;
    in property <bool> pinned: false;
    in property <bool> muted: false;
    in property <color> av-a;
    in property <color> av-b;
    in property <string> av-initials;
    in property <image> picture;
    in property <bool> has-picture: false;

    // Collapsed-strip mode: on narrow windows the side panel hands rows only
    // ~60px, so drop the text columns and float the unread badge over the
    // avatar. The avatar keeps the exact spot it has when expanded.
    in property <bool> compact: false;

    // Content-driven so a wrapping preview can grow the row; a short preview
    // keeps the standard single-line height.
    min-height: 64px;
    background: root.selected ? Palette.selected : (touch.has-hover ? Palette.hover : transparent);
    border-radius: (8px) * Theme.r-scale;
    border-width: Theme.selected-inverts-text && root.selected ? Theme.border-w : (root.selected && !Theme.selected-inverts-text ? 1px : 0px);
    border-color: root.selected && !Theme.selected-inverts-text ? Palette.mint-glow : Palette.border;
    animate background, border-color {
        duration: 140ms;
        easing: ease-out;
    }

    // Animated mint selection bar — grows from center when selected.
    if !Theme.pixel-select-marker: Rectangle {
        x: 0px;
        width: 3px;
        height: root.selected ? 40px : 0px;
        y: (parent.height - self.height) / 2;
        background: Palette.mint;
        border-radius: (1.5px) * Theme.r-scale;
        drop-shadow-blur: root.selected ? 6px : 0px;
        drop-shadow-color: Palette.mint-glow;
        opacity: root.selected ? 1.0 : 0.0;
        animate height {
            duration: 220ms;
            easing: ease-in-out;
        }
        animate opacity {
            duration: 160ms;
            easing: ease-out;
        }
    }
    // SNES selection chevron — slides in from outside the edge.
    if Theme.pixel-select-marker: Text {
        x: root.selected ? 2px : -14px;
        y: (parent.height - self.height) / 2;
        text: "▶";
        color: Palette.bubble-out-fg;
        font-size: Theme.fs(14px, 18px);
        font-family: Theme.font;
        vertical-alignment: center;
        opacity: root.selected ? 1.0 : 0.0;
        animate x {
            duration: 140ms;
            easing: ease-out;
        }
        animate opacity { duration: Theme.hover-dur; }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 12px;
        Avatar {
            size: 36px;
            initials: root.av-initials;
            color-a: root.av-a;
            color-b: root.av-b;
            picture: root.picture;
            has-picture: root.has-picture;
            a11y-label: root.name;
            font-size: Theme.fs(11px, 16px);
        }

        if !root.compact: VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: root.name;
                    color: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-hi;
                    font-size: Theme.fs(13px, 16px);
                    font-weight: 700;
                    font-family: Theme.font;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                if root.pinned: PinIcon {
                    fill: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.mint;
                    y: 2px;
                }
                if root.muted: MuteIcon {
                    stroke: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                    y: 1px;
                }
                Text {
                    text: root.stamp;
                    color: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                    font-size: Theme.fs(10px, 14px);
                    font-family: Theme.font;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }

            HorizontalLayout {
                spacing: 6px;
                // Wrap the preview but hard-cap it at three lines. Slint's Text
                // ignores max-height, so clip inside a height-capped box.
                Rectangle {
                    horizontal-stretch: 1;
                    clip: true;
                    max-height: Theme.fs(11px, 16px) * 3.75;
                    Text {
                        text: root.preview;
                        color: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                        font-size: Theme.fs(11px, 16px);
                        font-family: Theme.font;
                        width: 100%;
                        y: 0;
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }

                if root.badge != "": UnreadBadge {
                    count: root.badge;
                    // A muted chat's unread count is de-emphasized — new messages
                    // still register but shouldn't shout for attention.
                    opacity: root.muted ? 0.5 : 1.0;
                }
                if root.badge == "" && root.read: CheckMark {
                    stroke: Palette.text-lo;
                    double: true;
                    y: 4px;
                }
                if root.badge == "" && root.sending: Rectangle {
                    width: 12px;
                    height: 12px;
                    y: 3px;
                    border-radius: (6px) * Theme.r-scale;
                    border-width: 1px;
                    border-color: Palette.text-vlo;
                }
            }
        }
    }

    if root.compact && root.badge != "": UnreadBadge {
        x: parent.width - self.width - 3px;
        y: 3px;
        count: root.badge;
        opacity: root.muted ? 0.5 : 1.0;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.context-menu(
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y);
            }
        }
    }
}
