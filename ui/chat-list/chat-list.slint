// chat list panel — a SidePanel populated with chat list items.
import { AppState } from "../shell/app-state.slint";
import { ChatMeta, TextSelection } from "../tokens.slint";
import { ChatListEntry } from "chat-list-entry.slint";
import { SidePanel } from "../layout/side-panel.slint";

export component ChatListPanel inherits SidePanel {
    // Reads the chat list / relay health from AppState and invokes its
    // callbacks directly; the shell passes no bindings.
    property <string> query;

    add-clicked => {
        AppState.new-chat-requested();
    }

    // Typing in the header search field filters the rows below in place. Echo
    // the query to Rust so it recomputes `chat-match-flags` for the current
    // chats.
    search-edited(q) => {
        root.query = q;
        AppState.chat-search-changed(q);
    }
    // The chat list is re-pushed on new messages / re-sorts; re-derive the
    // match set so filtered rows track the fresh order (mirrors the forward
    // picker). No-op while the query is empty. Observed via a local mirror
    // (a `changed` handler must sit on a property of the element that
    // declares it).
    property <[ChatMeta]> chats-obs: AppState.chats;
    changed chats-obs => {
        if (root.query != "") {
            AppState.chat-search-changed(root.query);
        }
    }

    title: @tr("CHATS");
    count: AppState.chats.length;
    show-search: true;
    search-placeholder: @tr("Search chats…");
    show-search-shortcut: true;
    show-add: true;
    footer-text: AppState.network-total > 0 ? AppState.network-connected + "/" + AppState.network-total + " " + @tr("RELAYS") : @tr("NO RELAYS");
    footer-trail: AppState.sync-secs < 0 ? "· " + @tr("SYNCING…") : "· " + @tr("SYNCED") + " " + AppState.sync-secs + "S " + @tr("AGO");
    // Rows filter in place, so drop the layout's inter-row spacing and bake the
    // 2px gap into each shown wrapper — hidden rows then collapse to nothing.
    list-spacing: 0;

    for chat[idx] in AppState.chats: Rectangle {
        // Shown when the query is empty or this row matched (flags from Rust).
        property <bool> shown: root.query == "" || (idx < AppState.chat-match-flags.length && AppState.chat-match-flags[idx]);
        height: shown ? entry.preferred-height + 2px : 0px;
        clip: true;
        visible: shown;

        entry := ChatListEntry {
            x: 0;
            y: 0;
            width: 100%;
            chat: chat;
            compact: root.strip;
            selected: idx == AppState.active-chat;
            clicked => {
                // A leftover selection belongs to the chat being left behind; drop it.
                TextSelection.clear();
                AppState.chat-selected(idx);
            }
            context-menu(ax, ay) => {
                AppState.request-chat-context(idx, ax, ay);
            }
        }
    }
}
