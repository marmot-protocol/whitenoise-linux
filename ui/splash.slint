import { Palette, Theme } from "tokens.slint";

// Splash screen shown while the marmot runtime is booting. The boot path can
// take many seconds (open SQLcipher DBs, derive keys, publish key package,
// connect to relays), so this needs to be obviously alive — hence the
// breathing dot animation.
export component SplashScreen inherits Rectangle {
    in property <string> status: @tr("Connecting to relays…");

    background: Palette.bg;

    VerticalLayout {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        alignment: center;
        spacing: 28px;

        // Brand mark — three pulsing dots in the mint accent.
        HorizontalLayout {
            alignment: center;
            spacing: 10px;

            for i in [0, 1, 2] : Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: Palette.mint;

                property <float> pulse: 0.35;
                init => { self.pulse = 1.0; }
                opacity: self.pulse;
                animate pulse {
                    duration: 900ms;
                    delay: i * 180ms;
                    iteration-count: -1;
                    direction: alternate;
                    easing: ease-in-out;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "darkmatter";
                horizontal-alignment: center;
                color: Palette.text-hi;
                font-size: (22px) * Theme.fs-scale;
                font-weight: 700;
                font-family: Theme.font;
            }
            Text {
                text: root.status;
                horizontal-alignment: center;
                color: Palette.text-mid;
                font-size: (12px) * Theme.fs-scale;
                font-family: Theme.font;
            }
        }
    }
}
