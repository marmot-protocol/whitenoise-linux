import { Palette, Theme } from "tokens.slint";

// Splash screen shown while the marmot runtime is booting. Rust drives phased
// status text + a step rail so the multi-second boot path feels alive.
export component SplashScreen inherits Rectangle {
    in property <string> status: @tr("Connecting to relays…");
    in property <int> phase: 0;
    in property <int> phase-count: 4;

    background: Palette.bg;

    VerticalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        alignment: center;
        spacing: 28px;

        // Step rail — thin progress across boot phases.
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            for i in 4: Rectangle {
                width: i <= root.phase ? 28px : 10px;
                height: 4px;
                border-radius: (2px) * Theme.r-scale;
                background: i <= root.phase ? Palette.mint : Palette.field-border;
                animate width, background {
                    duration: 220ms;
                    easing: ease-out;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "darkmatter";
                horizontal-alignment: center;
                color: Palette.text-hi;
                font-size: (22px) * Theme.fs-scale;
                font-weight: 700;
                font-family: Theme.font;
            }

            Rectangle {
                height: 18px;
                status-text := Text {
                    text: root.status;
                    horizontal-alignment: center;
                    color: Palette.text-mid;
                    font-size: (12px) * Theme.fs-scale;
                    font-family: Theme.font;
                    x: (parent.width - self.width) / 2;
                    y: 0;
                }

                if Theme.pixel-icons: Rectangle {
                    width: 8px;
                    height: (12px) * Theme.fs-scale;
                    x: status-text.x + status-text.width + 2px;
                    y: 2px;
                    background: Palette.mint;
                    property <float> blink: 1.0;
                    init => {
                        self.blink = 0.0;
                    }
                    opacity: self.blink;
                    animate blink {
                        duration: 600ms;
                        iteration-count: -1;
                        direction: alternate;
                        easing: ease-in-out;
                    }
                }
            }
        }
    }
}
