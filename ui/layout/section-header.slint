import { Palette, Theme } from "../tokens.slint";

export component SectionHeader inherits HorizontalLayout {
    in property <string> label;
    in property <string> note;

    height: 24px;
    spacing: 8px;
    alignment: start;

    Text {
        text: root.label;
        color: Palette.text-mid;
        font-size: Theme.fs(10px, 14px);
        font-weight: 700;
        letter-spacing: 1.4px;
        vertical-alignment: center;
    }

    if root.note != "": Text {
        text: root.note;
        color: Palette.text-lo;
        font-size: Theme.fs(10px, 14px);
        font-weight: 600;
        vertical-alignment: center;
    }
    Rectangle {
        horizontal-stretch: 1;
    }

    VerticalLayout {
        alignment: center;
        @children
    }
}
