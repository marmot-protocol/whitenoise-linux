import { Palette, Theme } from "../tokens.slint";

// Full-width notice plate: icon slot (@children) beside a bold title and a
// wrapping detail line. Neutral by default; pass the scheme colors for
// warning/danger tones (bg, border-color, title-color, and the icon stroke).
export component InfoBanner inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <color> title-color: Palette.text-hi;
    // Wrapping the detail is opt-in: inside a width-tracking ScrollView a
    // wrapping Text creates a width↔height binding loop, so only enable it
    // where the banner's width is fixed (e.g. the login card).
    in property <bool> wrap-detail: false;

    height: 64px;
    background: Palette.banner;
    border-radius: (8px) * Theme.r-scale;
    border-width: 1px;
    border-color: Palette.border-2;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 12px;
        VerticalLayout {
            alignment: center;
            @children
        }

        VerticalLayout {
            spacing: 3px;
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.title;
                color: root.title-color;
                font-size: Theme.fs(12px, 16px);
                font-weight: 700;
            }

            Text {
                text: root.detail;
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                wrap: root.wrap-detail ? word-wrap : no-wrap;
            }
        }
    }
}
