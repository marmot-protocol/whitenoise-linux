import { Palette, Theme } from "../tokens.slint";

export component GroupCard inherits Rectangle {
    background: Palette.panel;
    border-radius: (8px) * Theme.r-scale;
    border-width: Theme.border-w;
    border-color: Palette.card-border;
    drop-shadow-color: Theme.hard-shadow ? Palette.shadow : transparent;
    drop-shadow-offset-x: Theme.hard-shadow ? 3px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 3px : 0px;
    drop-shadow-blur: 0px;
    VerticalLayout {
        spacing: 0;
        @children
    }
}
