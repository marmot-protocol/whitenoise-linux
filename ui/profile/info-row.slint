import { Palette, Theme } from "../tokens.slint";

export component InfoRow inherits Rectangle {
    in property <string> label;
    in property <string> sublabel;
    in property <string> value;
    in property <bool> show-divider: true;

    height: 56px;
    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        padding-top: 10px; padding-bottom: 10px;
        spacing: 14px;
        alignment: stretch;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 3px;
            alignment: center;
            Text {
                text: root.label;
                color: Palette.text-hi;
                font-size: (12px) * Theme.fs-scale;
                font-weight: 700;
            }
            if root.sublabel != "" : Text {
                text: root.sublabel;
                color: Palette.text-lo;
                font-size: (11px) * Theme.fs-scale;
            }
        }
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: end;
                spacing: 10px;
                if root.value != "" : Text {
                    text: root.value;
                    color: Palette.text-hi;
                    font-size: (12px) * Theme.fs-scale;
                    font-family: Theme.font;
                    vertical-alignment: center;
                }
                @children
            }
        }
    }
    if root.show-divider : Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}
