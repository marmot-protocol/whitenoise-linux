import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { CameraIcon } from "../icons/camera-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { Avatar } from "../primitives/avatar.slint";
import { ScrollView } from "../primitives/scroll-view.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Button, MicroButton } from "../primitives/button.slint";
import { StatusLine } from "../primitives/status-line.slint";
import { ProfileQrPlate } from "profile-qr-plate.slint";

// Single editable field row used by the edit form.
component FieldRow inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in property <bool> single-line: true;
    in property <bool> show-divider: true;
    in-out property <string> text <=> input.text;
    height: root.single-line ? 64px : 96px;
    VerticalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 6px;
        Text {
            text: root.label;
            color: Palette.text-hi;
            font-size: Theme.fs(12px, 16px);
            font-weight: 700;
        }

        Rectangle {
            background: Palette.bg;
            border-width: 1px;
            border-color: input.has-focus ? Palette.mint-dim : Palette.border-2;
            drop-shadow-blur: input.has-focus && Theme.focus-glow ? 10px : 0px;
            drop-shadow-color: Palette.mint-glow;
            animate border-color {
                duration: 140ms;
                easing: ease-out;
            }
            border-radius: (6px) * Theme.r-scale;
            vertical-stretch: 1;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 6px;
                padding-bottom: 6px;
                input := LineInput {
                    horizontal-stretch: 1;
                    placeholder: root.placeholder;
                    single-line: root.single-line;
                    // Multi-line rows (About) need plain Enter to insert a
                    // newline instead of firing the unbound submit callback.
                    enter-submits: root.single-line;
                    fg: Palette.text-hi;
                    placeholder-color: Palette.text-lo;
                }
            }
        }
    }

    if root.show-divider: Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }
}

// Picture row: an upload-to-Blossom button alongside the URL field, so the user
// can either pick a local file (uploaded for them) or paste a URL directly.
component PictureField inherits Rectangle {
    in-out property <string> text <=> input.text;
    in property <bool> uploading: false;
    callback upload-clicked();
    height: 96px;
    VerticalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 6px;
        Text {
            text: @tr("Picture");
            color: Palette.text-hi;
            font-size: Theme.fs(12px, 16px);
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 1;
            Rectangle {
                horizontal-stretch: 1;
                background: Palette.bg;
                border-width: 1px;
                border-color: input.has-focus ? Palette.mint-dim : Palette.border-2;
                drop-shadow-blur: input.has-focus && Theme.focus-glow ? 10px : 0px;
                drop-shadow-color: Palette.mint-glow;
                animate border-color {
                    duration: 140ms;
                    easing: ease-out;
                }
                border-radius: (6px) * Theme.r-scale;
                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    input := LineInput {
                        horizontal-stretch: 1;
                        placeholder: @tr("https://… or upload a file →");
                        single-line: true;
                        fg: Palette.text-hi;
                        placeholder-color: Palette.text-lo;
                    }
                }
            }

            Button {
                label: root.uploading ? @tr("Uploading…") : @tr("Upload");
                button-height: 40px;
                button-width: 120px;
                bg-color: Palette.mint-surface;
                fg: Palette.mint;
                outline: Palette.mint;
                hover-bg: Palette.mint-surface;
                clicked => {
                    if (!root.uploading) {
                        root.upload-clicked();
                    }
                }
                CameraIcon {
                    stroke: Palette.mint;
                }
            }
        }
    }
}

// Compact badge used under the display name (nip-05 / lightning) — only shown
// when the value is present.
component MetaChip inherits Rectangle {
    in property <string> text;
    in property <string> glyph;
    in property <color> tint: Palette.mint;
    height: 22px;
    background: Theme.soft-decor ? Palette.mint-surface : Palette.panel-2;
    border-radius: (11px) * Theme.r-scale;
    border-width: Theme.border-w;
    border-color: Theme.outline-surfaces ? Palette.card-border : transparent;
    HorizontalLayout {
        padding-left: 9px;
        padding-right: 10px;
        spacing: 5px;
        alignment: center;
        Text {
            text: root.glyph;
            color: root.tint;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            vertical-alignment: center;
        }

        Text {
            text: root.text;
            color: Theme.soft-decor ? root.tint : Palette.text-hi;
            font-size: Theme.fs(11px, 14px);
            font-weight: 600;
            font-family: Theme.font;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// Avatar with an in-place upload affordance. Tapping anywhere on the avatar
// while editing triggers an upload; a camera badge advertises it. We use a
// single full-cover TouchArea (no overlapping siblings) to dodge the Slint
// first-click-swallowing pitfall.
component AvatarEditable inherits Rectangle {
    in property <string> initials;
    in property <image> picture;
    in property <bool> has-picture: false;
    in property <bool> editing: false;
    in property <bool> uploading: false;
    // The picture download failed and the avatar fell back to initials; while
    // not editing, offer a retry instead of leaving it stuck on the fallback.
    in property <bool> failed: false;
    callback upload-clicked();
    callback retry-clicked();
    // Retry is offered only when the fetch failed, we are not editing (editing
    // already taps to upload), and no picture is currently shown.
    property <bool> show-retry: root.failed && !root.editing && !root.uploading && !root.has-picture;
    width: 96px;
    height: 96px;

    Avatar {
        size: 96px;
        initials: root.initials == "" ? "?" : root.initials;
        color-a: Palette.mint;
        color-b: Palette.mint-dim;
        picture: root.picture;
        has-picture: root.has-picture;
        a11y-label: AppState.profile-display-name != "" ? AppState.profile-display-name : root.initials;
        font-size: Theme.fs(34px, 40px);
    }

    // Dim + label while an upload is in flight.
    if root.uploading: Rectangle {
        width: 96px;
        height: 96px;
        border-radius: (48px) * Theme.r-scale;
        background: Palette.media-chip-bg;
        Text {
            text: @tr("Uploading…");
            color: Palette.media-chip-fg;
            font-size: Theme.fs(10px, 14px);
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Camera badge (decorative — the whole avatar is the hit target).
    if root.editing && !root.uploading: Rectangle {
        x: parent.width - self.width - 2px;
        y: parent.height - self.height - 2px;
        width: 30px;
        height: 30px;
        border-radius: (15px) * Theme.r-scale;
        background: Palette.mint;
        border-width: 2px;
        border-color: Palette.panel;
        CameraIcon {
            stroke: Palette.bubble-out-fg;
        }
    }

    if root.editing: TouchArea {
        width: 96px;
        height: 96px;
        mouse-cursor: pointer;
        clicked => {
            if (!root.uploading) {
                root.upload-clicked();
            }
        }
    }

    // Retry badge over the fallback initials when the picture failed to load.
    // The whole avatar is the hit target (below), so the badge only advertises.
    if root.show-retry: Rectangle {
        x: parent.width - self.width - 2px;
        y: parent.height - self.height - 2px;
        width: 30px;
        height: 30px;
        border-radius: (15px) * Theme.r-scale;
        background: Palette.danger;
        border-width: 2px;
        border-color: Palette.panel;
        RefreshIcon {
            stroke: white;
        }
    }

    if root.show-retry: TouchArea {
        width: 96px;
        height: 96px;
        mouse-cursor: pointer;
        accessible-role: button;
        accessible-label: @tr("Retry loading profile picture");
        accessible-action-default => {
            root.retry-clicked();
        }
        clicked => {
            root.retry-clicked();
        }
    }
}

export component ProfilePage inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-width: 0px;
    preferred-height: 0px;
    background: Palette.bg;

    // Reads/writes AppState directly (profile-* form state, my-npub/my-qr,
    // my-av-* picture) and invokes its callbacks; the shell passes no bindings.
    // Leaf children below (FieldRow, PictureField, AvatarEditable, MetaChip,
    // ProfileQrPlate) stay pure-props.
    ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-height: page.preferred-height;
        viewport-width: self.visible-width;

        page := VerticalLayout {
            width: parent.width;
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 16px;
            padding-bottom: 24px;
            spacing: 20px;

            // ── Action header ──────────────────────────────────────────
            HorizontalLayout {
                height: 40px;
                spacing: 10px;
                alignment: stretch;
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 4px;
                    Text {
                        text: @tr("Your profile");
                        color: Palette.text-hi;
                        font-size: Theme.fs(18px, 20px);
                        font-weight: 700;
                    }

                    Text {
                        text: AppState.profile-editing ? @tr("EDITING · BROADCAST TO RELAYS ON SAVE") : @tr("VISIBLE TO ANYONE YOU CHAT WITH");
                        color: Palette.text-lo;
                        font-size: Theme.fs(10px, 14px);
                        font-weight: 600;
                        letter-spacing: 1.2px;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    if !AppState.profile-editing: Button {
                        label: @tr("Edit profile");
                        bg-color: Palette.mint;
                        fg: Palette.bubble-out-fg;
                        hover-bg: Palette.mint-hi;
                        hover-fg: Palette.bubble-out-fg;
                        outline: Palette.mint;
                        button-width: 128px;
                        button-height: 36px;
                        clicked => {
                            AppState.start-edit-profile();
                        }
                        Text {
                            text: "✎";
                            color: Palette.bubble-out-fg;
                            font-size: Theme.fs(12px, 16px);
                        }
                    }
                    if AppState.profile-editing: HorizontalLayout {
                        spacing: 8px;
                        Button {
                            label: AppState.profile-busy ? @tr("Saving…") : @tr("Save");
                            enabled: !AppState.profile-busy;
                            bg-color: Palette.mint;
                            fg: Palette.bubble-out-fg;
                            hover-bg: Palette.mint-hi;
                            hover-fg: Palette.bubble-out-fg;
                            outline: Palette.mint;
                            button-width: 96px;
                            button-height: 36px;
                            clicked => {
                                if (!AppState.profile-busy) {
                                    AppState.save-profile();
                                }
                            }
                        }

                        Button {
                            label: @tr("Cancel");
                            button-width: 80px;
                            button-height: 36px;
                            clicked => {
                                AppState.cancel-edit-profile();
                            }
                        }
                    }
                }
            }

            // ── Hero card: banner + overlapping avatar + headline ──────
            Rectangle {
                height: 188px;
                background: Palette.panel;
                border-radius: (12px) * Theme.r-scale;
                border-width: Theme.border-w;
                border-color: Palette.card-border;
                drop-shadow-color: Theme.hard-shadow ? Palette.shadow : transparent;
                drop-shadow-offset-x: Theme.hard-shadow ? 3px : 0px;
                drop-shadow-offset-y: Theme.hard-shadow ? 3px : 0px;
                clip: true;

                // Banner wash.
                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 96px;
                    background: Theme.soft-decor ? @linear-gradient(120deg, Palette.mint 0%, Palette.mint-dim 100%) : Palette.panel-2;
                    opacity: Theme.soft-decor ? 0.92 : 1.0;
                    Rectangle {
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Palette.card-border;
                    }
                }

                // Avatar overlapping the banner's lower edge.
                Rectangle {
                    x: 24px;
                    y: 48px;
                    width: 104px;
                    height: 104px;
                    border-radius: (52px) * Theme.r-scale;
                    background: Palette.panel;
                    AvatarEditable {
                        x: 4px;
                        y: 4px;
                        initials: AppState.profile-display-name;
                        picture: AppState.my-av-picture;
                        has-picture: AppState.my-av-has-picture;
                        editing: AppState.profile-editing;
                        uploading: AppState.profile-uploading;
                        failed: AppState.my-av-load-failed;
                        upload-clicked => {
                            AppState.upload-profile-picture();
                        }
                        retry-clicked => {
                            AppState.retry-profile-picture();
                        }
                    }
                }

                // Headline — name + identity chips, to the right of the avatar.
                VerticalLayout {
                    x: 144px;
                    y: 104px;
                    width: parent.width - 168px;
                    height: 76px;
                    spacing: 6px;
                    alignment: center;
                    Text {
                        text: AppState.profile-display-name == "" ? @tr("(no display name)") : AppState.profile-display-name;
                        color: Palette.text-hi;
                        font-size: Theme.fs(24px, 28px);
                        font-weight: 700;
                        overflow: elide;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        // The check only appears once the handle is confirmed
                        // against the domain's `.well-known/nostr.json` — the
                        // same rule contact-detail.slint and profile-modal.slint
                        // apply to everyone else's handle.
                        if AppState.profile-nip05 != "": MetaChip {
                            glyph: AppState.profile-nip05-verified ? "✓" : "";
                            text: AppState.profile-nip05;
                            tint: AppState.profile-nip05-verified ? Palette.mint : Palette.text-lo;
                        }
                        if AppState.profile-lud16 != "": MetaChip {
                            glyph: "⚡";
                            text: AppState.profile-lud16;
                            tint: Palette.mint-dim;
                        }
                        if AppState.profile-nip05 == "" && AppState.profile-lud16 == "": Text {
                            text: AppState.profile-name == "" ? @tr("no handle yet") : "@" + AppState.profile-name;
                            color: Palette.text-lo;
                            font-size: Theme.fs(12px, 16px);
                            font-family: Theme.font;
                            vertical-alignment: center;
                        }
                    }

                    if AppState.profile-about != "": Text {
                        text: AppState.profile-about;
                        color: Palette.text-mid;
                        font-size: Theme.fs(12px, 16px);
                        wrap: word-wrap;
                        overflow: elide;
                    }
                }
            }

            // ── Status line (errors / publish receipts) ────────────────
            if AppState.profile-status != "": StatusLine {
                text: AppState.profile-status;
                kind: AppState.profile-status-kind;
            }

            // ── Identity (always visible — copyable npub) ──────────────
            Section {
                label: @tr("IDENTITY");
                GroupCard {
                    KVRow {
                        label: "npub";
                        sublabel: @tr("Your public key. Safe to share.");
                        value: AppState.my-npub;
                        MicroButton {
                            label: @tr("Copy");
                            clicked => {
                                AppState.copy-to-clipboard(AppState.my-npub);
                            }
                            CopyIcon {
                                stroke: Palette.text-mid;
                            }
                        }
                    }

                    ProfileQrPlate {
                        qr: AppState.my-qr;
                    }
                }
            }

            // ── Edit form OR read-only summary ─────────────────────────
            if AppState.profile-editing: Section {
                label: @tr("EDIT");
                GroupCard {
                    FieldRow {
                        label: @tr("Display name");
                        placeholder: @tr("How your name appears in chats");
                        text <=> AppState.profile-display-name;
                    }

                    FieldRow {
                        label: @tr("Username");
                        placeholder: @tr("Short handle (no spaces)");
                        text <=> AppState.profile-name;
                    }

                    FieldRow {
                        label: @tr("About");
                        placeholder: @tr("A line or two about you");
                        single-line: false;
                        text <=> AppState.profile-about;
                    }

                    PictureField {
                        text <=> AppState.profile-picture;
                        uploading: AppState.profile-uploading;
                        upload-clicked => {
                            AppState.upload-profile-picture();
                        }
                    }

                    FieldRow {
                        label: @tr("NIP-05");
                        placeholder: "you@example.com";
                        text <=> AppState.profile-nip05;
                    }

                    FieldRow {
                        label: @tr("Lightning address (LUD-16)");
                        placeholder: "you@walletofsatoshi.com";
                        text <=> AppState.profile-lud16;
                        show-divider: false;
                    }
                }
            }

            if !AppState.profile-editing: Section {
                label: @tr("PROFILE");
                GroupCard {
                    KVRow {
                        label: @tr("Username");
                        value: AppState.profile-name == "" ? "—" : "@" + AppState.profile-name;
                    }

                    KVRow {
                        label: @tr("NIP-05");
                        value: AppState.profile-nip05 == "" ? "—" : AppState.profile-nip05;
                    }

                    KVRow {
                        label: @tr("Lightning");
                        value: AppState.profile-lud16 == "" ? "—" : AppState.profile-lud16;
                    }

                    KVRow {
                        label: @tr("Picture");
                        value: AppState.profile-picture == "" ? @tr("Not set") : @tr("Set");
                        show-divider: false;
                    }
                }
            }
        }
    }
}
