import { EmojiSheet } from "../tokens.slint";

// One-shot Telegram-style "message effect": a short burst of emoji-sprite
// particles flung from a chat bubble when a message is sent / arrives. Pure
// Slint animation — no Rust per-frame work. The motion profile is selected by
// `effect-id` (1 love · 2 fire · 3 party · 4 star · 5 like); the emoji drawn is
// whatever tile Rust resolved into `clip-x`/`clip-y` against the shared Twemoji
// sheet.
//
// Lifecycle: the burst is driven by `trigger` — any non-zero / changed value
// (re)starts it. The call site mounts the layer once the message has an effect
// and bumps `trigger` for the initial autoplay and on every replay click. It
// captures `animation-tick()` when fired, runs ~2.4s, then a Timer freezes the
// playhead so the otherwise free-running tick stops forcing repaints.
//
// Particles are deterministic: each draws its direction / speed / size / birth
// stagger from fract(sin(i·k)) seeds — same trick the inline text effects use —
// so there is no RNG to thread and rebuilds look identical.
export component MessageEffectLayer inherits Rectangle {
    in property <int> effect-id;
    in property <int> clip-x;
    in property <int> clip-y;
    // The bubble's box, so the emission origin can sit at its centre.
    in property <length> origin-w;
    in property <length> origin-h;
    // Bump to (re)play. The row sets it for autoplay and increments it on click.
    in property <int> trigger;

    clip: false;
    // Never intercept pointer input — the bubble underneath keeps its hover /
    // click / context-menu affordances.
    property <duration> t0;
    property <bool> playing: false;
    function fire() {
        root.t0 = animation-tick();
        root.playing = true;
        // Restart the stop-timer from zero even mid-burst.
        life.running = false;
        life.running = true;
    }
    init => {
        if (root.trigger > 0) {
            root.fire();
        }
    }
    changed trigger => {
        if (root.trigger > 0) {
            root.fire();
        }
    }
    // Elapsed seconds since the last fire while playing; frozen at 99 once the
    // burst ends so the tick is no longer read and repaints stop.
    property <float> tsec: root.playing ? (animation-tick() - root.t0) / 1s : 99;
    life := Timer {
        interval: 2.9s;
        running: false;
        triggered => {
            root.playing = false;
            self.running = false;
        }
    }

    // Particle count + tile size by effect — confetti wants a dense burst,
    // hearts/thumbs a sparser stream.
    property <int> pcount:
        root.effect-id == 4 ? 28 : root.effect-id == 3 ? 24 : root.effect-id == 2 ? 22 : root.effect-id == 1 ? 13 : root.effect-id == 5 ? 11 : 16;
    property <length> ox: root.origin-w / 2;
    // Risers emit low on the bubble; bursts from the middle.
    property <length> oy: root.origin-h * (root.effect-id == 1 ? 0.62 : root.effect-id == 2 ? 0.88 : root.effect-id == 5 ? 0.76 : 0.5);
    property <length> tile: 26px;

    for i in root.pcount: Image {
        // Per-particle fract(sin) seeds in [0,1) — independent axes, deterministic.
        property <float> r-dir-raw: sin((i + 1) * 137.5deg) * 731.7;
        property <float> r-spd-raw: sin((i + 1) * 71.3deg + 19deg) * 419.2;
        property <float> r-sz-raw:  sin((i + 1) * 43.9deg + 7deg) * 257.1;
        property <float> r-stg-raw: sin((i + 1) * 97.1deg + 3deg) * 613.3;
        property <float> r-spin-raw: sin((i + 1) * 53.7deg + 11deg) * 311.9;
        property <float> seed-dir: r-dir-raw - floor(r-dir-raw);
        property <float> seed-spd: r-spd-raw - floor(r-spd-raw);
        property <float> seed-sz:  r-sz-raw - floor(r-sz-raw);
        property <float> seed-stg: r-stg-raw - floor(r-stg-raw);
        property <float> seed-spin: r-spin-raw - floor(r-spin-raw);

        // Local clock in SECONDS — physics below is real velocity/gravity, not a
        // normalised lerp, so particles keep moving until they fade (no freeze).
        property <float> dur:
            root.effect-id == 1 ? 1.7 : root.effect-id == 2 ? 1.0 : root.effect-id == 3 ? 1.9 : root.effect-id == 4 ? 1.5 : 1.4;
        property <float> stg: seed-stg * (root.effect-id == 1 ? 0.8 : root.effect-id == 2 ? 0.8 : root.effect-id == 3 ? 0.12 : root.effect-id == 4 ? 0.12 : 0.35);
        property <float> t: clamp(root.tsec - stg, 0, dur);
        property <bool> alive: root.tsec > stg;
        property <float> p-life: clamp(t / dur, 0, 1);

        // Shared geometry for the radial/launch effects.
        property <angle> ang-launch: -90deg + (seed-dir - 0.5) * 120deg;   // confetti fan, upward
        property <float> v0: 175 + seed-spd * 175;                          // confetti muzzle speed (px/s)
        // Stars: golden-angle scatter to VARIED radii (a field, not a ring),
        // popped out on an ease-out then a slow continued drift.
        property <angle> ang-star: (i * 137.508deg) + (seed-dir - 0.5) * 24deg;
        property <float> star-R: 16 + seed-spd * 66;
        property <float> star-ease: 1 - (1 - clamp(t / 0.42, 0, 1)) * (1 - clamp(t / 0.42, 0, 1)) * (1 - clamp(t / 0.42, 0, 1));
        property <float> star-dist: star-R * star-ease + max(0, t - 0.42) * 14;

        // ── Horizontal displacement ──
        property <length> dx:
            // hearts: spread across the bubble, gentle sway as they rise
            root.effect-id == 1 ? ((seed-dir - 0.5) * root.origin-w * 0.5 + sin((t * 1.5 + seed-dir * 6.283) * 1rad) * (6px + seed-sz * 10px))
            // fire: wide flickering base that TAPERS toward centre as it rises
            // (flame shape), plus turbulence growing with height.
            : root.effect-id == 2 ? ((seed-dir - 0.5) * root.origin-w * 0.5 * (1 - 0.75 * p-life) + (sin((t * 9 + seed-dir * 6.283) * 1rad) * 5px + sin((t * 17 + seed-sz * 6.283) * 1rad) * 3px) * (0.3 + p-life))
            // confetti: ballistic — horizontal muzzle component, constant
            : root.effect-id == 3 ? (cos(ang-launch) * v0 * t * 1px)
            // stars: scatter outward to varied radii, then drift (a star field)
            : root.effect-id == 4 ? (cos(ang-star) * star-dist * 1px + sin((t * 2 + seed-spin * 6.283) * 1rad) * 3px)
            // thumbs: small fixed spread
            : ((seed-dir - 0.5) * root.origin-w * 0.42);
        // ── Vertical displacement (negative = up) ──
        property <length> dy:
            // hearts: steady rise off the top
            root.effect-id == 1 ? (-(50px + seed-spd * 45px) * t)
            // fire: accelerating rise (licks up off the bottom)
            : root.effect-id == 2 ? (-(95px * t + 55px * t * t))
            // confetti: real cannon arc — launch up, gravity pulls back down
            : root.effect-id == 3 ? ((sin(ang-launch) * v0 * t + 0.5 * 540 * t * t) * 1px)
            // stars: scatter outward with a slight upward bias, then hold/drift
            : root.effect-id == 4 ? ((sin(ang-star) * star-dist - 12 * star-ease) * 1px)
            // thumbs: rise
            : (-(44px + seed-spd * 36px) * t);

        // ── Size: per-glyph base × effect entrance/life ──
        property <float> base-scale: root.effect-id == 3 ? (0.5 + seed-sz * 0.55) : (0.62 + seed-sz * 0.5);
        // Back-overshoot pop (confetti + thumbs snap in past 1.0 then settle).
        property <float> u-pop: clamp(t / 0.16, 0, 1);
        property <float> back: 1 + 2.70158 * (u-pop - 1) * (u-pop - 1) * (u-pop - 1) + 1.70158 * (u-pop - 1) * (u-pop - 1);
        property <float> sc-mul:
            root.effect-id == 1 ? (0.55 + 0.45 * clamp(t / 0.4, 0, 1))                                                 // grow in
            // fire: big & hot at the base, shrinks to a tip, hard flicker
            : root.effect-id == 2 ? ((1.35 - 0.85 * p-life) * (1 + 0.22 * sin((root.tsec * 26 + seed-dir * 6.283) * 1rad))) : root.effect-id == 3 ? back
            // stars: pop in, then HOLD at size with a twinkle pulse (so the whole
            // field stays visible and sparkles, rather than flying away).
            : root.effect-id == 4 ? (clamp(t / 0.14, 0, 1) * (0.72 + 0.42 * abs(sin((root.tsec * 6 + i * 0.6 + seed-spin * 6.283) * 1rad)))) : back;
        property <length> sz: root.tile * base-scale * max(0, sc-mul);

        // ── Rotation ──
        property <angle> spin:
            root.effect-id == 1 ? ((seed-spin - 0.5) * 18deg * sin((t * 1.4) * 1rad))    // heart sway
            : root.effect-id == 2 ? ((seed-spin - 0.5) * 10deg)                          // flame lean
            : root.effect-id == 3 ? ((seed-spin < 0.5 ? -1 : 1) * (1.0 + seed-spd * 2.0) * t * 1turn) // confetti tumble
            : root.effect-id == 4 ? ((seed-spin - 0.5) * 0.5 * t * 1turn)                // star slow drift-spin
            : ((seed-spin - 0.5) * 14deg * sin((t * 2.2) * 1rad));                       // thumb wobble

        // ── Opacity: snap in, effect-appropriate fade-out ──
        property <float> op-in: clamp(t / 0.09, 0, 1);
        property <float> op-gen-out: 1 - clamp((t - (dur - 0.5)) / 0.5, 0, 1);
        // fire: bright low, fade as it rises, with a hot flicker.
        property <float> op-fire-out: (1 - p-life * p-life) * (0.78 + 0.22 * abs(sin((root.tsec * 24 + seed-dir * 6.283) * 1rad)));
        // stars: hold bright (twinkling) most of the life, fade over the last 0.6s.
        property <float> op-star-out: (1 - clamp((t - (dur - 0.6)) / 0.6, 0, 1)) * (0.5 + 0.5 * abs(sin((root.tsec * 7 + i * 1.0 + seed-spin * 6.283) * 1rad)));
        opacity: alive ? (op-in * (root.effect-id == 2 ? op-fire-out : (root.effect-id == 4 ? op-star-out : op-gen-out))) : 0;

        source: EmojiSheet.sprite;
        source-clip-x: root.clip-x;
        source-clip-y: root.clip-y;
        source-clip-width: EmojiSheet.tile;
        source-clip-height: EmojiSheet.tile;
        width: sz;
        height: sz;
        transform-rotation: spin;
        x: root.ox + dx - self.width / 2;
        y: root.oy + dy - self.height / 2;
    }
}
