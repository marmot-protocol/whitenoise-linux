import { Palette, Theme, QuickReact, TextSelection } from "../tokens.slint";
import { QuickReactCell } from "quick-react-cell.slint";
import { MenuItem } from "../primitives/menu-item.slint";
import { AppState } from "../shell/app-state.slint";


// Right-click context menu for a message bubble. Mounted full-window (like
// EmojiPicker) so the invisible backdrop catches outside clicks; the panel
// sits at the anchor point, clamped inside the window. The message this menu
// acts on is `AppState.ctx-menu-id`, so the quick-reaction strip can fire
// `QuickReact.react` directly without a callback per emoji.
export component MessageContextMenu inherits Rectangle {
    property <bool> can-edit: AppState.ctx-menu-can-edit;
    // True when the message has body text to copy (attachment-only messages
    // don't). Gates the "Copy text" row.
    property <bool> can-copy: AppState.ctx-menu-text != "";
    // True when this message holds the active text selection. Gates the
    // "Copy selection" row; implies can-copy (a selection needs body lines).
    property <bool> has-selection: TextSelection.active && TextSelection.owner == AppState.ctx-menu-id && TextSelection.a-line >= 0 && TextSelection.b-line >= 0;
    // Developer mode: reveals a "View raw event" row at the tail of the menu.
    property <bool> debug-enabled: AppState.debug-enabled;
    // Called with the panel's clamped position so the emoji picker can open
    // where the menu was.
    function add-reaction(ax: length, ay: length) {
        AppState.ctx-menu-open = false;
        AppState.emoji-picker-requested(AppState.ctx-menu-id, ax, ay);
    }
    function reply() {
        AppState.ctx-menu-open = false;
        AppState.request-reply(AppState.ctx-menu-id, AppState.ctx-menu-text, AppState.ctx-menu-author);
    }
    // The "Forward" item stashes the source message id in
    // `AppState.forward-src-id` and opens the forward picker.
    function forward() {
        AppState.ctx-menu-open = false;
        AppState.forward-src-id = AppState.ctx-menu-id;
        AppState.forward-picker-open = true;
    }
    function copy-text() {
        AppState.ctx-menu-open = false;
        AppState.copy-to-clipboard(AppState.ctx-menu-text);
    }
    function copy-selection() {
        AppState.ctx-menu-open = false;
        AppState.copy-selection(AppState.ctx-menu-id,
            TextSelection.a-line, TextSelection.a-run, TextSelection.a-frac,
            TextSelection.b-line, TextSelection.b-run, TextSelection.b-frac);
    }
    function edit() {
        AppState.ctx-menu-open = false;
        AppState.request-edit(AppState.ctx-menu-id, AppState.ctx-menu-text);
    }
    // "Delete for everyone" (kind-5 retraction) — author-only, so gated by
    // can-edit. "Delete for me" is a local-only hide, available on any message.
    // Deletes are destructive, so both arm the confirm modal instead of firing
    // immediately; `delete-confirm-everyone` picks the wording + which callback
    // the confirm dispatches, and the target is still `ctx-menu-id`.
    function delete-for-everyone() {
        AppState.ctx-menu-open = false;
        AppState.delete-confirm-everyone = true;
        AppState.show-delete-confirm = true;
    }
    function delete-for-me() {
        AppState.ctx-menu-open = false;
        AppState.delete-confirm-everyone = false;
        AppState.show-delete-confirm = true;
    }
    // Developer-mode "View raw event" (debug-enabled only).
    function view-raw() {
        AppState.ctx-menu-open = false;
        AppState.view-raw-event(AppState.ctx-menu-id);
    }
    function dismissed() {
        AppState.ctx-menu-open = false;
    }

    // Keyboard navigation. Rows are ordered so the visible set is always the
    // contiguous [0, count-1]: the two copy rows sit between Forward and
    // Delete for me and shift the tail indices when shown, and the
    // author-only rows close the list:
    //   0 = Add reaction, 1 = Reply, 2 = Forward             (always)
    //   3 = Copy text                                        (can-copy)
    //   4 = Copy selection                                   (has-selection)
    //   idx-del-me = Delete for me                           (always)
    //   idx-del-me + 1 = Edit, + 2 = Delete for everyone     (author-only)
    //   idx-view-raw = View raw event                        (debug-enabled)
    property <int> n-copy: root.can-copy ? 1 : 0;
    property <int> n-sel: root.has-selection ? 1 : 0;
    property <int> n-edit: root.can-edit ? 2 : 0;
    property <int> n-debug: root.debug-enabled ? 1 : 0;
    property <int> idx-del-me: 3 + root.n-copy + root.n-sel;
    property <int> idx-view-raw: root.idx-del-me + 1 + root.n-edit;
    property <int> item-count: 4 + root.n-copy + root.n-sel + root.n-edit + root.n-debug;
    property <int> selected-index: 0;

    function move-selection(delta: int) {
        root.selected-index = min(max(0, root.selected-index + delta), root.item-count - 1);
    }
    // Tab wraps around the list rather than escaping the menu.
    function wrap-selection(delta: int) {
        // Manual modulo so this doesn't depend on a Math.mod builtin.
        if (root.selected-index + delta < 0) {
            root.selected-index = root.item-count - 1;
        } else if (root.selected-index + delta >= root.item-count) {
            root.selected-index = 0;
        } else {
            root.selected-index = root.selected-index + delta;
        }
    }
    function activate-selected() {
        if (root.selected-index == 0) {
            root.add-reaction(root.px, root.py);
        } else if (root.selected-index == 1) {
            root.reply();
        } else if (root.selected-index == 2) {
            root.forward();
        } else if (root.selected-index == 3 && root.can-copy) {
            root.copy-text();
        } else if (root.selected-index == 4 && root.has-selection) {
            root.copy-selection();
        } else if (root.selected-index == root.idx-del-me) {
            root.delete-for-me();
        } else if (root.selected-index == root.idx-del-me + 1 && root.can-edit) {
            root.edit();
        } else if (root.selected-index == root.idx-del-me + 2 && root.can-edit) {
            root.delete-for-everyone();
        } else if (root.selected-index == root.idx-view-raw && root.debug-enabled) {
            root.view-raw();
        }
    }

    // Backdrop — invisible, dismisses on a click or another right-click
    // outside the panel.
    TouchArea {
        clicked => {
            root.dismissed();
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.right) {
                root.dismissed();
            }
        }
    }

    // Clamp the panel inside the window with a small inset. The anchor point
    // (top-left of the panel, in window coords) comes from AppState.
    property <length> inset: 8px;
    property <length> px: min(max(root.inset, AppState.ctx-menu-x), root.width - panel.width - root.inset);
    property <length> py: min(max(root.inset, AppState.ctx-menu-y), root.height - panel.height - root.inset);

    // Open animation — same flip-after-mount trick as EmojiPicker.
    property <bool> opened: false;
    init => {
        root.opened = true;
        root.selected-index = 0;
        keys.focus();
    }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -4px);
        width: max(150px, col.preferred-width);
        height: col.preferred-height;
        opacity: root.opened ? 1.0 : 0.0;
        animate opacity {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        animate y {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        background: Palette.elevated;
        border-radius: (10px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 14px;

        // Swallow any click inside the panel that no item claims. Wrapping
        // the content (rather than being a sibling) guarantees the nested
        // item TouchAreas win the hit-test — see emoji-picker.slint.
        TouchArea {
            col := VerticalLayout {
                padding: 4px;
                spacing: 1px;
                // One-tap quick reactions, ending in a "+" to the full picker.
                // Mouse-first; keyboard users reach the same picker through the
                // "Add reaction" item below (the strip skips the arrow-key
                // index model, which stays a single vertical list).
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    padding-top: 2px;
                    padding-bottom: 2px;
                    spacing: 1px;
                    alignment: start;
                    for e in QuickReact.list: QuickReactCell {
                        emoji: e.emoji;
                        clip-x: e.clip-x;
                        clip-y: e.clip-y;
                        clicked => {
                            QuickReact.react(AppState.ctx-menu-id, e.emoji);
                            root.dismissed();
                        }
                    }

                    QuickReactCell {
                        emoji: "+";
                        clicked => {
                            root.add-reaction(root.px, root.py);
                        }
                    }
                }

                // Divider under the strip.
                Rectangle {
                    height: 7px;
                    Rectangle {
                        x: 6px;
                        y: 3px;
                        width: parent.width - 12px;
                        height: 1px;
                        background: Palette.border-2;
                    }
                }

                MenuItem {
                    glyph: "☺";
                    label: @tr("Add reaction");
                    selected: root.selected-index == 0;
                    activated => {
                        root.add-reaction(root.px, root.py);
                    }
                    hovered => {
                        root.selected-index = 0;
                    }
                }

                MenuItem {
                    glyph: "↩";
                    label: @tr("Reply");
                    selected: root.selected-index == 1;
                    activated => {
                        root.reply();
                    }
                    hovered => {
                        root.selected-index = 1;
                    }
                }

                MenuItem {
                    glyph: "➦";
                    label: @tr("Forward");
                    selected: root.selected-index == 2;
                    activated => {
                        root.forward();
                    }
                    hovered => {
                        root.selected-index = 2;
                    }
                }

                MenuItem {
                    glyph: "⧉";
                    label: @tr("Copy text");
                    shown: root.can-copy;
                    selected: root.can-copy && root.selected-index == 3;
                    activated => {
                        root.copy-text();
                    }
                    hovered => {
                        root.selected-index = 3;
                    }
                }

                MenuItem {
                    glyph: "⧉";
                    label: @tr("Copy selection");
                    shown: root.has-selection;
                    selected: root.has-selection && root.selected-index == 4;
                    activated => {
                        root.copy-selection();
                    }
                    hovered => {
                        root.selected-index = 4;
                    }
                }

                MenuItem {
                    glyph: "⌫";
                    label: @tr("Delete for me");
                    selected: root.selected-index == root.idx-del-me;
                    activated => {
                        root.delete-for-me();
                    }
                    hovered => {
                        root.selected-index = root.idx-del-me;
                    }
                }

                MenuItem {
                    glyph: "✎";
                    label: @tr("Edit message");
                    shown: root.can-edit;
                    selected: root.selected-index == root.idx-del-me + 1;
                    activated => {
                        root.edit();
                    }
                    hovered => {
                        root.selected-index = root.idx-del-me + 1;
                    }
                }

                MenuItem {
                    glyph: "⊘";
                    label: @tr("Delete for everyone");
                    shown: root.can-edit;
                    selected: root.selected-index == root.idx-del-me + 2;
                    activated => {
                        root.delete-for-everyone();
                    }
                    hovered => {
                        root.selected-index = root.idx-del-me + 2;
                    }
                }

                MenuItem {
                    glyph: "{ }";
                    label: @tr("View raw event");
                    shown: root.debug-enabled;
                    selected: root.selected-index == root.idx-view-raw;
                    activated => {
                        root.view-raw();
                    }
                    hovered => {
                        root.selected-index = root.idx-view-raw;
                    }
                }
            }
        }
    }

    // Keyboard handling — focused on mount so keys land here. Esc dismisses;
    // Up/Down (and Tab/Backtab) move the selection, Home/End jump to the
    // first/last item; Return/Enter activates.
    keys := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            if (e.text == Key.UpArrow) {
                root.move-selection(-1);
                return accept;
            }
            if (e.text == Key.DownArrow) {
                root.move-selection(1);
                return accept;
            }
            if (e.text == Key.Home) {
                root.selected-index = 0;
                return accept;
            }
            if (e.text == Key.End) {
                root.selected-index = root.item-count - 1;
                return accept;
            }
            if (e.text == Key.Tab) {
                root.wrap-selection(1);
                return accept;
            }
            if (e.text == Key.Backtab) {
                root.wrap-selection(-1);
                return accept;
            }
            if (e.text == Key.Return) {
                root.activate-selected();
                return accept;
            }
            return reject;
        }
    }
}
