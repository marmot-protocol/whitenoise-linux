// messages area — driven by a model fed from Rust.
//
// Virtualized: the rows live in a ListView, so only visible messages are
// instantiated (opening a chat builds ~a screenful, not the whole 80-row
// window). Two consequences vs. the old full-materialize ScrollView:
//   - `viewport-height` is an ESTIMATE that refines as rows instantiate; the
//     stick-to-bottom logic self-corrects through `changed bottom-y`.
//   - Off-screen rows have no geometry, so jump-to-message and the
//     load-older anchor run in two phases: scroll near the target row by
//     index (estimated), then snap exactly when the target instantiates and
//     reports its real position (see scroll-target machinery below).
import { ListView } from "std-widgets.slint";
import { AppState } from "../shell/app-state.slint";
import { Palette, Theme, ChatMessage } from "../tokens.slint";
import { MessageView } from "message-view.slint";
import { MessageEffectLayer } from "message-effect-layer.slint";
import { PaperDoodles } from "../theme-decor/paper-doodles.slint";
import { SynthGrid } from "../theme-decor/synth-grid.slint";
import { ChevronDownIcon } from "../icons/chevron-down-icon.slint";
import { ChatBubbleIcon } from "../icons/chat-bubble-icon.slint";
import { SessionDivider } from "../main-pane/session-divider.slint";
import { EmptyState } from "../layout/empty-state.slint";

// One slot in the effect-burst pool. `gen` is a per-slot generation counter —
// bumping it (re)fires that slot's layer; the position/effect fields say where
// and what. Default (all-zero, gen 0) = an idle slot that never plays.
struct EffectBurst {
    x: length,
    y: length,
    w: length,
    h: length,
    id: int,
    cx: int,
    cy: int,
    gen: int,
}

export component MessagesArea inherits Rectangle {
    // Reads AppState directly: the open chat's rows, loading flag, and the
    // scroll/jump ticks. Actions are invoked by the rows themselves (also via
    // AppState); only per-row data flows down the tree.
    property <[ChatMessage]> messages: AppState.chats-messages[AppState.active-chat];
    in property <length> available-w: 9999px;
    property <bool> loading: AppState.messages-loading;
    // Bumped by Rust whenever a fresh outgoing message lands. The `changed`
    // handler below jumps the viewport to the bottom so the user always sees
    // the message they just sent. (Local mirrors of the AppState ticks — a
    // `changed` handler must sit on a property of the declaring element.)
    property <int> scroll-tick: AppState.messages-scroll-tick;
    property <int> jump-tick: AppState.message-jump-tick;
    // Bumped by Rust on opening a chat that had unread messages: scroll so the
    // "New messages" divider (above message-unread-index) lands near the top.
    property <int> unread-tick: AppState.message-unread-tick;
    // True when older history exists beyond the loaded window; shows the
    // "load earlier messages" pill at the top of the list.
    property <bool> has-older: AppState.messages-has-older;
    property <length> content-w: max(120px, root.available-w - 36px);

    // Message-effect stage. A pool of overlay layers (declared after the scroll,
    // so they paint above every bubble) plays bursts. Rows report their bubble's
    // window position + size via `play-effect`; we convert to overlay-local
    // coords, write the next round-robin slot, and bump that slot's `gen` to
    // fire. Each layer binds to its own slot, so a new burst STACKS instead of
    // interrupting the ones already playing (Telegram-style). 8 concurrent.
    property <[EffectBurst]> bursts: [{ }, { }, { }, { }, { }, { }, { }, { }];
    property <int> burst-next: 0;
    function stage-effect(eid: int, cx: int, cy: int, ax: length, ay: length, w: length, h: length) {
        root.bursts[root.burst-next] = {
            // Window coords → overlay-local (the clip wrapper fills root at 0,0).
            x: ax - fx-clip.absolute-position.x,
            y: ay - fx-clip.absolute-position.y,
            w: w,
            h: h,
            id: eid,
            cx: cx,
            cy: cy,
            gen: root.bursts[root.burst-next].gen + 1,
        };
        root.burst-next = root.burst-next + 1 < 8 ? root.burst-next + 1 : 0;
    }
    // Subtle vertical lift — keeps the chat canvas from feeling flat.
    background: Theme.soft-decor ? @linear-gradient(180deg, Palette.canvas-top 0%, Palette.bg 28%) : Palette.bg;

    // Hand-drawn paper backdrop: faint cute shapes scattered behind the message
    // list. Declared before `cs` so it sits behind the (transparent) scroll;
    // fixed to the viewport, so it reads as paper rather than scrolling content.
    if Theme.paper-doodles: PaperDoodles {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
    }
    // Synthwave neon grid + sunset backdrop, same fixed-to-viewport placement.
    if Theme.synth-grid: SynthGrid {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
    }

    // Computed "stick to bottom" position. We don't bind viewport-y directly
    // to this (that would override manual scrolling) — instead the auto-follow
    // below imperatively snaps to it at the right moments.
    property <length> bottom-y: -max(0px, cs.viewport-height - cs.visible-height);
    // True when the user is within 40px of the bottom — used to auto-follow
    // incoming messages without yanking the scroll out from under them if
    // they've explicitly paged up to read history.
    property <bool> at-bottom: (-cs.viewport-y) >= (-root.bottom-y) - 40px;

    // ── Auto-follow (stick-to-bottom) ──────────────────────────────────────
    // The list is a virtualized ListView whose total height is an ESTIMATE
    // that refines as rows instantiate, so `bottom-y` jitters while you scroll
    // and whenever a row re-measures (a wrapped Markdown body, a reaction row).
    // The follow must NOT chase every `bottom-y` change: doing so re-snapped
    // the viewport on pure estimate noise (the idle "settling" twitch) and
    // yanked back a reader who had nudged up inside the band. So it is driven
    // by REAL content changes only, never by `bottom-y`:
    //   - `following` latches whether the viewport is pinned to the bottom,
    //     sampled from user scrolls (`changed vy`). Estimate refinement moves
    //     `bottom-y`, not `vy`, so it never flips this — that is what removes
    //     the twitch. Sampling on scroll (before an append lands) also avoids
    //     reading a `bottom-y` already grown by the new row.
    //   - a genuine append (send tick, or a new row while pinned) opens a
    //     short `converge-frames` window that re-snaps to the refreshed bottom
    //     for a few frames, so a tall new message lands fully in view before
    //     the window closes. Outside that window nothing snaps on `bottom-y`.
    property <length> vy: cs.viewport-y;
    property <bool> following: true;
    property <int> converge-frames: 0;
    changed vy => {
        root.following = root.at-bottom;
    }
    converge-timer := Timer {
        interval: 16ms;
        running: root.converge-frames > 0;
        triggered => {
            root.converge-frames -= 1;
            // Skip while a jump/anchor owns the viewport (see below).
            if (root.scroll-target-idx < 0) {
                cs.viewport-y = root.bottom-y;
            }
        }
    }
    // Snap to the bottom now and converge onto the appended row's real height
    // over the next few frames. Yields to an in-flight jump/anchor.
    function follow-bottom() {
        if (root.scroll-target-idx < 0) {
            cs.viewport-y = root.bottom-y;
            root.following = true;
            root.converge-frames = 16; // ~256ms
        }
    }

    // ── Two-phase scroll targeting (jump-to-message + load-older anchor) ────
    // Phase 1: the timer scrolls near the target row using the index-fraction
    // estimate, re-applying every tick as the ListView refines its layout.
    // Phase 2: once the target delegate is instantiated, the probe handler in
    // the row answers with its exact geometry and `snap-to-row` finishes.
    property <int> scroll-target-idx: -1;
    property <bool> scroll-center: true; // center (jump) vs. top-align (anchor)
    property <int> scroll-tries: 0;
    property <int> probe-gen: 0;
    scroll-timer := Timer {
        interval: 30ms;
        running: root.scroll-target-idx >= 0;
        triggered => {
            if (root.scroll-tries <= 0) {
                // Never instantiated (extreme height variance) — the estimate
                // scroll is as close as it gets; let the highlight fade.
                root.scroll-target-idx = -1;
                root.jump-reset-pending = true;
                return;
            }
            root.scroll-tries -= 1;
            if (root.messages.length > 0) {
                cs.viewport-y = -clamp(
                    (root.scroll-target-idx / root.messages.length) * cs.viewport-height - (root.scroll-center ? cs.visible-height / 2 : 0px),
                    0px, max(0px, cs.viewport-height - cs.visible-height));
            }
            root.probe-gen += 1;
        }
    }

    function snap-to-row(row-y: length, row-h: length) {
        cs.viewport-y = -clamp(
            root.scroll-center ? (row-y + row-h / 2 - cs.visible-height / 2) : (row-y - 44px),
            0px, max(0px, cs.viewport-height - cs.visible-height));
        // Highlight fade only applies to jumps; the anchor has no highlight.
        root.jump-reset-pending = root.scroll-center;
        root.scroll-target-idx = -1;
    }

    property <bool> jump-reset-pending: false;
    jump-reset := Timer {
        interval: 1.8s;
        // While the in-conversation search bar is open the current match
        // keeps its highlight instead of fading; closing the search clears
        // message-jump-id from Rust.
        running: root.jump-reset-pending && !AppState.msg-search-open;
        triggered => {
            root.jump-reset-pending = false;
            AppState.message-jump-id = "";
        }
    }

    changed jump-tick => {
        if (AppState.message-jump-id != "" && AppState.message-jump-index >= 0) {
            root.jump-reset-pending = false;
            root.scroll-center = true;
            root.scroll-target-idx = AppState.message-jump-index;
            root.scroll-tries = 40;
        }
    }

    // Jump-to-unread on open: top-align the first-unread row (no highlight) so
    // the "New messages" divider above it is visible, reusing the two-phase
    // scroll targeting. Same mechanism as the load-earlier anchor.
    changed unread-tick => {
        if (AppState.message-unread-index >= 0) {
            root.jump-reset-pending = false;
            root.scroll-center = false;
            root.scroll-target-idx = AppState.message-unread-index;
            root.scroll-tries = 40;
        }
    }

    // Scroll anchoring for "load earlier messages": content grows at the TOP,
    // so without correction the viewport would show the middle of the newly
    // loaded history. The pill click records the current row count; when the
    // model grows, the previously-first row (index = new − old) is scrolled
    // back under the pill, so what the user was reading stays put.
    property <int> anchor-old-len: 0;
    property <bool> anchor-armed: false;
    property <int> msg-count: root.messages.length;
    changed msg-count => {
        if (root.anchor-armed && root.msg-count > root.anchor-old-len) {
            // "Load earlier": content grew at the TOP — anchor, don't follow.
            root.anchor-armed = false;
            root.scroll-center = false;
            root.scroll-target-idx = root.msg-count - root.anchor-old-len;
            root.scroll-tries = 40;
        } else if (root.following) {
            // A new row appended at the bottom while we were pinned there —
            // follow it. Reading `following` (latched on the last scroll)
            // rather than a live `at-bottom` avoids the just-grown `bottom-y`.
            root.follow-bottom();
        }
    }

    // Send-driven scroll: any tick bump (from Rust) snaps to bottom even if
    // the user had paged up. This is "I just hit send / opened the chat, take
    // me there."
    changed scroll-tick => {
        root.follow-bottom();
    }

    cs := ListView {
        width: parent.width;
        height: parent.height;
        // Drags belong to in-bubble text selection (TextSelection), never to
        // panning — scrolling is wheel/scrollbar only, like the ScrollView
        // this replaced.
        mouse-drag-pan-enabled: false;
        // NO `animate viewport-y` here: viewport-y is a two-way alias of the
        // Flickable's property, so a declared animation applies to EVERY
        // write — including wheel ticks and scrollbar thumb drags, which
        // then rubber-band through the easing curve and make scrolling feel
        // laggy. Programmatic snaps (send, chat open, load-older anchor) are
        // instant, which is what a chat wants anyway.

        for msg[idx] in root.messages: VerticalLayout {
            width: parent.width;
            spacing: 0;
            // The old container padding/spacing, folded per-row: 18px frame at
            // the top of the first and bottom of the last row, 3px between
            // rows (tight within a group; Rust adds `gap-before` between
            // message groups).
            padding-left: 18px;
            padding-right: 18px;
            padding-top: idx == 0 ? 18px : 3px;
            padding-bottom: idx == root.messages.length - 1 ? 18px : 0px;

            // Exact-position answer for the two-phase scroll targeting: fires
            // on the tick after this row instantiates.
            property <int> probe: root.probe-gen;
            changed probe => {
                if (idx == root.scroll-target-idx) {
                    root.snap-to-row(self.y, self.height);
                }
            }

            // "Load earlier messages" pill, riding the first row. Gated by
            // height/visible rather than `if` — an `if`-mounted TouchArea
            // swallows its first click when it (re)mounts.
            Rectangle {
                height: (idx == 0 && root.has-older) ? 36px : 0px;
                visible: idx == 0 && root.has-older;
                pill := Rectangle {
                    width: pill-label.preferred-width + 28px;
                    height: 26px;
                    border-radius: 13px * Theme.r-scale;
                    background: (pill-touch.has-hover || pill-focus.has-focus) ? Palette.hover : Palette.panel-2;
                    border-width: Theme.border-w;
                    border-color: (pill-touch.has-hover || pill-focus.has-focus) ? Palette.border-2 : Palette.border;
                    animate background, border-color { duration: Theme.hover-dur; }
                    accessible-role: button;
                    accessible-label: @tr("Load earlier messages");
                    accessible-action-default => {
                        root.anchor-old-len = root.messages.length;
                        root.anchor-armed = true;
                        AppState.messages-request-older();
                    }
                    pill-label := Text {
                        text: @tr("Load earlier messages");
                        color: (pill-touch.has-hover || pill-focus.has-focus) ? Palette.text-hi : Palette.text-lo;
                        animate color { duration: Theme.hover-dur; }
                        font-size: Theme.fs(10px, 14px);
                        font-weight: 600;
                        letter-spacing: 1.1px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }

                    pill-touch := TouchArea {
                        clicked => {
                            root.anchor-old-len = root.messages.length;
                            root.anchor-armed = true;
                            AppState.messages-request-older();
                        }
                    }

                    // Zero-size FocusScope: joins the Tab chain without
                    // stealing pointer focus from the composer on click
                    // (mirrors primitives/button.slint's `fs`).
                    pill-focus := FocusScope {
                        width: 0px;
                        height: 0px;
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == " ") {
                                root.anchor-old-len = root.messages.length;
                                root.anchor-armed = true;
                                AppState.messages-request-older();
                                return accept;
                            }
                            return reject;
                        }
                    }

                    if pill-focus.has-focus: Rectangle {
                        x: -3px;
                        y: -3px;
                        width: parent.width + 6px;
                        height: parent.height + 6px;
                        background: transparent;
                        border-radius: (13px + 3px) * Theme.r-scale;
                        border-width: 2px;
                        border-color: Palette.mint;
                    }
                }
            }

            // Date divider above the first message of each local day, so
            // multi-day history stays orientable (bubbles only stamp HH:MM).
            if msg.day-label != "": SessionDivider {
                label: msg.day-label;
            }
            // "New messages" divider above the first message that was unread when
            // the chat was opened — accented, so it reads apart from the date
            // dividers. Rust flags exactly one row per open (see chatmodel.rs).
            if msg.unread-divider: SessionDivider {
                label: @tr("NEW MESSAGES");
                accent: true;
            }
            if msg.gap-before > 0px: Rectangle {
                height: msg.gap-before;
            }

            // One skin slot per message. Theme.skin-message picks the render
            // body (skin 0 = standard incoming/outgoing bubble rows).
            MessageView {
                msg: msg;
                highlighted: AppState.message-jump-id == msg.message-id;
                row-w: root.content-w;
                play-effect(eid, cx, cy, ax, ay, w, h) => {
                    root.stage-effect(eid, cx, cy, ax, ay, w, h);
                }
            }
        }
    }

    // Empty / loading state — over the (empty) list, same slot as before.
    if root.messages.length == 0: EmptyState {
        width: parent.width;
        height: max(220px, root.height - 72px);
        title: root.loading ? @tr("Loading messages…") : @tr("No messages yet");
        description: root.loading ? @tr("Fetching the latest conversation history.") : @tr("Say hello to start the conversation.");
        ChatBubbleIcon {
            stroke: Palette.text-mid;
            filled: !root.loading;
        }
    }

    // Effect overlay — above all bubbles (declared after the scroll), below the
    // jump-pill. Fills the viewport and clips so particles don't spill into the
    // header / composer. Transparent to input (no TouchArea).
    fx-clip := Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        clip: true;
        // One layer per pool slot. Only the slot whose `gen` changed re-fires;
        // the rest keep playing — so bursts stack instead of interrupting.
        for b in root.bursts: MessageEffectLayer {
            x: b.x;
            y: b.y;
            width: b.w;
            height: b.h;
            effect-id: b.id;
            clip-x: b.cx;
            clip-y: b.cy;
            origin-w: b.w;
            origin-h: b.h;
            trigger: b.gen;
        }
    }

    // Floating "jump to latest" pill — fades in once the user pages up into
    // history, snaps the viewport back to the newest message on click.
    // Always mounted, opacity-gated (an `if`-mounted TouchArea swallows its
    // first click); the TouchArea is disabled while hidden so it never
    // intercepts clicks meant for the messages underneath.
    jump-pill := Rectangle {
        x: parent.width - self.width - 22px;
        y: parent.height - self.height - 16px;
        width: 38px;
        height: 38px;
        border-radius: (19px) * Theme.r-scale;
        background: jump-touch.has-hover ? Palette.field-hover : Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 16px;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-soft;
        drop-shadow-offset-x: Theme.hard-shadow ? 3px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 3px : 6px;
        opacity: root.at-bottom ? 0 : 1;
        animate opacity {
            duration: 160ms;
            easing: ease-out;
        }
        animate background { duration: Theme.hover-dur; }

        ChevronDownIcon {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            size: 14px;
            stroke: jump-touch.has-hover ? Palette.text-hi : Palette.text-mid;
            animate stroke { duration: Theme.hover-dur; }
        }

        jump-touch := TouchArea {
            enabled: !root.at-bottom;
            mouse-cursor: pointer;
            clicked => {
                cs.viewport-y = root.bottom-y;
            }
        }
    }
}
