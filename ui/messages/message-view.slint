// Message-row skin slot (theming engine, Layer 1).
//
// Takes one ChatMessage (the view-model contract struct) plus the small bit of
// row context that isn't on the message itself, and dispatches to the render
// body selected by `Theme.skin-message`. Skin 0 is the standard incoming/
// outgoing bubble rows. A drastic theme (e.g. terminal) adds skin 1+ here and
// selects it via its ThemeStyle pack — without any change to messages.slint or
// the Rust glue. See ui/CONTRACT.md.
//
// Actions (react/reply/edit/context/attachment/…) are invoked straight on the
// AppState contract by whichever element originates them — no callback
// forwarding through this slot. Only `play-effect` still bubbles up: it is
// messages-area mechanics (overlay-local burst staging), not contract.
import { Palette, Theme, ChatMessage } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { IncomingRow } from "incoming-row.slint";
import { OutgoingRow } from "outgoing-row.slint";
import { SystemLine } from "system-line.slint";
import { Tooltip } from "../primitives/tooltip.slint";

export component MessageView inherits VerticalLayout {
    spacing: 0;

    // The whole message (skins read whatever fields they render).
    in property <ChatMessage> msg;
    in property <bool> highlighted: false;
    // Row context not carried on the message.
    in property <length> row-w: 9999px;

    callback play-effect(int, int, int, length, length, length, length);

    // ── Group system row: a centered system line, shared across every skin.
    // Rendered before the skins and guarded out of them below so a kind-1210
    // record never falls into a bubble or terminal line. ──
    if root.msg.system-line: SystemLine {
        msg: root.msg;
    }

    // ── Skin 0: standard bubble rows ──
    if Theme.skin-message == 0 && !root.msg.system-line && !root.msg.outgoing: IncomingRow {
        msg: root.msg;
        highlighted: root.highlighted;
        row-w: root.row-w;
        play-effect(eid, cx, cy, ax, ay, w, h) => {
            root.play-effect(eid, cx, cy, ax, ay, w, h);
        }
    }

    if Theme.skin-message == 0 && !root.msg.system-line && root.msg.outgoing: OutgoingRow {
        msg: root.msg;
        highlighted: root.highlighted;
        row-w: root.row-w;
        play-effect(eid, cx, cy, ax, ay, w, h) => {
            root.play-effect(eid, cx, cy, ax, ay, w, h);
        }
    }

    // ── Skin 1: terminal line — `<sender> message text` (no bubbles/avatars) ──
    if Theme.skin-message == 1 && !root.msg.system-line: line := Rectangle {
        // Attachment state. Albums carry their cells in `album`; single
        // attachments use the `att-*` fields. A line with media routes its tap to
        // the same viewer/slideshow the bubble uses (attachment-clicked /
        // album-cell-clicked) so images stay openable in terminal mode.
        property <bool> is-album: root.msg.album.length > 0;
        property <bool> has-media: self.is-album || root.msg.has-attachment;
        property <string> media-label:
            self.is-album ? ("[" + root.msg.album.length + " images — click to view]") : (root.msg.att-is-image ? ("[image: " + root.msg.att-name + " — click to view]") : (root.msg.att-is-video ? ("[video: " + root.msg.att-name + " — click to play]") : (root.msg.att-is-audio ? ("[audio: " + root.msg.att-name + "]") : ("[file: " + root.msg.att-name + "]"))));
        // Shared whole-line action: album → attachment → reply.
        function activate() {
            if (self.is-album) {
                AppState.album-cell-clicked(root.msg.album[0].key);
            } else if (root.msg.has-attachment) {
                AppState.attachment-clicked(root.msg.message-id);
            } else {
                AppState.request-reply(root.msg.message-id, root.msg.text, root.msg.outgoing ? "you" : root.msg.sender-name);
            }
        }

        background: root.highlighted ? Palette.mint-glow : (root.msg.mentioned ? Palette.selected : (term-touch.has-hover ? Palette.hover : transparent));
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 1px;
            padding-bottom: 1px;
            spacing: 6px;
            alignment: start;
            Text {
                text: "<" + (root.msg.outgoing ? "you" : (root.msg.sender-name == "" ? root.msg.av-initials : root.msg.sender-name)) + ">";
                color: root.msg.outgoing ? Palette.mint-dim : Palette.mint;
                font-family: Theme.font;
                font-size: Theme.fs(13px, 16px);
                font-weight: 700;
                vertical-alignment: top;
            }

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: start;
                spacing: 1px;
                if root.msg.deleted: Text {
                    text: @tr("This message was deleted");
                    color: Palette.text-mid;
                    font-family: Theme.font;
                    font-size: Theme.fs(13px, 16px);
                    font-italic: true;
                    wrap: word-wrap;
                }
                if root.msg.text != "" && !root.msg.deleted: Text {
                    text: root.msg.text;
                    color: root.msg.failed ? Palette.danger : Palette.text-hi;
                    font-family: Theme.font;
                    font-size: Theme.fs(13px, 16px);
                    wrap: word-wrap;
                }
                // Accent-colored, clickable attachment label (the whole line is
                // the click target — see term-touch below).
                if line.has-media && !root.msg.deleted: Text {
                    text: line.media-label;
                    color: Palette.mint;
                    font-family: Theme.font;
                    font-size: Theme.fs(12px, 16px);
                    font-weight: 700;
                    wrap: word-wrap;
                }
            }

            if root.msg.stamp != "": Rectangle {
                width: term-stamp.preferred-width;
                term-stamp := Text {
                    text: root.msg.stamp;
                    color: Palette.text-vlo;
                    font-family: Theme.font;
                    font-size: Theme.fs(11px, 14px);
                    vertical-alignment: top;
                }
                // Hover tooltip with the full datetime. Forwards clicks to the
                // same handler as `term-touch` (which it sits on top of) so the
                // whole-line click target keeps working over the stamp.
                term-stamp-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        line.activate();
                    }
                }

                if term-stamp-touch.has-hover && root.msg.stamp-full != "": Tooltip {
                    x: parent.width - self.width;
                    y: -self.height - 4px;
                    label: root.msg.stamp-full;
                    is-visible: true;
                }
            }
        }
        // One TouchArea for the whole line; the action is chosen in the handler
        // (album → attachment → reply) to avoid overlapping/if-mounted TouchAreas.
        term-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                line.activate();
            }
        }
    }
}
