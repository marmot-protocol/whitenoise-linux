import {
    Palette,
    Theme,
    ChatMessage,
    ProfileSink,
} from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { Avatar } from "../primitives/avatar.slint";
import { MessageBubble } from "message-bubble.slint";
import { ReactionsRow } from "reactions-row.slint";
import { HoverActions } from "hover-actions.slint";

export component IncomingRow inherits VerticalLayout {
    // The whole message — fields render via `root.msg.*` (see ChatMessage in
    // tokens.slint for per-field docs). Only row context that is not carried
    // on the message stays a scalar property.
    in property <ChatMessage> msg;
    in property <bool> highlighted: false;
    in property <length> row-w: 9999px;

    // Fire the burst in the shared overlay (which paints above all bubbles),
    // reporting this bubble's window position + size. Autoplay is deferred a
    // beat so layout/scroll settle before the position is snapshotted.
    callback play-effect(int, int, int, length, length, length, length);
    function fire-effect() {
        root.play-effect(root.msg.effect-id, root.msg.effect-clip-x, root.msg.effect-clip-y,
            bubble.absolute-position.x, bubble.absolute-position.y, bubble.width, bubble.height);
    }
    init => {
        if (root.msg.effect-autoplay && root.msg.effect-id > 0) {
            fx-timer.running = true;
        }
    }
    fx-timer := Timer {
        interval: 120ms;
        running: false;
        triggered => {
            self.running = false;
            root.fire-effect();
        }
    }


    spacing: 0;

    HorizontalLayout {
        spacing: 10px;
        alignment: start;

        if root.msg.show-avatar: TouchArea {
            width: 28px;
            height: 28px;
            mouse-cursor: pointer;
            clicked => {
                if (root.msg.sender-id != "") {
                    ProfileSink.open(root.msg.sender-id);
                }
            }
            Avatar {
                size: 28px;
                y: 0;
                initials: root.msg.av-initials;
                color-a: root.msg.av-a;
                color-b: root.msg.av-b;
                picture: root.msg.picture;
                has-picture: root.msg.has-picture;
                a11y-label: root.msg.sender-name != "" ? root.msg.sender-name : root.msg.av-initials;
                font-size: Theme.fs(9px, 14px);
            }
        }
        if !root.msg.show-avatar: Rectangle {
            width: 28px;
        }

        VerticalLayout {
            spacing: 2px;
            // Sender label above the bubble — only on the first bubble of a
            // group (group chats only), so a stack doesn't repeat the name.
            if root.msg.show-sender-name && root.msg.sender-name != "": HorizontalLayout {
                alignment: start;
                name-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if (root.msg.sender-id != "") {
                            ProfileSink.open(root.msg.sender-id);
                        }
                    }
                    Text {
                        text: root.msg.sender-name;
                        color: name-touch.has-hover ? Palette.text-mid : Palette.text-lo;
                        animate color { duration: Theme.hover-dur; }
                        font-size: Theme.fs(11px, 12px);
                        font-weight: 700;
                        font-family: Theme.font;
                        overflow: elide;
                    }
                }
            }

            // Bubble + floating action toolbar. The block is exactly the
            // bubble's size; the toolbar overflows to the right into the gutter.
            block := Rectangle {
                horizontal-stretch: 0;
                width: bubble.width;
                height: bubble.height;

                // Stable hover region spanning bubble → toolbar (declared first
                // so it sits behind the bubble and the toolbar buttons).
                hover := TouchArea {
                    x: 0;
                    y: 0;
                    width: bubble.width + 6px + acts.width;
                    height: parent.height;
                }

                bubble := MessageBubble {
                    x: 0;
                    y: 0;
                    msg: root.msg;
                    highlighted: root.highlighted;
                    available-w: max(80px, root.row-w - 28px - 10px - 10px);
                    attachment-clicked => {
                        AppState.attachment-clicked(root.msg.message-id);
                    }
                    audio-play-clicked => {
                        AppState.audio-play-clicked(root.msg.message-id);
                    }
                    audio-seek-clicked(fraction) => {
                        AppState.audio-seek-clicked(root.msg.message-id, fraction);
                    }
                    album-cell-clicked(key) => {
                        AppState.album-cell-clicked(key);
                    }
                    show-history-clicked => {
                        AppState.show-edit-history(root.msg.message-id);
                    }
                    context-menu-requested(ax, ay) => {
                        // A retracted tombstone offers no actions, so suppress
                        // its menu entirely (matches the hover toolbar gate).
                        if (root.msg.message-id != "" && !root.msg.deleted) {
                            AppState.arm-context-menu(root.msg.message-id, root.msg.text, root.msg.sender-name != "" ? root.msg.sender-name : root.msg.av-initials, false, ax, ay);
                        }
                    }
                    body-clicked => {
                        if (root.msg.effect-id > 0) {
                            root.fire-effect();
                        }
                    }
                }

                acts := HoverActions {
                    x: bubble.width + 6px;
                    y: (parent.height - self.height) / 2;
                    message-id: root.msg.message-id;
                    reply-preview-text: root.msg.text;
                    reply-author: root.msg.sender-name != "" ? root.msg.sender-name : root.msg.av-initials;
                    can-edit: false;
                    // `bubble.hovered` joins in because the selection area
                    // inside the bubble consumes hover while the pointer is
                    // over body text, which starves the row-level sensor.
                    visible: root.msg.message-id != "" && !root.msg.deleted && (hover.has-hover || self.hovered || bubble.hovered);
                    opacity: (hover.has-hover || self.hovered || bubble.hovered) ? 1.0 : 0.0;
                    animate opacity { duration: Theme.hover-dur; }
                }
            }

            // Reaction chips — only present when the message has reactions, so
            // empty messages stack tightly.
            if root.msg.message-id != "" && root.msg.reaction-rows.length > 0: ReactionsRow {
                message-id: root.msg.message-id;
                rows: root.msg.reaction-rows;
                align-right: false;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }
    }
}
