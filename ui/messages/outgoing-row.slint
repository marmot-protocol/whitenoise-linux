import {
    Palette,
    Theme,
    ChatMessage,
    ProfileSink,
} from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { Avatar } from "../primitives/avatar.slint";
import { MessageBubble } from "message-bubble.slint";
import { ReactionsRow } from "reactions-row.slint";
import { HoverActions } from "hover-actions.slint";

export component OutgoingRow inherits VerticalLayout {
    // The whole message — fields render via `root.msg.*` (see ChatMessage in
    // tokens.slint for per-field docs). Only row context that is not carried
    // on the message stays a scalar property.
    in property <ChatMessage> msg;
    in property <bool> highlighted: false;
    in property <length> row-w: 9999px;
    property <bool> align-right: AppState.outgoing-on-right;
    // Own profile picture. Not on the message — read from AppState's
    // `my-av-*` set so the outgoing avatar matches the left rail.
    property <image> av-picture: AppState.my-av-picture;
    property <bool> av-has-picture: AppState.my-av-has-picture;

    // Fire the burst in the shared overlay (above all bubbles). See IncomingRow.
    callback play-effect(int, int, int, length, length, length, length);
    function fire-effect() {
        root.play-effect(root.msg.effect-id, root.msg.effect-clip-x, root.msg.effect-clip-y,
            bubble.absolute-position.x, bubble.absolute-position.y, bubble.width, bubble.height);
    }
    init => {
        if (root.msg.effect-autoplay && root.msg.effect-id > 0) {
            fx-timer.running = true;
        }
    }
    fx-timer := Timer {
        interval: 120ms;
        running: false;
        triggered => {
            self.running = false;
            root.fire-effect();
        }
    }


    spacing: 0;

    HorizontalLayout {
        spacing: 10px;
        alignment: root.align-right ? end : start;

        if root.align-right: Rectangle {
            horizontal-stretch: 1;
        }

        if !root.align-right && root.msg.show-avatar: TouchArea {
            width: 28px;
            height: 28px;
            mouse-cursor: pointer;
            clicked => {
                if (root.msg.sender-id != "") {
                    ProfileSink.open(root.msg.sender-id);
                }
            }
            Avatar {
                size: 28px;
                y: 0;
                initials: root.msg.av-initials;
                color-a: root.msg.av-a;
                color-b: root.msg.av-b;
                picture: root.av-picture;
                has-picture: root.av-has-picture;
                font-size: Theme.fs(9px, 14px);
            }
        }
        if !root.align-right && !root.msg.show-avatar: Rectangle {
            width: 28px;
        }

        VerticalLayout {
            spacing: 2px;

            block := Rectangle {
                horizontal-stretch: 0;
                width: bubble.width;
                height: bubble.height;

                // Stable hover region spanning toolbar → bubble. The toolbar
                // floats on the side opposite the avatar (left when right-
                // aligned), overflowing into the gutter.
                hover := TouchArea {
                    x: root.align-right ? -(acts.width + 6px) : 0px;
                    y: 0;
                    width: bubble.width + 6px + acts.width;
                    height: parent.height;
                }

                bubble := MessageBubble {
                    x: 0;
                    y: 0;
                    msg: root.msg;
                    highlighted: root.highlighted;
                    align-right: root.align-right;
                    available-w: max(80px, root.row-w - 28px - 10px - 10px);
                    retry-clicked => {
                        AppState.retry-message(root.msg.message-id);
                    }
                    attachment-clicked => {
                        AppState.attachment-clicked(root.msg.message-id);
                    }
                    audio-play-clicked => {
                        AppState.audio-play-clicked(root.msg.message-id);
                    }
                    audio-seek-clicked(fraction) => {
                        AppState.audio-seek-clicked(root.msg.message-id, fraction);
                    }
                    album-cell-clicked(key) => {
                        AppState.album-cell-clicked(key);
                    }
                    show-history-clicked => {
                        AppState.show-edit-history(root.msg.message-id);
                    }
                    context-menu-requested(ax, ay) => {
                        // Same gate as the hover toolbar: confirmed rows only,
                        // and never on a retracted tombstone.
                        if (root.msg.message-id != "" && !root.msg.pending && !root.msg.failed && !root.msg.deleted) {
                            AppState.arm-context-menu(root.msg.message-id, root.msg.text, @tr("You"), root.msg.can-edit, ax, ay);
                        }
                    }
                    body-clicked => {
                        if (root.msg.effect-id > 0) {
                            root.fire-effect();
                        }
                    }
                }

                acts := HoverActions {
                    x: root.align-right ? -(self.width + 6px) : (bubble.width + 6px);
                    y: (parent.height - self.height) / 2;
                    message-id: root.msg.message-id;
                    reply-preview-text: root.msg.text;
                    reply-author: @tr("You");
                    can-edit: root.msg.can-edit;
                    // `bubble.hovered` joins in because the selection area
                    // inside the bubble consumes hover while the pointer is
                    // over body text, which starves the row-level sensor.
                    visible: root.msg.message-id != "" && !root.msg.pending && !root.msg.failed && !root.msg.deleted && (hover.has-hover || self.hovered || bubble.hovered);
                    opacity: (hover.has-hover || self.hovered || bubble.hovered) ? 1.0 : 0.0;
                    animate opacity { duration: Theme.hover-dur; }
                }
            }

            if root.msg.message-id != "" && !root.msg.pending && !root.msg.failed && root.msg.reactions.length > 0: ReactionsRow {
                message-id: root.msg.message-id;
                reactions: root.msg.reactions;
                align-right: root.align-right;
            }
        }

        if root.align-right && root.msg.show-avatar: TouchArea {
            width: 28px;
            height: 28px;
            mouse-cursor: pointer;
            clicked => {
                if (root.msg.sender-id != "") {
                    ProfileSink.open(root.msg.sender-id);
                }
            }
            Avatar {
                size: 28px;
                y: 0;
                initials: root.msg.av-initials;
                color-a: root.msg.av-a;
                color-b: root.msg.av-b;
                picture: root.av-picture;
                has-picture: root.av-has-picture;
                font-size: Theme.fs(9px, 14px);
            }
        }
        if root.align-right && !root.msg.show-avatar: Rectangle {
            width: 28px;
        }

        if !root.align-right: Rectangle {
            horizontal-stretch: 1;
        }
    }
}
