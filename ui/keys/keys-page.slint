import { Palette , Theme} from "../tokens.slint";
import { KeyIcon } from "../icons/key-icon.slint";
import { LockIcon } from "../icons/lock-icon.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { PageHeader } from "../shells/page-header.slint";
import { GroupCard } from "../shells/group-card.slint";
import { CypherScroll } from "../primitives/cypher-scroll.slint";
import { Signer, LinkedDevice, KeyPackageInfo } from "types.slint";
import { KVRow } from "kv-row.slint";
import { MicroButton } from "../primitives/button.slint";
import { SectionHeader } from "section-header.slint";
import { DeviceRow } from "device-row.slint";

export component KeysPage inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-width: 0px;
    preferred-height: 0px;
    background: Palette.bg;

    in property <string> npub;
    in property <[KeyPackageInfo]> key-packages;
    in property <[string]> kp-relays;
    in property <string> kp-status;     // last action status ("publishing…", "ok · 2/3 relays", "error: …")
    in property <bool> kp-busy: false;
    callback copy-npub-clicked;
    callback publish-clicked;
    callback rotate-clicked;
    callback refresh-clicked;

    in property <[LinkedDevice]> devices: [
        { name: @tr("This computer"), detail: "Linux · darkmatter v0.1.4", current: true },
    ];

    CypherScroll {
        viewport-height: page.preferred-height;
        viewport-width: self.visible-width;

        page := VerticalLayout {
            padding-left: 28px; padding-right: 28px;
            padding-top: 16px; padding-bottom: 24px;
            spacing: 20px;

            PageHeader {
                title: @tr("Keys & identity");
                caption: @tr("MLS  ·  YOUR KEY MATERIAL");
                KeyIcon { stroke: Palette.mint; }
            }

            Rectangle {
                height: 64px;
                background: Palette.banner;
                border-radius: (8px) * Theme.r-scale;
                border-width: 1px;
                border-color: Palette.border-2;
                HorizontalLayout {
                    padding-left: 18px; padding-right: 18px;
                    padding-top: 12px; padding-bottom: 12px;
                    spacing: 12px;
                    alignment: start;
                    VerticalLayout {
                        alignment: center;
                        LockIcon { stroke: Palette.mint; }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        alignment: center;
                        Text {
                            text: @tr("Your identity is sovereign");
                            color: Palette.text-hi;
                            font-size: (13px) * Theme.fs-scale;
                            font-weight: 700;
                        }
                        Text {
                            text: @tr("Dark Matter never sees your private key. It lives only on this device and any signer you connect.");
                            color: Palette.text-lo;
                            font-size: (11px) * Theme.fs-scale;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("IDENTITY");
                    note: "";
                }
                GroupCard {
                    KVRow {
                        label: @tr("Public key (npub)");
                        sublabel: @tr("Safe to share. This is how people find you.");
                        value: root.npub;
                        show-divider: false;
                        MicroButton {
                            label: @tr("Copy");
                            CopyIcon { stroke: Palette.text-mid; }
                            clicked => { root.copy-npub-clicked(); }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("KEY PACKAGES");
                    note: root.kp-relays.length > 0
                        ? @tr("(published to your kind-10051 relay list)")
                        : @tr("(no key-package relays configured)");
                    MicroButton {
                        label: root.kp-busy ? @tr("…") : @tr("Refresh");
                        RefreshIcon { stroke: Palette.text-mid; }
                        clicked => { if (!root.kp-busy) { root.refresh-clicked(); } }
                    }
                }
                if root.key-packages.length == 0 : Rectangle {
                    height: 60px;
                    border-radius: (8px) * Theme.r-scale;
                    background: Palette.panel-2;
                    border-width: 1px;
                    border-color: Palette.border-2;
                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px;
                        padding-top: 12px; padding-bottom: 12px;
                        spacing: 12px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            Text {
                                text: @tr("No key packages yet");
                                color: Palette.text-hi;
                                font-size: (12px) * Theme.fs-scale;
                                font-weight: 700;
                            }
                            Text {
                                text: root.kp-relays.length > 0
                                    ? @tr("Publish one so other users can invite you to groups.")
                                    : @tr("Configure key-package relays first.");
                                color: Palette.text-lo;
                                font-size: (11px) * Theme.fs-scale;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            MicroButton {
                                label: root.kp-busy ? @tr("Publishing…") : @tr("Publish");
                                clicked => { if (!root.kp-busy) { root.publish-clicked(); } }
                            }
                        }
                    }
                }
                if root.key-packages.length > 0 : GroupCard {
                    for kp[i] in root.key-packages : KVRow {
                        label: "0x" + kp.key-package-ref;
                        sublabel: (kp.published-at != "" ? (kp.published-at + " · ") : "")
                            + (kp.on-relay
                                ? @tr("{n} relay" | "{n} relays" % kp.relay-count, kp.relay-count)
                                : @tr("local only"));
                        value: kp.local ? "LOCAL" : "REMOTE";
                        show-divider: i < root.key-packages.length - 1;
                    }
                }
            }

            if root.kp-status != "" : Rectangle {
                height: 32px;
                background: Palette.panel-2;
                border-radius: (6px) * Theme.r-scale;
                border-width: 1px;
                border-color: Palette.border-2;
                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: root.kp-status;
                    color: Palette.text-mid;
                    font-size: (11px) * Theme.fs-scale;
                    font-family: Theme.font;
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("LINKED DEVICES");
                    note: @tr("(other Dark Matter instances signed into this identity)");
                }
                GroupCard {
                    for d[i] in root.devices : DeviceRow {
                        name: d.name;
                        detail: d.detail;
                        status: d.current ? @tr("current") : "";
                        action-label: d.current ? "" : @tr("Sign out");
                        dim-action: d.current;
                        show-divider: i < root.devices.length - 1;
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("DANGER ZONE");
                    note: "";
                }
                Rectangle {
                    height: 60px;
                    border-radius: (8px) * Theme.r-scale;
                    background: #2A1418;
                    border-width: 1px;
                    border-color: #5A2429;
                    HorizontalLayout {
                        padding-left: 16px; padding-right: 16px;
                        padding-top: 12px; padding-bottom: 12px;
                        spacing: 12px;
                        alignment: stretch;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 4px;
                            alignment: center;
                            Text {
                                text: @tr("Rotate key package now");
                                color: #FCA5A5;
                                font-size: (12px) * Theme.fs-scale;
                                font-weight: 700;
                            }
                            Text {
                                text: @tr("Invalidates the current package and uploads a fresh one to your relays.");
                                color: Palette.text-lo;
                                font-size: (11px) * Theme.fs-scale;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            MicroButton {
                                label: root.kp-busy ? @tr("…") : @tr("Rotate");
                                fg: #FCA5A5;
                                bg-color: #2A1418;
                                hover-bg: #3A1A20;
                                outline: #5A2429;
                                hover-outline: #7A2E36;
                                RefreshIcon { stroke: #FCA5A5; }
                                clicked => { if (!root.kp-busy) { root.rotate-clicked(); } }
                            }
                        }
                    }
                }
            }
        }
    }
}
