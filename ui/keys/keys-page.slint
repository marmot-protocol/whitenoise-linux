import { AppState } from "../shell/app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { KeyIcon } from "../icons/key-icon.slint";
import { LockIcon } from "../icons/lock-icon.slint";
import { CopyIcon } from "../icons/copy-icon.slint";
import { RefreshIcon } from "../icons/refresh-icon.slint";
import { EyeIcon } from "../icons/eye-icon.slint";
import { PageHeader } from "../layout/page-header.slint";
import { GroupCard } from "../layout/group-card.slint";
import { ScrollView } from "../primitives/scroll-view.slint";
import { KVRow } from "../layout/kv-row.slint";
import { MicroButton } from "../primitives/button.slint";
import { SectionHeader } from "../layout/section-header.slint";
import { DangerActionRow } from "danger-action-row.slint";
import { InfoBanner } from "../layout/info-banner.slint";

// One line of status text for a single key-package operation (refresh,
// publish, or rotate), styled like the page's other status plates.
component KpStatusLine inherits Rectangle {
    in property <string> text;
    height: 32px;
    background: Palette.panel-2;
    border-radius: (6px) * Theme.r-scale;
    border-width: 1px;
    border-color: Palette.border-2;
    Text {
        x: 12px;
        y: (parent.height - self.height) / 2;
        text: root.text;
        color: Palette.text-mid;
        font-size: Theme.fs(11px, 14px);
        font-family: Theme.font;
    }
}

export component KeysPage inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-width: 0px;
    preferred-height: 0px;
    background: Palette.bg;

    ScrollView {
        viewport-height: page.preferred-height;
        viewport-width: self.visible-width;

        page := VerticalLayout {
            width: parent.width;
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 16px;
            padding-bottom: 24px;
            spacing: 20px;

            PageHeader {
                title: @tr("Keys & identity");
                caption: @tr("MLS  ·  YOUR KEY MATERIAL");
                KeyIcon {
                    stroke: Palette.mint;
                }
            }

            InfoBanner {
                title: @tr("Your identity is sovereign");
                detail: @tr("White Noise never sees your private key. It lives only on this device and any signer you connect.");
                LockIcon {
                    stroke: Palette.mint;
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("IDENTITY");
                    note: "";
                }

                GroupCard {
                    KVRow {
                        row-height: 64px;
                        label: @tr("Public key (npub)");
                        sublabel: @tr("Safe to share. This is how people find you.");
                        value: AppState.my-npub;
                        show-divider: false;
                        MicroButton {
                            label: @tr("Copy");
                            CopyIcon {
                                stroke: Palette.text-mid;
                            }

                            clicked => {
                                AppState.copy-to-clipboard(AppState.my-npub);
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("KEY PACKAGES");
                    note: AppState.kp-relays.length > 0 ? @tr("(published to your kind-10051 relay list)") : @tr("(no key-package relays configured)");
                    MicroButton {
                        label: AppState.kp-refresh-busy ? @tr("Refreshing…") : @tr("Refresh");
                        RefreshIcon {
                            stroke: Palette.text-mid;
                        }

                        clicked => {
                            if (!AppState.kp-refresh-busy) {
                                AppState.kp-refresh-clicked();
                            }
                        }
                    }
                }

                if AppState.key-packages.length == 0: Rectangle {
                    height: 60px;
                    border-radius: (8px) * Theme.r-scale;
                    background: Palette.panel-2;
                    border-width: 1px;
                    border-color: Palette.border-2;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 12px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            Text {
                                text: @tr("No key packages yet");
                                color: Palette.text-hi;
                                font-size: Theme.fs(12px, 16px);
                                font-weight: 700;
                            }

                            Text {
                                text: AppState.kp-relays.length > 0 ? @tr("Publish one so other users can invite you to groups.") : @tr("Configure key-package relays first.");
                                color: Palette.text-lo;
                                font-size: Theme.fs(11px, 14px);
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            MicroButton {
                                label: AppState.kp-publish-busy ? @tr("Publishing…") : @tr("Publish");
                                clicked => {
                                    if (!AppState.kp-publish-busy) {
                                        AppState.kp-publish-clicked();
                                    }
                                }
                            }
                        }
                    }
                }
                if AppState.key-packages.length > 0: GroupCard {
                    for kp[i] in AppState.key-packages: KVRow {
                        row-height: 64px;
                        label: "0x" + kp.key-package-ref;
                        sublabel: (kp.published-at != "" ? (kp.published-at + " · ") : "") + (kp.on-relay ? @tr("{n} relay" | "{n} relays" % kp.relay-count, kp.relay-count) : @tr("local only"));
                        value: kp.local ? "LOCAL" : "REMOTE";
                        show-divider: i < AppState.key-packages.length - 1;
                    }
                }
            }

            if AppState.kp-refresh-status != "": KpStatusLine {
                text: AppState.kp-refresh-status;
            }

            if AppState.kp-publish-status != "": KpStatusLine {
                text: AppState.kp-publish-status;
            }

            if AppState.kp-rotate-status != "": KpStatusLine {
                text: AppState.kp-rotate-status;
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("LINKED DEVICES");
                    note: "";
                }

                Rectangle {
                    height: 60px;
                    border-radius: (8px) * Theme.r-scale;
                    background: Palette.panel-2;
                    border-width: 1px;
                    border-color: Palette.border-2;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 12px;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            Text {
                                text: @tr("Multi-device isn't available yet");
                                color: Palette.text-hi;
                                font-size: Theme.fs(12px, 16px);
                                font-weight: 700;
                            }

                            Text {
                                text: @tr("Your identity lives only on this device for now. When device linking ships, the devices signed into your key will appear here.");
                                color: Palette.text-lo;
                                font-size: Theme.fs(11px, 14px);
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                SectionHeader {
                    label: @tr("DANGER ZONE");
                    note: "";
                }

                DangerActionRow {
                    title: @tr("Rotate key package now");
                    detail: @tr("Invalidates the current package and uploads a fresh one to your relays.");
                    action-label: @tr("Rotate");
                    busy-label: @tr("Rotating…");
                    busy: AppState.kp-rotate-busy;
                    triggered => {
                        AppState.show-rotate-confirm = true;
                    }
                    RefreshIcon {
                        stroke: Palette.danger;
                    }
                }

                DangerActionRow {
                    title: @tr("Reveal private key (nsec)");
                    detail: @tr("Shows your secret key after you confirm your vault password. Never share it — it is your identity.");
                    action-label: @tr("Reveal");
                    triggered => {
                        AppState.reveal-nsec-password = "";
                        AppState.reveal-nsec-value = "";
                        AppState.show-reveal-nsec = true;
                    }
                    EyeIcon {
                        stroke: Palette.danger;
                    }
                }
            }
        }
    }
}
