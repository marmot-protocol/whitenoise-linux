import { Palette, Theme } from "../tokens.slint";
import { MicroButton } from "../primitives/button.slint";

export component DeviceRow inherits Rectangle {
    in property <string> name;
    in property <string> detail;
    in property <string> status;
    in property <string> action-label: @tr("Revoke");
    in property <bool> show-divider: true;
    in property <bool> dim-action: false;

    height: 56px;

    HorizontalLayout {
        padding-left: 16px; padding-right: 16px;
        padding-top: 10px; padding-bottom: 10px;
        spacing: 12px;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;
            Text {
                text: root.name;
                color: Palette.text-hi;
                font-size: (12px) * Theme.fs-scale;
                font-weight: 700;
            }
            Text {
                text: root.detail;
                color: Palette.text-lo;
                font-size: (11px) * Theme.fs-scale;
                font-family: Theme.font;
            }
        }

        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: end;
                spacing: 10px;
                if root.status != "" : Text {
                    text: root.status;
                    color: root.status == "active" ? Palette.mint : Palette.text-lo;
                    font-size: (10px) * Theme.fs-scale;
                    font-weight: 700;
                    font-family: Theme.font;
                    letter-spacing: 1.0px;
                    vertical-alignment: center;
                }
                MicroButton {
                    label: root.action-label;
                    fg: root.dim-action ? Palette.text-mid : Palette.text-hi;
                    Text {
                        text: "×";
                        color: Palette.text-mid;
                        font-size: (13px) * Theme.fs-scale;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    if root.show-divider : Rectangle {
        y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: Palette.border-2;
    }
}
