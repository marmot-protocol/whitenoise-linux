import { Palette, Theme } from "../tokens.slint";
import { AppState } from "app-state.slint";

// Dismissible danger plate for `AppState.backend-error`.
//
// Nineteen Rust call sites write that property when an operation fails — a send
// with no backend, a "Delete for everyone" that never landed, an edit that
// reverted, archive/unarchive, accepting an invitation, switching or removing
// an account — and nothing in the UI read it, so every one of those failures
// was silent. The writers span Chats, Contacts, Archive and Settings, so this
// floats over the shell canvas instead of living inside one page.
//
// `InfoBanner` (ui/layout/info-banner.slint) is the neighbouring plate, but it
// is a fixed 64px tall and defaults to `no-wrap`, which elides the two-sentence
// `ErrorCopy` strings, and it has no dismiss affordance — hence a sibling
// rather than a mode flag on it.
//
// Dismissing sets `backend-error-dismissed` rather than clearing the string:
// `save_profile` reads the captured boot failure back out of `backend-error` to
// explain why the backend is missing, and a dismissal must not erase that.
// `show_backend_error` (src/state.rs) re-arms the flag with every new message.
export component ErrorBanner inherits Rectangle {
    background: Palette.danger-soft;
    border-radius: 10px * Theme.r-scale;
    border-width: max(Theme.border-w, 1px);
    border-color: Palette.danger-border;
    drop-shadow-blur: Theme.hard-shadow ? 0px : 20px;
    drop-shadow-offset-x: Theme.hard-shadow ? 4px : 0px;
    drop-shadow-offset-y: Theme.hard-shadow ? 4px : 8px;
    drop-shadow-color: Palette.shadow-card;
    clip: true;

    // Reveal on mount — the shell only instantiates this row when a failure
    // arrives, so flipping `shown` in `init` fades the plate in over
    // `transition-dur` instead of snapping it on. Opacity rather than a slide,
    // because the row sizes itself in the shell's VerticalLayout and offsetting
    // the content's `y` drops that content-driven height. Matches the
    // flip-after-mount pattern MemberMenu and the tooltip use.
    property <bool> shown: false;
    init => {
        root.shown = true;
    }
    opacity: root.shown ? 1.0 : 0.0;
    animate opacity {
        duration: Theme.transition-dur;
        easing: ease-out;
    }

    HorizontalLayout {
        spacing: 0;

        // Solid danger rail down the leading edge — reads as "error" at a
        // glance, before the copy is even parsed.
        Rectangle {
            width: 4px;
            background: Palette.danger;
        }

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 8px;
            padding-top: 11px;
            padding-bottom: 11px;
            spacing: 11px;

            // Filled danger disc with a light glyph — a firmer focal point
            // than the old outline ring. The glyph reads in `danger-soft`, the
            // plate's own surface colour, so it stays legible on the disc in
            // every theme. Centred with the copy so the whole row reads level.
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    background: Palette.danger;
                    Text {
                        text: "!";
                        color: Palette.danger-soft;
                        font-size: Theme.fs(12px, 15px);
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: AppState.backend-error;
                color: Palette.danger;
                font-size: Theme.fs(12px, 15px);
                font-weight: 600;
                wrap: word-wrap;
                vertical-alignment: center;
                horizontal-stretch: 1;
                min-width: 0;
            }

            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 26px;
                    height: 26px;
                    border-radius: (6px) * Theme.r-scale;
                    background: close-touch.has-hover ? Palette.danger-soft-hover : transparent;
                    animate background { duration: Theme.hover-dur; }
                    accessible-role: button;
                    accessible-label: @tr("Dismiss");
                    accessible-action-default => {
                        AppState.backend-error-dismissed = true;
                    }
                    close-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            AppState.backend-error-dismissed = true;
                        }
                    }

                    Text {
                        text: "✕";
                        color: Palette.danger;
                        font-size: Theme.fs(12px, 15px);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    // Zero-size FocusScope: joins the Tab chain without taking
                    // pointer events, mirroring chat-header.slint's icon
                    // buttons.
                    close-fs := FocusScope {
                        width: 0px;
                        height: 0px;
                        key-pressed(event) => {
                            if (event.text == Key.Return || event.text == " ") {
                                AppState.backend-error-dismissed = true;
                                return accept;
                            }
                            return reject;
                        }
                    }
                    if close-fs.has-focus: Rectangle {
                        x: 1px;
                        y: 1px;
                        width: parent.width - 2px;
                        height: parent.height - 2px;
                        border-radius: (5px) * Theme.r-scale;
                        border-width: 2px;
                        border-color: Palette.danger;
                    }
                }
            }
        }
    }
}
