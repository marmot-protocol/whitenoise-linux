// title bar — DARKMATTER mark, breadcrumb, and global actions.
import { AppState } from "app-state.slint";
import { Palette, Theme } from "../tokens.slint";
import { MentionsIcon } from "mentions-icon.slint";
import { SearchIcon } from "../icons/search-icon.slint";

export component TitleBar inherits Rectangle {
    in property <length> rail-width: 56px;

    height: 30px;

    HorizontalLayout {
        spacing: 0px;
        padding-left: 8px;
        padding-right: 8px;

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 14px;
            alignment: center;

            Text {
                text: "DARKMATTER";
                color: Palette.text-hi;
                font-size: Theme.fs(11px, 14px);
                font-weight: 700;
                vertical-alignment: center;
                letter-spacing: 1.6px;
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: (parent.height - 14px) / 2;
                background: Palette.border;
            }

            Text {
                text: AppState.breadcrumb;
                color: Palette.mint-dim;
                font-size: Theme.fs(10px, 14px);
                font-weight: 600;
                vertical-alignment: center;
                letter-spacing: 1.2px;
                opacity: 0.9;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        // Global message search — opens the cross-chat search modal.
        Rectangle {
            width: 30px;
            height: 30px;
            background: search-touch.has-hover ? Palette.hover : transparent;
            border-radius: (6px) * Theme.r-scale;
            animate background { duration: Theme.hover-dur; }

            search-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    AppState.msg-global-open = true;
                }

                SearchIcon {
                    size: 13px;
                    stroke: search-touch.has-hover ? Palette.mint : Palette.text-mid;
                    // Optically center on the lens, not the bbox: the handle
                    // sticks out bottom-right, so exact bbox centering reads
                    // high-left next to the "@" glyph. The lens center sits at
                    // 5/14 of the glyph; the +2/14 shifts it onto the button
                    // center (7/14).
                    x: (parent.width - self.width) / 2 + self.size * 2 / 14;
                    y: (parent.height - self.height) / 2 + self.size * 2 / 14;
                }
            }
        }

        MentionsIcon {
            mention-items: AppState.mention-inbox-items;
            mentions-loading: AppState.mention-inbox-loading;
            mentions-inbox-opened => {
                AppState.mention-inbox-opened();
            }
            mention-inbox-item-selected(group-id, message-id) => {
                AppState.mention-inbox-selected(group-id, message-id);
            }
        }
    }
}
