// title bar — DARKMATTER mark, breadcrumb, and global actions.
import { MentionInboxItem, Palette, Theme } from "../tokens.slint";
import { MentionsIcon } from "mentions-icon.slint";

export component TitleBar inherits Rectangle {
    in property <string> breadcrumb;
    in property <length> rail-width: 56px;
    in property <[MentionInboxItem]> mention-items;
    in property <bool> mentions-loading: false;
    callback mentions-inbox-opened();
    callback mention-inbox-item-selected(string, string);

    height: 30px;

    HorizontalLayout {
        spacing: 0px;
        padding-left: 8px;
        padding-right: 8px;

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 14px;
            alignment: center;

            Text {
                text: "DARKMATTER";
                color: Palette.text-hi;
                font-size: Theme.fs(11px, 14px);
                font-weight: 700;
                vertical-alignment: center;
                letter-spacing: 1.6px;
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: (parent.height - 14px) / 2;
                background: Palette.border;
            }

            Text {
                text: root.breadcrumb;
                color: Palette.mint-dim;
                font-size: Theme.fs(10px, 14px);
                font-weight: 600;
                vertical-alignment: center;
                letter-spacing: 1.2px;
                opacity: 0.9;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        MentionsIcon {
            mention-items: root.mention-items;
            mentions-loading: root.mentions-loading;
            mentions-inbox-opened => {
                root.mentions-inbox-opened();
            }
            mention-inbox-item-selected(group-id, message-id) => {
                root.mention-inbox-item-selected(group-id, message-id);
            }
        }
    }
}
