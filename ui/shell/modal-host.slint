// ModalHost — the overlay stack: every modal, context menu and picker that
// paints over the app shell. Extracted from the window root; shared state
// flows through the AppState global, while state that never leaves this
// stack (delete/admin confirm arming, the forward-picker flag) is private
// here. Each mount below is a Rectangle-rooted component outside any layout,
// so Slint defaults it to this host's geometry — the full window at x/y 0.

import { Palette, TextSelection } from "../tokens.slint";
import { StartNewChatModal } from "../modals/start-new-chat-modal.slint";
import { AddContactModal } from "../modals/add-contact-modal.slint";
import { NicknameModal } from "../modals/nickname-modal.slint";
import { AccountSwitcherModal } from "../modals/account-switcher-modal.slint";
import { AddAccountModal } from "../modals/add-account-modal.slint";
import { RevealNsecModal } from "../modals/reveal-nsec-modal.slint";
import { ExportKeyModal } from "../modals/export-key-modal.slint";
import { ImportBackupModal } from "../modals/import-backup-modal.slint";
import { BackupCreateModal } from "../modals/backup-create-modal.slint";
import { ForwardPickerModal } from "../modals/forward-chat-picker-modal.slint";
import { CommandPalette } from "../modals/command-palette.slint";
import { GlobalSearchModal } from "../modals/global-search-modal.slint";
import { LanguagePickerModal } from "../modals/language-picker-modal.slint";
import { EditHistoryModal } from "../modals/edit-history-modal.slint";
import { ImageViewerModal } from "../modals/image-viewer-modal.slint";
import { VideoViewerModal } from "../modals/video-viewer-modal.slint";
import { ProfileModal } from "../modals/profile-modal.slint";
import { QrModal } from "../modals/qr-modal.slint";
import { EncryptionInfoModal } from "../modals/encryption-info-modal.slint";
import { DebugJsonModal } from "../modals/debug-json-modal.slint";
import { ConfirmFlows } from "confirm-flows.slint";
import { EmojiPicker } from "../emoji/emoji-picker.slint";
import { MessageContextMenu } from "../messages/message-context-menu.slint";
import { ChatContextMenu } from "../chat-list/chat-context-menu.slint";
import { GroupMemberMenu } from "../main-pane/group-member-menu.slint";
import { AppState } from "app-state.slint";

export component ModalHost inherits Rectangle {

    if AppState.show-language-picker: LanguagePickerModal {
            active-locale: AppState.locale;
            locale-selected(code) => {
                AppState.locale-selected(code);
            }
            dismissed => {
                AppState.show-language-picker = false;
            }
        }

        if AppState.show-new-chat: StartNewChatModal {
            chat-name <=> AppState.new-chat-name;
            members-text <=> AppState.new-chat-members;
            busy: AppState.new-chat-busy;
            status: AppState.new-chat-status;
            start-chat(n, m) => {
                AppState.start-chat(n, m);
            }
            dismissed => {
                AppState.modal-dismissed();
            }
        }

        if AppState.show-add-contact: AddContactModal {
            npub-text <=> AppState.add-contact-input;
            busy: AppState.add-contact-busy;
            status: AppState.add-contact-status;
            add-contact(n) => {
                AppState.add-contact(n);
            }
            dismissed => {
                AppState.add-contact-dismissed();
            }
        }

        if AppState.show-account-switcher: switcher := AccountSwitcherModal {
            accounts: AppState.accounts;
            select(id) => {
                AppState.switch-account(id);
            }
            remove-account(id) => {
                AppState.remove-account(id);
            }
            add-account => {
                AppState.add-account-requested();
            }
            // While the remove confirm is up, Esc / backdrop / Cancel step back
            // to the account's detail card rather than closing the switcher.
            dismissed => {
                if (switcher.confirming) {
                    switcher.confirming = false;
                } else {
                    AppState.show-account-switcher = false;
                }
            }
        }

        if AppState.show-add-account: AddAccountModal {
            nsec-text <=> AppState.add-account-nsec;
            generated: AppState.add-account-generated;
            primary-busy: AppState.add-account-busy;
            status: AppState.add-account-status;
            add(nsec) => {
                AppState.add-account(nsec);
            }
            generate => {
                AppState.generate-add-account-key();
            }
            dismissed => {
                AppState.add-account-dismissed();
            }
        }

        if AppState.show-import-backup: ImportBackupModal {
            file-name: AppState.import-backup-file;
            restore-mode: AppState.import-backup-restore-mode;
            password-text <=> AppState.import-backup-password;
            primary-busy: AppState.import-backup-busy;
            status: AppState.import-backup-status;
            pick-file => {
                AppState.import-backup-pick-file();
            }
            import(pw) => {
                AppState.import-backup-submit(pw);
            }
            dismissed => {
                AppState.import-backup-dismissed();
            }
        }

        if AppState.show-create-backup: BackupCreateModal {
            password-text <=> AppState.create-backup-password;
            primary-busy: AppState.create-backup-busy;
            status: AppState.create-backup-status;
            create(pw) => {
                AppState.create-backup-submit(pw);
            }
            dismissed => {
                AppState.create-backup-dismissed();
            }
        }

        if AppState.show-nickname-modal: NicknameModal {
            nickname-text <=> AppState.nickname-input;
            contact-name: AppState.nickname-contact-name;
            save(n) => {
                AppState.set-contact-nickname(n);
            }
            dismissed => {
                AppState.nickname-modal-dismissed();
            }
        }

        if AppState.show-reveal-nsec: RevealNsecModal {
            password <=> AppState.reveal-nsec-password;
            nsec-value: AppState.reveal-nsec-value;
            primary-busy: AppState.reveal-nsec-busy;
            status: AppState.reveal-nsec-status;
            status-color: AppState.reveal-nsec-status-error ? Palette.danger : Palette.text-lo;
            confirm(password) => {
                AppState.reveal-nsec-confirm(password);
            }
            copy(nsec) => {
                AppState.reveal-nsec-copy(nsec);
            }
            dismissed => {
                AppState.show-reveal-nsec = false;
                AppState.reveal-nsec-dismissed();
            }
        }

        if AppState.show-export-key: ExportKeyModal {
            password <=> AppState.export-key-password;
            key-value: AppState.export-key-value;
            primary-busy: AppState.export-key-busy;
            status: AppState.export-key-status;
            status-color: AppState.export-key-status-error ? Palette.danger : Palette.text-lo;
            confirm(password) => {
                AppState.export-key-confirm(password);
            }
            copy(key) => {
                AppState.copy-to-clipboard(key);
            }
            dismissed => {
                AppState.show-export-key = false;
                AppState.export-key-dismissed();
            }
        }


        if AppState.msg-global-open: GlobalSearchModal {
            dismissed => {
                AppState.msg-global-open = false;
                // Clears the results model and cancels any in-flight scan.
                AppState.msg-global-query-changed("");
            }
        }

        if AppState.show-palette: CommandPalette {
            actions: AppState.palette-actions;
            query <=> AppState.palette-query;
            dismissed => {
                AppState.palette-dismissed();
            }
            execute(id) => {
                AppState.palette-execute(id);
            }
            query-changed(q) => {
                AppState.palette-query-changed(q);
            }
        }

        // Right-click menus: both read their AppState.member-menu-* /
        // ctx-menu-* invocation context directly and re-fire the same AppState
        // callbacks the hover toolbar uses, so the Rust side is untouched.
        if AppState.member-menu-open: GroupMemberMenu { }

        if AppState.ctx-menu-open: MessageContextMenu { }

        // Developer-mode raw JSON viewer, shared by "View raw event" (message
    // context menu) and "View" key packages (contact detail).
    if AppState.debug-view-open: DebugJsonModal {
            title: AppState.debug-view-title;
            subtitle: AppState.debug-view-subtitle;
            json: AppState.debug-view-json;
            busy: AppState.debug-view-busy;
            copy-clicked => {
                AppState.debug-view-copy();
            }
            dismissed => {
                AppState.debug-view-open = false;
            }
        }

        // Forward destination picker — lists chats (minus the current one); a pick
    // hands the chosen index to Rust, which re-sends `forward-src-id`'s content
    // (text + re-encrypted attachments) into that chat.
    if AppState.forward-picker-open: ForwardPickerModal {
            chats: AppState.chats;
            active-chat: AppState.active-chat;
        // The picker only opens from the message context menu, so the menu's
        // captured author/text still describe the message being forwarded.
        source-author: AppState.ctx-menu-author;
            source-text: AppState.ctx-menu-text;
            match-flags: AppState.forward-match-flags;
            visible-rows: AppState.forward-visible-rows;
            query-changed(q) => {
                AppState.forward-filter-changed(q);
            }
            select(dest) => {
                AppState.forward-picker-open = false;
                AppState.request-forward(dest);
            }
            dismissed => {
                AppState.forward-picker-open = false;
            }
        }

        // Right-click rail chat-row context menu — pin/unpin, mute/unmute, and
    // leaving eligible group rows by captured index, independent of open chat.
    if AppState.chat-ctx-open: ChatContextMenu {
            anchor-x: AppState.chat-ctx-x;
            anchor-y: AppState.chat-ctx-y;
            pinned: AppState.chat-ctx-pinned;
            muted: AppState.chat-ctx-muted;
            can-leave: AppState.chat-ctx-can-leave;
            can-pin: AppState.chat-ctx-can-pin;
            toggle-pin => {
                AppState.chat-ctx-open = false;
                AppState.toggle-pin-chat(AppState.chat-ctx-idx);
            }
            toggle-mute => {
                AppState.chat-ctx-open = false;
                AppState.toggle-mute-chat-at(AppState.chat-ctx-idx);
            }
            export-chat => {
                AppState.chat-ctx-open = false;
                AppState.export-chat-at(AppState.chat-ctx-idx);
            }
            leave-group => {
                AppState.chat-ctx-open = false;
                AppState.leave-confirm-chat-idx = AppState.chat-ctx-idx;
                AppState.show-leave-confirm = true;
            }
            dismissed => {
                AppState.chat-ctx-open = false;
            }
        }

        // Confirm ladder — every destructive/irreversible flow, extracted to
        // shell/confirm-flows.slint. Mounted late so an armed confirm paints
        // above the menus and pickers that arm it.
        ConfirmFlows { }

        // `if`-mounted so the (expensive) emoji grid doesn't paint when closed.
    if AppState.show-emoji-picker: EmojiPicker {
            anchor-x: AppState.emoji-anchor-x;
            anchor-y: AppState.emoji-anchor-y;
            emoji-list: AppState.emoji-list;
            sprite: AppState.emoji-sprite;
            tile: AppState.emoji-tile;
            total-shown: AppState.emoji-shown;
            query <=> AppState.emoji-query;
            query-changed(q) => {
                AppState.emoji-query-changed(q);
            }
            picked(emoji) => {
                AppState.emoji-picked(AppState.emoji-target-message-id, emoji);
            }
            dismissed => {
                AppState.emoji-picker-dismissed();
            }
        }

        if AppState.edit-history-open: EditHistoryModal {
            versions: AppState.edit-history;
            dismissed => {
                AppState.dismiss-edit-history();
            }
        }

        if AppState.image-viewer-open: ImageViewerModal {
            source: AppState.image-viewer-image;
            count: AppState.image-viewer-count;
            index: AppState.image-viewer-index;
            loading: AppState.image-viewer-loading;
            failed: AppState.image-viewer-failed;
            actions-ready: AppState.image-viewer-actions-ready;
            dismissed => {
                AppState.dismiss-image-viewer();
            }
            prev => {
                AppState.image-viewer-prev();
            }
            next => {
                AppState.image-viewer-next();
            }
            retry => {
                AppState.image-viewer-retry();
            }
            copy => {
                AppState.image-viewer-copy();
            }
            save => {
                AppState.image-viewer-save();
            }
        }

        if AppState.video-viewer-open: VideoViewerModal {
            frame: AppState.video-viewer-frame;
            has-frame: AppState.video-viewer-has-frame;
            playing: AppState.video-viewer-playing;
            loading: AppState.video-viewer-loading;
            failed: AppState.video-viewer-failed;
            progress: AppState.video-viewer-progress;
            pos-label: AppState.video-viewer-pos;
            dur-label: AppState.video-viewer-dur;
            dismissed => {
                AppState.dismiss-video-viewer();
            }
            toggle-play => {
                AppState.video-viewer-toggle-play();
            }
            seek(f) => {
                AppState.video-viewer-seek(f);
            }
            seek-relative(s) => {
                AppState.video-viewer-seek-relative(s);
            }
            fullscreen => {
                AppState.video-viewer-fullscreen();
            }
            retry => {
                AppState.video-viewer-retry();
            }
        }

        if AppState.peer-profile-open: ProfileModal {
            display-name: AppState.peer-profile-name;
            npub-short: AppState.peer-profile-npub-short;
            nip05: AppState.peer-profile-nip05;
            nip05-verified: AppState.peer-profile-nip05-verified;
            about: AppState.peer-profile-about;
            lud16: AppState.peer-profile-lud16;
            loading: AppState.peer-profile-loading;
            not-found: AppState.peer-profile-not-found;
            is-contact: AppState.peer-profile-is-contact;
            is-self: AppState.peer-profile-is-self;
            adding: AppState.peer-profile-adding;
            status: AppState.peer-profile-status;
            av-a: AppState.peer-profile-av-a;
            av-b: AppState.peer-profile-av-b;
            av-initials: AppState.peer-profile-av-initials;
            av-picture: AppState.peer-profile-picture;
            av-has-picture: AppState.peer-profile-has-picture;
            picture-failed: AppState.peer-profile-picture-failed;
            shared-groups: AppState.peer-profile-shared-groups;
            copy-npub => {
                AppState.copy-to-clipboard(AppState.peer-profile-npub);
            }
            retry-picture => {
                AppState.retry-peer-profile-picture();
            }
            add-contact => {
                AppState.peer-profile-add-contact();
            }
            open-shared-group(id) => {
                AppState.open-shared-group(id);
            }
            dismissed => {
                AppState.peer-profile-dismissed();
            }
        }

        if AppState.encryption-info-open: EncryptionInfoModal {
            group-id: AppState.chats[AppState.active-chat].npub;
            copy-group-id => {
                AppState.copy-to-clipboard(AppState.chats[AppState.active-chat].npub);
            }
            dismissed => {
                AppState.encryption-info-open = false;
            }
        }

        if AppState.contact-qr-open: QrModal {
            qr: AppState.contact-qr;
            npub-short: AppState.contact-qr-npub-short;
            name: AppState.contact-qr-name;
            copy-npub => {
                AppState.copy-to-clipboard(AppState.contact-qr-npub);
            }
            dismissed => {
                AppState.contact-qr-dismissed();
            }
        }
}
