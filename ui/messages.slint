// messages area — driven by a model fed from Rust.
import { Palette, Theme, ChatMessage } from "tokens.slint";
import { MessageView } from "primitives/message-view.slint";
import { CypherScroll } from "primitives/cypher-scroll.slint";
import { MessageEffectLayer } from "primitives/message-effect-layer.slint";
import { PaperDoodles } from "primitives/paper-doodles.slint";
import { SynthGrid } from "primitives/synth-grid.slint";
import { ChevronDownIcon } from "icons/chevron-down-icon.slint";
import { SessionDivider } from "main-pane/session-divider.slint";

// One slot in the effect-burst pool. `gen` is a per-slot generation counter —
// bumping it (re)fires that slot's layer; the position/effect fields say where
// and what. Default (all-zero, gen 0) = an idle slot that never plays.
struct EffectBurst {
    x: length,
    y: length,
    w: length,
    h: length,
    id: int,
    cx: int,
    cy: int,
    gen: int,
}

export component MessagesArea inherits Rectangle {
    in property <[ChatMessage]> messages;
    in property <length> available-w: 9999px;
    in property <bool> outgoing-on-right: true;
    in property <image> my-picture;
    in property <bool> my-has-picture: false;
    // Bumped by Rust whenever a fresh outgoing message lands. The `changed`
    // handler below jumps the viewport to the bottom — with animation — so
    // the user always sees the message they just sent.
    in property <int> scroll-tick: 0;
    // True when older history exists beyond the loaded window; shows the
    // "load earlier messages" pill at the top of the list.
    in property <bool> has-older: false;
    callback request-older();
    callback react(string, string);
    callback unreact(string);
    callback request-picker(string, length, length);
    callback request-reply(string, string, string);
    callback request-edit(string, string);
    callback request-context-menu(string, string, string, bool, length, length);
    callback show-history(string);
    callback retry(string);
    callback attachment-clicked(string);
    callback audio-play-clicked(string);
    callback audio-seek-clicked(string, float);
    callback album-cell-clicked(string);
    property <length> content-w: max(120px, root.available-w - 36px);

    // Message-effect stage. A pool of overlay layers (declared after the scroll,
    // so they paint above every bubble) plays bursts. Rows report their bubble's
    // window position + size via `play-effect`; we convert to overlay-local
    // coords, write the next round-robin slot, and bump that slot's `gen` to
    // fire. Each layer binds to its own slot, so a new burst STACKS instead of
    // interrupting the ones already playing (Telegram-style). 8 concurrent.
    property <[EffectBurst]> bursts: [{}, {}, {}, {}, {}, {}, {}, {}];
    property <int> burst-next: 0;
    function stage-effect(eid: int, cx: int, cy: int, ax: length, ay: length, w: length, h: length) {
        root.bursts[root.burst-next] = {
            // Window coords → overlay-local (the clip wrapper fills root at 0,0).
            x: ax - fx-clip.absolute-position.x,
            y: ay - fx-clip.absolute-position.y,
            w: w,
            h: h,
            id: eid,
            cx: cx,
            cy: cy,
            gen: root.bursts[root.burst-next].gen + 1,
        };
        root.burst-next = root.burst-next + 1 < 8 ? root.burst-next + 1 : 0;
    }
    // Subtle vertical lift — keeps the chat canvas from feeling flat.
    background: Theme.retro
        ? Palette.bg
        : @linear-gradient(180deg, Palette.canvas-top 0%, Palette.bg 28%);

    // Hand-drawn paper backdrop: faint cute shapes scattered behind the message
    // list. Declared before `cs` so it sits behind the (transparent) scroll;
    // fixed to the viewport, so it reads as paper rather than scrolling content.
    if Theme.paper-doodles : PaperDoodles {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
    }
    // Synthwave neon grid + sunset backdrop, same fixed-to-viewport placement.
    if Theme.synth-grid : SynthGrid {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
    }

    // Computed "stick to bottom" position. We don't bind viewport-y directly
    // to this (that would override manual scrolling) — instead the changed
    // handlers below imperatively snap to it at the right moments.
    property <length> bottom-y: -max(0px, inner.preferred-height - cs.visible-height);
    // True when the user is within 40px of the bottom — used to auto-follow
    // incoming messages without yanking the scroll out from under them if
    // they've explicitly paged up to read history.
    property <bool> at-bottom: (-cs.viewport-y) >= (-root.bottom-y) - 40px;

    // Scroll anchoring for "load earlier messages": content grows at the
    // TOP, so without correction the viewport would suddenly show the middle
    // of the newly-loaded history. Armed by the pill's click; the
    // preferred-height change handler below shifts viewport-y by exactly the
    // added height so what the user was reading stays put.
    property <length> anchor-h: 0px;
    property <bool> anchor-armed: false;

    // Send-driven scroll: any tick bump (from Rust) snaps to bottom even if
    // the user had paged up. This is "I just hit send, take me there."
    changed scroll-tick => {
        cs.viewport-y = root.bottom-y;
    }
    // Content-driven scroll: when new rows append (preferred-height grows),
    // only follow if we were already near the bottom. Prevents the scroll
    // from yanking when a message arrives mid-history-reading.
    changed bottom-y => {
        if (root.at-bottom) {
            cs.viewport-y = root.bottom-y;
        }
    }

    cs := CypherScroll {
        width: parent.width;
        height: parent.height;
        viewport-width: self.width;
        viewport-height: inner.preferred-height;
        // NO `animate viewport-y` here: viewport-y is a two-way alias of the
        // Flickable's property, so a declared animation applies to EVERY
        // write — including wheel ticks and scrollbar thumb drags, which
        // then rubber-band through the easing curve and make scrolling feel
        // laggy. Programmatic snaps (send, chat open, load-older anchor) are
        // instant, which is what a chat wants anyway.

        inner := VerticalLayout {
            width: parent.width;
            padding-left: 18px; padding-right: 18px;
            padding-top: 18px; padding-bottom: 18px;
            // Tight within a group; Rust adds `gap-before` between groups.
            spacing: 3px;

            changed preferred-height => {
                if (root.anchor-armed) {
                    root.anchor-armed = false;
                    cs.viewport-y = cs.viewport-y - (self.preferred-height - root.anchor-h);
                }
            }

            // Always mounted, gated by height/visible — an `if`-mounted
            // TouchArea swallows its first click when it (re)mounts.
            Rectangle {
                height: root.has-older ? 36px : 0px;
                visible: root.has-older;
                pill := Rectangle {
                    width: pill-label.preferred-width + 28px;
                    height: 26px;
                    border-radius: 13px * Theme.r-scale;
                    background: pill-touch.has-hover ? Palette.hover : Palette.panel-2;
                    border-width: Theme.border-w;
                    border-color: pill-touch.has-hover ? Palette.border-2 : Palette.border;
                    animate background, border-color { duration: 100ms; }
                    pill-label := Text {
                        text: @tr("Load earlier messages");
                        color: pill-touch.has-hover ? Palette.text-hi : Palette.text-lo;
                        animate color { duration: 100ms; }
                        font-size: 10px * Theme.fs-scale;
                        font-weight: 600;
                        letter-spacing: 1.1px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                    pill-touch := TouchArea {
                        clicked => {
                            root.anchor-h = inner.preferred-height;
                            root.anchor-armed = true;
                            root.request-older();
                        }
                    }
                }
            }

            for msg in root.messages : VerticalLayout {
                spacing: 0;
                // Date divider above the first message of each local day, so
                // multi-day history stays orientable (bubbles only stamp HH:MM).
                if msg.day-label != "" : SessionDivider { label: msg.day-label; }
                if msg.gap-before > 0px : Rectangle { height: msg.gap-before; }

                // One skin slot per message. Theme.skin-message picks the render
                // body (skin 0 = standard incoming/outgoing bubble rows).
                MessageView {
                    msg: msg;
                    row-w: root.content-w;
                    outgoing-on-right: root.outgoing-on-right;
                    my-picture: root.my-picture;
                    my-has-picture: root.my-has-picture;
                    react(id, emoji) => { root.react(id, emoji); }
                    unreact(id) => { root.unreact(id); }
                    request-picker(id, ax, ay) => { root.request-picker(id, ax, ay); }
                    request-reply(id, preview, author) => { root.request-reply(id, preview, author); }
                    request-edit(id, current) => { root.request-edit(id, current); }
                    request-context-menu(id, text, author, can-edit, ax, ay) => { root.request-context-menu(id, text, author, can-edit, ax, ay); }
                    show-history(id) => { root.show-history(id); }
                    retry(id) => { root.retry(id); }
                    attachment-clicked(id) => { root.attachment-clicked(id); }
                    audio-play-clicked(id) => { root.audio-play-clicked(id); }
                    audio-seek-clicked(id, fraction) => { root.audio-seek-clicked(id, fraction); }
                    album-cell-clicked(key) => { root.album-cell-clicked(key); }
                    play-effect(eid, cx, cy, ax, ay, w, h) => { root.stage-effect(eid, cx, cy, ax, ay, w, h); }
                }
            }
        }
    }

    // Effect overlay — above all bubbles (declared after the scroll), below the
    // jump-pill. Fills the viewport and clips so particles don't spill into the
    // header / composer. Transparent to input (no TouchArea).
    fx-clip := Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        clip: true;
        // One layer per pool slot. Only the slot whose `gen` changed re-fires;
        // the rest keep playing — so bursts stack instead of interrupting.
        for b in root.bursts : MessageEffectLayer {
            x: b.x;
            y: b.y;
            width: b.w;
            height: b.h;
            effect-id: b.id;
            clip-x: b.cx;
            clip-y: b.cy;
            origin-w: b.w;
            origin-h: b.h;
            trigger: b.gen;
        }
    }

    // Floating "jump to latest" pill — fades in once the user pages up into
    // history, snaps the viewport back to the newest message on click.
    // Always mounted, opacity-gated (an `if`-mounted TouchArea swallows its
    // first click); the TouchArea is disabled while hidden so it never
    // intercepts clicks meant for the messages underneath.
    jump-pill := Rectangle {
        x: parent.width - self.width - 22px;
        y: parent.height - self.height - 16px;
        width: 38px;
        height: 38px;
        border-radius: (19px) * Theme.r-scale;
        background: jump-touch.has-hover ? Palette.field-hover : Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 16px;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : (Theme.light ? #1F293744 : #000000A0);
        drop-shadow-offset-x: Theme.hard-shadow ? 3px : 0px;
        drop-shadow-offset-y: Theme.hard-shadow ? 3px : 6px;
        opacity: root.at-bottom ? 0 : 1;
        animate opacity { duration: 160ms; easing: ease-out; }
        animate background { duration: 100ms; }

        ChevronDownIcon {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            size: 14px;
            stroke: jump-touch.has-hover ? Palette.text-hi : Palette.text-mid;
            animate stroke { duration: 100ms; }
        }

        jump-touch := TouchArea {
            enabled: !root.at-bottom;
            mouse-cursor: pointer;
            clicked => { cs.viewport-y = root.bottom-y; }
        }
    }
}
