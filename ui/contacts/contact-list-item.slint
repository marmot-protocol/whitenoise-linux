import { Palette, Theme, Contact } from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { Avatar } from "../primitives/avatar.slint";

export component ContactListItem inherits Rectangle {
    callback clicked;
    in property <Contact> data;
    in property <bool> selected: false;

    height: 56px;
    background: root.selected ? Palette.selected : (touch.has-hover ? Palette.hover : transparent);
    border-radius: (6px) * Theme.r-scale;
    border-width: Theme.retro && root.selected ? Theme.border-w : 0px;
    border-color: Palette.border;
    animate background { duration: 120ms; easing: ease-out; }

    // Mint accent bar — only in normal mode; in retro the yellow bar would vanish
    // against the yellow selected tile.
    if !Theme.retro : Rectangle {
        x: 0;
        width: 2px;
        height: root.selected ? 44px : 0px;
        y: (parent.height - self.height) / 2;
        background: Palette.mint;
        border-radius: (1px) * Theme.r-scale;
        opacity: root.selected ? 1.0 : 0.0;
        animate height { duration: 220ms; easing: ease-in-out; }
        animate opacity { duration: 160ms; }
    }
    // Retro selection chevron — slides in from outside.
    if Theme.retro : Text {
        x: root.selected ? 2px : -14px;
        y: (parent.height - self.height) / 2;
        text: "▶";
        color: Palette.bubble-out-fg;
        font-size: 14px;
        font-family: Theme.font;
        vertical-alignment: center;
        opacity: root.selected ? 1.0 : 0.0;
        animate x { duration: 140ms; easing: ease-out; }
        animate opacity { duration: 100ms; }
    }

    HorizontalLayout {
        padding-left: 12px; padding-right: 12px;
        padding-top: 10px; padding-bottom: 10px;
        spacing: 12px;
        Rectangle {
            width: 36px;
            Avatar {
                size: 36px;
                initials: root.data.av-initials;
                color-a: root.data.av-a;
                color-b: root.data.av-b;
                font-size: (Theme.retro ? 16px : 11px) * Theme.fs-scale;
            }
            if root.data.online : Rectangle {
                x: parent.width - 10px;
                y: parent.height - 10px;
                width: 10px; height: 10px;
                border-radius: (5px) * Theme.r-scale;
                background: Palette.mint-dim;
                Rectangle {
                    width: 10px; height: 10px;
                    border-radius: (5px) * Theme.r-scale;
                    border-width: 1.5px;
                    border-color: Palette.bg;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Text {
                    text: root.data.name;
                    // Cream on yellow is invisible in retro — switch to dark indigo when selected.
                    color: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.text-hi;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 700;
                    font-family: Theme.font;
                    vertical-alignment: center;
                }
                if root.data.verified : CheckMark {
                    // Yellow check on yellow tile is invisible — go indigo when selected in retro.
                    stroke: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.mint;
                    double: false;
                    y: 4px;
                }
            }
            Text {
                text: root.data.npub-short;
                color: Theme.retro && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                font-size: (10px) * Theme.fs-scale;
                font-family: Theme.font;
                overflow: elide;
            }
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
