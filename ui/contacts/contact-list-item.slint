import { Palette, Theme, Contact } from "../tokens.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { Avatar } from "../primitives/avatar.slint";

export component ContactListItem inherits Rectangle {
    callback clicked;
    in property <Contact> data;
    in property <bool> selected: false;

    height: 64px;
    background: root.selected ? Palette.selected : (touch.has-hover ? Palette.hover : transparent);
    border-radius: (8px) * Theme.r-scale;
    border-width: Theme.selected-inverts-text && root.selected ? Theme.border-w : (root.selected && !Theme.selected-inverts-text ? 1px : 0px);
    border-color: root.selected && !Theme.selected-inverts-text ? Palette.mint-glow : Palette.border;
    animate background, border-color {
        duration: 140ms;
        easing: ease-out;
    }

    // Mint accent bar — only in normal mode; in retro the yellow bar would vanish
    // against the yellow selected tile.
    if !Theme.pixel-select-marker: Rectangle {
        x: 0;
        width: 3px;
        height: root.selected ? 40px : 0px;
        y: (parent.height - self.height) / 2;
        background: Palette.mint;
        border-radius: (1.5px) * Theme.r-scale;
        drop-shadow-blur: root.selected ? 6px : 0px;
        drop-shadow-color: Palette.mint-glow;
        opacity: root.selected ? 1.0 : 0.0;
        animate height {
            duration: 220ms;
            easing: ease-in-out;
        }
        animate opacity {
            duration: 160ms;
            easing: ease-out;
        }
    }
    // Retro selection chevron — slides in from outside.
    if Theme.pixel-select-marker: Text {
        x: root.selected ? 2px : -14px;
        y: (parent.height - self.height) / 2;
        text: "▶";
        color: Palette.bubble-out-fg;
        font-size: (14px) * Theme.fs-scale;
        font-family: Theme.font;
        vertical-alignment: center;
        opacity: root.selected ? 1.0 : 0.0;
        animate x {
            duration: 140ms;
            easing: ease-out;
        }
        animate opacity { duration: 100ms; }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 12px;
        Rectangle {
            width: 36px;
            Avatar {
                size: 36px;
                initials: root.data.av-initials;
                color-a: root.data.av-a;
                color-b: root.data.av-b;
                picture: root.data.picture;
                has-picture: root.data.has-picture;
                font-size: Theme.fs(11px, 16px);
            }

            if root.data.online: Rectangle {
                x: parent.width - 10px;
                y: parent.height - 10px;
                width: 10px;
                height: 10px;
                border-radius: (5px) * Theme.r-scale;
                background: Palette.mint-dim;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: (5px) * Theme.r-scale;
                    border-width: 1.5px;
                    border-color: Palette.bg;
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Text {
                    text: root.data.name;
                    // Cream on yellow is invisible in retro — switch to dark indigo when selected.
                    color: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-hi;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 700;
                    font-family: Theme.font;
                    vertical-alignment: center;
                }

                if root.data.verified: CheckMark {
                    // Yellow check on yellow tile is invisible — go indigo when selected in retro.
                    stroke: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.mint;
                    double: false;
                    y: 4px;
                }
            }

            Text {
                text: root.data.npub-short;
                color: Theme.selected-inverts-text && root.selected ? Palette.bubble-out-fg : Palette.text-lo;
                font-size: (10px) * Theme.fs-scale;
                font-family: Theme.font;
                overflow: elide;
            }
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}
