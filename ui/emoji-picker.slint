import { Palette, Theme, EmojiEntry } from "tokens.slint";
import { LineInput } from "primitives/line-input.slint";
import { CypherScroll } from "primitives/cypher-scroll.slint";

// Popover emoji picker — anchored under the trigger button. Fixed at
// EMOJI_COLS-wide so geometry never depends on window size (resize is free).
//
// The grid uses a small fixed-size row pool; only `first-row` shifts on
// scroll, so no subtree churn ever.
export component EmojiPicker inherits Rectangle {
    in property <[EmojiEntry]> emoji-list;
    in property <image> sprite;
    in property <int> tile;
    in-out property <string> query;
    in property <int> total-shown;
    // Anchor point (top-left of the popover, in window coords).
    in property <length> anchor-x;
    in property <length> anchor-y;
    callback query-changed(string);
    callback picked(string);
    callback dismissed();

    // ── Fixed geometry ─────────────────────────────────────────────────
    property <int> cols: 10;
    property <length> cell-size: 30px;
    property <length> cell-spacing: 2px;
    property <length> grid-pad: 8px;
    property <length> row-h: self.cell-size + self.cell-spacing;
    property <length> panel-w: 2 * self.grid-pad + self.cols * self.cell-size + (self.cols - 1) * self.cell-spacing + 15px /* scrollbar + breathing */;
    property <length> panel-h: 280px;

    // Backdrop — invisible but eats clicks for dismissal.
    TouchArea {
        clicked => { root.dismissed(); }
    }

    // Clamp the popover inside the window with a small inset.
    property <length> inset: 8px;
    property <length> px: min(max(root.inset, root.anchor-x), root.width - root.panel-w - root.inset);
    property <length> py: min(max(root.inset, root.anchor-y), root.height - root.panel-h - root.inset);

    // Open animation. `opened` flips true right after mount so the bound
    // properties animate from their pre-open values to the final ones.
    property <bool> opened: false;
    init => { root.opened = true; }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -6px);
        width: root.panel-w;
        height: root.panel-h;
        opacity: root.opened ? 1.0 : 0.0;
        background: Palette.panel;
        animate opacity { duration: 140ms; easing: ease-out; }
        animate y { duration: 140ms; easing: ease-out; }
        border-radius: (8px) * Theme.r-scale;
        border-width: 1px;
        border-color: Palette.border;
        drop-shadow-color: #00000080;
        drop-shadow-blur: 24px;
        drop-shadow-offset-y: 6px;

        // Swallow any click that lands inside the panel and isn't claimed
        // by a more-specific TouchArea (search input, emoji cells, etc.).
        // Wrapping the content (rather than being a sibling) guarantees the
        // nested cell TouchAreas win the hit-test — sibling-TouchArea hit
        // priority was the cause of the "first click does nothing" bug:
        // the empty sibling consumed the first event before the deeper cell
        // TouchArea got a chance.
        TouchArea {

        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            // ── Search bar ─────────────────────────────────────────────
            Rectangle {
                height: 28px;
                background: Palette.bg;
                border-radius: (5px) * Theme.r-scale;
                border-width: 1px;
                border-color: search.has-focus ? Palette.mint-dim : Palette.border-2;
                animate border-color { duration: 140ms; easing: ease-out; }
                HorizontalLayout {
                    padding-left: 8px; padding-right: 8px;
                    spacing: 6px;
                    search := LineInput {
                        horizontal-stretch: 1;
                        text <=> root.query;
                        placeholder: @tr("search…");
                        fg: Palette.text-hi;
                        placeholder-color: Palette.text-lo;
                        // LineInput multiplies by fs-scale internally.
                        font-size: 12px;
                    }
                }
            }

            // ── Grid ───────────────────────────────────────────────────
            grid-frame := Rectangle {
                vertical-stretch: 1;
                background: Palette.bg;
                border-radius: (5px) * Theme.r-scale;
                border-width: 1px;
                border-color: Palette.border-2;
                clip: true;

                property <int> total: emoji-list.length;
                property <int> total-rows: (self.total + root.cols - 1) / root.cols;
                property <length> content-h: self.total-rows * root.row-h - root.cell-spacing + 2 * root.grid-pad;

                // Fixed row pool — enough to cover the popover height plus
                // an overscan margin. row-h≈32, panel-grid≈220 → ~7 rows
                // visible. 12 covers it with headroom.
                property <int> pool-rows: 12;

                scroll := CypherScroll {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: self.width;
                    viewport-height: grid-frame.content-h;

                    property <int> first-row: max(0, floor((-self.viewport-y - root.grid-pad) / root.row-h));

                    for r[idx] in grid-frame.pool-rows : row := Rectangle {
                        property <int> row-index: scroll.first-row + idx;
                        property <bool> row-active: self.row-index >= 0 && self.row-index < grid-frame.total-rows;

                        x: root.grid-pad;
                        y: root.grid-pad + self.row-index * root.row-h;
                        width: parent.width - 2 * root.grid-pad;
                        height: root.cell-size;
                        visible: self.row-active;

                        if row.row-active : Rectangle {
                            width: 100%;
                            height: 100%;
                            for c[ci] in root.cols : cell-slot := Rectangle {
                                property <int> flat-idx: row.row-index * root.cols + ci;
                                property <bool> active: self.flat-idx < grid-frame.total;

                                x: ci * (root.cell-size + root.cell-spacing);
                                y: 0;
                                width: root.cell-size;
                                height: root.cell-size;
                                visible: self.active;

                                // Always-mounted background + image + cell
                                // TouchArea. `if`-guarded mounting used to
                                // race the first user click — by the time
                                // the inner Rectangle had instantiated, the
                                // click had already been processed (and
                                // swallowed by the panel's sibling TouchArea).
                                // Keeping everything live with `visible` and
                                // `enabled` gating fixes that.
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    visible: cell-slot.active;
                                    border-radius: (4px) * Theme.r-scale;
                                    background: cell.has-hover ? Palette.hover : transparent;

                                    Image {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        visible: cell-slot.active;
                                        source: root.sprite;
                                        source-clip-x: cell-slot.active ? emoji-list[cell-slot.flat-idx].clip-x : 0;
                                        source-clip-y: cell-slot.active ? emoji-list[cell-slot.flat-idx].clip-y : 0;
                                        source-clip-width: root.tile;
                                        source-clip-height: root.tile;
                                        // Slight pop on hover so the glyph responds
                                        // along with the cell highlight.
                                        width: cell.has-hover ? 26px : 22px;
                                        height: cell.has-hover ? 26px : 22px;
                                        animate width, height { duration: 80ms; easing: ease-out; }
                                        image-fit: contain;
                                    }
                                    cell := TouchArea {
                                        enabled: cell-slot.active;
                                        clicked => {
                                            if (cell-slot.active) {
                                                root.picked(emoji-list[cell-slot.flat-idx].emoji);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if grid-frame.total == 0 : Text {
                        x: (parent.width - self.width) / 2;
                        y: root.grid-pad;
                        text: root.query == ""
                            ? @tr("no matches")
                            : @tr("no matches for \"{}\"", root.query);
                        color: Palette.text-lo;
                        font-size: (11px) * Theme.fs-scale;
                    }
                }
            }
        }
        } // close swallow TouchArea wrapping VerticalLayout

        // Esc dismiss.
        FocusScope {
            key-pressed(e) => {
                if (e.text == Key.Escape) {
                    root.dismissed();
                    return accept;
                }
                return reject;
            }
        }
    }

    // Echo query changes back to Rust so it can refilter the grid.
    property <string> last-query: "";
    changed query => {
        if (root.query != root.last-query) {
            root.last-query = root.query;
            root.query-changed(root.query);
        }
    }
}
