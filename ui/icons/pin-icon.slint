import { Palette } from "../tokens.slint";

// A small filled push-pin / map-pin glyph. Marks a chat row that the user has
// pinned to the top of the rail. Drawn (not an emoji) so it renders under the
// retro pixel font too. See ui/CONTRACT.md — icons are rects/paths only.
export component PinIcon inherits Rectangle {
    in property <color> fill: Palette.mint;
    width: 10px;
    height: 12px;
    Path {
        width: 10px;
        height: 12px;
        viewbox-width: 10;
        viewbox-height: 12;
        commands: "M 5 0 C 2.24 0 0 2.24 0 5 C 0 8.75 5 12 5 12 C 5 12 10 8.75 10 5 C 10 2.24 7.76 0 5 0 Z M 5 3 C 6.1 3 7 3.9 7 5 C 7 6.1 6.1 7 5 7 C 3.9 7 3 6.1 3 5 C 3 3.9 3.9 3 5 3 Z";
        fill: root.fill;
    }
}
