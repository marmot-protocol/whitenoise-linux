import { Palette } from "../tokens.slint";

export component ChevronRightIcon inherits Rectangle {
    in property <color> stroke: Palette.text-mid;
    in property <length> size: 10px;
    width: root.size; height: root.size;
    Path {
        width: root.size; height: root.size;
        viewbox-width: 10; viewbox-height: 10;
        commands: "M 3 1.5 L 7 5 L 3 8.5";
        stroke: root.stroke; stroke-width: 1.3px; fill: transparent;
    }
}
