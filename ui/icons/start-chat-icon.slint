import { Palette } from "../tokens.slint";

export component StartChatIcon inherits Rectangle {
    in property <color> stroke: Palette.text-mid;
    width: 14px;
    height: 12px;
    Rectangle {
        x: 0;
        y: 0;
        width: 14px;
        height: 10px;
        border-radius: 2px;
        border-width: 1.3px;
        border-color: root.stroke;
    }

    Path {
        x: 3px;
        y: 10px;
        width: 4px;
        height: 3px;
        viewbox-width: 4;
        viewbox-height: 3;
        commands: "M 0 0 L 4 0 L 2 3 Z";
        fill: root.stroke;
        stroke-width: 0;
    }
}
