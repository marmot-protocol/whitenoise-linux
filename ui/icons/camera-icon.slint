        height: 18px;
        viewbox-width: 18;
        viewbox-height: 18;
        commands: "M 2.5 5.5 L 5 5.5 L 6.3 3.5 L 11.7 3.5 L 13 5.5 L 15.5 5.5 C 16.3 5.5 17 6.2 17 7 L 17 13 C 17 13.8 16.3 14.5 15.5 14.5 L 2.5 14.5 C 1.7 14.5 1 13.8 1 13 L 1 7 C 1 6.2 1.7 5.5 2.5 5.5 Z";
        stroke: root.stroke;
