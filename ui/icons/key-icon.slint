import { Palette, Theme } from "../tokens.slint";

export component KeyIcon inherits Rectangle {
    in property <color> stroke: Palette.text-mid;
    width: 18px;
    height: 16px;
    if !Theme.pixel-icons: Rectangle {
        x: 0px;
        y: 4px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        border-width: 1.2px;
        border-color: root.stroke;
    }
    if !Theme.pixel-icons: Rectangle {
        x: 7px;
        y: 7.4px;
        width: 10px;
        height: 1.2px;
        background: root.stroke;
    }
    if !Theme.pixel-icons: Rectangle {
        x: 14.5px;
        y: 7.4px;
        width: 1.2px;
        height: 3.5px;
        background: root.stroke;
    }
    // Retro: pixel-art key.
    // Bow (head ring)
    if Theme.pixel-icons: Rectangle {
        x: 0px;
        y: 4px;
        width: 8px;
        height: 2px;
        background: root.stroke;
    }
    if Theme.pixel-icons: Rectangle {
        x: 0px;
        y: 10px;
        width: 8px;
        height: 2px;
        background: root.stroke;
    }
    if Theme.pixel-icons: Rectangle {
        x: 0px;
        y: 6px;
        width: 2px;
        height: 4px;
        background: root.stroke;
    }
    if Theme.pixel-icons: Rectangle {
        x: 6px;
        y: 6px;
        width: 2px;
        height: 4px;
        background: root.stroke;
    }
    // Shaft
    if Theme.pixel-icons: Rectangle {
        x: 8px;
        y: 7px;
        width: 10px;
        height: 2px;
        background: root.stroke;
    }
    // Tooth
    if Theme.pixel-icons: Rectangle {
        x: 14px;
        y: 9px;
        width: 2px;
        height: 4px;
        background: root.stroke;
    }
    if Theme.pixel-icons: Rectangle {
        x: 16px;
        y: 9px;
        width: 2px;
        height: 2px;
        background: root.stroke;
    }
}
