import { Palette } from "../tokens.slint";

export component AddUserIcon inherits Rectangle {
    in property <color> stroke: Palette.text-mid;
    width: 16px; height: 12px;
    Rectangle {
        x: 1px; y: 0;
        width: 6px; height: 6px;
        border-radius: 3px;
        border-width: 1.2px; border-color: root.stroke;
    }
    Path {
        x: 0; y: 6px;
        width: 9px; height: 6px;
        viewbox-width: 9; viewbox-height: 6;
        commands: "M 0.5 5.5 C 1 2 2.5 1 4.5 1 C 6.5 1 8 2 8.5 5.5";
        stroke: root.stroke; stroke-width: 1.2px; fill: transparent;
    }
    Rectangle { x: 10px; y: 4.5px; width: 5px; height: 1.2px; background: root.stroke; }
    Rectangle { x: 11.9px; y: 2.6px; width: 1.2px; height: 5px; background: root.stroke; }
}
