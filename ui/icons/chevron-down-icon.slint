import { Palette } from "../tokens.slint";

export component ChevronDownIcon inherits Rectangle {
    in property <color> stroke: Palette.text-mid;
    in property <length> size: 10px;
    width: root.size;
    height: root.size;
    Path {
        width: root.size;
        height: root.size;
        viewbox-width: 10;
        viewbox-height: 10;
        commands: "M 1.5 3 L 5 7 L 8.5 3";
        stroke: root.stroke;
        stroke-width: 1.3px;
        fill: transparent;
    }
}
