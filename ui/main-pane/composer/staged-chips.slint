import { Palette, Theme, StagedAttachment } from "../../tokens.slint";
import { PaperclipIcon } from "../../icons/paperclip-icon.slint";
import { MicroButton } from "../../primitives/button.slint";
import { Tooltip } from "../../primitives/tooltip.slint";

// Staged-attachment chips — the "are you sure" step. Everything queued here is
// visible (with a thumbnail for images) and removable before Send fires the
// uploads.
export component StagedChips inherits Rectangle {
    in property <[StagedAttachment]> staged;
    callback remove-staged(int);

    // Which chip's name is hovered and still cut off, plus the name and offset
    // to draw. The chips live inside a clipping Flickable, so the reveal has to
    // be mounted out here at the root — these carry the hovered row's data past
    // that boundary. -1 means nothing to reveal.
    property <int> hover-index: -1;
    property <string> hover-name: "";
    property <length> hover-x: 0px;

    height: 58px;
    background: Palette.bg;
    staged-flick := Flickable {
        x: 18px;
        width: parent.width - 36px;
        height: parent.height;
        viewport-width: max(self.width, staged-row.preferred-width);
        viewport-height: self.height;
        staged-row := HorizontalLayout {
            padding-top: 9px;
            padding-bottom: 9px;
            spacing: 8px;
            alignment: start;
            // 192px is the floor, not the width: a chip grows with its name up
            // to 320px so ordinary filenames are never cut for want of room,
            // and only what's still too long falls back to eliding.
            for att[att-i] in root.staged: Rectangle {
                min-width: 192px;
                max-width: 320px;
                height: 40px;
                border-radius: (8px) * Theme.r-scale;
                background: Palette.panel;
                border-width: 1px;
                border-color: Palette.border-2;
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 4px;
                    spacing: 8px;
                    alignment: stretch;
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        y: (parent.height - self.height) / 2;
                        border-radius: (5px) * Theme.r-scale;
                        background: Palette.panel-2;
                        clip: true;
                        if att.has-thumb: Image {
                            width: parent.width;
                            height: parent.height;
                            source: att.thumb;
                            image-fit: cover;
                        }
                        if !att.has-thumb && att.icon != "": Text {
                            text: att.icon;
                            color: Palette.text-lo;
                            font-size: Theme.fs(14px, 18px);
                            font-family: Theme.font;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        if !att.has-thumb && att.icon == "": PaperclipIcon {
                            stroke: Palette.text-lo;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }

                    // The name/size stack doubles as the hover target for the
                    // reveal; keeping it off the chip as a whole leaves Remove
                    // free to take its own hover.
                    //
                    // min-width: 0 on the column and on both Texts is what
                    // keeps Remove intact. A VerticalLayout otherwise adopts
                    // its widest child's min-width, so a long filename made the
                    // name column un-shrinkable and the row stole the width
                    // back from the button, clipping it to "Rem".
                    Rectangle {
                        horizontal-stretch: 1;
                        min-width: 0px;
                        VerticalLayout {
                            alignment: center;
                            name-text := Text {
                                text: att.name;
                                color: Palette.text-hi;
                                font-size: Theme.fs(11px, 14px);
                                font-family: Theme.font;
                                overflow: elide;
                                min-width: 0px;
                            }

                            Text {
                                text: att.size-label;
                                color: Palette.text-lo;
                                font-size: Theme.fs(10px, 14px);
                                font-family: Theme.font;
                                overflow: elide;
                                min-width: 0px;
                            }
                        }

                        name-touch := TouchArea {
                            changed has-hover => {
                                if (self.has-hover && name-text.preferred-width > name-text.width) {
                                    root.hover-index = att-i;
                                    root.hover-name = att.name;
                                    root.hover-x = self.absolute-position.x - root.absolute-position.x;
                                } else if (root.hover-index == att-i) {
                                    root.hover-index = -1;
                                }
                            }
                        }
                    }

                    MicroButton {
                        label: @tr("Remove");
                        // Button's min-width defaults to 0, so a long filename
                        // used to shrink the label away to "Rem". Pinning the
                        // floor to its own natural width keeps the whole word
                        // in every locale and pushes the eliding onto the name.
                        min-w: self.preferred-width;
                        button-height: 32px;
                        y: (parent.height - self.height) / 2;
                        focusable: true;
                        fg: Palette.text-mid;
                        hover-fg: Palette.text-hi;
                        bg-color: transparent;
                        hover-bg: Palette.panel-2;
                        outline: Palette.border-2;
                        hover-outline: Palette.border;
                        clicked => {
                            root.remove-staged(att-i);
                        }
                    }
                }
            }
        }
    }

    // Reveal of the hovered chip's full filename, floated above the row and
    // outside the Flickable that would otherwise clip it.
    if root.hover-index >= 0: Tooltip {
        x: max(18px, min(root.hover-x, root.width - self.width - 18px));
        y: -self.height - 6px;
        label: root.hover-name;
        wrap-width: root.width - 36px;
        is-visible: true;
    }
}
