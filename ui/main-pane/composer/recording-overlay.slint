import { Palette, Theme } from "../../tokens.slint";
import { Button, MicroButton } from "../../primitives/button.slint";

// Recording overlay — painted on top of the input pill while `recording` is
// true. Red indicator dot, live timer, stop (send) + cancel buttons.
export component RecordingOverlay inherits Rectangle {
    in property <int> recording-secs;
    // Peak input amplitude (0.0-1.0), refreshed ~10x/sec while recording.
    in property <float> recording-level;
    callback stop-recording();
    callback cancel-recording();

    x: 0;
    y: 0;
    width: 100%;
    height: 100%;
    background: Palette.panel;
    border-radius: (10px) * Theme.r-scale;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 8px;
        spacing: 12px;
        alignment: stretch;

        Rectangle {
            width: 22px;
            height: parent.height;
            // Red record dot (steady; avoids continuous repaints).
            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: (6px) * Theme.r-scale;
                background: Palette.danger;
                y: (parent.height - self.height) / 2;
                x: (parent.width - self.width) / 2;
            }
        }

        // Live input-level meter: bars light up in sequence as `recording-level`
        // rises, so a dead/muted mic reads as visibly silent before the clip
        // is sent, instead of only being discoverable after the recipient
        // complains.
        HorizontalLayout {
            width: 36px;
            height: parent.height;
            spacing: 3px;
            alignment: center;
            for threshold[i] in [0.05, 0.14, 0.28, 0.46, 0.68]: Rectangle {
                width: 4px;
                height: 7px + i * 3px;
                y: (parent.height - self.height) / 2;
                border-radius: (2px) * Theme.r-scale;
                background: root.recording-level >= threshold ? Palette.danger : Palette.bubble-inset-strong;
                animate background { duration: 90ms; }
            }
        }

        Text {
            text: @tr("{}s", root.recording-secs);
            color: Palette.text-hi;
            font-size: Theme.fs(13px, 16px);
            font-family: Theme.font;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        // Stop — finishes the clip and sends it.
        Button {
            label: @tr("Send");
            button-width: 92px;
            button-height: 36px;
            y: (parent.height - self.height) / 2;
            radius: 8px;
            pad-left: 12px;
            pad-right: 14px;
            spacing: 8px;
            use-hover: true;
            bg-color: Palette.mint;
            hover-bg: Palette.mint-hi;
            outline: Palette.mint;
            hover-outline: Palette.mint-hi;
            fg: Palette.bubble-out-fg;
            hover-fg: Palette.bubble-out-fg;
            clicked => {
                root.stop-recording();
            }
        }

        // Cancel — discards the clip.
        MicroButton {
            label: @tr("Cancel recording");
            button-height: 32px;
            y: (parent.height - self.height) / 2;
            focusable: true;
            fg: Palette.text-mid;
            hover-fg: Palette.text-hi;
            bg-color: transparent;
            hover-bg: Palette.panel-2;
            outline: Palette.border-2;
            hover-outline: Palette.border;
            clicked => {
                root.cancel-recording();
            }
        }
    }
}
