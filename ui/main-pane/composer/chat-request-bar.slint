import { Palette, Theme } from "../../tokens.slint";
import { Button } from "../../primitives/button.slint";
import { CheckMark } from "../../icons/check-mark.slint";

// Chat-request action bar — replaces the composer while the chat is a pending
// request. The input pill and its controls are hidden; this renders as a flat
// centered bar with an Accept button. The TouchArea absorbs clicks aimed at
// the hidden controls; Accept routes to the same handler as the header button.
export component ChatRequestBar inherits Rectangle {
    callback accept-clicked();

    x: 0;
    y: 0;
    width: 100%;
    height: 100%;
    TouchArea { }

    HorizontalLayout {
        spacing: 12px;
        alignment: center;

        Text {
            text: @tr("Accept the request to start messaging");
            color: Palette.text-lo;
            font-size: Theme.fs(13px, 16px);
            font-family: Theme.font;
            vertical-alignment: center;
        }

        Button {
            label: @tr("Accept");
            focusable: true;
            y: (parent.height - self.height) / 2;
            bg-color: Palette.mint;
            fg: Palette.bubble-out-fg;
            outline: Palette.mint;
            hover-bg: Palette.mint-hi;
            hover-outline: Palette.mint-hi;
            clicked => {
                root.accept-clicked();
            }
            CheckMark {
                stroke: Palette.bubble-out-fg;
                double: false;
            }
        }
    }
}
