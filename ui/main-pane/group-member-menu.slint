import { Palette, Theme } from "../tokens.slint";
import { MenuItem } from "../primitives/menu-item.slint";
import { AppState } from "../shell/app-state.slint";

// Per-member admin action menu, opened from a member row's "⋯" button. Mounted
// full-window (like MessageContextMenu) so the invisible backdrop catches
// outside clicks and the panel can sit at the anchor, clamped inside the
// window. Items are gated by the same can-* flags the row carries; each closes
// the menu and calls the AppState request-* function, which arms the existing
// admin-confirm modal.
export component GroupMemberMenu inherits Rectangle {
    // Invisible backdrop — dismisses on any click outside the panel.
    TouchArea {
        clicked => {
            AppState.member-menu-open = false;
        }
    }

    // Clamp the panel inside the window with a small inset. The anchor point
    // (top-left of the panel, in window coords) comes from AppState.
    property <length> inset: 8px;
    property <length> px: min(max(root.inset, AppState.member-menu-x), root.width - panel.width - root.inset);
    property <length> py: min(max(root.inset, AppState.member-menu-y), root.height - panel.height - root.inset);

    // Open animation — flip-after-mount, matching MessageContextMenu.
    property <bool> opened: false;
    init => {
        root.opened = true;
        keys.focus();
    }

    panel := Rectangle {
        x: root.px;
        y: root.py + (root.opened ? 0px : -4px);
        width: max(184px, col.preferred-width);
        height: col.preferred-height;
        opacity: root.opened ? 1.0 : 0.0;
        animate opacity {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        animate y {
            duration: Theme.transition-dur;
            easing: ease-out;
        }
        background: Palette.elevated;
        border-radius: (10px) * Theme.r-scale;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
        drop-shadow-offset-x: Theme.hard-shadow ? 2px : 0px;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 14px;

        // Wrap the content so any click the items don't claim is swallowed
        // (nested item TouchAreas still win the hit-test).
        TouchArea {
            col := VerticalLayout {
                padding: 4px;
                spacing: 1px;

                // Header naming the member this menu acts on.
                Rectangle {
                    height: 26px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 16px;
                        Text {
                            text: AppState.member-menu-name;
                            color: Palette.text-lo;
                            font-size: Theme.fs(11px, 14px);
                            font-family: Theme.font;
                            font-weight: 700;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Palette.border-2;
                }

                MenuItem {
                    glyph: "★";
                    label: @tr("Make admin");
                    shown: AppState.member-menu-can-promote;
                    activated => {
                        AppState.member-menu-open = false;
                        AppState.request-promote-admin(AppState.member-menu-id, AppState.member-menu-name);
                    }
                }

                MenuItem {
                    glyph: "☆";
                    label: @tr("Remove admin");
                    shown: AppState.member-menu-can-demote;
                    activated => {
                        AppState.member-menu-open = false;
                        AppState.request-demote-admin(AppState.member-menu-id, AppState.member-menu-name);
                    }
                }

                MenuItem {
                    glyph: "↩";
                    label: @tr("Step down");
                    shown: AppState.member-menu-can-self-demote;
                    activated => {
                        AppState.member-menu-open = false;
                        AppState.request-self-demote-admin(AppState.member-menu-name);
                    }
                }

                MenuItem {
                    glyph: "⊘";
                    label: @tr("Remove from group");
                    shown: AppState.member-menu-can-remove;
                    activated => {
                        AppState.member-menu-open = false;
                        AppState.request-remove-member(AppState.member-menu-id, AppState.member-menu-name);
                    }
                }
            }
        }
    }

    // Esc dismisses; focused on mount so the key lands here.
    keys := FocusScope {
        key-pressed(e) => {
            if (e.text == Key.Escape) {
                AppState.member-menu-open = false;
                return accept;
            }
            return reject;
        }
    }
}
