import { Palette, Theme } from "../tokens.slint";
import { LockIcon } from "../icons/lock-icon.slint";

export component EncryptionBanner inherits Rectangle {
    in property <string> npub;
    // True the first time this chat's banner is shown — drives a one-time
    // stripe draw-in + lock reveal. Rust clears after the entrance completes.
    in property <bool> first-show: false;

    height: 56px;
    background: Theme.soft-decor ? @linear-gradient(90deg, Palette.banner-edge 0%, Palette.banner 40%, Palette.banner-edge 100%) : Palette.banner;

    property <float> reveal: 1;
    property <float> shimmer: 1.0;
    changed first-show => {
        if (root.first-show) {
            self.reveal = 0;
            self.reveal = 1;
            self.shimmer = 0.65;
            self.shimmer = 1.0;
        }
    }
    animate reveal {
        duration: Theme.motion-fast ? 200ms : 420ms;
        easing: ease-out;
    }
    animate shimmer {
        duration: 480ms;
        easing: ease-in-out;
    }

    // Left accent stripe — draws in on first show; shimmer via opacity pulse.
    Rectangle {
        x: 0;
        y: 0;
        width: 3px * root.reveal;
        height: parent.height;
        background: Palette.mint;
        opacity: Theme.soft-decor ? root.shimmer : 1.0;
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }

    HorizontalLayout {
        padding-left: 22px;
        padding-right: 22px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 12px;

        Rectangle {
            width: 16px;
            height: 16px;
            opacity: root.reveal;
            y: (parent.height - self.height) / 2 + (1.0 - root.reveal) * -4px;
            LockIcon {
                stroke: Palette.mint;
            }
        }

        // Stretch the text column so it can shrink below its natural width on a
        // narrow window — that's what lets the npub run elide instead of spilling.
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Text {
                    text: @tr("End-to-end encrypted with");
                    color: Palette.text-hi;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                if Theme.pixel-icons: Rectangle {
                    height: 18px;
                    border-width: Theme.border-w;
                    border-color: Palette.bevel-hi;
                    background: Palette.mint;
                    HorizontalLayout {
                        padding-left: 5px;
                        padding-right: 5px;
                        Text {
                            text: "MLS";
                            color: Palette.bubble-out-fg;
                            font-size: (10px) * Theme.fs-scale;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                }
                if !Theme.pixel-icons: Text {
                    text: "MLS";
                    color: Palette.mint;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
            // No `alignment: start` here: the default stretch alignment lets the
            // npub Text (the only horizontal-stretch:1 child) absorb the free
            // space and elide when the row is too narrow, while the fixed labels
            // keep their natural width.
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: @tr("Forward secret");
                    color: Palette.text-lo;
                    font-size: (11px) * Theme.fs-scale;
                    vertical-alignment: center;
                }

                Text {
                    text: "·";
                    color: Palette.text-vlo;
                    font-size: (11px) * Theme.fs-scale;
                    vertical-alignment: center;
                }

                Text {
                    text: @tr("post-compromise secure");
                    color: Palette.text-lo;
                    font-size: (11px) * Theme.fs-scale;
                    vertical-alignment: center;
                }

                Text {
                    text: "·";
                    color: Palette.text-vlo;
                    font-size: (11px) * Theme.fs-scale;
                    vertical-alignment: center;
                }

                Text {
                    text: root.npub;
                    color: Palette.mint;
                    font-size: (11px) * Theme.fs-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
        }
    }
}
