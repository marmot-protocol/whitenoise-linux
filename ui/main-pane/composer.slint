import { Palette , Theme, StagedAttachment, EmojiSheet, EffectCatalog, EffectChoice } from "../tokens.slint";
import { PaperclipIcon } from "../icons/paperclip-icon.slint";
import { MicIcon } from "../icons/mic-icon.slint";
import { SmileyIcon } from "../icons/smiley-icon.slint";
import { SendIcon } from "../icons/send-icon.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Button, MicroButton } from "../primitives/button.slint";
import { Tooltip } from "../primitives/tooltip.slint";

export component Composer inherits Rectangle {
    in-out property <string> draft <=> composer-input.text;
    // Reply target — when non-empty, the next send goes out as a reply and a
    // small "Replying to <author>: <preview>" chip renders above the input.
    in property <string> reply-target-id;
    in property <string> reply-target-author;
    in property <string> reply-target-preview;
    // When non-empty the composer is in edit mode: a banner shows and the next
    // send rewrites that message instead of posting a new one.
    in property <string> editing-message-id;
    // Mention-autocomplete passthrough (see MentionPicker). `mention-active`
    // makes the input capture nav keys; the callbacks bubble up to Rust.
    in property <bool> mention-active: false;
    callback caret-moved(int);
    callback mention-nav(int);
    callback mention-commit();
    callback mention-dismiss();
    public function set-cursor(pos: int) { composer-input.set-cursor(pos); }
    callback send-clicked();
    callback cancel-reply();
    callback cancel-edit();
    callback attach-clicked();
    // Paste shortcut pressed in the input — Rust probes the clipboard and
    // stages an image attachment if one is there (text paste stays native).
    callback paste-image();
    // Voice message recording. While `recording` is true the composer switches
    // to a red recording row; `recording-secs` is the live clip length in
    // seconds. Stop finishes + sends; cancel discards.
    in property <bool> recording: false;
    in property <int> recording-secs: 0;
    callback record-clicked();
    callback stop-recording();
    callback cancel-recording();
    // Attachments queued for the next send. They render as a chip row above the
    // input (thumbnail for images) so the user confirms what goes out by
    // pressing Send; ✕ on a chip drops it before anything is uploaded.
    in property <[StagedAttachment]> staged: [];
    callback remove-staged(int);
    // Open the emoji picker anchored at (x, y) in window coords; the picked
    // emoji is appended to the draft rather than sent as a reaction.
    callback emoji-clicked(length, length);

    property <length> min-row-h: 52px;
    property <length> max-row-h: 132px;
    property <length> row-h: clamp(composer-input.preferred-height + 20px, root.min-row-h, root.max-row-h);
    property <length> chip-h: (root.reply-target-id == "" && root.editing-message-id == "") ? 0px : 36px;
    property <length> staged-h: root.staged.length == 0 ? 0px : 58px;
    property <bool> can-send: root.draft != "" || root.staged.length > 0;
    property <string> primary-action-label: root.can-send ? @tr("Send message") : @tr("Record voice message");
    // Message-effect picker (Telegram-style): opened by right-click / long-press
    // on Send. The chosen effect lives in EffectCatalog.selected and rides the
    // next send; Rust reads + clears it. The popover only toggles visibility.
    property <bool> show-effects: false;

    height: root.row-h + 26px + root.chip-h + root.staged-h;
    background: Palette.bg;

    VerticalLayout {
        spacing: 0;

    if root.editing-message-id != "" : Rectangle {
        height: root.chip-h;
        background: Palette.panel;
        border-width: 1px;
        border-color: Palette.border-2;
        border-radius: (6px) * Theme.r-scale;
        HorizontalLayout {
            padding-left: 18px; padding-right: 18px;
            spacing: 8px;
            alignment: stretch;
            Rectangle {
                width: 3px;
                background: Palette.mint;
                y: (parent.height - self.height) / 2;
                height: 18px;
                border-radius: 1.5px;
            }
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                Text {
                    text: @tr("Editing message  ·  Enter to save");
                    color: Palette.mint;
                    font-size: (11px) * Theme.fs-scale;
                    font-family: Theme.font;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
            MicroButton {
                label: @tr("Cancel edit");
                button-height: 32px;
                y: (parent.height - self.height) / 2;
                focusable: true;
                fg: Palette.text-mid;
                hover-fg: Palette.text-hi;
                bg-color: transparent;
                hover-bg: Palette.panel-2;
                outline: Palette.border-2;
                hover-outline: Palette.border;
                clicked => { root.cancel-edit(); }
            }
        }
    }

    if root.reply-target-id != "" : Rectangle {
        height: root.chip-h;
        background: Palette.panel;
        border-width: 1px;
        border-color: Palette.border-2;
        border-radius: (6px) * Theme.r-scale;
        HorizontalLayout {
            padding-left: 18px; padding-right: 18px;
            spacing: 8px;
            alignment: stretch;
            Rectangle {
                width: 3px;
                background: Palette.mint;
                y: (parent.height - self.height) / 2;
                height: 18px;
                border-radius: 1.5px;
            }
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: root.reply-target-author == ""
                            ? @tr("Replying to message:")
                            : @tr("Replying to {}:", root.reply-target-author);
                        color: Palette.mint;
                        font-size: (11px) * Theme.fs-scale;
                        font-family: Theme.font;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.reply-target-preview;
                        color: Palette.text-mid;
                        font-size: (11px) * Theme.fs-scale;
                        font-family: Theme.font;
                        overflow: elide;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                }
            }
            MicroButton {
                label: @tr("Cancel reply");
                button-height: 32px;
                y: (parent.height - self.height) / 2;
                focusable: true;
                fg: Palette.text-mid;
                hover-fg: Palette.text-hi;
                bg-color: transparent;
                hover-bg: Palette.panel-2;
                outline: Palette.border-2;
                hover-outline: Palette.border;
                clicked => { root.cancel-reply(); }
            }
        }
    }

    // Staged-attachment chips — the "are you sure" step. Everything queued
    // here is visible (with a thumbnail for images) and removable before
    // Send fires the uploads.
    if root.staged.length > 0 : Rectangle {
        height: root.staged-h;
        background: Palette.bg;
        staged-flick := Flickable {
            x: 18px;
            width: parent.width - 36px;
            height: parent.height;
            viewport-width: max(self.width, staged-row.preferred-width);
            viewport-height: self.height;
            staged-row := HorizontalLayout {
                padding-top: 9px;
                padding-bottom: 9px;
                spacing: 8px;
                alignment: start;
                for att[att-i] in root.staged : Rectangle {
                    width: 192px;
                    height: 40px;
                    border-radius: (8px) * Theme.r-scale;
                    background: Palette.panel;
                    border-width: 1px;
                    border-color: Palette.border-2;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 4px;
                        spacing: 8px;
                        alignment: stretch;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            y: (parent.height - self.height) / 2;
                            border-radius: (5px) * Theme.r-scale;
                            background: Palette.panel-2;
                            clip: true;
                            if att.has-thumb : Image {
                                width: parent.width;
                                height: parent.height;
                                source: att.thumb;
                                image-fit: cover;
                            }
                            if !att.has-thumb : PaperclipIcon {
                                stroke: Palette.text-lo;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: att.name;
                                color: Palette.text-hi;
                                font-size: (11px) * Theme.fs-scale;
                                font-family: Theme.font;
                                overflow: elide;
                            }
                            Text {
                                text: att.size-label;
                                color: Palette.text-lo;
                                font-size: (10px) * Theme.fs-scale;
                                font-family: Theme.font;
                                overflow: elide;
                            }
                        }
                        MicroButton {
                            label: @tr("Remove");
                            button-height: 32px;
                            y: (parent.height - self.height) / 2;
                            focusable: true;
                            fg: Palette.text-mid;
                            hover-fg: Palette.text-hi;
                            bg-color: transparent;
                            hover-bg: Palette.panel-2;
                            outline: Palette.border-2;
                            hover-outline: Palette.border;
                            clicked => { root.remove-staged(att-i); }
                        }
                    }
                }
            }
        }
    }

    HorizontalLayout {
        padding-left: 18px; padding-right: 18px;
        padding-top: 12px; padding-bottom: 14px;
        Rectangle {
            horizontal-stretch: 1;
            height: root.row-h;
            border-radius: (10px) * Theme.r-scale;
            background: Palette.panel;
            border-width: 1px;
            border-color: root.recording
                ? Palette.danger
                : (composer-input.has-focus ? Palette.mint-dim : Palette.border-2);
            drop-shadow-blur: !root.recording && composer-input.has-focus && Theme.focus-glow ? 12px : 0px;
            drop-shadow-color: root.recording ? Palette.danger-soft : Palette.mint-glow;
            animate border-color { duration: 160ms; easing: ease-out; }
            animate drop-shadow-blur { duration: 160ms; easing: ease-out; }

            // Normal composer: paperclip, mic, text input, emoji, send.
            HorizontalLayout {
                padding-left: 16px; padding-right: 8px;
                spacing: 12px;
                alignment: stretch;

                Rectangle {
                    width: 22px;
                    height: parent.height;
                    border-radius: (4px) * Theme.r-scale;
                    background: attach-touch.has-hover ? Palette.panel-2 : transparent;
                    animate background { duration: 100ms; }
                    PaperclipIcon {
                        stroke: attach-touch.has-hover ? Palette.text-hi : Palette.text-lo;
                        y: (parent.height - self.height) / 2;
                    }
                    attach-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.attach-clicked(); }
                    }
                }
                composer-input := LineInput {
                    placeholder: @tr("Send a message…");
                    font-size: Theme.fs(13px, 16px);
                    fg: Palette.text-hi;
                    placeholder-color: Palette.text-lo;
                    single-line: false;
                    horizontal-stretch: 1;
                    capture-nav: root.mention-active;
                    submit => { root.send-clicked(); }
                    paste-image => { root.paste-image(); }
                    caret-moved(c) => { root.caret-moved(c); }
                    nav(d) => { root.mention-nav(d); }
                    commit-mention => { root.mention-commit(); }
                    dismiss-mention => { root.mention-dismiss(); }
                }
                emoji-rect := Rectangle {
                    width: 32px;
                    height: parent.height;
                    Rectangle {
                        width: 26px;
                        height: 26px;
                        y: (parent.height - self.height) / 2;
                        border-radius: (4px) * Theme.r-scale;
                        background: emoji-touch.has-hover ? Palette.panel-2 : transparent;
                        animate background { duration: 100ms; }
                        SmileyIcon {
                            stroke: emoji-touch.has-hover ? Palette.text-hi : Palette.text-lo;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    emoji-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.emoji-clicked(
                                emoji-rect.absolute-position.x,
                                emoji-rect.absolute-position.y);
                        }
                    }
                }
                // Icon-only circular action: with content it's Send (mint);
                // empty it becomes the mic, so the draft governs which action
                // sits in the slot. Dropping the 92px "Send" word frees that
                // width back to the input. Stays named `send-button` so the
                // effect badge/popover anchor math below is unchanged.
                send-button := Button {
                    focusable: true;
                    accessible-label: root.primary-action-label;
                    clicked => {
                        if (root.can-send) { root.send-clicked(); }
                        else { root.record-clicked(); }
                    }
                    // Right-click / long-press arms a message effect — only
                    // meaningful when there's actually a message to send.
                    alt-action => { if (root.can-send) { root.show-effects = !root.show-effects; } }
                    button-width: 36px;
                    button-height: 36px;
                    y: (parent.height - self.height) / 2;
                    radius: 18px;
                    pad-left: 0px;
                    pad-right: 0px;
                    spacing: 0px;
                    use-hover: true;
                    bg-color: root.can-send ? Palette.mint : Palette.panel-2;
                    hover-bg: root.can-send ? Palette.mint-hi : Palette.panel-2;
                    outline: root.can-send ? Palette.mint : Palette.border-2;
                    hover-outline: root.can-send ? Palette.mint-hi : Palette.border;
                    animate bg-color, outline { duration: 140ms; easing: ease-out; }
                    if root.can-send : Rectangle {
                        width: 16px;
                        height: 16px;
                        SendIcon {
                            fill-color: Palette.bubble-out-fg;
                            size: 16px;
                            // optical-center the asymmetric arrow in the circle
                            x: (parent.width - self.width) / 2 - 1px;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    if !root.can-send : MicIcon {
                        stroke: send-button.has-hover ? Palette.text-hi : Palette.text-lo;
                    }
                }
            }

            // Recording overlay: red indicator, live timer, stop (send) + cancel.
            // Painted on top of the normal composer when `recording` is true.
            if root.recording : Rectangle {
                x: 0; y: 0;
                width: 100%; height: 100%;
                background: Palette.panel;
                border-radius: (10px) * Theme.r-scale;

                HorizontalLayout {
                    padding-left: 16px; padding-right: 8px;
                    spacing: 12px;
                    alignment: stretch;

                    Rectangle {
                        width: 22px;
                        height: parent.height;
                        // Red record dot (steady; avoids continuous repaints).
                        Rectangle {
                            width: 12px;
                            height: 12px;
                            border-radius: 6px;
                            background: Palette.danger;
                            y: (parent.height - self.height) / 2;
                            x: (parent.width - self.width) / 2;
                        }
                    }

                    Text {
                        text: @tr("{}s", root.recording-secs);
                        color: Palette.text-hi;
                        font-size: Theme.fs(13px, 16px);
                        font-family: Theme.font;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    // Stop — finishes the clip and sends it.
                    Button {
                        label: @tr("Send");
                        button-width: 92px;
                        button-height: 36px;
                        y: (parent.height - self.height) / 2;
                        radius: 8px;
                        pad-left: 12px;
                        pad-right: 14px;
                        spacing: 8px;
                        use-hover: true;
                        bg-color: Palette.danger;
                        hover-bg: Palette.danger-soft-hover;
                        outline: Palette.danger;
                        hover-outline: Palette.danger;
                        fg: #FFFFFF;
                        hover-fg: #FFFFFF;
                        clicked => { root.stop-recording(); }
                    }

                    // Cancel — discards the clip.
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        y: (parent.height - self.height) / 2;
                        border-radius: (8px) * Theme.r-scale;
                        background: rec-cancel-touch.has-hover ? Palette.panel-2 : transparent;
                        animate background { duration: 100ms; }
                        Text {
                            text: "✕";
                            color: rec-cancel-touch.has-hover ? Palette.text-hi : Palette.text-mid;
                            font-size: (14px) * Theme.fs-scale;
                            font-family: Theme.font;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        rec-cancel-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.cancel-recording(); }
                        }
                    }
                }
            }
        }
    }
    }

    // Badge: the chosen effect's emoji over the top-right of Send, when an
    // effect is armed. Lives at the composer root (not in the Button's layout
    // slot, which ignores explicit x/y) and floats over the button corner.
    if EffectCatalog.selected > 0 && root.can-send : Rectangle {
        x: send-button.absolute-position.x - root.absolute-position.x + send-button.width - self.width + 4px;
        y: send-button.absolute-position.y - root.absolute-position.y - 4px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: Palette.bg;
        border-width: 1.5px;
        border-color: Palette.mint;
        for c in EffectCatalog.choices : Rectangle {
            if c.id == EffectCatalog.selected : Image {
                width: 14px;
                height: 14px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: EmojiSheet.sprite;
                source-clip-x: c.clip-x;
                source-clip-y: c.clip-y;
                source-clip-width: EmojiSheet.tile;
                source-clip-height: EmojiSheet.tile;
            }
        }
    }

    if send-button.has-hover : Tooltip {
        x: send-button.absolute-position.x - root.absolute-position.x
           + send-button.width - self.width;
        y: send-button.absolute-position.y - root.absolute-position.y - self.height - 8px;
        label: root.primary-action-label;
        is-visible: send-button.has-hover;
        offset-y: 0px;
    }

    // Newline hint — teaches Shift+Enter on entry, then gets out of the way:
    // shown only while the input is focused and still empty, floating above the
    // pill so it never covers typed text. Replaces the old crammed placeholder.
    if composer-input.has-focus && root.draft == "" : Rectangle {
        x: send-button.absolute-position.x - root.absolute-position.x
           + send-button.width - self.width;
        y: send-button.absolute-position.y - root.absolute-position.y - self.height - 6px;
        width: hint-row.preferred-width + 16px;
        height: 24px;
        border-radius: (6px) * Theme.r-scale;
        background: Palette.elevated;
        border-width: Theme.border-w;
        border-color: Palette.elevated-border;
        drop-shadow-color: Theme.hard-shadow ? Palette.shadow : #00000033;
        drop-shadow-blur: Theme.hard-shadow ? 0px : 4px;
        drop-shadow-offset-y: Theme.hard-shadow ? 2px : 1px;
        hint-row := HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            alignment: center;
            Text {
                text: @tr("Shift+Enter for newline");
                color: Palette.text-mid;
                font-size: (10px) * Theme.fs-scale;
                font-weight: 600;
                font-family: Theme.font;
                vertical-alignment: center;
            }
        }
    }

    // Effect picker popover — floats just above the Send button. Non-modal; a
    // light backdrop over the composer closes it on an outside tap. Choosing an
    // effect arms it (persists into the next send) and closes; the ✕ clears.
    if root.show-effects : TouchArea {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        clicked => { root.show-effects = false; }
    }
    if root.show-effects : Rectangle {
        x: min(root.width - self.width - 12px,
               send-button.absolute-position.x - root.absolute-position.x
               + send-button.width - self.width);
        y: send-button.absolute-position.y - root.absolute-position.y - self.height - 8px;
        width: effect-row.preferred-width + 16px;
        height: 44px;
        border-radius: (12px) * Theme.r-scale;
        background: Palette.panel;
        border-width: Theme.border-w;
        border-color: Palette.border-2;
        drop-shadow-color: Palette.shadow;
        drop-shadow-blur: 16px;
        drop-shadow-offset-y: 4px;
        effect-row := HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 4px;
            alignment: center;
            // Clear / none.
            Rectangle {
                width: 30px;
                height: 30px;
                y: (parent.height - self.height) / 2;
                border-radius: (8px) * Theme.r-scale;
                background: none-touch.has-hover ? Palette.panel-2 : transparent;
                border-width: EffectCatalog.selected == 0 ? 1.5px : 0px;
                border-color: Palette.mint;
                animate background { duration: 100ms; }
                Text {
                    text: "✕";
                    color: Palette.text-mid;
                    font-size: (13px) * Theme.fs-scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                none-touch := TouchArea {
                    clicked => {
                        EffectCatalog.selected = 0;
                        root.show-effects = false;
                    }
                }
            }
            for c in EffectCatalog.choices : Rectangle {
                width: 34px;
                height: 30px;
                y: (parent.height - self.height) / 2;
                border-radius: (8px) * Theme.r-scale;
                background: fx-touch.has-hover ? Palette.panel-2 : transparent;
                border-width: EffectCatalog.selected == c.id ? 1.5px : 0px;
                border-color: Palette.mint;
                animate background { duration: 100ms; }
                Image {
                    width: 24px;
                    height: 24px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: EmojiSheet.sprite;
                    source-clip-x: c.clip-x;
                    source-clip-y: c.clip-y;
                    source-clip-width: EmojiSheet.tile;
                    source-clip-height: EmojiSheet.tile;
                }
                fx-touch := TouchArea {
                    clicked => {
                        EffectCatalog.selected = c.id;
                        root.show-effects = false;
                    }
                }
            }
        }
    }
}
