import {
    Palette,
    ChatMeta,
    ChatMessage,
    GroupMember,
    StagedAttachment,
} from "../tokens.slint";
import { MessagesArea } from "../messages.slint";
import { ChatHeader } from "chat-header.slint";
import { EncryptionBanner } from "encryption-banner.slint";
import { ChatRequestBanner } from "chat-request-banner.slint";
import { SessionDivider } from "session-divider.slint";
import { Composer } from "composer.slint";
import { MentionPicker } from "mention-picker.slint";
import { GroupMembersPanel } from "group-members-panel.slint";

export component MainPane inherits Rectangle {
    in property <ChatMeta> chat;
    in property <int> active-chat;
    in property <bool> is-group: false;
    in property <bool> can-show-members: false;
    in property <bool> chat-muted: false;
    callback mute-toggle-clicked();
    in property <bool> encryption-banner-first-show: false;
    in property <int> member-count: 0;
    in property <[GroupMember]> members;
    in property <bool> can-add-members: false;
    in property <bool> add-member-busy: false;
    in property <string> add-member-status;
    in-out property <string> add-member-draft;
    callback add-member(string);
    callback promote-admin(string, string);
    callback demote-admin(string, string);
    callback self-demote-admin(string);
    in property <image> group-picture;
    in property <bool> group-has-picture: false;
    in property <color> group-av-a;
    in property <color> group-av-b;
    in property <string> group-av-initials;
    in property <bool> group-rename-busy: false;
    in property <bool> group-image-busy: false;
    in property <bool> group-leave-busy: false;
    in property <string> group-status;
    in-out property <string> group-rename-draft;
    callback rename-group(string);
    callback change-group-image();
    callback clear-group-image();
    callback leave-group();
    in-out property <bool> show-members: false;
    in property <bool> outgoing-on-right: true;
    in property <image> my-picture;
    in property <bool> my-has-picture: false;
    in property <[ChatMessage]> messages;
    in property <int> scroll-tick: 0;
    in property <bool> has-older: false;
    callback request-older();
    in-out property <string> draft <=> composer.draft;
    in property <string> reply-target-id;
    in property <string> reply-target-author;
    in property <string> reply-target-preview;
    in property <image> reply-target-image;
    in property <bool> reply-target-has-image: false;
    in property <string> editing-message-id;
    // Mention autocomplete.
    in property <bool> mention-active: false;
    in property <[GroupMember]> mention-candidates;
    in property <int> mention-selected: 0;
    callback caret-moved(int);
    callback mention-nav(int);
    callback mention-commit();
    callback mention-choose(int);
    callback mention-dismiss();
    // Caret restore after a mention splice — bumping `caret-tick` re-applies
    // `caret-pos` even when the offset is unchanged.
    in property <int> caret-pos: 0;
    in property <int> caret-tick: 0;
    changed caret-tick => {
        composer.set-cursor(self.caret-pos);
    }
    callback send-clicked();
    callback cancel-reply();
    callback cancel-edit();
    callback attach-clicked();
    callback paste-image();
    in property <[StagedAttachment]> staged;
    callback remove-staged(int);
    callback emoji-clicked(length, length);
    callback attachment-clicked(string);
    callback audio-play-clicked(string);
    callback audio-seek-clicked(string, float);
    callback album-cell-clicked(string);
    // Voice message recording state, driven by Rust.
    in-out property <bool> recording: false;
    in property <int> recording-secs: 0;
    callback record-clicked();
    callback stop-recording();
    callback cancel-recording();
    callback react(string, string);
    callback unreact(string);
    callback request-picker(string, length, length);
    callback request-reply(string, string, string);
    callback request-edit(string, string);
    callback request-context-menu(string, string, string, bool, length, length);
    callback show-history(string);
    callback retry(string);
    callback accept-clicked();
    callback block-clicked();
    callback archive-clicked();
    callback members-toggle-clicked();

    horizontal-stretch: 1;
    background: Palette.bg;

    HorizontalLayout {
        spacing: 0;
        vertical-stretch: 1;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 0;

            ChatHeader {
                chat: root.chat;
                is-group: root.is-group;
                group-picture: root.group-picture;
                group-has-picture: root.group-has-picture;
                can-show-members: root.can-show-members;
                member-count: root.member-count;
                members-open: root.show-members;
                muted: root.chat-muted;
                accept-clicked => {
                    root.accept-clicked();
                }
                block-clicked => {
                    root.block-clicked();
                }
                archive-clicked => {
                    root.archive-clicked();
                }
                members-toggle-clicked => {
                    root.members-toggle-clicked();
                }
                mute-toggle-clicked => {
                    root.mute-toggle-clicked();
                }
            }

            if root.chat.is-chat-request: ChatRequestBanner { }
            if !root.chat.is-chat-request: EncryptionBanner {
                npub: root.chat.npub;
                first-show: root.encryption-banner-first-show;
            }

            SessionDivider {
                label: root.chat.is-chat-request ? @tr("CHAT REQUEST") + " · " + root.chat.session-time : "MLS · " + @tr("SESSION ESTABLISHED") + " · " + root.chat.session-time;
            }

            MessagesArea {
                vertical-stretch: 1;
                messages: root.messages;
                scroll-tick: root.scroll-tick;
                has-older: root.has-older;
                request-older => {
                    root.request-older();
                }
                available-w: parent.width;
                outgoing-on-right: root.outgoing-on-right;
                my-picture: root.my-picture;
                my-has-picture: root.my-has-picture;
                react(id, emoji) => {
                    root.react(id, emoji);
                }
                unreact(id) => {
                    root.unreact(id);
                }
                request-picker(id, ax, ay) => {
                    root.request-picker(id, ax, ay);
                }
                request-reply(id, preview, author) => {
                    root.request-reply(id, preview, author);
                }
                request-edit(id, current) => {
                    root.request-edit(id, current);
                }
                request-context-menu(id, text, author, can-edit, ax, ay) => {
                    root.request-context-menu(id, text, author, can-edit, ax, ay);
                }
                show-history(id) => {
                    root.show-history(id);
                }
                retry(id) => {
                    root.retry(id);
                }
                attachment-clicked(id) => {
                    root.attachment-clicked(id);
                }
                audio-play-clicked(id) => {
                    root.audio-play-clicked(id);
                }
                audio-seek-clicked(id, fraction) => {
                    root.audio-seek-clicked(id, fraction);
                }
                album-cell-clicked(key) => {
                    root.album-cell-clicked(key);
                }
            }

            composer := Composer {
                chat-request: root.chat.is-chat-request;
                accept-clicked => {
                    root.accept-clicked();
                }
                reply-target-id: root.reply-target-id;
                reply-target-author: root.reply-target-author;
                reply-target-preview: root.reply-target-preview;
                reply-target-image: root.reply-target-image;
                reply-target-has-image: root.reply-target-has-image;
                editing-message-id: root.editing-message-id;
                mention-active: root.mention-active;
                send-clicked => {
                    root.send-clicked();
                }
                cancel-reply => {
                    root.cancel-reply();
                }
                cancel-edit => {
                    root.cancel-edit();
                }
                attach-clicked => {
                    root.attach-clicked();
                }
                paste-image => {
                    root.paste-image();
                }
                staged: root.staged;
                remove-staged(i) => {
                    root.remove-staged(i);
                }
                emoji-clicked(ax, ay) => {
                    root.emoji-clicked(ax, ay);
                }
                caret-moved(c) => {
                    root.caret-moved(c);
                }
                mention-nav(d) => {
                    root.mention-nav(d);
                }
                mention-commit => {
                    root.mention-commit();
                }
                mention-dismiss => {
                    root.mention-dismiss();
                }
                recording: root.recording;
                recording-secs: root.recording-secs;
                record-clicked => {
                    root.record-clicked();
                }
                stop-recording => {
                    root.stop-recording();
                }
                cancel-recording => {
                    root.cancel-recording();
                }
            }
        }

        if root.can-show-members && root.show-members: GroupMembersPanel {
            members: root.members;
            member-count: root.member-count;
            is-group: root.is-group;
            can-add-members: root.can-add-members;
            add-busy: root.add-member-busy;
            add-status: root.add-member-status;
            add-draft <=> root.add-member-draft;
            group-picture: root.group-picture;
            group-has-picture: root.group-has-picture;
            group-av-a: root.group-av-a;
            group-av-b: root.group-av-b;
            group-av-initials: root.group-av-initials;
            rename-busy: root.group-rename-busy;
            image-busy: root.group-image-busy;
            leave-busy: root.group-leave-busy;
            group-status: root.group-status;
            rename-draft <=> root.group-rename-draft;
            close-clicked => {
                root.members-toggle-clicked();
            }
            add-member(npub) => {
                root.add-member(npub);
            }
            promote-admin(id, name) => {
                root.promote-admin(id, name);
            }
            demote-admin(id, name) => {
                root.demote-admin(id, name);
            }
            self-demote-admin(name) => {
                root.self-demote-admin(name);
            }
            rename-group(name) => {
                root.rename-group(name);
            }
            change-image => {
                root.change-group-image();
            }
            clear-image => {
                root.clear-group-image();
            }
            leave-group => {
                root.leave-group();
            }
        }
    }

    // Mention autocomplete popup, floated just above the composer's text field.
    // A direct child of the root Rectangle (not the layout) so it can be
    // free-positioned and overlay the messages area.
    if root.mention-active && root.mention-candidates.length > 0: MentionPicker {
        candidates: root.mention-candidates;
        selected: root.mention-selected;
        x: composer.absolute-position.x - root.absolute-position.x + 46px;
        y: composer.absolute-position.y - root.absolute-position.y - self.height - 2px;
        choose(i) => {
            root.mention-choose(i);
        }
    }
}
