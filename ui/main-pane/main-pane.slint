import { Palette, ChatMeta } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { MessagesArea } from "../messages/messages.slint";
import { ChatHeader } from "chat-header.slint";
import { ChatRequestBanner } from "chat-request-banner.slint";
import { SessionDivider } from "session-divider.slint";
import { Composer } from "composer.slint";
import { MentionPicker } from "mention-picker.slint";
import { GroupMembersPanel } from "group-members-panel.slint";

// The open-conversation pane: header, message scroll, composer, and the
// group-members side panel. Reads AppState directly (per the AGENTS.md rule:
// shell/pages read the global; leaf primitives stay pure-props) — the shell
// mounts it with layout geometry only.
export component MainPane inherits Rectangle {
    // The open chat's row — the single indexed lookup the children share.
    property <ChatMeta> chat: AppState.chats[AppState.active-chat];

    horizontal-stretch: 1;
    background: Palette.bg;

    HorizontalLayout {
        spacing: 0;
        vertical-stretch: 1;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 0;

            ChatHeader {
                chat: root.chat;
                is-group: AppState.chat-is-group;
                group-picture: AppState.chat-group-picture;
                group-has-picture: AppState.chat-group-has-picture;
                can-show-members: AppState.chat-can-show-members;
                member-count: AppState.chat-member-count;
                group-description: AppState.chat-group-description;
                members-open: AppState.show-chat-members;
                muted: AppState.active-chat-muted;
                accept-clicked => {
                    AppState.accept-chat-request();
                }
                block-clicked => {
                    AppState.show-block-confirm = true;
                }
                archive-clicked => {
                    AppState.archive-chat();
                }
                members-toggle-clicked => {
                    AppState.members-toggle-clicked();
                }
                mute-toggle-clicked => {
                    AppState.toggle-mute-chat();
                }
                badge-clicked => {
                    AppState.encryption-info-open = true;
                }
            }

            if root.chat.is-chat-request: ChatRequestBanner { }

            SessionDivider {
                label: root.chat.is-chat-request ? @tr("CHAT REQUEST") + " · " + root.chat.session-time : "MLS · " + @tr("SESSION ESTABLISHED") + " · " + root.chat.session-time;
            }

            MessagesArea {
                vertical-stretch: 1;
                available-w: parent.width;
            }

            composer := Composer { }
        }

        if AppState.chat-can-show-members && AppState.show-chat-members: GroupMembersPanel {
            members: AppState.chat-members;
            invited-members: AppState.chat-invited-members;
            member-count: AppState.chat-member-count;
            group-description: AppState.chat-group-description;
            is-group: AppState.chat-is-group;
            can-add-members: AppState.chat-can-add-members;
            add-busy: AppState.add-member-busy;
            add-status: AppState.add-member-status;
            add-draft <=> AppState.add-member-draft;
            group-picture: AppState.chat-group-picture;
            group-has-picture: AppState.chat-group-has-picture;
            group-av-a: AppState.chat-group-av-a;
            group-av-b: AppState.chat-group-av-b;
            group-av-initials: AppState.chat-group-av-initials;
            rename-busy: AppState.group-rename-busy;
            description-busy: AppState.group-description-busy;
            image-busy: AppState.group-image-busy;
            leave-busy: AppState.group-leave-busy;
            group-status: AppState.group-settings-status;
            rename-draft <=> AppState.group-rename-draft;
            description-draft <=> AppState.group-description-draft;
            close-clicked => {
                AppState.members-toggle-clicked();
            }
            add-member(npub) => {
                AppState.add-member(npub);
            }
            request-member-menu(id, name, cp, cd, csd, cr, ax, ay) => {
                AppState.member-menu-id = id;
                AppState.member-menu-name = name;
                AppState.member-menu-can-promote = cp;
                AppState.member-menu-can-demote = cd;
                AppState.member-menu-can-self-demote = csd;
                AppState.member-menu-can-remove = cr;
                AppState.member-menu-x = ax;
                AppState.member-menu-y = ay;
                AppState.member-menu-open = true;
            }
            rename-group(name) => {
                AppState.rename-group(name);
            }
            set-group-description(description) => {
                AppState.set-group-description(description);
            }
            change-image => {
                AppState.change-group-image();
            }
            clear-image => {
                AppState.clear-group-image();
            }
            leave-group => {
                AppState.leave-confirm-chat-idx = AppState.active-chat;
                AppState.show-leave-confirm = true;
            }
        }
    }

    // Mention autocomplete popup, floated just above the composer's text field.
    // A direct child of the root Rectangle (not the layout) so it can be
    // free-positioned and overlay the messages area.
    if AppState.mention-active && AppState.mention-candidates.length > 0: MentionPicker {
        candidates: AppState.mention-candidates;
        selected: AppState.mention-selected;
        x: composer.absolute-position.x - root.absolute-position.x + 46px;
        y: composer.absolute-position.y - root.absolute-position.y - self.height - 2px;
        choose(i) => {
            AppState.mention-choose(i);
        }
    }
}
