import { Palette, Theme } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { GroupCard } from "../layout/group-card.slint";
import { Section } from "../layout/section.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Button } from "../primitives/button.slint";
import { Avatar } from "../primitives/avatar.slint";
import { StatusLine } from "../primitives/status-line.slint";

// Group settings surface: admin-only avatar/name/description controls plus the
// member leave action. Reads AppState directly (admin controls gate on
// chat-can-add-members); mounted bare by GroupMembersPanel.
export component GroupSettingsCard inherits Section {
    vertical-stretch: 0;
    label: @tr("Group settings");

    GroupCard {
        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 10px;

            if AppState.chat-can-add-members: HorizontalLayout {
                spacing: 12px;
                alignment: start;
                Avatar {
                    size: 56px;
                    initials: AppState.chat-group-av-initials;
                    color-a: AppState.chat-group-av-a;
                    color-b: AppState.chat-group-av-b;
                    picture: AppState.chat-group-picture;
                    has-picture: AppState.chat-group-has-picture;
                    font-size: Theme.fs(18px, 20px);
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Button {
                        label: AppState.group-image-busy ? @tr("Uploading…") : @tr("Change image");
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        clicked => {
                            if (!AppState.group-image-busy) {
                                AppState.change-group-image();
                            }
                        }
                    }

                    if AppState.chat-group-has-picture && !AppState.group-image-busy: Button {
                        label: @tr("Remove image");
                        button-height: 26px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: transparent;
                        outline: transparent;
                        has-fill: false;
                        use-hover: true;
                        hover-bg: Palette.hover;
                        fg: Palette.text-mid;
                        hover-fg: Palette.text-hi;
                        clicked => {
                            AppState.clear-group-image();
                        }
                    }
                }
            }

            if AppState.chat-can-add-members: VerticalLayout {
                spacing: 6px;
                Text {
                    text: @tr("Group name");
                    color: Palette.text-hi;
                    font-size: Theme.fs(12px, 16px);
                    font-weight: 700;
                }

                Rectangle {
                    height: 36px;
                    border-radius: (6px) * Theme.r-scale;
                    background: Palette.field;
                    border-width: Theme.border-w;
                    border-color: rename-input.has-focus ? Palette.mint-dim : Palette.field-border;
                    drop-shadow-blur: rename-input.has-focus && Theme.focus-glow ? 10px : 0px;
                    drop-shadow-color: Palette.mint-glow;
                    animate border-color {
                        duration: 140ms;
                        easing: ease-out;
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        rename-input := LineInput {
                            placeholder: @tr("Group name");
                            text <=> AppState.group-rename-draft;
                            font-size: Theme.fsr(12px, 14px);
                            fg: Palette.text-hi;
                            placeholder-color: Palette.text-vlo;
                            submit => {
                                if (!AppState.group-rename-busy && AppState.group-rename-draft != "") {
                                    AppState.rename-group(AppState.group-rename-draft);
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button {
                        label: AppState.group-rename-busy ? @tr("Saving…") : @tr("Save name");
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: Palette.mint-surface;
                        fg: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-surface;
                        clicked => {
                            if (!AppState.group-rename-busy && AppState.group-rename-draft != "") {
                                AppState.rename-group(AppState.group-rename-draft);
                            }
                        }
                    }
                }

                Text {
                    text: @tr("Group description");
                    color: Palette.text-hi;
                    font-size: Theme.fs(12px, 16px);
                    font-weight: 700;
                }

                Rectangle {
                    height: 84px;
                    border-radius: (6px) * Theme.r-scale;
                    background: Palette.field;
                    border-width: Theme.border-w;
                    border-color: description-input.has-focus ? Palette.mint-dim : Palette.field-border;
                    drop-shadow-blur: description-input.has-focus && Theme.focus-glow ? 10px : 0px;
                    drop-shadow-color: Palette.mint-glow;
                    animate border-color {
                        duration: 140ms;
                        easing: ease-out;
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        description-input := LineInput {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            placeholder: @tr("Purpose, rules, or invite blurb");
                            text <=> AppState.group-description-draft;
                            single-line: false;
                            enter-submits: false;
                            font-size: Theme.fsr(12px, 14px);
                            fg: Palette.text-hi;
                            placeholder-color: Palette.text-vlo;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button {
                        label: AppState.group-description-busy ? @tr("Saving…") : @tr("Save description");
                        enabled: !AppState.group-description-busy;
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: Palette.mint-surface;
                        fg: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-surface;
                        clicked => {
                            if (!AppState.group-description-busy) {
                                AppState.set-group-description(AppState.group-description-draft);
                            }
                        }
                    }
                }
            }

            if AppState.group-settings-status != "": StatusLine {
                compact: true;
                text: AppState.group-settings-status;
                kind: AppState.group-settings-status-kind;
            }

            if AppState.chat-can-add-members: Rectangle {
                height: 1px;
                background: Palette.border-2;
            }

            VerticalLayout {
                spacing: 6px;
                Text {
                    text: @tr("Leave group");
                    color: Palette.danger;
                    font-size: Theme.fs(12px, 16px);
                    font-weight: 700;
                }

                Text {
                    text: AppState.chat-can-add-members ? @tr("Admins must step down before leaving.") : @tr("Leave this group and stop receiving new messages. The chat moves to Archive.");
                    color: Palette.text-lo;
                    font-size: Theme.fs(10px, 14px);
                    wrap: word-wrap;
                }

                if !AppState.chat-can-add-members: HorizontalLayout {
                    alignment: start;
                    Button {
                        label: AppState.group-leave-busy ? @tr("Leaving…") : @tr("Leave group");
                        enabled: !AppState.group-leave-busy;
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        fg: Palette.danger;
                        bg-color: Palette.danger-soft;
                        hover-bg: Palette.danger-soft-hover;
                        outline: Palette.danger-border;
                        hover-outline: Palette.danger-border-hover;
                        clicked => {
                            AppState.leave-confirm-chat-idx = AppState.active-chat;
                            AppState.show-leave-confirm = true;
                        }
                    }
                }
            }
        }
    }
}
