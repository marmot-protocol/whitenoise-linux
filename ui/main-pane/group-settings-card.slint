import { Palette, Theme } from "../tokens.slint";
import { GroupCard } from "../shells/group-card.slint";
import { Section } from "../shells/section.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Button } from "../primitives/button.slint";
import { Avatar } from "../primitives/avatar.slint";

// Group settings surface: admin-only avatar/name/description controls plus the member leave action.
export component GroupSettingsCard inherits Section {
    in property <bool> can-manage: false;
    in property <image> group-picture;
    in property <bool> group-has-picture: false;
    in property <color> group-av-a;
    in property <color> group-av-b;
    in property <string> group-av-initials;
    in property <bool> rename-busy: false;
    in property <bool> description-busy: false;
    in property <bool> image-busy: false;
    in property <bool> leave-busy: false;
    in property <string> group-status;
    in-out property <string> rename-draft;
    in-out property <string> description-draft;
    callback rename-group(string);
    callback set-group-description(string);
    callback change-image();
    callback clear-image();
    callback leave-group();

    vertical-stretch: 0;
    label: @tr("Group settings");

    GroupCard {
        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 10px;

            if root.can-manage: HorizontalLayout {
                spacing: 12px;
                alignment: start;
                Avatar {
                    size: 56px;
                    initials: root.group-av-initials;
                    color-a: root.group-av-a;
                    color-b: root.group-av-b;
                    picture: root.group-picture;
                    has-picture: root.group-has-picture;
                    font-size: Theme.fs(18px, 20px);
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Button {
                        label: root.image-busy ? @tr("Uploading…") : @tr("Change image");
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        clicked => {
                            if (!root.image-busy) {
                                root.change-image();
                            }
                        }
                    }

                    if root.group-has-picture && !root.image-busy: Button {
                        label: @tr("Remove image");
                        button-height: 26px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: transparent;
                        outline: transparent;
                        has-fill: false;
                        use-hover: true;
                        hover-bg: Palette.hover;
                        fg: Palette.text-mid;
                        hover-fg: Palette.text-hi;
                        clicked => {
                            root.clear-image();
                        }
                    }
                }
            }

            if root.can-manage: VerticalLayout {
                spacing: 6px;
                Text {
                    text: @tr("Group name");
                    color: Palette.text-hi;
                    font-size: (12px) * Theme.fs-scale;
                    font-weight: 700;
                }

                Rectangle {
                    height: 36px;
                    border-radius: (6px) * Theme.r-scale;
                    background: Palette.field;
                    border-width: Theme.border-w;
                    border-color: rename-input.has-focus ? Palette.mint-dim : Palette.field-border;
                    drop-shadow-blur: rename-input.has-focus && Theme.focus-glow ? 10px : 0px;
                    drop-shadow-color: Palette.mint-glow;
                    animate border-color {
                        duration: 140ms;
                        easing: ease-out;
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        rename-input := LineInput {
                            placeholder: @tr("Group name");
                            text <=> root.rename-draft;
                            font-size: Theme.fsr(12px, 14px);
                            fg: Palette.text-hi;
                            placeholder-color: Palette.text-vlo;
                            submit => {
                                if (!root.rename-busy && root.rename-draft != "") {
                                    root.rename-group(root.rename-draft);
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button {
                        label: root.rename-busy ? @tr("Saving…") : @tr("Save name");
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: Palette.mint-surface;
                        fg: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-surface;
                        clicked => {
                            if (!root.rename-busy && root.rename-draft != "") {
                                root.rename-group(root.rename-draft);
                            }
                        }
                    }
                }

                Text {
                    text: @tr("Group description");
                    color: Palette.text-hi;
                    font-size: (12px) * Theme.fs-scale;
                    font-weight: 700;
                }

                Rectangle {
                    height: 84px;
                    border-radius: (6px) * Theme.r-scale;
                    background: Palette.field;
                    border-width: Theme.border-w;
                    border-color: description-input.has-focus ? Palette.mint-dim : Palette.field-border;
                    drop-shadow-blur: description-input.has-focus && Theme.focus-glow ? 10px : 0px;
                    drop-shadow-color: Palette.mint-glow;
                    animate border-color {
                        duration: 140ms;
                        easing: ease-out;
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        description-input := LineInput {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            placeholder: @tr("Purpose, rules, or invite blurb");
                            text <=> root.description-draft;
                            single-line: false;
                            enter-submits: false;
                            font-size: Theme.fsr(12px, 14px);
                            fg: Palette.text-hi;
                            placeholder-color: Palette.text-vlo;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Button {
                        label: root.description-busy ? @tr("Saving…") : @tr("Save description");
                        enabled: !root.description-busy;
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        bg-color: Palette.mint-surface;
                        fg: Palette.mint;
                        outline: Palette.mint;
                        hover-bg: Palette.mint-surface;
                        clicked => {
                            if (!root.description-busy) {
                                root.set-group-description(root.description-draft);
                            }
                        }
                    }
                }
            }

            if root.group-status != "": Rectangle {
                height: 28px;
                border-radius: (4px) * Theme.r-scale;
                background: Palette.panel-2;
                border-width: Theme.border-w;
                border-color: Palette.border-2;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    Text {
                        text: root.group-status;
                        color: Palette.text-lo;
                        font-size: (10px) * Theme.fs-scale;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            if root.can-manage: Rectangle {
                height: 1px;
                background: Palette.border-2;
            }

            VerticalLayout {
                spacing: 6px;
                Text {
                    text: @tr("Leave group");
                    color: Palette.danger;
                    font-size: (12px) * Theme.fs-scale;
                    font-weight: 700;
                }

                Text {
                    text: root.can-manage ? @tr("Admins must step down before leaving.") : @tr("Leave this group and stop receiving new messages. The chat moves to Archive.");
                    color: Palette.text-lo;
                    font-size: (10px) * Theme.fs-scale;
                    wrap: word-wrap;
                }

                if !root.can-manage: HorizontalLayout {
                    alignment: start;
                    Button {
                        label: root.leave-busy ? @tr("Leaving…") : @tr("Leave group");
                        enabled: !root.leave-busy;
                        button-height: 28px;
                        pad-left: 10px;
                        pad-right: 10px;
                        font-size: Theme.fsr(11px, 14px);
                        fg: Palette.danger;
                        bg-color: Palette.danger-soft;
                        hover-bg: Palette.danger-soft-hover;
                        outline: Palette.danger-border;
                        hover-outline: Palette.danger-border-hover;
                        clicked => {
                            root.leave-group();
                        }
                    }
                }
            }
        }
    }
}
