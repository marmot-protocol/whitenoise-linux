import { Palette, Theme, MentionInboxItem } from "../tokens.slint";
import { Avatar } from "../primitives/avatar.slint";
import { CypherScroll } from "../primitives/cypher-scroll.slint";

// Discord-style global mentions inbox. The trigger lives in TitleBar; this
// zero-size component owns an anchored PopupWindow and reports the chosen chat
// + message back to Rust for navigation.
export component MentionsInbox inherits Rectangle {
    in property <[MentionInboxItem]> items;
    in property <bool> loading: false;
    callback selected(string, string);

    width: 0px;
    height: 0px;

    public function open() {
        popup.show();
    }

    popup := PopupWindow {
        // Keep the panel compact enough to fit below the header in narrow or
        // tiled windows. Its right edge stays pinned to the trigger.
        x: -self.width;
        y: 41px;
        width: 420px;
        height: 420px;
        close-policy: close-on-click-outside;

        Rectangle {
            background: Palette.elevated;
            border-width: Theme.border-w;
            border-color: Palette.elevated-border;
            border-radius: 12px * Theme.r-scale;
            drop-shadow-color: Theme.hard-shadow ? Palette.shadow : Palette.shadow-popover;
            drop-shadow-offset-x: Theme.hard-shadow ? 4px : 0px;
            drop-shadow-offset-y: Theme.hard-shadow ? 4px : 10px;
            drop-shadow-blur: Theme.hard-shadow ? 0px : 24px;
            clip: true;

            VerticalLayout {
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: Palette.panel;

                    Rectangle {
                        y: parent.height - Theme.border-w;
                        width: parent.width;
                        height: Theme.border-w;
                        background: Palette.border-2;
                    }

                    HorizontalLayout {
                        padding-left: 18px;
                        padding-right: 18px;
                        spacing: 10px;
                        alignment: start;

                        Text {
                            text: "@";
                            color: Palette.mint;
                            font-family: Theme.font;
                            font-size: Theme.fs(15px, 20px);
                            font-weight: 800;
                            vertical-alignment: center;
                        }

                        Text {
                            text: @tr("Mentions");
                            color: Palette.text-hi;
                            font-family: Theme.font;
                            font-size: Theme.fs(13px, 16px);
                            font-weight: 800;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }

                        if !root.loading: Text {
                            text: root.items.length;
                            color: Palette.text-lo;
                            font-family: Theme.font;
                            font-size: Theme.fs(10px, 12px);
                            vertical-alignment: center;
                        }
                    }
                }

                if root.loading: Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: @tr("Loading mentions…");
                        color: Palette.text-lo;
                        font-family: Theme.font;
                        font-size: Theme.fs(11px, 13px);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if !root.loading && root.items.length == 0: Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: @tr("No mentions yet");
                        color: Palette.text-lo;
                        font-family: Theme.font;
                        font-size: Theme.fs(11px, 13px);
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if !root.loading && root.items.length > 0: CypherScroll {
                    vertical-stretch: 1;
                    viewport-width: self.visible-width;
                    viewport-height: list.preferred-height;

                    list := VerticalLayout {
                        width: parent.width;
                        padding: 8px;
                        spacing: 4px;

                        for item in root.items: card := Rectangle {
                            height: 108px;
                            background: card-touch.has-hover ? Palette.hover : transparent;
                            border-radius: 8px * Theme.r-scale;
                            border-width: Theme.border-w;
                            border-color: card-touch.has-hover ? Palette.border-2 : Palette.border;
                            animate background, border-color { duration: Theme.hover-dur; }

                            HorizontalLayout {
                                padding: 12px;
                                spacing: 12px;
                                alignment: start;

                                Avatar {
                                    size: 36px;
                                    initials: item.sender-initials;
                                    color-a: item.sender-a;
                                    color-b: item.sender-b;
                                    font-size: Theme.fs(10px, 13px);
                                    y: 1px;
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 5px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text {
                                            text: item.sender-name;
                                            color: Palette.text-hi;
                                            font-family: Theme.font;
                                            font-size: Theme.fs(11px, 13px);
                                            font-weight: 700;
                                            overflow: elide;
                                            horizontal-stretch: 1;
                                        }

                                        Text {
                                            text: item.stamp;
                                            color: Palette.text-vlo;
                                            font-family: Theme.font;
                                            font-size: Theme.fs(9px, 11px);
                                        }
                                    }

                                    Text {
                                        text: "# " + item.chat-name;
                                        color: Palette.mint;
                                        font-family: Theme.font;
                                        font-size: Theme.fs(9px, 11px);
                                        font-weight: 650;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: item.text;
                                        color: Palette.text-mid;
                                        font-family: Theme.font;
                                        font-size: Theme.fs(10px, 12px);
                                        height: Theme.fs(28px, 34px);
                                        wrap: word-wrap;
                                        overflow: elide;
                                    }
                                }
                            }

                            card-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.selected(item.group-id, item.message-id);
                                    popup.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
