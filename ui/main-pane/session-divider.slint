import { Palette, Theme } from "../tokens.slint";

export component SessionDivider inherits Rectangle {
    in property <string> label;
    // When true the rules and label render in the accent colour, marking the
    // "New messages" line apart from the neutral date dividers.
    in property <bool> accent: false;
    property <color> rule-color: root.accent ? Palette.mint : Palette.border;
    height: 40px;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 0;
        alignment: stretch;

        Rectangle {
            horizontal-stretch: 1;
            Rectangle {
                width: parent.width;
                height: 1px;
                y: (parent.height - 1px) / 2;
                background: @linear-gradient(90deg, transparent 0%, root.rule-color 100%);
            }
        }

        Rectangle {
            width: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            if Theme.soft-decor: Rectangle {
                width: 5px;
                height: 5px;
                border-radius: 2.5px * Theme.r-scale;
                background: Palette.mint-dim;
                y: (parent.height - self.height) / 2;
                opacity: 0.7;
            }
            Text {
                text: root.label;
                color: root.accent ? Palette.mint-hi : Palette.text-lo;
                font-size: Theme.fs(10px, 14px);
                font-weight: 600;
                letter-spacing: 1.4px;
                vertical-alignment: center;
            }

            if Theme.soft-decor: Rectangle {
                width: 5px;
                height: 5px;
                border-radius: 2.5px * Theme.r-scale;
                background: Palette.mint-dim;
                y: (parent.height - self.height) / 2;
                opacity: 0.7;
            }
        }

        Rectangle {
            width: 10px;
        }

        Rectangle {
            horizontal-stretch: 1;
            Rectangle {
                width: parent.width;
                height: 1px;
                y: (parent.height - 1px) / 2;
                background: @linear-gradient(90deg, root.rule-color 0%, transparent 100%);
            }
        }
    }
}
