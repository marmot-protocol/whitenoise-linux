import { Palette, ChatMeta, Theme } from "../tokens.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";
import { BanIcon } from "../icons/ban-icon.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { PeopleIcon } from "../icons/people-icon.slint";
import { BellIcon } from "../icons/bell-icon.slint";
import { MuteIcon } from "../icons/mute-icon.slint";
import { Avatar } from "../primitives/avatar.slint";
import { Pill } from "../primitives/pill.slint";
import { Button } from "../primitives/button.slint";

export component ChatHeader inherits Rectangle {
    in property <ChatMeta> chat;
    in property <bool> is-group: false;
    in property <image> group-picture;
    in property <bool> group-has-picture: false;
    in property <bool> can-show-members: false;
    in property <int> member-count: 0;
    in property <string> group-description;
    in property <bool> members-open: false;
    in property <bool> muted: false;
    in property <bool> mentions-filter-active: false;
    callback accept-clicked();
    callback block-clicked();
    callback archive-clicked();
    callback members-toggle-clicked();
    callback mute-toggle-clicked();
    callback mentions-filter-toggle-clicked();
    // Tapping the encryption badge opens the "what is this?" explainer modal.
    callback badge-clicked();

    property <string> member-label: @tr("1 member" | "{n} members" % root.member-count);

    height: 72px;
    background: Palette.bg;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 14px;
        alignment: stretch;

        Rectangle {
            width: 44px;
            Avatar {
                size: 40px;
                initials: root.chat.av-initials;
                color-a: root.chat.av-a;
                color-b: root.chat.av-b;
                picture: root.is-group ? root.group-picture : root.chat.picture;
                has-picture: root.is-group ? root.group-has-picture : root.chat.has-picture;
                font-size: Theme.fs(12px, 17px);
            }

            Rectangle {
                x: parent.width / 2 + 10px;
                y: parent.height / 2 + 8px;
                width: 11px;
                height: 11px;
                border-radius: (5.5px) * Theme.r-scale;
                background: Palette.mint-dim;
                Rectangle {
                    width: 11px;
                    height: 11px;
                    border-radius: (5.5px) * Theme.r-scale;
                    border-width: 1.6px;
                    border-color: Palette.bg;
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;
            HorizontalLayout {
                spacing: 10px;
                alignment: start;
                Text {
                    text: root.chat.name;
                    color: Palette.text-hi;
                    font-size: (14px) * Theme.fs-scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                // The badge now surfaces the chat's MLS group id. Tap it to
                // learn what end-to-end MLS encryption means.
                badge-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        root.badge-clicked();
                    }
                    Pill {
                        label: root.chat.npub;
                        has-lock: true;
                        bg-color: badge-touch.has-hover ? Palette.mint-hi : Palette.mint;
                        fg: Palette.bubble-out-fg;
                    }
                }
            }

            Text {
                text: root.is-group ? (root.group-description == "" ? root.member-label : root.member-label + " · " + root.group-description) : root.chat.last-seen;
                color: Palette.text-lo;
                font-size: (11px) * Theme.fs-scale;
                overflow: elide;
            }
        }

        // Mentions filter — turns the open thread into a lightweight mentions
        // inbox for messages that address the local user.
        if !root.chat.is-chat-request: Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            background: root.mentions-filter-active ? Palette.selected : (mention-filter-touch.has-hover ? Palette.hover : transparent);
            border-radius: (6px) * Theme.r-scale;
            border-width: root.mentions-filter-active ? 1px : 0px;
            border-color: Palette.border-2;
            animate background { duration: 100ms; }
            mention-filter-touch := TouchArea {
                clicked => {
                    root.mentions-filter-toggle-clicked();
                }
                Text {
                    text: "@";
                    color: root.mentions-filter-active ? Palette.mint : Palette.text-mid;
                    font-family: Theme.font;
                    font-size: 17px * Theme.fs-scale;
                    font-weight: 800;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        // Mute toggle — silences this chat's desktop notifications. Shown for
        // any established chat (not pending requests). Muted = mint bell-off.
        if !root.chat.is-chat-request: Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            background: root.muted ? Palette.selected : (mute-touch.has-hover ? Palette.hover : transparent);
            border-radius: (6px) * Theme.r-scale;
            border-width: root.muted ? 1px : 0px;
            border-color: Palette.border-2;
            animate background { duration: 100ms; }
            mute-touch := TouchArea {
                clicked => {
                    root.mute-toggle-clicked();
                }
                if root.muted: MuteIcon {
                    stroke: Palette.mint;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
                if !root.muted: BellIcon {
                    stroke: Palette.text-mid;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        if root.can-show-members && !root.chat.is-chat-request: Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            background: root.members-open ? Palette.selected : transparent;
            border-radius: (6px) * Theme.r-scale;
            border-width: root.members-open ? 1px : 0px;
            border-color: Palette.border-2;
            TouchArea {
                clicked => {
                    root.members-toggle-clicked();
                }
                PeopleIcon {
                    stroke: root.members-open ? Palette.mint : Palette.text-mid;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        if root.chat.is-chat-request: HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                label: @tr("Block");
                focusable: true;
                y: (parent.height - self.height) / 2;
                clicked => {
                    root.block-clicked();
                }
                BanIcon {
                    stroke: Palette.text-mid;
                    size: 13px;
                }
            }

            Button {
                label: @tr("Archive");
                focusable: true;
                y: (parent.height - self.height) / 2;
                clicked => {
                    root.archive-clicked();
                }
                ArchiveIcon {
                    stroke: Palette.text-mid;
                }
            }

            Button {
                label: @tr("Accept");
                focusable: true;
                bg-color: Palette.mint;
                fg: Palette.bubble-out-fg;
                outline: Palette.mint;
                hover-bg: Palette.mint-hi;
                hover-outline: Palette.mint-hi;
                y: (parent.height - self.height) / 2;
                clicked => {
                    root.accept-clicked();
                }
                CheckMark {
                    stroke: Palette.bubble-out-fg;
                    double: false;
                }
            }
        }
    }
}
