import { Palette, ChatMeta, Theme } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";
import { BanIcon } from "../icons/ban-icon.slint";
import { CheckMark } from "../icons/check-mark.slint";
import { PeopleIcon } from "../icons/people-icon.slint";
import { BellIcon } from "../icons/bell-icon.slint";
import { MuteIcon } from "../icons/mute-icon.slint";
import { Avatar } from "../primitives/avatar.slint";
import { Pill } from "../primitives/pill.slint";
import { Button } from "../primitives/button.slint";

export component ChatHeader inherits Rectangle {
    // The open chat's row — reads AppState directly; the pane mounts this bare.
    property <ChatMeta> chat: AppState.chats[AppState.active-chat];

    property <string> member-label: @tr("1 member" | "{n} members" % AppState.chat-member-count);

    height: 72px;
    background: Palette.bg;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Palette.border-2;
    }

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 14px;
        alignment: stretch;

        Rectangle {
            width: 44px;
            Avatar {
                size: 40px;
                initials: root.chat.av-initials;
                color-a: root.chat.av-a;
                color-b: root.chat.av-b;
                picture: AppState.chat-is-group ? AppState.chat-group-picture : root.chat.picture;
                has-picture: AppState.chat-is-group ? AppState.chat-group-has-picture : root.chat.has-picture;
                font-size: Theme.fs(12px, 17px);
            }

            Rectangle {
                x: parent.width / 2 + 10px;
                y: parent.height / 2 + 8px;
                width: 11px;
                height: 11px;
                border-radius: (5.5px) * Theme.r-scale;
                background: Palette.mint-dim;
                Rectangle {
                    width: 11px;
                    height: 11px;
                    border-radius: (5.5px) * Theme.r-scale;
                    border-width: 1.6px;
                    border-color: Palette.bg;
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;
            HorizontalLayout {
                spacing: 10px;
                alignment: start;
                Text {
                    text: root.chat.name;
                    color: Palette.text-hi;
                    font-size: Theme.fs(14px, 18px);
                    font-weight: 700;
                    vertical-alignment: center;
                }

                // The badge now surfaces the chat's MLS group id. Tap it to
                // learn what end-to-end MLS encryption means.
                badge-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        AppState.encryption-info-open = true;
                    }
                    Pill {
                        label: root.chat.npub;
                        has-lock: true;
                        bg-color: badge-touch.has-hover ? Palette.mint-hi : Palette.mint;
                        fg: Palette.bubble-out-fg;
                    }
                }
            }

            Text {
                text: AppState.chat-is-group ? (AppState.chat-group-description == "" ? root.member-label : root.member-label + " · " + AppState.chat-group-description) : root.chat.last-seen;
                color: Palette.text-lo;
                font-size: Theme.fs(11px, 14px);
                overflow: elide;
            }
        }

        // Mute toggle — silences this chat's desktop notifications. Shown for
        // any established chat (not pending requests). Muted = mint bell-off.
        if !root.chat.is-chat-request: Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            background: AppState.active-chat-muted ? Palette.selected : (mute-touch.has-hover ? Palette.hover : transparent);
            border-radius: (6px) * Theme.r-scale;
            border-width: AppState.active-chat-muted ? 1px : 0px;
            border-color: Palette.border-2;
            animate background { duration: Theme.hover-dur; }
            mute-touch := TouchArea {
                clicked => {
                    AppState.toggle-mute-chat();
                }
                if AppState.active-chat-muted: MuteIcon {
                    stroke: Palette.mint;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
                if !AppState.active-chat-muted: BellIcon {
                    stroke: Palette.text-mid;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        if AppState.chat-can-show-members && !root.chat.is-chat-request: Rectangle {
            width: 36px;
            height: 36px;
            y: (parent.height - self.height) / 2;
            background: AppState.show-chat-members ? Palette.selected : transparent;
            border-radius: (6px) * Theme.r-scale;
            border-width: AppState.show-chat-members ? 1px : 0px;
            border-color: Palette.border-2;
            TouchArea {
                clicked => {
                    AppState.members-toggle-clicked();
                }
                PeopleIcon {
                    stroke: AppState.show-chat-members ? Palette.mint : Palette.text-mid;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        if root.chat.is-chat-request: HorizontalLayout {
            spacing: 8px;
            alignment: end;

            Button {
                label: @tr("Block");
                focusable: true;
                y: (parent.height - self.height) / 2;
                clicked => {
                    AppState.show-block-confirm = true;
                }
                BanIcon {
                    stroke: Palette.text-mid;
                    size: 13px;
                }
            }

            Button {
                label: @tr("Archive");
                focusable: true;
                y: (parent.height - self.height) / 2;
                clicked => {
                    AppState.archive-chat();
                }
                ArchiveIcon {
                    stroke: Palette.text-mid;
                }
            }

            Button {
                label: @tr("Accept");
                focusable: true;
                bg-color: Palette.mint;
                fg: Palette.bubble-out-fg;
                outline: Palette.mint;
                hover-bg: Palette.mint-hi;
                hover-outline: Palette.mint-hi;
                y: (parent.height - self.height) / 2;
                clicked => {
                    AppState.accept-chat-request();
                }
                CheckMark {
                    stroke: Palette.bubble-out-fg;
                    double: false;
                }
            }
        }
    }
}
