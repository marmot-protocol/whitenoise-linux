import { Palette } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { GroupCard } from "../layout/group-card.slint";
import { ScrollView } from "../primitives/scroll-view.slint";
import { GroupMemberRow } from "group-member-row.slint";
import { Section } from "../layout/section.slint";
import { GroupMembersHeader } from "group-members-header.slint";
import { GroupSettingsCard } from "group-settings-card.slint";
import { AddMemberCard } from "add-member-card.slint";

export component GroupMembersPanel inherits Rectangle {
    // Reads AppState directly; the pane mounts this bare (the visibility guard
    // stays in MainPane). Member rows stay pure-props — the "⋯" menu arming
    // writes AppState at the row's request-menu handler here.
    width: 300px;
    background: Palette.panel;

    Rectangle {
        x: 0;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Palette.border-2;
    }

    VerticalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 16px;
        padding-bottom: 16px;
        spacing: 12px;

        GroupMembersHeader { }

        if AppState.chat-is-group: GroupSettingsCard { }

        // ── Members list ─────────────────────────────────────
        // Active members and invited-but-not-yet-accepted members share one
        // scroll, split into two labelled sections.
        Rectangle {
            vertical-stretch: 1;
            ScrollView {
                vertical-stretch: 1;
                viewport-height: memcol.preferred-height;
                viewport-width: self.visible-width;
                memcol := VerticalLayout {
                    spacing: 12px;
                    Section {
                        label: @tr("Members");
                        GroupCard {
                            background: Palette.panel-2;
                            for m[i] in AppState.chat-members: GroupMemberRow {
                                data: m;
                                show-divider: i < AppState.chat-members.length - 1;
                                request-menu(id, name, cp, cd, csd, cr, ax, ay) => {
                                    AppState.member-menu-id = id;
                                    AppState.member-menu-name = name;
                                    AppState.member-menu-can-promote = cp;
                                    AppState.member-menu-can-demote = cd;
                                    AppState.member-menu-can-self-demote = csd;
                                    AppState.member-menu-can-remove = cr;
                                    AppState.member-menu-x = ax;
                                    AppState.member-menu-y = ay;
                                    AppState.member-menu-open = true;
                                }
                            }
                        }
                    }

                    if AppState.chat-invited-members.length > 0: Section {
                        label: @tr("Invited");
                        GroupCard {
                            background: Palette.panel-2;
                            for m[i] in AppState.chat-invited-members: GroupMemberRow {
                                data: m;
                                show-divider: i < AppState.chat-invited-members.length - 1;
                                request-menu(id, name, cp, cd, csd, cr, ax, ay) => {
                                    AppState.member-menu-id = id;
                                    AppState.member-menu-name = name;
                                    AppState.member-menu-can-promote = cp;
                                    AppState.member-menu-can-demote = cd;
                                    AppState.member-menu-can-self-demote = csd;
                                    AppState.member-menu-can-remove = cr;
                                    AppState.member-menu-x = ax;
                                    AppState.member-menu-y = ay;
                                    AppState.member-menu-open = true;
                                }
                            }
                        }
                    }
                }
            }
        }

        if AppState.chat-can-add-members: AddMemberCard { }
    }
}
