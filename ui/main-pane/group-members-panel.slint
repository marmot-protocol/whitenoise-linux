import { Palette, Theme, GroupMember } from "../tokens.slint";
import { PeopleIcon } from "../icons/people-icon.slint";
import { GroupCard } from "../shells/group-card.slint";
import { CypherScroll } from "../primitives/cypher-scroll.slint";
import { GroupMemberRow } from "group-member-row.slint";
import { LineInput } from "../primitives/line-input.slint";
import { Button } from "../primitives/button.slint";
import { Avatar } from "../primitives/avatar.slint";
import { Section } from "../shells/section.slint";

export component GroupMembersPanel inherits Rectangle {
    in property <[GroupMember]> members;
    in property <int> member-count;
    in property <bool> can-add-members: false;
    in property <bool> add-busy: false;
    in property <string> add-status;
    in-out property <string> add-draft;
    // Admin group-settings surface (only meaningful when can-add-members, i.e. admin).
    in property <image> group-picture;
    in property <bool> group-has-picture: false;
    in property <color> group-av-a;
    in property <color> group-av-b;
    in property <string> group-av-initials;
    in property <bool> rename-busy: false;
    in property <bool> image-busy: false;
    in property <string> group-status;
    in-out property <string> rename-draft;
    callback close-clicked();
    callback add-member(string);
    callback promote-admin(string);
    callback demote-admin(string);
    callback self-demote-admin();
    callback rename-group(string);
    callback change-image();
    callback clear-image();

    width: 300px;
    background: Palette.panel;

    Rectangle {
        x: 0; y: 0;
        width: 1px; height: parent.height;
        background: Palette.border-2;
    }

    VerticalLayout {
        padding-left: 16px; padding-right: 16px;
        padding-top: 16px; padding-bottom: 16px;
        spacing: 12px;

        // ── Header ───────────────────────────────────────────
        HorizontalLayout {
            height: 28px;
            spacing: 8px;
            alignment: stretch;
            PeopleIcon { stroke: Palette.mint; }
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 2px;
                alignment: center;
                Text {
                    text: @tr("Members");
                    color: Palette.text-hi;
                    font-size: (13px) * Theme.fs-scale;
                    font-weight: 700;
                }
                Text {
                    text: @tr("1 in this group" | "{n} in this group" % root.member-count);
                    color: Palette.text-lo;
                    font-size: (10px) * Theme.fs-scale;
                    letter-spacing: 0.8px;
                }
            }
            TouchArea {
                width: 28px; height: 28px;
                clicked => { root.close-clicked(); }
                Text {
                    text: "✕";
                    color: Palette.text-mid;
                    font-size: (14px) * Theme.fs-scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── Admin group settings ─────────────────────────────
        if root.can-add-members : Section {
            label: @tr("Group settings");
            GroupCard {
                VerticalLayout {
                    padding-left: 12px; padding-right: 12px;
                    padding-top: 12px; padding-bottom: 12px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 12px;
                        alignment: start;
                        Avatar {
                            size: 56px;
                            initials: root.group-av-initials;
                            color-a: root.group-av-a;
                            color-b: root.group-av-b;
                            picture: root.group-picture;
                            has-picture: root.group-has-picture;
                            font-size: (Theme.retro ? 20px : 18px) * Theme.fs-scale;
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 6px;
                            Button {
                                label: root.image-busy ? @tr("Uploading…") : @tr("Change image");
                                button-height: 28px;
                                pad-left: 10px;
                                pad-right: 10px;
                                font-size: Theme.retro ? 14px : 11px;
                                clicked => {
                                    if (!root.image-busy) { root.change-image(); }
                                }
                            }
                            if root.group-has-picture && !root.image-busy : Button {
                                label: @tr("Remove image");
                                button-height: 26px;
                                pad-left: 10px;
                                pad-right: 10px;
                                font-size: Theme.retro ? 14px : 11px;
                                bg-color: transparent;
                                outline: transparent;
                                has-fill: false;
                                use-hover: true;
                                hover-bg: Palette.hover;
                                fg: Palette.text-mid;
                                hover-fg: Palette.text-hi;
                                clicked => { root.clear-image(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Group name");
                            color: Palette.text-hi;
                            font-size: (12px) * Theme.fs-scale;
                            font-weight: 700;
                        }
                        Rectangle {
                            height: 36px;
                            border-radius: (6px) * Theme.r-scale;
                            background: Palette.field;
                            border-width: Theme.border-w;
                            border-color: Palette.field-border;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px;
                                LineInput {
                                    placeholder: @tr("Group name");
                                    text <=> root.rename-draft;
                                    font-size: (Theme.retro ? 14px : 12px);
                                    fg: Palette.text-hi;
                                    placeholder-color: Palette.text-vlo;
                                    submit => {
                                        if (!root.rename-busy && root.rename-draft != "") {
                                            root.rename-group(root.rename-draft);
                                        }
                                    }
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Button {
                                label: root.rename-busy ? @tr("Saving…") : @tr("Save name");
                                button-height: 28px;
                                pad-left: 10px;
                                pad-right: 10px;
                                font-size: Theme.retro ? 14px : 11px;
                                bg-color: Palette.mint-surface;
                                fg: Palette.mint;
                                outline: Palette.mint;
                                hover-bg: Palette.mint-surface;
                                clicked => {
                                    if (!root.rename-busy && root.rename-draft != "") {
                                        root.rename-group(root.rename-draft);
                                    }
                                }
                            }
                            if root.group-status != "" : Rectangle {
                                height: 28px;
                                border-radius: (4px) * Theme.r-scale;
                                background: Palette.panel-2;
                                border-width: Theme.border-w;
                                border-color: Palette.border-2;
                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 8px;
                                    Text {
                                        text: root.group-status;
                                        color: Palette.text-lo;
                                        font-size: (10px) * Theme.fs-scale;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── Members list ─────────────────────────────────────
        Section {
            label: @tr("Members");
            CypherScroll {
                vertical-stretch: 1;
                viewport-height: list.preferred-height;
                viewport-width: self.visible-width;
                list := GroupCard {
                    background: Palette.panel-2;
                    for m[i] in root.members : GroupMemberRow {
                        data: m;
                        show-divider: i < root.members.length - 1;
                        promote-admin(id) => { root.promote-admin(id); }
                        demote-admin(id) => { root.demote-admin(id); }
                        self-demote-admin => { root.self-demote-admin(); }
                    }
                }
            }
        }

        // ── Add member ───────────────────────────────────────
        if root.can-add-members : Section {
            label: @tr("Add member");
            GroupCard {
                VerticalLayout {
                    padding-left: 12px; padding-right: 12px;
                    padding-top: 12px; padding-bottom: 12px;
                    spacing: 8px;

                    Rectangle {
                        height: 36px;
                        border-radius: (6px) * Theme.r-scale;
                        background: Palette.field;
                        border-width: Theme.border-w;
                        border-color: Palette.field-border;
                        HorizontalLayout {
                            padding-left: 10px; padding-right: 10px;
                            LineInput {
                                placeholder: "npub1…";
                                text <=> root.add-draft;
                                font-size: (Theme.retro ? 14px : 12px);
                                fg: Palette.text-hi;
                                placeholder-color: Palette.text-vlo;
                                submit => {
                                    if (!root.add-busy && root.add-draft != "") {
                                        root.add-member(root.add-draft);
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Button {
                            label: root.add-busy ? @tr("Inviting…") : @tr("Invite");
                            button-height: 28px;
                            pad-left: 10px;
                            pad-right: 10px;
                            font-size: Theme.retro ? 14px : 11px;
                            bg-color: Palette.mint-surface;
                            fg: Palette.mint;
                            outline: Palette.mint;
                            hover-bg: Palette.mint-surface;
                            clicked => {
                                if (!root.add-busy && root.add-draft != "") {
                                    root.add-member(root.add-draft);
                                }
                            }
                        }
                        if root.add-status != "" : Rectangle {
                            height: 28px;
                            border-radius: (4px) * Theme.r-scale;
                            background: Palette.panel-2;
                            border-width: Theme.border-w;
                            border-color: Palette.border-2;
                            HorizontalLayout {
                                padding-left: 8px; padding-right: 8px;
                                Text {
                                    text: root.add-status;
                                    color: Palette.text-lo;
                                    font-size: (10px) * Theme.fs-scale;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
