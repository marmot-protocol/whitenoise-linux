import { Palette } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { ScrollView } from "../primitives/scroll-view.slint";
import { Section } from "../layout/section.slint";
import { GroupHero } from "group-hero.slint";
import { GroupMemberRow } from "group-member-row.slint";
import { AddMemberRow } from "add-member-row.slint";
import { GroupLeaveRow } from "group-leave-row.slint";

export component GroupMembersPanel inherits Rectangle {
    // Reads AppState directly; the pane mounts this bare (the visibility guard
    // stays in MainPane). Member rows stay pure-props — the "⋯" menu arming
    // writes AppState at the row's request-menu handler here.
    background: Palette.panel;

    Rectangle {
        x: 0;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Palette.border-2;
    }

    VerticalLayout {
        // Group identity + in-place admin editing; owns the close button.
        GroupHero { }

        // Pinned above the scroll (always reachable in long lists — and a
        // LineInput inside the ScrollView loops the bar-dependent width
        // through its own wrap-height).
        if AppState.chat-can-add-members: VerticalLayout {
            padding-left: 10px;
            padding-right: 10px;
            AddMemberRow { }
        }

        // ── Members list ─────────────────────────────────────
        // Active members (admins sorted first, crown-badged) and
        // invited-but-not-yet-accepted members share one scroll.
        Rectangle {
            vertical-stretch: 1;
            ScrollView {
                vertical-stretch: 1;
                viewport-height: memcol.preferred-height;
                viewport-width: self.visible-width;
                memcol := VerticalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-bottom: 12px;
                    spacing: 14px;

                    Section {
                        label: @tr("Members");
                        note: "\{AppState.chat-members.length}";
                        VerticalLayout {
                            spacing: 2px;
                            for m in AppState.chat-members: GroupMemberRow {
                                data: m;
                                request-menu(id, name, cp, cd, csd, cr, ax, ay) => {
                                    AppState.member-menu-id = id;
                                    AppState.member-menu-name = name;
                                    AppState.member-menu-can-promote = cp;
                                    AppState.member-menu-can-demote = cd;
                                    AppState.member-menu-can-self-demote = csd;
                                    AppState.member-menu-can-remove = cr;
                                    AppState.member-menu-x = ax;
                                    AppState.member-menu-y = ay;
                                    AppState.member-menu-open = true;
                                }
                            }
                        }
                    }

                    if AppState.chat-invited-members.length > 0: Section {
                        label: @tr("Invited");
                        note: "\{AppState.chat-invited-members.length}";
                        VerticalLayout {
                            spacing: 2px;
                            for m in AppState.chat-invited-members: GroupMemberRow {
                                data: m;
                                request-menu(id, name, cp, cd, csd, cr, ax, ay) => {
                                    AppState.member-menu-id = id;
                                    AppState.member-menu-name = name;
                                    AppState.member-menu-can-promote = cp;
                                    AppState.member-menu-can-demote = cd;
                                    AppState.member-menu-can-self-demote = csd;
                                    AppState.member-menu-can-remove = cr;
                                    AppState.member-menu-x = ax;
                                    AppState.member-menu-y = ay;
                                    AppState.member-menu-open = true;
                                }
                            }
                        }
                    }
                }
            }
        }

        if AppState.chat-is-group: GroupLeaveRow { }
    }
}
