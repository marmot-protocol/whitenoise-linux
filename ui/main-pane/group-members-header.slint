import { Palette, Theme } from "../tokens.slint";
import { PeopleIcon } from "../icons/people-icon.slint";

// Members panel title row: people icon, count, and close button.
export component GroupMembersHeader inherits HorizontalLayout {
    in property <int> member-count;
    in property <string> group-description;
    callback close-clicked();

    height: root.group-description == "" ? 28px : 64px;
    spacing: 8px;
    alignment: stretch;
    PeopleIcon {
        stroke: Palette.mint;
    }

    VerticalLayout {
        horizontal-stretch: 1;
        spacing: 2px;
        alignment: center;
        Text {
            text: @tr("Members");
            color: Palette.text-hi;
            font-size: Theme.fs(13px, 16px);
            font-weight: 700;
        }

        Text {
            text: @tr("1 in this group" | "{n} in this group" % root.member-count);
            color: Palette.text-lo;
            font-size: Theme.fs(10px, 14px);
            letter-spacing: 0.8px;
        }

        if root.group-description != "": Text {
            text: root.group-description;
            color: Palette.text-lo;
            font-size: Theme.fs(10px, 14px);
            wrap: word-wrap;
            overflow: elide;
        }
    }

    TouchArea {
        width: 28px;
        height: 28px;
        clicked => {
            root.close-clicked();
        }
        Text {
            text: "✕";
            color: Palette.text-mid;
            font-size: Theme.fs(14px, 18px);
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
