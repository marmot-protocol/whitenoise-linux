// Localized time/date vocabulary for the Rust-side stamp formatters
// (`format_chat_stamp`, `relative_since`, date parts, day dividers). Same
// bridge as `ErrorCopy`: the strings live here as `@tr()` properties so the
// gettext catalogs cover them, and Rust snapshots them on the UI thread at
// startup and on every locale change. `%1`/`%2`/`%3` are substituted by Rust
// (number, month/day/year) — they are placeholders for translators, not Slint
// format args.
export global TimeCopy {
    out property <string> today: @tr("Today");
    out property <string> yesterday: @tr("Yesterday");
    out property <string> just-now: @tr("just now");
    out property <string> minutes-ago: @tr("relative time, %1 = minutes" => "%1m ago");
    out property <string> hours-ago: @tr("relative time, %1 = hours" => "%1h ago");
    out property <string> days-ago: @tr("relative time, %1 = days" => "%1d ago");
    out property <string> wd-mon: @tr("weekday" => "Mon");
    out property <string> wd-tue: @tr("weekday" => "Tue");
    out property <string> wd-wed: @tr("weekday" => "Wed");
    out property <string> wd-thu: @tr("weekday" => "Thu");
    out property <string> wd-fri: @tr("weekday" => "Fri");
    out property <string> wd-sat: @tr("weekday" => "Sat");
    out property <string> wd-sun: @tr("weekday" => "Sun");
    out property <string> mo-jan: @tr("month" => "Jan");
    out property <string> mo-feb: @tr("month" => "Feb");
    out property <string> mo-mar: @tr("month" => "Mar");
    out property <string> mo-apr: @tr("month" => "Apr");
    out property <string> mo-may: @tr("month" => "May");
    out property <string> mo-jun: @tr("month" => "Jun");
    out property <string> mo-jul: @tr("month" => "Jul");
    out property <string> mo-aug: @tr("month" => "Aug");
    out property <string> mo-sep: @tr("month" => "Sep");
    out property <string> mo-oct: @tr("month" => "Oct");
    out property <string> mo-nov: @tr("month" => "Nov");
    out property <string> mo-dec: @tr("month" => "Dec");
    // Date composition templates. Which one applies is the user's date-format
    // setting (mdy/dmy); the translation controls separators/suffixes (e.g.
    // Japanese "%1%2日"). %1/%2/%3 keep the slot meaning named in the context.
    out property <string> date-md: @tr("date, %1 = month, %2 = day" => "%1 %2");
    out property <string> date-dm: @tr("date, %1 = day, %2 = month" => "%1 %2");
    out property <string> date-mdy: @tr("date, %1 = month, %2 = day, %3 = year" => "%1 %2 %3");
    out property <string> date-dmy: @tr("date, %1 = day, %2 = month, %3 = year" => "%1 %2 %3");
}

// Group system-line templates (marmot kind-1210 rows). Authored as `@tr()` so
// they flow through the gettext catalogs, then composed Rust-side in
// `system_event_text` (via the `SystemCopySnapshot` + `tmpl` %1/%2 substitution,
// the same pattern as `TimeCopy`), so the sentence stays translatable while
// `SystemLine` is a dumb presenter. %1 = actor, %2 = subject/name — except
// member-left, where %1 is the member who left.
export global SystemCopy {
    out property <string> member-added: @tr("group system line, %1 = actor, %2 = added member" => "%1 added %2");
    out property <string> member-removed: @tr("group system line, %1 = actor, %2 = removed member" => "%1 removed %2");
    out property <string> member-left: @tr("group system line, %1 = the member who left" => "%1 left the group");
    out property <string> admin-added: @tr("group system line, %1 = actor, %2 = new admin" => "%1 made %2 an admin");
    out property <string> admin-removed: @tr("group system line, %1 = actor, %2 = former admin" => "%1 dismissed %2 as admin");
    out property <string> group-renamed: @tr("group system line, %1 = actor, %2 = new group name" => "%1 renamed the group to %2");
    out property <string> group-avatar-changed: @tr("group system line, %1 = actor" => "%1 changed the group photo");
}

// Link activation sink. Chat bubbles render Markdown anchors deep inside the
// IncomingRow/OutgoingRow → MessageBubble → RunCell chain; rather than thread a
// callback through every level, the leaf RunCell invokes `Linkout.open(url)`
// directly and Rust binds the handler once (opens the URL externally).
export global Linkout {
    callback open(string);
}

// Profile activation sink, mirroring `Linkout`: tapping a user's avatar (or
// sender name) anywhere in the message tree invokes `ProfileSink.open` with
// the account-id hex, and Rust binds the handler once (opens the profile
// modal) instead of threading a callback through every row component.
export global ProfileSink {
    callback open(string);
}

// One entry in the quick-reaction row: the emoji plus its resolved tile in the
// shared Twemoji sprite sheet, so a cell draws the same colour glyph the chat
// bubbles do. `clip-x < 0` means the sheet carries no tile for it, so the cell
// falls back to the raw text glyph (also how the "+" add cell renders). Rust
// fills clip-x/clip-y from the build-time sprite map when it pushes the list.
export struct QuickReaction {
    emoji: string,
    clip-x: int,
    clip-y: int,
}

// Quick-reaction hub. One place holds the customizable one-tap emoji set and
// every action on it, so neither the message-row tree (HoverActions, the
// context menu) nor the Settings pane threads a callback through five layers
// — they read `list` and fire the callbacks directly, the way `ProfileSink`
// centralizes profile opens. Rust pushes `list` at startup and after each
// edit; the default here seeds the picker in live-preview before Rust runs
// (clip -1, so the shim shows text glyphs until Rust resolves sprite tiles).
export global QuickReact {
    in property <[QuickReaction]> list: [
        { emoji: "👍", clip-x: -1, clip-y: -1 },
        { emoji: "❤️", clip-x: -1, clip-y: -1 },
        { emoji: "😂", clip-x: -1, clip-y: -1 },
        { emoji: "😮", clip-x: -1, clip-y: -1 },
        { emoji: "😢", clip-x: -1, clip-y: -1 },
        { emoji: "🙏", clip-x: -1, clip-y: -1 },
    ];
    // React to a message in one tap. message-id, emoji.
    callback react(string, string);
    // Settings editor: open the full picker (anchored at x, y) to append one…
    callback add-clicked(length, length);
    // …drop the emoji at `index`…
    callback remove(int);
    // …or restore the default set.
    callback reset();
}

// Shared Twemoji sprite sheet — set once at startup from Rust and read by
// every chat bubble that needs to draw inline emoji. A global avoids drilling
// the sprite + tile size through the IncomingRow/OutgoingRow → MessageBubble
// chain.
export global EmojiSheet {
    in property <image> sprite;
    in property <int> tile;
}

// Native (rfd) file-dialog titles. These are set by the OS file picker, which
// lives on the Rust side — but the project keeps all user-facing i18n in the
// Slint @tr catalogs, so we expose the localized title here as an @tr property
// and Rust reads it (on the UI thread) before opening the dialog. A global
// avoids threading the string through any component tree.
export global NativeDialogStrings {
    out property <string> choose-profile-picture: @tr("Choose a profile picture");
}

// One pickable message effect (Telegram-style burst). `clip-x`/`clip-y` index
// the chosen emoji's tile in the shared Twemoji sheet, supplied by Rust at
// startup. The composer's send-button picker iterates these; the per-message
// playback reads its own clip coords off `ChatMessage`.
export struct EffectChoice {
    id: int,
    clip-x: int,
    clip-y: int,
}

// Catalog + current composer selection for message effects. `selected` is the
// effect that rides along with the next send (0 = none); Rust reads and clears
// it in on_send_message. A global keeps the composer popover and the send
// wiring talking without threading a window property through the whole tree.
export global EffectCatalog {
    in property <[EffectChoice]> choices;
    in-out property <int> selected: 0;
}

// One image in a multi-image album (Telegram-style grid). Rust computes the
// pixel rect (x/y/w/h) within the album box via an aspect-aware layout engine;
// the bubble just absolute-positions a clipped image at that rect. `key` is the
// per-image cache/slideshow handle (message-id for a lone image, `id#index`
// inside an album) the tap routes through.
export struct AlbumCell {
    x: length,
    y: length,
    w: length,
    h: length,
    image: image,
    has-image: bool,
    loading: bool,
    // Download/decrypt failed for this cell; renders a distinct error glyph
    // and stays tappable so the cell can be retried.
    failed: bool,
    key: string,
}

export struct MentionInboxItem {
    group-id: string,
    message-id: string,
    // Keys the async profile-picture bind (see src/mentions.rs).
    sender-id: string,
    chat-name: string,
    sender-name: string,
    sender-initials: string,
    sender-a: color,
    sender-b: color,
    picture: image,
    has-picture: bool,
    text: string,
    stamp: string,
}

// One global-search hit. Snippet comes pre-split around the first matched
// token so the row can highlight it as separate text runs; `sender-id` keys
// the async profile-picture bind (see src/wiring/search.rs).
export struct SearchHit {
    group-id: string,
    message-id: string,
    sender-id: string,
    chat-name: string,
    sender-name: string,
    sender-initials: string,
    sender-a: color,
    sender-b: color,
    picture: image,
    has-picture: bool,
    text-pre: string,
    text-match: string,
    text-post: string,
    stamp: string,
}

export struct ChatMessage {
    text: string,
    // Pre-tokenized + pre-wrapped body, grouped into lines. Empty for
    // synthetic rows; the bubble falls back to plain `Text` when empty.
    lines: [MessageLine],
    stamp: string,
    // Full localized date+time ("Jun 12 2026 · 14:32", honoring the user's
    // date/time format settings) shown as a tooltip when hovering the stamp.
    // Empty for pending rows (no confirmed timestamp yet).
    stamp-full: string,
    outgoing: bool,
    show-avatar: bool,
    av-initials: string,
    av-a: color,
    av-b: color,
    // Sender account-id hex. Not rendered — it's the stable key the avatar
    // fetch worker uses to find this sender's rows and bind a picture once it
    // decodes, without rebuilding the whole message list.
    sender-id: string,
    // Sender display name (resolved from the directory profile). Rendered as a
    // small label above incoming group-chat bubbles; `show-sender-name` gates
    // it so 1:1 chats and outgoing rows don't repeat the obvious.
    sender-name: string,
    show-sender-name: bool,
    // Incoming row whose body mentions the local user's npub/nprofile. Drives
    // the accent outline and the mentions-only review filter.
    mentioned: bool,
    // Sender profile picture. When `has-picture` is true the avatar renders the
    // decoded image instead of initials. Populated lazily from the picture
    // cache, same as the members list.
    picture: image,
    has-picture: bool,
    bubble-max: length,
    gap-before: length,
    // Visual grouping of consecutive same-sender messages. `first-in-group`
    // rounds the top corner on the avatar side; `last-in-group` is the row
    // that carries the avatar + tail. A standalone message is both true.
    first-in-group: bool,
    last-in-group: bool,
    // Local-day identity of the message's timestamp (yyyymmdd as an int, 0 =
    // unknown). Rust compares consecutive rows' keys to find day boundaries.
    day-key: int,
    // Non-empty on the first message of a new local day: the list renders a
    // date divider (reusing SessionDivider) above this row with this label.
    day-label: string,
    // Stable id of the underlying Marmot inner event (kind-9 chat). Empty
    // when the message hasn't been confirmed yet. Needed to send / aggregate
    // reactions which target this id.
    message-id: string,
    reactions: [Reaction],
    // Same chips as `reactions`, pre-wrapped into rows that fit within
    // `bubble-max` — what `ReactionsRow` actually renders.
    reaction-rows: [ReactionRow],
    // Optimistic-send state. `pending` = inserted locally, waiting for relay
    // ack; bubble dims + shows a clock instead of the double-check. `failed`
    // = send threw; bubble gains a red border and becomes clickable to retry.
    pending: bool,
    failed: bool,
    // Reply preview. When `reply-to-id` is non-empty this row was sent as a
    // reply to that message; the bubble renders a quoted-parent block above
    // its own text. `reply-to-text` is already truncated by Rust for display.
    // `reply-to-author` is the parent's display label ("You" or initials/name).
    reply-to-id: string,
    reply-to-text: string,
    reply-to-author: string,
    // Thumbnail of the parent's media (single image, first album cell, or
    // captured video poster), rendered at the right edge of the quoted block.
    // False on cache miss — the text label carries the quote until the
    // parent's media has been downloaded.
    reply-to-image: image,
    reply-to-has-image: bool,
    // Attachment (NIP-92 imeta payload, parsed in Rust). When `has-attachment`
    // is true the bubble renders a chip / image preview block above the body.
    has-attachment: bool,
    // Album: 2+ images sent in one message, rendered as an aspect-aware grid
    // instead of the single `att-*` tile. When `album` has entries the bubble
    // renders the grid (sized `album-w` × `album-h`) and ignores `att-*`.
    album: [AlbumCell],
    album-w: length,
    album-h: length,
    att-name: string,
    att-mime: string,
    // Generic-file chip presentation, precomputed in Rust: `att-icon` is the
    // per-type emoji (📄/📊/📦/…) and `att-type-label` the short type name
    // ("PDF", "ZIP") the chip's meta line shows instead of the raw mime.
    att-icon: string,
    att-type-label: string,
    att-size-label: string,
    att-is-image: bool,
    // Video attachment (mime `video/*`). Renders a poster tile (reusing
    // `att-image`/`att-has-image` as the poster frame) with a ▶ overlay and,
    // when known, an `att-duration` badge ("1:23"). Tapping opens the in-app
    // libmpv viewer instead of the image lightbox.
    att-is-video: bool,
    // Audio attachment (mime `audio/*`). Renders an inline player with
    // play/pause, a progress bar, and the current/total time. Tapping the
    // play button or the progress bar routes back to Rust.
    att-is-audio: bool,
    att-audio-playing: bool,
    att-audio-progress: float,
    // Decode failure (unsupported codec / corrupt data): the player swaps its
    // size label for a "Can't play this audio format" notice.
    att-audio-failed: bool,
    att-duration: string,
    // Cached decoded preview pixels. Populated lazily on first tap; empty
    // (default) image otherwise.
    att-image: image,
    att-has-image: bool,
    att-loading: bool,
    att-failed: bool,
    // Edit state. `edited` true => the bubble renders the latest edit's text
    // and shows an "(edited · N)" affordance that opens the history modal.
    // `can-edit` gates the edit pencil to the author's own messages.
    edited: bool,
    edit-count: int,
    can-edit: bool,
    // Retracted message (kind-5 "delete for everyone"). When true the bubble
    // drops its body/attachments/reactions and renders a muted "this message
    // was deleted" tombstone in their place.
    deleted: bool,
    // Emoji-only body (1–3 emoji, no attachment/album/reply): renders jumbo and
    // bubble-less, Telegram-style, with the timestamp floating on hover.
    jumbo-emoji: bool,
    // Message effect (Telegram-style particle burst). `effect-id` is the
    // persistent catalog identity (0 = none, 1..5) carried by every row whose
    // body had the marker, so a tap can replay it; `effect-clip-x/y` index the
    // chosen emoji's tile in the shared Twemoji sheet. `effect-autoplay` is the
    // transient one-shot trigger Rust sets only on the build where the burst
    // should fire by itself (live incoming arrival / optimistic outgoing row).
    effect-id: int,
    effect-clip-x: int,
    effect-clip-y: int,
    effect-autoplay: bool,
    // Group system row (marmot kind-1210: member added/removed/left, admin
    // added/removed, group renamed/avatar-changed). When `system-line` is true
    // the row renders as a centered system line (from `text`), never a bubble,
    // and carries no reply/react/edit affordances.
    system-line: bool,
    // True on the first unread message of the chat as it stood when opened: the
    // list renders an accented "New messages" divider (reusing SessionDivider)
    // above this row. Captured once on open and held for the session, so the
    // marker stays put while you read past it.
    unread-divider: bool,
}

// One entry in a message's edit history (original + each subsequent edit),
// rendered by the edit-history modal. `label` is "Original" / "Edited".
export struct EditVersion {
    label: string,
    text: string,
    stamp: string,
}

export struct GroupMember {
    name: string,
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    is-self: bool,
    picture: image,
    has-picture: bool,
    // Stable account-id hex; the ref passed back to promote a member to admin.
    member-id: string,
    // This member is already an admin of the group.
    is-admin: bool,
    // The viewer is an admin and this row is a non-self, non-admin member,
    // so the "Make admin" affordance should show.
    can-promote: bool,
    // The viewer is an admin and this row is another admin — "Remove admin".
    can-demote: bool,
    // The viewer is an admin and this is their own admin row — "Step down".
    can-self-demote: bool,
    // The viewer is an admin and this row is another member (any role) —
    // "Remove from group".
    can-remove: bool,
    // This member is in the MLS roster but has not been seen active in the
    // group yet (no message, reaction, or admin action). Rendered under a
    // separate "Invited" section, dimmed, until they show up.
    is-invited: bool,
}

export struct ChatMeta {
    name: string,
    preview: string,
    stamp: string,
    last-seen: string,
    npub: string,
    session-time: string,
    badge: string,
    read: bool,
    sending: bool,
    av-a: color,
    av-b: color,
    av-initials: string,
    // Peer profile picture for 1:1 chats (group chats stay on the gradient).
    // Bound lazily from the picture cache, same pipeline as the members list.
    picture: image,
    has-picture: bool,
    is-chat-request: bool,
    // User has pinned this chat to the top of the rail (local ordering).
    pinned: bool,
    // User has muted this chat: its incoming messages don't notify. Rendered
    // as a small MuteIcon in the row so a muted chat is distinguishable from an
    // active one at a glance.
    muted: bool,
}
