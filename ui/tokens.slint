// design tokens — colors + shared structs.

// Retro mode uses Zpix — a 12px-grid pixel font with full CJK coverage. Picked
// over Press Start 2P because PS2P is ASCII-only, so any non-Latin chat text
// rendered as tofu in retro.
import "../assets/fonts/Zpix.ttf";

// ── Theming engine, Layer 0 ──────────────────────────────────────────────
// A theme's full color set is one `ThemeColors` value. Themes live as data in
// `Theme.color-packs` (indexed by `Theme.id`); `Palette` is a pure reader over
// the active pack + the orthogonal accent index. Defining a theme's colors is
// therefore one struct literal — no per-token ternaries, no component edits.
// See ui/CONTRACT.md.
export struct ThemeColors {
    bg: color, panel: color, panel-2: color, rail: color, banner: color,
    border: color, border-2: color, bubble-in: color,
    text-hi: color, text-mid: color, text-lo: color, text-vlo: color,
    hover: color, bubble-out-fg: color,
    bevel-hi: color, bevel-lo: color,
    danger: color, danger-soft: color, danger-border: color,
    danger-soft-hover: color, danger-border-hover: color,
    warning: color, warning-soft: color, warning-border: color,
    field: color, field-hover: color, field-border: color, field-border-hover: color,
    divider: color, elevated: color, elevated-border: color,
    top-glint: color, canvas-top: color, banner-edge: color,
    // Card/well outline color: the cream border in retro, the dimmer border-2 in
    // modern themes. (Was `Theme.retro ? Palette.border : Palette.border-2`.)
    card-border: color,
    // When true the "selected" surface uses the solid accent (retro's SNES
    // highlight); otherwise the soft accent-surface wash (modern themes).
    selected-uses-base: bool,
    // Accent lookup tables, indexed by Theme.accent (0..4 = mint/ocean/berry/coral/lavender).
    accent-base: [color], accent-hi: [color], accent-dim: [color],
    accent-glow: [color], accent-surface: [color],
}

// Structural / non-color personality of a theme (Layer 0, the part that lets a
// theme change *how* things are drawn, not just their color). Components read
// these capability flags instead of branching on theme identity (`Theme.retro`),
// so a new theme opts into bevels / hard shadows / pixel icons purely as data.
export struct ThemeStyle {
    hard-shadow: bool,           // hard pixel drop-shadow vs soft blur
    focus-glow: bool,            // accent glow ring on focused inputs
    char-wrap: bool,             // char-wrap (pixel/CJK font) vs word-wrap
    motion-fast: bool,           // snappier enter/transition durations
    bubble-bounce: bool,         // message bubbles pop/bounce on enter
    bevel: bool,                 // SNES-style raised button bevel
    pixel-icons: bool,           // pixel-art icon glyphs vs vector paths
    selected-inverts-text: bool, // selected list rows invert text onto a solid fill
    pixel-select-marker: bool,   // ▶ text marker for selection vs a slim bar
    pixel-metrics: bool,         // use the larger pixel-font size at every fs() call site
    outline-surfaces: bool,      // draw a border on surfaces modern themes leave borderless
    // ── Layer 1: per-family skin selectors ──────────────────────────────────
    // Each picks which render body a dispatch slot mounts for that component
    // family. 0 = the standard/modern body. A drastic theme bumps these to
    // select an alternate skin (e.g. terminal lines, bracketed buttons) WITHOUT
    // touching main.rs — see ui/CONTRACT.md. Shell is the whole-window skeleton.
    skin-message: int, skin-button: int, skin-list: int,
    skin-avatar: int, skin-modal: int, shell: int,
    bracket-labels: bool,        // wrap button labels in [ ... ] (terminal/TUI look)
    // ── Hand-drawn / "doodle" capabilities ──────────────────────────────────
    paper-doodles: bool,         // scatter faint cute shapes across the chat canvas
    sketch-bubbles: bool,        // soft ink-outlined, flat-filled bubbles with a speech tail
    // ── Synthwave capability ─────────────────────────────────────────────────
    synth-grid: bool,            // neon perspective grid + sunset glow on the chat canvas
}

export global Theme {
    // Active theme id: 0=dark, 1=light, 2=retro, 3=terminal, 4=crayon,
    // 5=synthwave. The single value Rust sets to pick a theme (mapped from the
    // root light-theme/retro-mode/terminal-mode/crayon-mode/synthwave-mode props).
    in-out property <int> id: 0;
    // 0=mint, 1=ocean, 2=berry, 3=coral, 4=lavender — orthogonal to the theme id.
    in-out property <int> accent: 0;
    // true on macOS — lets shortcut hints render ⌘ instead of Ctrl. Set from
    // Rust at startup via the root `is-macos` property.
    in-out property <bool> is-mac: false;

    // Back-compat identity flags, derived from id. Components still branching on
    // these (structural retro-isms) read them until Phase B2/B3 tokenizes those.
    out property <bool> retro: root.id == 2;
    out property <bool> light: root.id == 1;

    out property <string> font: root.retro ? "Zpix" : "JetBrains Mono";
    // multiplier applied to every border-radius — 0 in retro for pixel-sharp corners.
    out property <float> r-scale: root.retro ? 0.0 : 1.0;
    // base border width — chunky 2px outlines in retro.
    out property <length> border-w: root.retro ? 2px : 1px;
    // Zpix is a bitmap pixel font — it renders crisply only at integer
    // multiples of its native 12px grid and looks blurry/tiny at fractional
    // sizes. Identity scale in both modes; per-call-site `font-size` values
    // are authoritative.
    out property <float> fs-scale: 1.0;

    // The theme registry. Index = Theme.id. Add a theme by appending an entry.
    // `out` so the settings theme-picker can render a live preview of each theme
    // (e.g. Theme.color-packs[i].bg) without activating it.
    out property <[ThemeColors]> color-packs: [
        // ── 0: Dark (modern charcoal) ──
        {
            bg: #060708, panel: #0B0D0F, panel-2: #101316, rail: #060708, banner: #0D1014,
            border: #1C2128, border-2: #14181D, bubble-in: #141A21,
            text-hi: #E4E7EC, text-mid: #9CA3AF, text-lo: #6B7280, text-vlo: #4B5563,
            hover: #0D1114, bubble-out-fg: #0A1410,
            bevel-hi: #FFFFFF, bevel-lo: #0A0A2A,
            danger: #FF5A5A, danger-soft: #FF5A5A20, danger-border: #5A2429,
            danger-soft-hover: #FF5A5A33, danger-border-hover: #7A2E36,
            warning: #F59E0B, warning-soft: #F59E0B20, warning-border: #5A3F1A,
            field: #0A0D11, field-hover: #12171C, field-border: #1F242A, field-border-hover: #2C333B,
            divider: #1A1F25, elevated: #0F1318, elevated-border: #242A31,
            top-glint: #FFFFFF0A, canvas-top: #0E1216, banner-edge: #0E1418, card-border: #14181D,
            selected-uses-base: false,
            accent-base:    [#72F0B0, #4AA8FF, #FF6B9D, #FF8C42, #B8A1E6],
            accent-hi:      [#8AF7C0, #6BC4FF, #FF8CB5, #FFAB6B, #D4BFF2],
            accent-dim:     [#3DD68A, #2A7ACC, #CC3E6E, #CC6B2A, #8C75B8],
            accent-glow:    [#72F0B018, #4AA8FF18, #FF6B9D18, #FF8C4218, #B8A1E618],
            accent-surface: [#122820, #0F1A2E, #2E0F18, #2E150F, #1A0F2E],
        },
        // ── 1: Light (warm paper) ──
        {
            bg: #F6F2EA, panel: #FFFFFF, panel-2: #F8FAFC, rail: #ECE6DA, banner: #ECFDF3,
            border: #D7D0C3, border-2: #E7DFD2, bubble-in: #FFFFFF,
            text-hi: #1F2937, text-mid: #4B5563, text-lo: #6B7280, text-vlo: #9CA3AF,
            hover: #F0EADF, bubble-out-fg: #FFFFFF,
            bevel-hi: #FFFFFF, bevel-lo: #D8CFBF,
            danger: #C62828, danger-soft: #C628281A, danger-border: #E3B8B8,
            danger-soft-hover: #C628282E, danger-border-hover: #D49C9C,
            warning: #B45309, warning-soft: #B453091A, warning-border: #E2C9A4,
            field: #FFFFFF, field-hover: #F8FAFC, field-border: #D7D0C3, field-border-hover: #C5BCAD,
            divider: #E7DFD2, elevated: #FFFFFF, elevated-border: #D7D0C3,
            top-glint: #FFFFFFB8, canvas-top: #FFFDF7, banner-edge: #F6F2EA, card-border: #E7DFD2,
            selected-uses-base: false,
            accent-base:    [#16855F, #0D5AA0, #C73E6E, #C45C1A, #7B5FB0],
            accent-hi:      [#1EA875, #1A70B8, #E05585, #D4712E, #9678C9],
            accent-dim:     [#0F6B4B, #084578, #9E2E56, #9E4710, #5E4696],
            accent-glow:    [#16855F22, #0D5AA022, #C73E6E22, #C45C1A22, #7B5FB022],
            accent-surface: [#DFF5EA, #E0F0FF, #FFE0EC, #FFF0E0, #F0E8FF],
        },
        // ── 2: Retro (SNES-era indigo) ──
        {
            bg: #0d0d28, panel: #2B2B7F, panel-2: #3838A8, rail: #0E0E36, banner: #3838A8,
            border: #E8E0C4, border-2: #9090E0, bubble-in: #1F1F6E,
            text-hi: #F4EFDD, text-mid: #DDDAEE, text-lo: #B5B5E8, text-vlo: #5858A4,
            hover: #3838A8, bubble-out-fg: #1A1A4E,
            bevel-hi: #F4EFDD, bevel-lo: #0A0A2A,
            danger: #FF5A5A, danger-soft: #FF5A5A30, danger-border: #FF5A5A,
            danger-soft-hover: #FF5A5A48, danger-border-hover: #FF5A5A,
            warning: #FFD75A, warning-soft: #FFD75A30, warning-border: #FFD75A,
            field: #0E0E36, field-hover: #2B2B7F, field-border: #E8E0C4, field-border-hover: #E8E0C4,
            divider: #E8E0C4, elevated: #2B2B7F, elevated-border: #E8E0C4,
            top-glint: #FFFFFF0A, canvas-top: #0E1216, banner-edge: #0E1418, card-border: #E8E0C4,
            selected-uses-base: true,
            accent-base:    [#FFD93D, #6B8CFF, #FF6B9D, #FF8C42, #C9A0DC],
            accent-hi:      [#FFE873, #8CA5FF, #FF8CB5, #FFAB6B, #DEB8F0],
            accent-dim:     [#C9A521, #4A6BCC, #CC3E6E, #CC6B2A, #A07AB8],
            accent-glow:    [#FFD93D40, #6B8CFF40, #FF6B9D40, #FF8C4240, #C9A0DC40],
            accent-surface: [#FFD93D30, #6B8CFF30, #FF6B9D30, #FF8C4230, #C9A0DC30],
        },
        // ── 3: Terminal (green-on-black TUI) ──
        {
            bg: #0A0E0A, panel: #0C120C, panel-2: #0F160F, rail: #080C08, banner: #0C120C,
            border: #1B3A1B, border-2: #142814, bubble-in: #0C120C,
            text-hi: #33FF66, text-mid: #2BCC52, text-lo: #1F9E3E, text-vlo: #176B2C,
            hover: #0F1A0F, bubble-out-fg: #0A0E0A,
            bevel-hi: #33FF66, bevel-lo: #0A0E0A,
            danger: #FF5555, danger-soft: #FF555520, danger-border: #5A2424,
            danger-soft-hover: #FF555533, danger-border-hover: #7A2E2E,
            warning: #FFCC33, warning-soft: #FFCC3320, warning-border: #5A4F1A,
            field: #0A0E0A, field-hover: #0F160F, field-border: #1B3A1B, field-border-hover: #2B5A2B,
            divider: #142814, elevated: #0C120C, elevated-border: #1B3A1B,
            top-glint: #33FF6610, canvas-top: #0A0E0A, banner-edge: #0A0E0A, card-border: #1B3A1B,
            selected-uses-base: false,
            accent-base:    [#33FF66, #33CCFF, #FF66AA, #FFAA33, #BB88FF],
            accent-hi:      [#66FF99, #66DDFF, #FF99CC, #FFCC66, #CCAAFF],
            accent-dim:     [#22AA44, #2299CC, #CC4488, #CC8822, #8866CC],
            accent-glow:    [#33FF6618, #33CCFF18, #FF66AA18, #FFAA3318, #BB88FF18],
            accent-surface: [#0E2614, #0A1E2E, #2E0E1E, #2E200A, #1A0E2E],
        },
        // ── 4: Sketch (hand-drawn ink on paper) ──
        // Warm craft-paper canvas, graphite "pencil" text, dark-ink outlined
        // bubbles + pencil doodles. Neutral, NOT pastel — the look is a
        // sketchbook page, not a kawaii sticker pack. The ink outline (text-hi)
        // is the signature; sketch-bubbles + paper-doodles in the style pack do
        // the rest.
        {
            bg: #F4EEDF, panel: #FBF6EA, panel-2: #EFE8D6, rail: #ECE4D0, banner: #EFE8D6,
            border: #C7B894, border-2: #D8CCAE, bubble-in: #FCF8EE,
            text-hi: #33302B, text-mid: #6E6657, text-lo: #968B76, text-vlo: #BBB199,
            hover: #EBE3CF, bubble-out-fg: #FFFFFF,
            bevel-hi: #FFFFFF, bevel-lo: #D8CCAE,
            danger: #C4453B, danger-soft: #C4453B1A, danger-border: #D8A99A,
            danger-soft-hover: #C4453B2E, danger-border-hover: #C89283,
            warning: #C8821F, warning-soft: #C8821F1A, warning-border: #DEC79A,
            field: #FBF6EA, field-hover: #F4EEDF, field-border: #C7B894, field-border-hover: #B0A07C,
            divider: #DED2B6, elevated: #FBF6EA, elevated-border: #C7B894,
            top-glint: #FFFFFFAA, canvas-top: #FAF5E8, banner-edge: #F4EEDF, card-border: #C7B894,
            selected-uses-base: false,
            accent-base:    [#3E9E7A, #4A8FC0, #D45C86, #E08544, #9B7BC0],
            accent-hi:      [#52B891, #62A6D2, #E0789F, #EE9C62, #B193D2],
            accent-dim:     [#2E7E60, #387098, #B0476C, #B86836, #7C5FA0],
            accent-glow:    [#3E9E7A22, #4A8FC022, #D45C8622, #E0854422, #9B7BC022],
            accent-surface: [#DCEDE3, #DEEAF3, #F6E2EA, #F8EADD, #EDE5F4],
        },
        // ── 5: Synthwave (neon Miami sunset) ──
        // Deep indigo night, hot-magenta/cyan neon accents, glow on focus. The
        // grid-and-sunset palette: dark bubble-out-fg so text reads on bright neon.
        {
            bg: #0E0420, panel: #170A2E, panel-2: #1F1040, rail: #0A0318, banner: #170A2E,
            border: #3A1E66, border-2: #271145, bubble-in: #1C0E38,
            text-hi: #F5E9FF, text-mid: #C9A8E8, text-lo: #9A78C0, text-vlo: #6B4F8E,
            hover: #1F1040, bubble-out-fg: #1A0726,
            bevel-hi: #FF6AD5, bevel-lo: #0E0420,
            danger: #FF4D6D, danger-soft: #FF4D6D26, danger-border: #6B2440,
            danger-soft-hover: #FF4D6D3D, danger-border-hover: #8A2E52,
            warning: #FFC857, warning-soft: #FFC85726, warning-border: #5A4520,
            field: #130826, field-hover: #1F1040, field-border: #3A1E66, field-border-hover: #5A2E9E,
            divider: #271145, elevated: #170A2E, elevated-border: #3A1E66,
            top-glint: #FF6AD518, canvas-top: #130826, banner-edge: #0E0420, card-border: #271145,
            selected-uses-base: false,
            accent-base:    [#2DE2C0, #36C5FF, #FF49B0, #FF7E5F, #B66BFF],
            accent-hi:      [#5BF0D4, #6BD7FF, #FF74C4, #FF9B82, #C98FFF],
            accent-dim:     [#1FB89C, #2897C4, #C92E84, #C95E45, #8A4FCC],
            accent-glow:    [#2DE2C033, #36C5FF33, #FF49B033, #FF7E5F33, #B66BFF33],
            accent-surface: [#0E2E2A, #0E2435, #2E0E22, #2E160E, #1E0E2E],
        },
        // ── 6: Chalkboard (dark Sketch — chalk on a blackboard) ──
        // Dark slate-green board, warm chalk-white "ink" (text-hi) for outlines +
        // text, dusty chalk-pastel accents. Reuses every Sketch capability
        // (sketch-bubbles + paper-doodles); only the palette inverts to dark.
        {
            bg: #243029, panel: #2A382F, panel-2: #1E2A23, rail: #1B2620, banner: #2A382F,
            border: #4C594F, border-2: #3A473F, bubble-in: #2C3A32,
            text-hi: #ECE9D8, text-mid: #B6B8A8, text-lo: #889084, text-vlo: #5C665E,
            hover: #2E3C33, bubble-out-fg: #1E2A23,
            bevel-hi: #ECE9D8, bevel-lo: #1B2620,
            danger: #E27A6E, danger-soft: #E27A6E20, danger-border: #6E3A34,
            danger-soft-hover: #E27A6E33, danger-border-hover: #8A4840,
            warning: #E8C57F, warning-soft: #E8C57F20, warning-border: #5E4F2A,
            field: #1E2A23, field-hover: #2A382F, field-border: #4C594F, field-border-hover: #5E6C60,
            divider: #3A473F, elevated: #2A382F, elevated-border: #4C594F,
            top-glint: #FFFFFF0C, canvas-top: #283529, banner-edge: #243029, card-border: #4C594F,
            selected-uses-base: false,
            accent-base:    [#7FD1A8, #7FB4E0, #E89BB8, #E8B97F, #B49BD6],
            accent-hi:      [#9BDDBC, #9BC6EA, #EFB0C7, #EFC99B, #C6B0E2],
            accent-dim:     [#5BAE86, #5B90BC, #C47894, #C4955B, #9078B2],
            accent-glow:    [#7FD1A828, #7FB4E028, #E89BB828, #E8B97F28, #B49BD628],
            accent-surface: [#1E3329, #1E2C38, #331E29, #332B1E, #291E33],
        },
    ];
    // The active theme's resolved color set — read by Palette below.
    out property <ThemeColors> c: root.color-packs[root.id];

    // Structural personality registry. Index = Theme.id, parallel to color-packs.
    property <[ThemeStyle]> style-packs: [
        // 0: Dark — modern soft shadows, vector icons, glow on focus.
        { hard-shadow: false, focus-glow: true, char-wrap: false, motion-fast: false,
          bubble-bounce: false, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: false, pixel-metrics: false,
          outline-surfaces: false,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: false, sketch-bubbles: false, synth-grid: false },
        // 1: Light — same structural personality as dark.
        { hard-shadow: false, focus-glow: true, char-wrap: false, motion-fast: false,
          bubble-bounce: false, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: false, pixel-metrics: false,
          outline-surfaces: false,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: false, sketch-bubbles: false, synth-grid: false },
        // 2: Retro — hard pixel shadows, bevels, pixel icons, snappy motion, pixel metrics.
        { hard-shadow: true, focus-glow: false, char-wrap: true, motion-fast: true,
          bubble-bounce: true, bevel: true, pixel-icons: true,
          selected-inverts-text: true, pixel-select-marker: true, pixel-metrics: true,
          outline-surfaces: true,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: false, sketch-bubbles: false, synth-grid: false },
        // 3: Terminal — flat (no shadows/bevels), monospace, drastic skins: terminal
        // message lines + IRC chat list + bracketed buttons. 3-pane shell kept.
        { hard-shadow: false, focus-glow: false, char-wrap: false, motion-fast: true,
          bubble-bounce: false, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: true, pixel-metrics: false,
          outline-surfaces: false,
          skin-message: 1, skin-button: 0, skin-list: 1, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: true, paper-doodles: false, sketch-bubbles: false, synth-grid: false },
        // 4: Sketch — the hand-drawn one. Outlined paper surfaces
        // (outline-surfaces), springy bubbles (bubble-bounce), plus the doodle
        // capabilities: a paper canvas scattered with pencil doodles
        // (paper-doodles) and dark-ink-outlined, flat-filled speech bubbles with
        // tails (sketch-bubbles). Vector icons, focus glow, word-wrap.
        { hard-shadow: false, focus-glow: true, char-wrap: false, motion-fast: false,
          bubble-bounce: true, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: false, pixel-metrics: false,
          outline-surfaces: true,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: true, sketch-bubbles: true, synth-grid: false },
        // 5: Synthwave — modern dark personality (soft shadows, focus glow,
        // vector icons) plus the synth-grid capability: a neon perspective grid +
        // sunset glow on the chat canvas. The neon palette + grid carry the look.
        { hard-shadow: false, focus-glow: true, char-wrap: false, motion-fast: false,
          bubble-bounce: false, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: false, pixel-metrics: false,
          outline-surfaces: false,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: false, sketch-bubbles: false, synth-grid: true },
        // 6: Chalkboard — identical structural personality to Sketch (the
        // hand-drawn capabilities), just a dark blackboard palette.
        { hard-shadow: false, focus-glow: true, char-wrap: false, motion-fast: false,
          bubble-bounce: true, bevel: false, pixel-icons: false,
          selected-inverts-text: false, pixel-select-marker: false, pixel-metrics: false,
          outline-surfaces: true,
          skin-message: 0, skin-button: 0, skin-list: 0, skin-avatar: 0, skin-modal: 0, shell: 0,
          bracket-labels: false, paper-doodles: true, sketch-bubbles: true, synth-grid: false },
    ];
    out property <ThemeStyle> s: root.style-packs[root.id];

    // Flat capability flags — what components actually read. Never branch on
    // `Theme.retro`/`Theme.light` for styling; branch on these.
    out property <bool> hard-shadow:           root.s.hard-shadow;
    out property <bool> focus-glow:            root.s.focus-glow;
    out property <bool> char-wrap:             root.s.char-wrap;
    out property <bool> motion-fast:           root.s.motion-fast;
    out property <bool> bubble-bounce:         root.s.bubble-bounce;
    out property <bool> bevel:                 root.s.bevel;
    out property <bool> pixel-icons:           root.s.pixel-icons;
    out property <bool> selected-inverts-text: root.s.selected-inverts-text;
    out property <bool> pixel-select-marker:   root.s.pixel-select-marker;
    out property <bool> pixel-metrics:         root.s.pixel-metrics;
    out property <bool> outline-surfaces:      root.s.outline-surfaces;
    out property <int>  skin-message:          root.s.skin-message;
    out property <int>  skin-button:           root.s.skin-button;
    out property <int>  skin-list:             root.s.skin-list;
    out property <int>  skin-avatar:           root.s.skin-avatar;
    out property <int>  skin-modal:            root.s.skin-modal;
    out property <int>  shell:                 root.s.shell;
    out property <bool> bracket-labels:        root.s.bracket-labels;
    out property <bool> paper-doodles:         root.s.paper-doodles;
    out property <bool> sketch-bubbles:        root.s.sketch-bubbles;
    out property <bool> synth-grid:            root.s.synth-grid;

    // Font-size helpers. A call site declares both metrics; the active theme's
    // `pixel-metrics` flag picks one. `fs` applies fs-scale (for the former
    // `(... ) * Theme.fs-scale` sites); `fsr` is the raw, unscaled variant.
    // Replaces every `(Theme.retro ? PIXEL : MODERN) [* Theme.fs-scale]` ternary.
    public pure function fs(modern: length, pixel: length) -> length {
        (root.pixel-metrics ? pixel : modern) * root.fs-scale
    }
    public pure function fsr(modern: length, pixel: length) -> length {
        root.pixel-metrics ? pixel : modern
    }
}

export global Palette {
    out property <color> bg:        Theme.c.bg;
    out property <color> panel:     Theme.c.panel;
    out property <color> panel-2:   Theme.c.panel-2;
    out property <color> rail:      Theme.c.rail;
    out property <color> banner:    Theme.c.banner;
    out property <color> border:    Theme.c.border;
    out property <color> border-2:  Theme.c.border-2;
    out property <color> bubble-in: Theme.c.bubble-in;

    // Accent resolution: active pack's table indexed by the orthogonal accent.
    out property <color> mint:      Theme.c.accent-base[Theme.accent];
    out property <color> mint-hi:   Theme.c.accent-hi[Theme.accent];
    out property <color> mint-dim:  Theme.c.accent-dim[Theme.accent];
    out property <color> mint-glow: Theme.c.accent-glow[Theme.accent];
    out property <color> mint-surface: Theme.c.accent-surface[Theme.accent];

    out property <color> text-hi:   Theme.c.text-hi;
    out property <color> text-mid:  Theme.c.text-mid;
    out property <color> text-lo:   Theme.c.text-lo;
    out property <color> text-vlo:  Theme.c.text-vlo;
    out property <color> selected:  Theme.c.selected-uses-base
        ? Theme.c.accent-base[Theme.accent] : Theme.c.accent-surface[Theme.accent];
    out property <color> hover:     Theme.c.hover;
    out property <color> bubble-out-fg: Theme.c.bubble-out-fg;
    // Hard pixel shadow color — constant across themes.
    out property <color> shadow:    #000000;
    out property <color> bevel-hi:  Theme.c.bevel-hi;
    out property <color> bevel-lo:  Theme.c.bevel-lo;

    out property <color> danger:      Theme.c.danger;
    out property <color> danger-soft: Theme.c.danger-soft;
    // Danger *inside* the outgoing accent bubble: that bubble is a dark
    // saturated accent even in light theme, so this stays bright everywhere.
    out property <color> danger-on-bubble: #FF5A5A;
    out property <color> danger-border: Theme.c.danger-border;
    out property <color> danger-soft-hover:   Theme.c.danger-soft-hover;
    out property <color> danger-border-hover: Theme.c.danger-border-hover;

    out property <color> warning:      Theme.c.warning;
    out property <color> warning-soft: Theme.c.warning-soft;
    out property <color> warning-border: Theme.c.warning-border;

    out property <color> field: Theme.c.field;
    out property <color> field-hover: Theme.c.field-hover;
    out property <color> field-border: Theme.c.field-border;
    out property <color> field-border-hover: Theme.c.field-border-hover;
    out property <color> divider: Theme.c.divider;
    out property <color> elevated: Theme.c.elevated;
    out property <color> elevated-border: Theme.c.elevated-border;
    out property <color> top-glint: Theme.c.top-glint;
    out property <color> canvas-top: Theme.c.canvas-top;
    out property <color> banner-edge: Theme.c.banner-edge;
    out property <color> card-border: Theme.c.card-border;
}

// One signed-in account in the account switcher. All accounts stay connected
// in the background; `active` marks the one the UI is currently displaying.
export struct AccountEntry {
    id: string,           // account-id hex — the switch-account callback key
    name: string,         // display name (published profile, or npub tail)
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    picture: image,
    has-picture: bool,
    active: bool,
}

export struct Contact {
    // Resolved display name: the private nickname when set, else the
    // published profile name. `real-name` always holds the published one.
    name: string,
    real-name: string,
    nickname: string,
    account-id: string,
    npub-full: string,
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    verified: bool,
    online: bool,
    relays: int,
    added: string,
    // Profile picture, lazily bound from the process-wide picture cache.
    picture: image,
    has-picture: bool,
}

// One on-disk forensic audit-log file (Settings → Advanced). `path` is the
// opaque key handed back to the delete callback; `meta` is the preformatted
// "size · date" line (formatting stays Rust-side).
export struct AuditLogEntry {
    path: string,
    name: string,
    meta: string,
}

export struct ArchivedChat {
    name: string,
    last-msg: string,
    last-date: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    members: int,
    group-id: string,
    // Peer profile picture for archived 1:1 chats (groups keep the gradient).
    picture: image,
    has-picture: bool,
}

// One aggregated reaction on a message: an emoji, how many people used it,
// and whether *I* am one of them (drives the highlight chip).
export struct Reaction {
    emoji: string,
    count: int,
    mine: bool,
}

// One emoji in the picker grid. `clip-x`/`clip-y` are pixel coordinates
// into the shared Twemoji sprite sheet (passed in separately at the picker
// level). `name` is the human-readable label.
export struct EmojiEntry {
    emoji: string,
    name: string,
    clip-x: int,
    clip-y: int,
}

// One queued composer attachment (paperclip picker or clipboard paste).
// Nothing uploads until the user presses Send — the chip row above the
// input is the confirmation step. `thumb` is a small decoded preview for
// images (`has-thumb` false → generic file chip).
export struct StagedAttachment {
    name: string,
    size-label: string,
    is-image: bool,
    thumb: image,
    has-thumb: bool,
}

// One inline cell inside a wrapped line of a chat-message body. Slint's
// `Text` can't host inline images and `HorizontalLayout` doesn't wrap, so
// Rust pre-tokenizes the message into text + emoji runs and pre-groups them
// into lines (see `MessageLine`). The bubble renders one HorizontalLayout
// per line, letting Slint size text cells naturally — no per-cell width
// estimation in Rust (which used to overshoot and produce huge inter-word
// gaps because Rust didn't know JetBrains Mono's real advance).
export struct MessageRun {
    is-emoji: bool,
    text: string,
    clip-x: int,
    clip-y: int,
    // Inline Markdown styling, resolved per-run by the Rust AST walker.
    // `link` is the destination URL ("" = not a link); when set the run
    // renders as an accent-colored, underlined, tappable anchor.
    bold: bool,
    italic: bool,
    strike: bool,
    code: bool,
    link: string,
    // iMessage-style inline text effects, resolved from `{name}…{/name}`
    // markup, as a bitmask so any effects stack on one glyph (each acts on an
    // independent visual axis — e.g. `{big}{explode}` or `{jitter}{ripple}`):
    //   1 Big, 2 Small, 4 Explode, 8 Bloom, 16 Shake, 32 Nod, 64 Ripple,
    //   128 Jitter. The bubble's RunCell decodes the bits and composes them.
    // `phase` staggers the per-letter animation across a span (a travelling
    // crest for Ripple, decorrelated wobble for Jitter); it increments per
    // effect run and resets between spans.
    fx: int,
    phase: float,
}

// One wrapped line of a chat-message body. Beyond its runs a line carries
// block-level Markdown context resolved in Rust: `indent` is the left inset
// from list/blockquote nesting, `scale` multiplies the body font (headings),
// `quote` is the blockquote depth (0 = none, drives the left accent bar),
// `code-block` flags a fenced/indented code line (monospace plate), and
// `rule` marks a thematic break (renders a horizontal divider, no runs).
export struct MessageLine {
    runs: [MessageRun],
    indent: length,
    scale: float,
    quote: int,
    code-block: bool,
    rule: bool,
}

// User-facing error / status copy shown by the Rust glue layer. These strings
// are *set from Rust* (status fields, backend-error banner) but the project
// keeps all i18n in the Slint `@tr` catalogs, so they live here as `@tr()`
// properties and Rust reads them back on the UI thread (mirroring how
// `EmojiSheet`/`ProfileSink` bridge Rust↔Slint). Tier-1 entries name a concrete
// thing the user can fix; the rest are operation-specific fallbacks that name
// no internals. The raw error is still logged at every call site for diagnosis.
export global ErrorCopy {
    // Tier 1 — content-based classification.
    out property <string> invalid-key: @tr("That doesn't look like a valid npub or public key. Double-check it and try again.");
    out property <string> network: @tr("Can't reach your relays right now. Check your network and relay settings, then try again.");
    // Tier 2 — operation-specific fallbacks.
    out property <string> sync: @tr("Couldn't finish syncing. We'll keep retrying — check your relay settings if this keeps happening.");
    out property <string> backend: @tr("Couldn't start up. Check your network and relay settings, then try again.");
    out property <string> switch-account: @tr("Couldn't switch accounts. Please try again in a moment.");
    out property <string> accept: @tr("Couldn't accept the invitation. Please try again in a moment.");
    out property <string> block: @tr("Couldn't decline the invitation. Please try again in a moment.");
    out property <string> archive: @tr("Couldn't archive this chat. Please try again.");
    out property <string> unarchive: @tr("Couldn't restore this chat. Please try again.");
    out property <string> send: @tr("Couldn't send your message. Check your connection and try again.");
    out property <string> edit: @tr("Couldn't save your edit. Check your connection and try again.");
    out property <string> react: @tr("Couldn't add your reaction. Please try again.");
    out property <string> unreact: @tr("Couldn't remove your reaction. Please try again.");
    out property <string> kp-publish: @tr("Couldn't publish your key package. Check your relay settings and try again.");
    out property <string> kp-rotate: @tr("Couldn't rotate your key package. Check your relay settings and try again.");
    out property <string> kp-refresh: @tr("Couldn't refresh your key packages. Check your relay settings and try again.");
    out property <string> republish: @tr("Couldn't republish to your relays. Check your relay settings and try again.");
    out property <string> add-account: @tr("Couldn't add that account. Please check the key and try again.");
    out property <string> create-chat: @tr("Couldn't create the chat. Please try again.");
    out property <string> add-contact: @tr("Couldn't add that contact. Please try again.");
    out property <string> add-member: @tr("Couldn't add that member. Please try again.");
    out property <string> group-settings: @tr("Couldn't update the group settings. Please try again.");
    out property <string> group-image: @tr("Couldn't update the group image. Please try again.");
    out property <string> save-profile: @tr("Couldn't save your profile. Check your connection and try again.");
    out property <string> upload-picture: @tr("Couldn't upload your picture. Please try again.");
    out property <string> generic: @tr("Something went wrong. Please try again.");
    // Network-pane status copy (also Rust-set).
    out property <string> not-connected: @tr("Not connected yet. Please wait a moment and try again.");
    out property <string> relay-already-listed: @tr("That relay is already in your list.");
    out property <string> save-relays-failed: @tr("Couldn't save your relay list. Please try again.");
    out property <string> relay-added: @tr("Relay added.");
    out property <string> relay-removed: @tr("Relay removed.");
    out property <string> republishing: @tr("Republishing…");
}

// Link activation sink. Chat bubbles render Markdown anchors deep inside the
// IncomingRow/OutgoingRow → MessageBubble → RunCell chain; rather than thread a
// callback through every level, the leaf RunCell invokes `Linkout.open(url)`
// directly and Rust binds the handler once (opens the URL externally).
export global Linkout {
    callback open(string);
}

// Profile activation sink, mirroring `Linkout`: tapping a user's avatar (or
// sender name) anywhere in the message tree invokes `ProfileSink.open` with
// the account-id hex, and Rust binds the handler once (opens the profile
// modal) instead of threading a callback through every row component.
export global ProfileSink {
    callback open(string);
}

// Shared Twemoji sprite sheet — set once at startup from Rust and read by
// every chat bubble that needs to draw inline emoji. A global avoids drilling
// the sprite + tile size through the IncomingRow/OutgoingRow → MessageBubble
// chain.
export global EmojiSheet {
    in property <image> sprite;
    in property <int> tile;
}

// Native (rfd) file-dialog titles. These are set by the OS file picker, which
// lives on the Rust side — but the project keeps all user-facing i18n in the
// Slint @tr catalogs, so we expose the localized title here as an @tr property
// and Rust reads it (on the UI thread) before opening the dialog. A global
// avoids threading the string through any component tree.
export global NativeDialogStrings {
    out property <string> choose-profile-picture: @tr("Choose a profile picture");
}

// One pickable message effect (Telegram-style burst). `clip-x`/`clip-y` index
// the chosen emoji's tile in the shared Twemoji sheet, supplied by Rust at
// startup. The composer's send-button picker iterates these; the per-message
// playback reads its own clip coords off `ChatMessage`.
export struct EffectChoice {
    id: int,
    clip-x: int,
    clip-y: int,
}

// Catalog + current composer selection for message effects. `selected` is the
// effect that rides along with the next send (0 = none); Rust reads and clears
// it in on_send_message. A global keeps the composer popover and the send
// wiring talking without threading a window property through the whole tree.
export global EffectCatalog {
    in property <[EffectChoice]> choices;
    in-out property <int> selected: 0;
}

// One image in a multi-image album (Telegram-style grid). Rust computes the
// pixel rect (x/y/w/h) within the album box via an aspect-aware layout engine;
// the bubble just absolute-positions a clipped image at that rect. `key` is the
// per-image cache/slideshow handle (message-id for a lone image, `id#index`
// inside an album) the tap routes through.
export struct AlbumCell {
    x: length,
    y: length,
    w: length,
    h: length,
    image: image,
    has-image: bool,
    loading: bool,
    key: string,
}

export struct ChatMessage {
    text: string,
    // Pre-tokenized + pre-wrapped body, grouped into lines. Empty for
    // synthetic rows; the bubble falls back to plain `Text` when empty.
    lines: [MessageLine],
    stamp: string,
    outgoing: bool,
    show-avatar: bool,
    av-initials: string,
    av-a: color,
    av-b: color,
    // Sender account-id hex. Not rendered — it's the stable key the avatar
    // fetch worker uses to find this sender's rows and bind a picture once it
    // decodes, without rebuilding the whole message list.
    sender-id: string,
    // Sender display name (resolved from the directory profile). Rendered as a
    // small label above incoming group-chat bubbles; `show-sender-name` gates
    // it so 1:1 chats and outgoing rows don't repeat the obvious.
    sender-name: string,
    show-sender-name: bool,
    // Sender profile picture. When `has-picture` is true the avatar renders the
    // decoded image instead of initials. Populated lazily from the picture
    // cache, same as the members list.
    picture: image,
    has-picture: bool,
    bubble-max: length,
    gap-before: length,
    // Visual grouping of consecutive same-sender messages. `first-in-group`
    // rounds the top corner on the avatar side; `last-in-group` is the row
    // that carries the avatar + tail. A standalone message is both true.
    first-in-group: bool,
    last-in-group: bool,
    // Stable id of the underlying Marmot inner event (kind-9 chat). Empty
    // when the message hasn't been confirmed yet. Needed to send / aggregate
    // reactions which target this id.
    message-id: string,
    reactions: [Reaction],
    // Optimistic-send state. `pending` = inserted locally, waiting for relay
    // ack; bubble dims + shows a clock instead of the double-check. `failed`
    // = send threw; bubble gains a red border and becomes clickable to retry.
    pending: bool,
    failed: bool,
    // Reply preview. When `reply-to-id` is non-empty this row was sent as a
    // reply to that message; the bubble renders a quoted-parent block above
    // its own text. `reply-to-text` is already truncated by Rust for display.
    // `reply-to-author` is the parent's display label ("You" or initials/name).
    reply-to-id: string,
    reply-to-text: string,
    reply-to-author: string,
    // Attachment (NIP-92 imeta payload, parsed in Rust). When `has-attachment`
    // is true the bubble renders a chip / image preview block above the body.
    has-attachment: bool,
    // Album: 2+ images sent in one message, rendered as an aspect-aware grid
    // instead of the single `att-*` tile. When `album` has entries the bubble
    // renders the grid (sized `album-w` × `album-h`) and ignores `att-*`.
    album: [AlbumCell],
    album-w: length,
    album-h: length,
    att-name: string,
    att-mime: string,
    att-size-label: string,
    att-is-image: bool,
    // Video attachment (mime `video/*`). Renders a poster tile (reusing
    // `att-image`/`att-has-image` as the poster frame) with a ▶ overlay and,
    // when known, an `att-duration` badge ("1:23"). Tapping opens the in-app
    // libmpv viewer instead of the image lightbox.
    att-is-video: bool,
    // Audio attachment (mime `audio/*`). Renders an inline player with
    // play/pause, a progress bar, and the current/total time. Tapping the
    // play button or the progress bar routes back to Rust.
    att-is-audio: bool,
    att-audio-playing: bool,
    att-audio-progress: float,
    att-duration: string,
    // Cached decoded preview pixels. Populated lazily on first tap; empty
    // (default) image otherwise.
    att-image: image,
    att-has-image: bool,
    att-loading: bool,
    att-failed: bool,
    // Edit state. `edited` true => the bubble renders the latest edit's text
    // and shows an "(edited · N)" affordance that opens the history modal.
    // `can-edit` gates the edit pencil to the author's own messages.
    edited: bool,
    edit-count: int,
    can-edit: bool,
    // Emoji-only body (1–3 emoji, no attachment/album/reply): renders jumbo and
    // bubble-less, Telegram-style, with the timestamp floating on hover.
    jumbo-emoji: bool,
    // Message effect (Telegram-style particle burst). `effect-id` is the
    // persistent catalog identity (0 = none, 1..5) carried by every row whose
    // body had the marker, so a tap can replay it; `effect-clip-x/y` index the
    // chosen emoji's tile in the shared Twemoji sheet. `effect-autoplay` is the
    // transient one-shot trigger Rust sets only on the build where the burst
    // should fire by itself (live incoming arrival / optimistic outgoing row).
    effect-id: int,
    effect-clip-x: int,
    effect-clip-y: int,
    effect-autoplay: bool,
}

// One entry in a message's edit history (original + each subsequent edit),
// rendered by the edit-history modal. `label` is "Original" / "Edited".
export struct EditVersion {
    label: string,
    text: string,
    stamp: string,
}

export struct GroupMember {
    name: string,
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    is-self: bool,
    picture: image,
    has-picture: bool,
    // Stable account-id hex; the ref passed back to promote a member to admin.
    member-id: string,
    // This member is already an admin of the group.
    is-admin: bool,
    // The viewer is an admin and this row is a non-self, non-admin member,
    // so the "Make admin" affordance should show.
    can-promote: bool,
    // The viewer is an admin and this row is another admin — "Remove admin".
    can-demote: bool,
    // The viewer is an admin and this is their own admin row — "Step down".
    can-self-demote: bool,
}

export struct ChatMeta {
    name: string,
    preview: string,
    stamp: string,
    last-seen: string,
    npub: string,
    session-time: string,
    badge: string,
    read: bool,
    sending: bool,
    av-a: color,
    av-b: color,
    av-initials: string,
    // Peer profile picture for 1:1 chats (group chats stay on the gradient).
    // Bound lazily from the picture cache, same pipeline as the members list.
    picture: image,
    has-picture: bool,
    is-chat-request: bool,
}
