// design tokens — colors + shared structs.

// Retro mode uses Zpix — a 12px-grid pixel font with full CJK coverage. Picked
// over Press Start 2P because PS2P is ASCII-only, so any non-Latin chat text
// rendered as tofu in retro.
import "../assets/fonts/Zpix.ttf";

// ── Theming engine, Layer 0 ──────────────────────────────────────────────
// A theme's full color set is one `ThemeColors` value. Themes live as data in
// `Theme.color-packs` (indexed by `Theme.id`); `Palette` is a pure reader over
// the active pack + the orthogonal accent index. Rust fills the registry at
// startup from theme files (built-ins embedded, user themes from `$WN_HOME`);
// defining a theme is therefore one `.toml`, no per-token ternaries and no
// component edits. See ui/CONTRACT.md and src/themes.rs.
export struct ThemeColors {
    bg: color,
    panel: color,
    panel-2: color,
    rail: color,
    banner: color,
    border: color,
    border-2: color,
    bubble-in: color,
    // Recessed surfaces *inside* a received bubble, drawn over bubble-in.
    // `bubble-inset` is the standard plate (reply quote, attachment tiles and
    // chips, audio player); `bubble-inset-strong` is the deeper recess drawn on
    // top of an inset plate (audio scrubber track). (Were
    // `Theme.light ? #E2E8F0 : #ffffff10`-style two-way hexes in message-bubble.)
    bubble-inset: color,
    bubble-inset-strong: color,
    // Code background inside a received bubble: the fenced-block plate and
    // inline-code chips.
    code-plate: color,
    // Letterbox behind video posters — dark in every theme so the white play
    // badge and duration chip stay readable over it.
    media-backdrop: color,
    // Recessed surfaces inside the outgoing accent bubble, mirroring the
    // received-bubble tokens above so components never hardcode black alphas.
    bubble-inset-out: color,
    bubble-inset-out-strong: color,
    code-plate-out: color,
    media-backdrop-out: color,
    bubble-selection-out: color,
    text-hi: color,
    text-mid: color,
    text-lo: color,
    text-vlo: color,
    hover: color,
    bubble-out-fg: color,
    bevel-hi: color,
    bevel-lo: color,
    danger: color,
    danger-soft: color,
    danger-border: color,
    danger-soft-hover: color,
    danger-border-hover: color,
    warning: color,
    warning-soft: color,
    warning-border: color,
    field: color,
    field-hover: color,
    field-border: color,
    field-border-hover: color,
    divider: color,
    elevated: color,
    elevated-border: color,
    top-glint: color,
    canvas-top: color,
    banner-edge: color,
    // Card/well outline color: the cream border in retro, the dimmer border-2 in
    // modern themes. (Was `Theme.retro ? Palette.border : Palette.border-2`.)
    card-border: color,
    // Window-chrome bar background (status bar): the dark rail tone in retro,
    // panel in modern themes. (Was `Theme.retro ? Palette.rail : Palette.panel`.)
    status-bar: color,
    // Recessed strip inside a modal card (footer row).
    // (Was `Theme.retro ? Palette.rail : Palette.panel-2`.)
    card-well: color,
    // Modal backdrop wash behind the card.
    overlay: color,
    // Stronger full-screen scrim for media lightboxes (image/video viewer).
    // Darker than `overlay` so the media is the only bright thing on screen.
    overlay-strong: color,
    // Media lightbox control surfaces — chips, pills, buttons, and the video
    // control bar that sit on top of `overlay-strong`. Same across all themes
    // because a media lightbox is always a dark environment (the backdrop is
    // `overlay-strong = #000000e6` everywhere). `ghost` is the low-prominence
    // tier for close buttons and nav chevrons that only need to be visible on
    // hover; `chip` is the prominent tier for pills, action buttons, and bars;
    // `control-bg` is the rest fill for icon buttons (play/fullscreen) that
    // light up to the accent on hover.
    media-chip-bg: color,
    media-chip-bg-hover: color,
    media-chip-fg: color,
    media-chip-fg-dim: color,
    media-chip-outline: color,
    media-ghost-bg: color,
    media-ghost-bg-hover: color,
    media-control-bg: color,
    // Soft (blurred) drop-shadow tints; hard-shadow themes use Palette.shadow
    // instead. `shadow-soft` is the in-canvas lift (jump pill), `shadow-card`
    // the strongest modal/login card shadow, `shadow-popover` menu/dropdown
    // lift, `shadow-float` compact chips/tooltips, and `shadow-bubble-in` the
    // received-message bubble lift.
    shadow-soft: color,
    shadow-card: color,
    shadow-popover: color,
    shadow-float: color,
    shadow-bubble-in: color,
    // Edge color of the login screen's radial vignette (the center is this
    // color at alpha 0).
    vignette: color,
    // Hairline ring around avatars.
    avatar-ring: color,
    // When true the "selected" surface uses the solid accent (retro's SNES
    // highlight); otherwise the soft accent-surface wash (modern themes).
    selected-uses-base: bool,
    // Accent lookup tables, indexed by Theme.accent (0..4 = mint/ocean/berry/coral/lavender).
    // Column order must match the ACCENTS table in src/state.rs, the single
    // Rust-side source of the name-to-index mapping.
    accent-base: [color],
    accent-hi: [color],
    accent-dim: [color],
    accent-glow: [color],
    accent-surface: [color],
}

// Structural / non-color personality of a theme (Layer 0, the part that lets a
// theme change *how* things are drawn, not just their color). Components read
// these capability flags and structural metrics instead of branching on theme
// identity, so a new theme opts into bevels / hard shadows / pixel icons /
// its own font and border widths purely as data.
export struct ThemeStyle {
    hard-shadow: bool,           // hard pixel drop-shadow vs soft blur
    focus-glow: bool,            // accent glow ring on focused inputs
    char-wrap: bool,             // char-wrap (pixel/CJK font) vs word-wrap
    motion-fast: bool,           // snappier enter/transition durations
    bubble-bounce: bool,         // message bubbles pop/bounce on enter
    bevel: bool,                 // SNES-style raised button bevel
    pixel-icons: bool,           // pixel-art icon glyphs vs vector paths
    selected-inverts-text: bool, // selected list rows invert text onto a solid fill
    pixel-select-marker: bool,   // ▶ text marker for selection vs a slim bar
    pixel-metrics: bool,         // pixel-grid metrics: the larger pixel-font size at every fs() call site, chunkier fixed geometry
    outline-surfaces: bool,      // draw a border on surfaces modern themes leave borderless
    soft-decor: bool,            // gradient washes, glows, halos, shimmer, accent tints; false = flat fills + hard separators (pixel look)
    // ── Layer 1: per-family skin selectors ──────────────────────────────────
    // Each picks which render body a dispatch slot mounts for that component
    // family. 0 = the standard/modern body. A drastic theme bumps these to
    // select an alternate skin (e.g. terminal lines, bracketed buttons) WITHOUT
    // touching main.rs — see ui/CONTRACT.md.
    skin-message: int,
    skin-button: int,
    skin-list: int,
    skin-avatar: int,
    skin-modal: int,
    bracket-labels: bool,        // wrap button labels in [ ... ] (terminal/TUI look)
    // ── Hand-drawn / "doodle" capabilities ──────────────────────────────────
    paper-doodles: bool,         // scatter faint cute shapes across the chat canvas
    sketch-bubbles: bool,        // soft ink-outlined, flat-filled bubbles with a speech tail
    // ── Synthwave capability ─────────────────────────────────────────────────
    synth-grid: bool,            // neon perspective grid + sunset glow on the chat canvas
    // ── Structural metrics (theme-file-driven, not identity-branched) ────────
    font: string,                // font family name (e.g. "JetBrains Mono", "Zpix")
    r-scale: float,              // multiplier applied to every border-radius (0 = pixel-sharp)
    border-w: length,            // base border width (chunkier in pixel themes)
    // Motion durations (milliseconds). `hover-dur` drives quick hover-state
    // feedback (background/color/stroke swaps); `transition-dur` drives slightly
    // longer state transitions (focus rings, toggles, menu entrance). Tunable
    // per theme so a snappy pixel theme can set lower values without call-site
    // ternaries — matching how `motion-fast` already gates the modal entrance.
    hover-dur: int,
    transition-dur: int,
}

export global Theme {
    // Active theme id: 0=dark, 1=light, 2=retro, 3=terminal, 4=crayon,
    // 5=synthwave, 6=chalkboard, 7=amoled. Rust sets the root `theme-id` (mapped
    // from the persisted mode name via `THEME_MODES` in state.rs) and the root
    // folds it straight onto this id — the whole palette/style follows.
    in-out property <int> id: 0;
    // 0=mint, 1=ocean, 2=berry, 3=coral, 4=lavender — orthogonal to the theme id.
    in-out property <int> accent: 0;
    // true on macOS — lets shortcut hints render ⌘ instead of Ctrl. Set from
    // Rust at startup via the root `is-macos` property.
    in-out property <bool> is-mac: false;
    // Display names and stable mode ids of the user-defined themes, in the order
    // they occupy after the built-ins in `color-packs`, so the picker can list
    // them below the built-ins. Rust fills both from the theme files at startup.
    in property <[string]> user-theme-names: [];
    in property <[string]> user-theme-modes: [];

    // Font family, border-radius scale, and base border width — all driven by
    // the active theme's `ThemeStyle` pack, so each `.toml` owns them. No
    // identity branching; a theme that wants chunky borders or a different
    // font family just sets the values in its `[style]` section.
    out property <string> font: root.s.font;
    out property <float> r-scale: root.s.r-scale;
    out property <length> border-w: root.s.border-w;
    out property <duration> hover-dur: root.s.hover-dur * 1ms;
    out property <duration> transition-dur: root.s.transition-dur * 1ms;

    // The theme registry, index = Theme.id. Rust fills this at startup from the
    // embedded built-in theme files and any user themes (src/themes.rs), in id
    // order; it is empty until then, and the window is not shown before the
    // load runs. `in` so Rust can push it; the picker reads it for previews.
    in property <[ThemeColors]> color-packs: [];
    // Resolve any theme id to its color pack.
    public pure function colors-at(i: int) -> ThemeColors {
        return root.color-packs[i];
    }
    // The active theme's resolved color set — read by Palette below.
    out property <ThemeColors> c: root.colors-at(root.id);

    // Structural personality registry, parallel to color-packs. Rust fills it
    // from the same theme files at startup.
    in property <[ThemeStyle]> style-packs: [];
    public pure function style-at(i: int) -> ThemeStyle {
        return root.style-packs[i];
    }
    out property <ThemeStyle> s: root.style-at(root.id);

    // Flat capability flags — what components actually read. Never branch on
    // theme identity (`Theme.id == N`) for styling; branch on these.
    out property <bool> hard-shadow:           root.s.hard-shadow;
    out property <bool> focus-glow:            root.s.focus-glow;
    out property <bool> char-wrap:             root.s.char-wrap;
    out property <bool> motion-fast:           root.s.motion-fast;
    out property <bool> bubble-bounce:         root.s.bubble-bounce;
    out property <bool> bevel:                 root.s.bevel;
    out property <bool> pixel-icons:           root.s.pixel-icons;
    out property <bool> selected-inverts-text: root.s.selected-inverts-text;
    out property <bool> pixel-select-marker:   root.s.pixel-select-marker;
    out property <bool> pixel-metrics:         root.s.pixel-metrics;
    out property <bool> outline-surfaces:      root.s.outline-surfaces;
    out property <bool> soft-decor:            root.s.soft-decor;
    out property <int> skin-message:          root.s.skin-message;
    out property <int> skin-button:           root.s.skin-button;
    out property <int> skin-list:             root.s.skin-list;
    out property <int> skin-avatar:           root.s.skin-avatar;
    out property <int> skin-modal:           root.s.skin-modal;
    out property <bool> bracket-labels:        root.s.bracket-labels;
    out property <bool> paper-doodles:         root.s.paper-doodles;
    out property <bool> sketch-bubbles:        root.s.sketch-bubbles;
    out property <bool> synth-grid:            root.s.synth-grid;

    // Font-size helpers. A call site declares both metrics; the active theme's
    // `pixel-metrics` flag picks one (retro is the only pixel-metrics theme).
    // `fs` is the render-site helper; `fsr` is the convention for primitive
    // property defaults consumed through `root.font-size`.
    public pure function fs(modern: length, pixel: length) -> length {
        root.pixel-metrics ? pixel : modern
    }
    public pure function fsr(modern: length, pixel: length) -> length {
        root.pixel-metrics ? pixel : modern
    }

    // The size a chat bubble draws its body text at. It lives here rather than
    // at the bubble's render site because Rust wraps message text against this
    // exact value: `render.rs` estimates character widths from it to pick line
    // breaks, so a second declaration of the pair would let the wrapper and the
    // renderer drift (they did — the wrapper assumed 13px under every theme,
    // while a pixel-metrics theme draws at 16px and overflowed the bubble).
    // The window root pushes it to Rust through `AppState.body-fs-changed`.
    out property <length> body-fs: root.fs(13px, 16px);
}

export global Palette {
    out property <color> bg:        Theme.c.bg;
    // Bento chat-shell surfaces: the canvas is the window background and the
    // cards use the theme's own elevated surface, so every theme lifts the
    // cards correctly (near-black in amoled, white in light, a subtle rise in
    // dark) instead of a fixed nudge toward white that greyed amoled out.
    out property <color> canvas:      Theme.c.bg;
    out property <color> card:        Theme.c.elevated;
    out property <color> panel:     Theme.c.panel;
    out property <color> panel-2:   Theme.c.panel-2;
    out property <color> rail:      Theme.c.rail;
    out property <color> banner:    Theme.c.banner;
    out property <color> border:    Theme.c.border;
    out property <color> border-2:  Theme.c.border-2;
    out property <color> bubble-in: Theme.c.bubble-in;
    out property <color> bubble-inset: Theme.c.bubble-inset;
    out property <color> bubble-inset-strong: Theme.c.bubble-inset-strong;
    out property <color> code-plate: Theme.c.code-plate;
    out property <color> media-backdrop: Theme.c.media-backdrop;
    out property <color> bubble-inset-out: Theme.c.bubble-inset-out;
    out property <color> bubble-inset-out-strong: Theme.c.bubble-inset-out-strong;
    out property <color> code-plate-out: Theme.c.code-plate-out;
    out property <color> media-backdrop-out: Theme.c.media-backdrop-out;
    out property <color> bubble-selection-out: Theme.c.bubble-selection-out;

    // Accent resolution: active pack's table indexed by the orthogonal accent.
    out property <color> mint:      Theme.c.accent-base[Theme.accent];
    out property <color> mint-hi:   Theme.c.accent-hi[Theme.accent];
    out property <color> mint-dim:  Theme.c.accent-dim[Theme.accent];
    out property <color> mint-glow: Theme.c.accent-glow[Theme.accent];
    out property <color> mint-surface: Theme.c.accent-surface[Theme.accent];

    out property <color> text-hi:   Theme.c.text-hi;
    out property <color> text-mid:  Theme.c.text-mid;
    out property <color> text-lo:   Theme.c.text-lo;
    out property <color> text-vlo:  Theme.c.text-vlo;
    out property <color> selected:  Theme.c.selected-uses-base ? Theme.c.accent-base[Theme.accent] : Theme.c.accent-surface[Theme.accent];
    out property <color> hover:     Theme.c.hover;
    out property <color> bubble-out-fg: Theme.c.bubble-out-fg;
    // Hard pixel shadow color — constant across themes.
    out property <color> shadow:    #000000;
    // QR plate — white in every theme so codes keep their light quiet zone
    // and stay scannable. Constant, like `shadow`.
    out property <color> qr-plate:  #FFFFFF;
    // Letterbox plate behind the About-page artwork; matches the background
    // baked into assets/about.png, so it is asset-locked, not themed.
    out property <color> artwork-plate: #0a0a14;
    out property <color> bevel-hi:  Theme.c.bevel-hi;
    out property <color> bevel-lo:  Theme.c.bevel-lo;

    out property <color> danger:      Theme.c.danger;
    out property <color> danger-soft: Theme.c.danger-soft;
    // Danger *inside* the outgoing accent bubble: that bubble is a dark
    // saturated accent even in light theme, so this stays bright everywhere.
    out property <color> danger-on-bubble: #FF5A5A;
    out property <color> danger-border: Theme.c.danger-border;
    out property <color> danger-soft-hover:   Theme.c.danger-soft-hover;
    out property <color> danger-border-hover: Theme.c.danger-border-hover;

    out property <color> warning:      Theme.c.warning;
    out property <color> warning-soft: Theme.c.warning-soft;
    out property <color> warning-border: Theme.c.warning-border;

    out property <color> field: Theme.c.field;
    out property <color> field-hover: Theme.c.field-hover;
    out property <color> field-border: Theme.c.field-border;
    out property <color> field-border-hover: Theme.c.field-border-hover;
    out property <color> divider: Theme.c.divider;
    out property <color> elevated: Theme.c.elevated;
    out property <color> elevated-border: Theme.c.elevated-border;
    out property <color> top-glint: Theme.c.top-glint;
    out property <color> canvas-top: Theme.c.canvas-top;
    out property <color> banner-edge: Theme.c.banner-edge;
    out property <color> card-border: Theme.c.card-border;
    out property <color> status-bar: Theme.c.status-bar;
    out property <color> card-well: Theme.c.card-well;
    out property <color> overlay: Theme.c.overlay;
    out property <color> overlay-strong: Theme.c.overlay-strong;
    out property <color> media-chip-bg: Theme.c.media-chip-bg;
    out property <color> media-chip-bg-hover: Theme.c.media-chip-bg-hover;
    out property <color> media-chip-fg: Theme.c.media-chip-fg;
    out property <color> media-chip-fg-dim: Theme.c.media-chip-fg-dim;
    out property <color> media-chip-outline: Theme.c.media-chip-outline;
    out property <color> media-ghost-bg: Theme.c.media-ghost-bg;
    out property <color> media-ghost-bg-hover: Theme.c.media-ghost-bg-hover;
    out property <color> media-control-bg: Theme.c.media-control-bg;
    out property <color> shadow-soft: Theme.c.shadow-soft;
    out property <color> shadow-card: Theme.c.shadow-card;
    out property <color> shadow-popover: Theme.c.shadow-popover;
    out property <color> shadow-float: Theme.c.shadow-float;
    out property <color> shadow-bubble-in: Theme.c.shadow-bubble-in;
    out property <color> vignette: Theme.c.vignette;
    out property <color> avatar-ring: Theme.c.avatar-ring;
}

// One signed-in account in the account switcher. All accounts stay connected
// in the background; `active` marks the one the UI is currently displaying.
export struct AccountEntry {
    id: string,           // account-id hex — the switch-account callback key
    name: string,         // display name (published profile, or npub tail)
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    picture: image,
    has-picture: bool,
    active: bool,
}

export struct Contact {
    // Resolved display name: the private nickname when set, else the
    // published profile name. `real-name` always holds the published one.
    name: string,
    real-name: string,
    nickname: string,
    account-id: string,
    npub-full: string,
    npub-short: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    verified: bool,
    online: bool,
    relays: int,
    added: string,
    // Profile picture, lazily bound from the process-wide picture cache.
    picture: image,
    has-picture: bool,
    // Real key-package state for the IDENTITY panel, computed Rust-side from
    // the directory record (never hardcoded). `kp-status` is the value column
    // ("Available" / "Not found" / "Checking…"); `kp-detail` is the sublabel
    // ("From <relay> · <when>" or an honest empty/loading line).
    kp-status: string,
    kp-detail: string,
    // True when the last fetch found no key package (or failed), so the detail
    // page offers a quiet Retry. False while a key package is present or a
    // fetch is in flight, keeping the row button-free in the common case.
    kp-can-retry: bool,
}

// One group the viewer has in common with a contact, rendered as a tappable
// row in the contact detail page and the profile modal. `group-id` is the
// group_id_hex handed back to open that chat.
export struct SharedGroup {
    name: string,
    group-id: string,
    members: int,
    av-a: color,
    av-b: color,
    av-initials: string,
    // Group avatar image, bound lazily from the picture cache (same pipeline
    // as the chat list). Falls back to the gradient when absent.
    picture: image,
    has-picture: bool,
}

// One on-disk forensic audit-log file (Settings → Advanced). `path` is the
// opaque key handed back to the delete callback; `meta` is the preformatted
// "size · date" line (formatting stays Rust-side).
export struct AuditLogEntry {
    path: string,
    name: string,
    meta: string,
}

export struct ArchivedChat {
    name: string,
    last-msg: string,
    last-date: string,
    av-a: color,
    av-b: color,
    av-initials: string,
    members: int,
    group-id: string,
    // Peer profile picture for archived 1:1 chats (groups keep the gradient).
    picture: image,
    has-picture: bool,
}

// One person who used a reaction emoji, rendered as a mention chip in the chip's
// hover popover. `id` is the account hex handed to `ProfileSink.open` so the
// profile opens the same way tapping any @mention or avatar does; `a`/`b` are
// the account's mention-plate gradient (already shaded for white text).
export struct Reactor {
    name: string,
    id: string,
    a: color,
    b: color,
}

// One aggregated reaction on a message: an emoji, how many people used it,
// and whether *I* am one of them (drives the highlight chip). `reactors` is the
// people who used the emoji (yourself first), shown as mention chips in the
// chip's hover popover so you can see who reacted and open their profiles.
export struct Reaction {
    emoji: string,
    count: int,
    mine: bool,
    reactors: [Reactor],
    // Tile in the shared Twemoji sprite sheet, so a reaction chip draws the
    // same colour glyph the quick-reaction row and chat bubbles do. clip-x < 0
    // falls back to the text glyph. Filled Rust-side via `emoji_clip`.
    clip-x: int,
    clip-y: int,
}

// One line of a message's reaction-chip row. Rust wraps the flat chip list
// into rows sized to the bubble's own width cap (Slint has no flow layout,
// so it can't discover where a row should break on its own), the same
// estimate-then-render split `MessageLine`/`MessageRun` use for message text.
export struct ReactionRow {
    chips: [Reaction],
}

// One emoji in the picker grid. `clip-x`/`clip-y` are pixel coordinates
// into the shared Twemoji sprite sheet (passed in separately at the picker
// level). `name` is the human-readable label.
export struct EmojiEntry {
    emoji: string,
    name: string,
    clip-x: int,
    clip-y: int,
}

// One queued composer attachment (paperclip picker or clipboard paste).
// Nothing uploads until the user presses Send — the chip row above the
// input is the confirmation step. `thumb` is a small decoded preview for
// images (`has-thumb` false → generic file chip).
export struct StagedAttachment {
    name: string,
    size-label: string,
    is-image: bool,
    thumb: image,
    has-thumb: bool,
    // Per-type emoji for thumb-less chips (📄/📊/📦/…); empty falls back to
    // the paperclip stroke icon.
    icon: string,
}

// One inline cell inside a wrapped line of a chat-message body. Slint's
// `Text` can't host inline images and `HorizontalLayout` doesn't wrap, so
// Rust pre-tokenizes the message into text + emoji runs and pre-groups them
// into lines (see `MessageLine`). The bubble renders one HorizontalLayout
// per line, letting Slint size text cells naturally — no per-cell width
// estimation in Rust (which used to overshoot and produce huge inter-word
// gaps because Rust didn't know JetBrains Mono's real advance).
export struct MessageRun {
    is-emoji: bool,
    text: string,
    clip-x: int,
    clip-y: int,
    // Inline Markdown styling, resolved per-run by the Rust AST walker.
    // `link` is the destination URL ("" = not a link); when set the run
    // renders as an accent-colored, underlined, tappable anchor.
    bold: bool,
    italic: bool,
    strike: bool,
    code: bool,
    link: string,
    // iMessage-style inline text effects, resolved from `{name}…{/name}`
    // markup, as a bitmask so any effects stack on one glyph (each acts on an
    // independent visual axis — e.g. `{big}{explode}` or `{jitter}{ripple}`):
    //   1 Big, 2 Small, 4 Explode, 8 Bloom, 16 Shake, 32 Nod, 64 Ripple,
    //   128 Jitter. The bubble's RunCell decodes the bits and composes them.
    // `phase` staggers the per-letter animation across a span (a travelling
    // crest for Ripple, decorrelated wobble for Jitter); it increments per
    // effect run and resets between spans.
    fx: int,
    phase: float,
    // Profile-mention chip: `mention` renders the run's text on a rounded
    // plate whose gradient (`mention-a` → `mention-b`) is the account's
    // stable avatar palette, resolved Rust-side (see src/mentions.rs).
    mention: bool,
    mention-a: color,
    mention-b: color,
}

// One wrapped line of a chat-message body. Beyond its runs a line carries
// block-level Markdown context resolved in Rust: `indent` is the left inset
// from list/blockquote nesting, `scale` multiplies the body font (headings),
// `quote` is the blockquote depth (0 = none, drives the left accent bar),
// `code-block` flags a fenced/indented code line (monospace plate), and
// `rule` marks a thematic break (renders a horizontal divider, no runs).
export struct MessageLine {
    runs: [MessageRun],
    indent: length,
    scale: float,
    quote: int,
    code-block: bool,
    rule: bool,
    // True when this visual line starts a new logical line (explicit break or
    // block boundary); false when it continues the previous one via wrapping.
    // Not rendered — the selection-copy extractor reads it to decide whether
    // two visual lines join with a newline or with nothing (the inter-word
    // space survives at the end of the previous line when the wrapper breaks).
    hard-break: bool,
    // Marks the first / last line that actually has run cells. Selection edge
    // claims hang off these (not off index 0 / length-1) so points above or
    // below the text block still resolve when the outermost line is a rule
    // or an empty line, which renders no cells.
    first-content: bool,
    last-content: bool,
}

// Signal-style in-bubble text selection. Exactly one message can hold a
// selection at a time: `owner` is its message id ("" = none). The anchor and
// cursor points live in the owner bubble's text-block coordinate space; the
// run cells hit-test themselves against those points, paint their own slice
// of the highlight, and claim the resolved document endpoints (line / run /
// fraction-within-run) back into this global (see RunCell in
// message-bubble.slint). The context menu's "Copy selection" reads the
// claimed endpoints and hands them to Rust for text extraction.
export global TextSelection {
    in-out property <string> owner;
    // True once the drag travelled far enough to count as a selection (a
    // plain click keeps `active` false and clears the previous selection).
    in-out property <bool> active;
    in-out property <length> anchor-x;
    in-out property <length> anchor-y;
    in-out property <length> cursor-x;
    in-out property <length> cursor-y;
    // Selection endpoints in document space; -1 = not yet resolved.
    // a = anchor, b = end — unordered, the extractor sorts them.
    in-out property <int> a-line: -1;
    in-out property <int> a-run: -1;
    in-out property <float> a-frac;
    in-out property <int> b-line: -1;
    in-out property <int> b-run: -1;
    in-out property <float> b-frac;
    // Raw document position of the pointer, claimed continuously by the run
    // cells while a selection is owned. The drag handler copies it into `b`
    // in character mode, or feeds it to `request-word-extend` in word mode —
    // keeping it separate lets Rust snap `a`/`b` to word boundaries without
    // the cursor claims overwriting them a frame later.
    in-out property <int> c-line: -1;
    in-out property <int> c-run: -1;
    in-out property <float> c-frac;
    // Document position of the last press, cached alongside the anchor
    // claims. `clear()` leaves it alone: the plain-click release between the
    // presses of a double-click clears the selection, and the second press
    // still needs the first press's position to pick the word.
    in-out property <int> p-line: -1;
    in-out property <int> p-run: -1;
    in-out property <float> p-frac;
    // Word mode (entered by double-click): dragging extends or retracts the
    // selection by whole words around the fixed anchor word below.
    in-out property <bool> word-mode;
    in-out property <int> wa-line;
    in-out property <int> wa-run;
    in-out property <float> wa-from;
    in-out property <float> wa-to;

    // Double-click word selection. The bubble passes the clicked document
    // position (already resolved by the run cells); Rust expands it to word
    // boundaries, stores the anchor word, and writes the endpoints back into
    // this global (bound in src/wiring/extra.rs).
    callback request-word(string, int, int, float);
    // Word-mode drag: the bubble passes the pointer's document position and
    // Rust re-derives the endpoints as the union of the anchor word and the
    // word under the pointer.
    callback request-word-extend(string, int, int, float);

    public function begin(id: string, x: length, y: length) {
        self.owner = id;
        self.active = false;
        self.word-mode = false;
        self.anchor-x = x;
        self.anchor-y = y;
        self.cursor-x = x;
        self.cursor-y = y;
        self.a-line = -1;
        self.a-run = -1;
        self.a-frac = 0;
        self.b-line = -1;
        self.b-run = -1;
        self.b-frac = 0;
        self.c-line = -1;
        self.c-run = -1;
        self.c-frac = 0;
        self.p-line = -1;
        self.p-run = -1;
        self.p-frac = 0;
    }
    public function clear() {
        self.owner = "";
        self.active = false;
        self.word-mode = false;
        self.a-line = -1;
        self.a-run = -1;
        self.b-line = -1;
        self.b-run = -1;
        self.c-line = -1;
        self.c-run = -1;
    }
}

// User-facing error / status copy shown by the Rust glue layer. These strings
// are *set from Rust* (status fields, backend-error banner) but the project
// keeps all i18n in the Slint `@tr` catalogs, so they live here as `@tr()`
// properties and Rust reads them back on the UI thread (mirroring how
// `EmojiSheet`/`ProfileSink` bridge Rust↔Slint). Tier-1 entries name a concrete
// thing the user can fix; the rest are operation-specific fallbacks that name
// no internals. The raw error is still logged at every call site for diagnosis.
export global ErrorCopy {
    // Tier 1 — content-based classification.
    out property <string> invalid-key: @tr("That doesn't look like a valid npub or public key. Double-check it and try again.");
    out property <string> nip05-not-found: @tr("We couldn't find anyone with that username. Double-check the name@domain and try again.");
    out property <string> network: @tr("Can't reach your relays right now. Check your network and relay settings, then try again.");
    out property <string> microphone-unavailable: @tr("No microphone available.");
    out property <string> audio-playback: @tr("Couldn't play audio.");
    // Tier 2 — operation-specific fallbacks.
    out property <string> sync: @tr("Couldn't finish syncing. We'll keep retrying — check your relay settings if this keeps happening.");
    out property <string> backend: @tr("Couldn't start up. Check your network and relay settings, then try again.");
    out property <string> switch-account: @tr("Couldn't switch accounts. Please try again in a moment.");
    out property <string> accept: @tr("Couldn't accept the invitation. Please try again in a moment.");
    out property <string> block: @tr("Couldn't decline the invitation. Please try again in a moment.");
    out property <string> archive: @tr("Couldn't archive this chat. Please try again.");
    out property <string> unarchive: @tr("Couldn't restore this chat. Please try again.");
    out property <string> send: @tr("Couldn't send your message. Check your connection and try again.");
    out property <string> edit: @tr("Couldn't save your edit. Check your connection and try again.");
    out property <string> react: @tr("Couldn't add your reaction. Please try again.");
    out property <string> unreact: @tr("Couldn't remove your reaction. Please try again.");
    out property <string> kp-publish: @tr("Couldn't publish your key package. Check your relay settings and try again.");
    out property <string> kp-rotate: @tr("Couldn't rotate your key package. Check your relay settings and try again.");
    out property <string> kp-refresh: @tr("Couldn't refresh your key packages. Check your relay settings and try again.");
    out property <string> republish: @tr("Couldn't republish to your relays. Check your relay settings and try again.");
    out property <string> add-account: @tr("Couldn't add that account. Please check the key and try again.");
    out property <string> create-chat: @tr("Couldn't create the chat. Please try again.");
    out property <string> add-contact: @tr("Couldn't add that contact. Please try again.");
    out property <string> remove-contact: @tr("Couldn't remove that contact. Please try again.");
    out property <string> add-member: @tr("Couldn't add that member. Please try again.");
    out property <string> group-settings: @tr("Couldn't update the group settings. Please try again.");
    out property <string> group-image: @tr("Couldn't update the group image. Please try again.");
    out property <string> save-profile: @tr("Couldn't save your profile. Check your connection and try again.");
    out property <string> upload-picture: @tr("Couldn't upload your picture. Please try again.");
    out property <string> generic: @tr("Something went wrong. Please try again.");
    // Forward failure: some source attachments could not be fetched to re-send.
    out property <string> forward-media: @tr("error banner when forwarding attachments fails, %1 = failed count, %2 = total count" => "Couldn't forward %1 of %2 attachments. Tap the message to try again.");
    // Save-attachment-to-disk outcomes (status-bar toast; %1 = file name).
