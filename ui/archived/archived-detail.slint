import { Palette, ArchivedChat, GroupMember, Theme } from "../tokens.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";
import { UnarchiveIcon } from "../icons/unarchive-icon.slint";
import { DetailPage } from "../layout/detail-page.slint";
import { PageHeader } from "../layout/page-header.slint";
import { Section } from "../layout/section.slint";
import { GroupCard } from "../layout/group-card.slint";
import { KVRow } from "../layout/kv-row.slint";
import { Button } from "../primitives/button.slint";
import { GroupMemberRow } from "../main-pane/group-member-row.slint";

export component ArchivedDetail inherits DetailPage {
    in property <ArchivedChat> data;
    in property <[GroupMember]> members;
    in property <bool> is-group: false;
    callback unarchive-clicked();

    HorizontalLayout {
        height: 56px;
        spacing: 10px;
        alignment: stretch;

        PageHeader {
            horizontal-stretch: 1;
            title: root.data.name;
            caption: root.is-group
                ? @tr("ARCHIVED  ·  1 MEMBER" | "ARCHIVED  ·  {n} MEMBERS" % root.data.members)
                : @tr("ARCHIVED");
            ArchiveIcon {
                stroke: Palette.text-mid;
            }
        }

        Button {
            label: @tr("Unarchive");
            button-height: 36px;
            y: (parent.height - self.height) / 2;
            clicked => {
                root.unarchive-clicked();
            }
            UnarchiveIcon {
                stroke: Palette.text-mid;
            }
        }
    }

    Rectangle {
        height: 72px;
        background: Palette.banner;
        border-radius: (8px) * Theme.r-scale;
        border-width: 1px;
        border-color: Palette.border-2;
        Rectangle {
            x: 0;
            y: 0;
            width: 3px;
            height: parent.height;
            background: Palette.mint-dim;
        }

        HorizontalLayout {
            padding-left: 18px;
            padding-right: 18px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 12px;
            alignment: start;
            VerticalLayout {
                alignment: center;
                ArchiveIcon {
                    stroke: Palette.mint;
                }
            }

            VerticalLayout {
                spacing: 4px;
                alignment: center;
                Text {
                    text: @tr("This chat is archived");
                    color: Palette.text-hi;
                    font-size: Theme.fs(13px, 16px);
                    font-weight: 600;
                }

                Text {
                    text: @tr("It stays end-to-end encrypted. Unarchiving returns it to your main list and resumes notifications.");
                    color: Palette.text-lo;
                    font-size: Theme.fs(11px, 14px);
                    wrap: word-wrap;
                }
            }
        }
    }

    Section {
        label: @tr("LAST ACTIVITY");
        GroupCard {
            KVRow {
                label: @tr("Last message");
                sublabel: root.data.last-msg;
                value: root.data.last-date;
                // No trailing divider when this is the only row (a direct message).
                show-divider: root.is-group;
            }

            if root.is-group: KVRow {
                label: @tr("Members");
                value: root.data.members;
            }

            if root.is-group: KVRow {
                label: @tr("Group id");
                value: root.data.group-id;
            }
        }
    }

    if root.is-group: Section {
        label: @tr("MEMBER LIST");
        GroupCard {
            for m in root.members: GroupMemberRow {
                data: m;
            }
        }
    }
}
