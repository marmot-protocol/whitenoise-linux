import { ListView } from "std-widgets.slint";
import { ArchivedChat } from "../tokens.slint";
import { AppState } from "../shell/app-state.slint";
import { SidePanel } from "../layout/side-panel.slint";
import { ArchivedListItem } from "archived-list-item.slint";

export component ArchivedSidebar inherits SidePanel {
    callback archive-clicked(int);
    in property <[ArchivedChat]> archives;
    in property <int> active-archived;

    // Live search: mirrors the chat-list/contacts-list filter — Rust
    // recomputes `archive-match-flags` (one flag per archived chat) for the
    // live query since Slint has no substring match.
    property <string> query;

    title: @tr("ARCHIVED");
    count: root.archives.length;
    show-search: true;
    search-placeholder: @tr("Search archived chats…");
    search-edited(q) => {
        root.query = q;
        AppState.archive-search-changed(q);
    }
    // The archived list is re-pushed on archive/unarchive; re-derive the
    // match set so filtered rows track the fresh order (mirrors the chat
    // list). No-op while the query is empty.
    changed archives => {
        if (root.query != "") {
            AppState.archive-search-changed(root.query);
        }
    }

    // Virtualized: only visible rows instantiate. The wrapper bakes the old
    // 2px inter-row spacing into each row.
    ListView {
        // Anchor + size against the runtime @children slot: `parent.*` here
        // resolves lexically to the panel root (oversizing the list), and an
        // oversized child gets default-centered — poking above the slot, over
        // the search field. x/y 0 + percentages track the actual slot.
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        for a[idx] in root.archives: Rectangle {
            width: parent.width;
            // Shown when the query is empty or this row matched (flags from
            // Rust). No `visible:` here — binding it on a ListView delegate
            // root breaks row placement (every delegate lands at y=0); zero
            // height + clip hides collapsed rows just as well.
            property <bool> shown: root.query == "" || (idx < AppState.archive-match-flags.length && AppState.archive-match-flags[idx]);
            height: shown ? item.height + 2px : 0px;
            clip: true;
            item := ArchivedListItem {
                x: 0;
                y: 0;
                width: 100%;
                data: a;
                compact: root.strip;
                selected: idx == root.active-archived;
                clicked => {
                    root.archive-clicked(idx);
                }
            }
        }
    }
}
