import { AppState } from "../shell/app-state.slint";
import { Palette } from "../tokens.slint";
import { ArchivedDetail } from "archived-detail.slint";
import { EmptyState } from "../layout/empty-state.slint";
import { ArchiveIcon } from "../icons/archive-icon.slint";

// The archived-chat detail. Its sidebar is hosted by the shell in the left
// card, so this page renders only the detail and fills the conversation card.
export component ArchivedPage inherits Rectangle {
    in property <length> window-width: 100000px;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    preferred-width: 0px;
    preferred-height: 0px;
    background: Palette.card;

    // No archived chats → empty state; otherwise the selected detail.
    if AppState.archived-chats.length == 0: EmptyState {
        width: parent.width;
        height: parent.height;
        title: @tr("No archived chats");
        description: @tr("Chats you archive are kept here, out of your main list.");
        ArchiveIcon {
            stroke: Palette.text-mid;
        }
    }
    if AppState.archived-chats.length > 0: ArchivedDetail {
        width: parent.width;
        height: parent.height;
        data: AppState.archived-chats[AppState.active-archived];
        members: AppState.chat-members;
        is-group: AppState.chat-is-group;
        unarchive-clicked => {
            AppState.unarchive-chat();
        }
    }
}
