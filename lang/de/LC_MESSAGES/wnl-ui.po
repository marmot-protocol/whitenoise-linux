msgid "Couldn't decline the invitation. Please try again in a moment."
msgstr "Einladung konnte nicht abgelehnt werden. Bitte versuche es gleich noch einmal."

#. Tier 2 — operation-specific fallbacks.
msgctxt "ErrorCopy"
msgid "Couldn't finish syncing. We'll keep retrying — check your relay settings if this keeps happening."
msgstr "Synchronisierung nicht abgeschlossen. Wir versuchen es weiter — überprüfe deine Relay-Einstellungen, falls das öfter vorkommt."

msgctxt "ErrorCopy"
msgid "Couldn't publish your key package. Check your relay settings and try again."
msgstr "Dein Key Package konnte nicht veröffentlicht werden. Überprüfe deine Relay-Einstellungen und versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't refresh your key packages. Check your relay settings and try again."
msgstr "Deine Key Packages konnten nicht aktualisiert werden. Überprüfe deine Relay-Einstellungen und versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't remove your reaction. Please try again."
msgstr "Reaktion konnte nicht entfernt werden. Bitte versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't republish to your relays. Check your relay settings and try again."
msgstr "Erneutes Veröffentlichen auf deinen Relays fehlgeschlagen. Überprüfe deine Relay-Einstellungen und versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't restore this chat. Please try again."
msgstr "Dieser Chat konnte nicht wiederhergestellt werden. Bitte versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't rotate your key package. Check your relay settings and try again."
msgstr "Dein Key Package konnte nicht erneuert werden. Überprüfe deine Relay-Einstellungen und versuche es erneut."

msgctxt "ErrorCopy"
msgid "Couldn't save your edit. Check your connection and try again."
msgstr "Änderung konnte nicht gespeichert werden. Überprüfe deine Verbindung und versuche es erneut."

